@page "/reset-password"
@layout AuthLayout
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using PTDoc.Application.Auth
@inject IUserService UserService
@inject NavigationManager Navigation

<PageTitle>Reset PIN</PageTitle>

<div class="auth-shell">
  <div class="auth-brand">PTDoc</div>

  <div class="auth-card" aria-live="polite">
    <header class="auth-card-header">
      <p class="auth-welcome">Reset PIN</p>
    </header>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
      <div class="auth-alert" role="alert">
        <span class="auth-alert-title">Reset failed</span>
        <span>@errorMessage</span>
      </div>
    }

    @if (isCheckingToken)
    {
      <div class="auth-info-alert" role="status" aria-live="polite">
        <span class="auth-info-icon" aria-hidden="true">ℹ️</span>
        <div class="auth-info-content">
          <strong>Checking link</strong>
          <p>Verifying your secure reset link.</p>
        </div>
      </div>
    }
    else if (tokenInvalid)
    {
      <div class="auth-alert" role="alert">
        <span class="auth-alert-title">Invalid link</span>
        <span>The reset link is invalid or expired.</span>
      </div>
      <button type="button" class="auth-primary" @onclick="ReturnToLogin">
        Return to Login
      </button>
    }
    else if (resetComplete)
    {
      <div class="auth-info-alert" role="status" aria-live="polite">
        <span class="auth-info-icon" aria-hidden="true">ℹ️</span>
        <div class="auth-info-content">
          <strong>PIN reset</strong>
          <p>Your PTDoc PIN has been reset.</p>
        </div>
      </div>
      <button type="button" class="auth-primary" @onclick="ReturnToLogin">
        Return to Login
      </button>
    }
    else
    {
      <EditForm FormName="ResetPasswordForm" Model="model" OnValidSubmit="HandleReset" class="auth-form" aria-busy="@isSubmitting">
        <DataAnnotationsValidator />

        <div class="auth-field">
          <label for="newPin">New 4-Digit PIN</label>
          <InputText id="newPin"
                     type="password"
                     class="auth-input"
                     autocomplete="new-password"
                     maxlength="4"
                     @bind-Value="model.NewPin" />
          <ValidationMessage For="@(() => model.NewPin)" class="auth-validation" />
        </div>

        <div class="auth-field">
          <label for="confirmPin">Confirm PIN</label>
          <InputText id="confirmPin"
                     type="password"
                     class="auth-input"
                     autocomplete="new-password"
                     maxlength="4"
                     @bind-Value="model.ConfirmPin" />
          <ValidationMessage For="@(() => model.ConfirmPin)" class="auth-validation" />
        </div>

        <button type="submit" class="auth-primary" disabled="@isSubmitting">
          @if (isSubmitting)
          {
            <span>Saving...</span>
          }
          else
          {
            <span>Reset PIN</span>
          }
        </button>
      </EditForm>
    }
  </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "token")]
    public string? Token { get; set; }

    private readonly ResetPinModel model = new();
    private string? errorMessage;
    private bool isSubmitting;
    private bool isCheckingToken = true;
    private bool tokenInvalid;
    private bool resetComplete;

    protected override async Task OnParametersSetAsync()
    {
        resetComplete = false;
        errorMessage = null;

        if (string.IsNullOrWhiteSpace(Token))
        {
            tokenInvalid = true;
            isCheckingToken = false;
            return;
        }

        isCheckingToken = true;
        tokenInvalid = false;
        var valid = await UserService.ValidatePasswordResetTokenAsync(Token);
        tokenInvalid = !valid;
        isCheckingToken = false;
    }

    private async Task HandleReset()
    {
        errorMessage = null;

        if (string.IsNullOrWhiteSpace(Token) || tokenInvalid)
        {
            errorMessage = "The reset link is invalid or expired.";
            return;
        }

        if (!string.Equals(model.NewPin, model.ConfirmPin, StringComparison.Ordinal))
        {
            errorMessage = "PIN and confirmation PIN do not match.";
            return;
        }

        isSubmitting = true;
        try
        {
            var succeeded = await UserService.CompletePasswordResetAsync(Token, model.NewPin);
            if (!succeeded)
            {
                errorMessage = "The reset link is invalid or expired.";
                return;
            }

            model.NewPin = string.Empty;
            model.ConfirmPin = string.Empty;
            resetComplete = true;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void ReturnToLogin()
    {
        Navigation.NavigateTo("/login");
    }

    private sealed class ResetPinModel
    {
        [Required(ErrorMessage = "PIN is required")]
        [StringLength(4, MinimumLength = 4, ErrorMessage = "PIN must be 4 digits")]
        [RegularExpression(@"^\d{4}$", ErrorMessage = "PIN must be 4 digits")]
        public string NewPin { get; set; } = string.Empty;

        [Required(ErrorMessage = "Confirm PIN is required")]
        [StringLength(4, MinimumLength = 4, ErrorMessage = "PIN must be 4 digits")]
        [RegularExpression(@"^\d{4}$", ErrorMessage = "PIN must be 4 digits")]
        public string ConfirmPin { get; set; } = string.Empty;
    }
}
