@page "/progress-tracking"
@attribute [Authorize(Policy = AuthorizationPolicies.ClinicalStaff)]
@rendermode InteractiveServer
@using System.Globalization
@using PTDoc.Application.Services
@using PTDoc.UI.Components.ProgressTracking
@using PTDoc.UI.Components.ProgressTracking.Models
@implements IDisposable
@inject NavigationManager NavigationManager
@inject INoteService NoteService
@inject IAppointmentService AppointmentService

<PageTitle>Progress Tracking - PTDoc</PageTitle>

<div class="progress-tracking-page">
    <GlobalPageHeader />

    <div class="progress-tracking-content">
        @if (isLoading && snapshot is null)
        {
            <div class="progress-loading" role="status" aria-label="Loading progress tracking data">
                <LoadingSkeleton Variant="SkeletonVariant.Rectangle" Size="SkeletonSize.Large" AdditionalClasses="progress-loading-skeleton" />
            </div>
        }
        else if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <section class="progress-selected-patient-empty" role="alert" aria-live="assertive">
                <h3>Unable to load progress tracking</h3>
                <p>@errorMessage</p>
                <button type="button" class="btn btn-primary" @onclick="ReloadAsync" disabled="@isLoading">Retry</button>
            </section>
        }
        else
        {
            @if (snapshot is not null && snapshot.Patients.Count == 0)
            {
                <section class="progress-selected-patient-empty" role="status" aria-live="polite">
                    <h3>No progress data matches the current filters</h3>
                    <p>Broaden the date range or adjust the program status and treatment phase filters to see patients with activity.</p>
                </section>
            }

            <section class="progress-top" aria-label="Progress tracking filters and summary metrics">
                <ProgressTrackingFilter State="filterState"
                                       OnStateChanged="HandleFilterStateChanged"
                                       IsDisabled="isLoading" />

                <ProgressTrackingMetricCards Items="visibleMetrics" />

                @if (showClinicalIntelligence)
                {
                    <ClinicalIntelligencePanel Alerts="clinicalAlerts" OnSelectPatient="SelectPatientFromAlert" />
                }

                <p class="progress-action-status" aria-live="polite">@quickActionStatus</p>
            </section>

            <div class="progress-main">
                <section class="progress-left" aria-label="Progress tracking tab content">
                    <ProgressTrackingTabs ActiveTab="activeTab" ActiveTabChanged="SetActiveTab" PanelIdPrefix="progress-tracking-panel" />

                    <div class="progress-tab-panel"
                         role="tabpanel"
                         id="@GetPanelId(activeTab)"
                         aria-labelledby="@GetTabId(activeTab)">
                        @switch (activeTab)
                        {
                            case ProgressTrackingTab.Overview:
                                <ProgressTrackingOverviewPanel Summary="overviewSummary" />
                                break;
                            case ProgressTrackingTab.Patients:
                                <ProgressTrackingPatientsPanel Items="filteredPatients" OnSelectPatient="SelectPatient" />
                                break;
                            case ProgressTrackingTab.Goals:
                                <ProgressTrackingGoalsPanel Goals="goalHighlights" />
                                break;
                            case ProgressTrackingTab.Trends:
                                <ProgressTrackingTrendsPanel OutcomeTrend="trendPoints"
                                                             ProviderProgress="providerProgress"
                                                             ErrorMessage="trendErrorMessage" />
                                break;
                        }
                    </div>
                </section>

                <aside class="progress-right" aria-label="Selected patient details and quick actions">
                    <SelectedPatientPanel SelectedPatient="selectedPatient" OnClearSelection="ClearSelectedPatient" />
                    <ProgressTrackingQuickLinks OnAction="HandleQuickAction" IsBusy="isLoading" />
                    <ProgressTrackingComplianceNote />
                </aside>
            </div>
        }
    </div>
</div>

@code {
    private readonly ProgressTrackingFilterState filterState = new();
    private ProgressTrackingAggregationService? aggregationService;
    private ProgressTrackingSnapshot? snapshot;
    private List<ProgressTrackingMetricVm> visibleMetrics = new();
    private List<ClinicalAlertVm> clinicalAlerts = new();
    private List<ProviderGoalProgressVm> providerProgress = new();
    private List<ProgressTrackingPatientVm> filteredPatients = new();
    private IReadOnlyList<string> goalHighlights = Array.Empty<string>();
    private IReadOnlyList<ProgressTrendPointVm> trendPoints = Array.Empty<ProgressTrendPointVm>();
    private ProgressTrackingPatientVm? selectedPatient;
    private string? selectedPatientId;
    private ProgressTrackingTab activeTab = ProgressTrackingTab.Overview;
    private bool isLoading = true;
    private string overviewSummary = string.Empty;
    private string quickActionStatus = "Loading progress tracking data...";
    private string? errorMessage;
    private string? trendErrorMessage;
    private CancellationTokenSource? loadCts;
    private CancellationTokenSource? trendCts;

    private bool showClinicalIntelligence => !filterState.IsDischargeSelected;

    protected override async Task OnInitializedAsync()
    {
        aggregationService = new ProgressTrackingAggregationService(NoteService, AppointmentService);
        await ReloadAsync();
    }

    public void Dispose()
    {
        loadCts?.Cancel();
        loadCts?.Dispose();
        trendCts?.Cancel();
        trendCts?.Dispose();
        selectedPatient = null;
    }

    private async Task ReloadAsync()
    {
        CancelLoadTokens();

        isLoading = true;
        errorMessage = null;
        trendErrorMessage = null;
        snapshot = null;
        ClearDerivedState();
        quickActionStatus = "Loading progress tracking data...";
        await InvokeAsync(StateHasChanged);

        loadCts = new CancellationTokenSource();
        var cancellationToken = loadCts.Token;

        try
        {
            aggregationService ??= new ProgressTrackingAggregationService(NoteService, AppointmentService);

            var result = await aggregationService.LoadAsync(filterState, cancellationToken);
            if (cancellationToken.IsCancellationRequested)
            {
                return;
            }

            snapshot = result;
            ApplySnapshot(result);
            await SyncSelectionAsync(cancellationToken);

            quickActionStatus = result.Patients.Count == 0
                ? "No patient activity found for the current filters."
                : $"Loaded {result.Patients.Count} patients from backend.";
        }
        catch (OperationCanceledException)
        {
            return;
        }
        catch (Exception ex)
        {
            snapshot = null;
            errorMessage = ex.Message;
            quickActionStatus = "Unable to load progress tracking data.";
            ClearDerivedState();
        }
        finally
        {
            isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void ApplySnapshot(ProgressTrackingSnapshot result)
    {
        filteredPatients = result.Patients.ToList();
        clinicalAlerts = result.Alerts.ToList();
        providerProgress = result.ProviderProgress.ToList();
        overviewSummary = result.OverviewSummary;
        visibleMetrics = BuildMetrics(filteredPatients);
    }

    private async Task SyncSelectionAsync(CancellationToken cancellationToken)
    {
        if (filteredPatients.Count == 0)
        {
            selectedPatientId = null;
            selectedPatient = null;
            goalHighlights = Array.Empty<string>();
            trendPoints = Array.Empty<ProgressTrendPointVm>();
            return;
        }

        selectedPatient = !string.IsNullOrWhiteSpace(selectedPatientId)
            ? filteredPatients.FirstOrDefault(patient => string.Equals(patient.Id, selectedPatientId, StringComparison.OrdinalIgnoreCase))
            : null;

        selectedPatient ??= filteredPatients.FirstOrDefault();
        selectedPatientId = selectedPatient?.Id;
        goalHighlights = selectedPatient?.Goals ?? Array.Empty<string>();
        trendErrorMessage = null;

        await LoadSelectedPatientTrendPointsAsync(selectedPatient, cancellationToken);
    }

    private async Task SelectPatient(string patientId)
    {
        if (filteredPatients.Count == 0)
        {
            return;
        }

        var patient = filteredPatients.FirstOrDefault(item => string.Equals(item.Id, patientId, StringComparison.OrdinalIgnoreCase));
        if (patient is null)
        {
            selectedPatientId = null;
            selectedPatient = null;
            goalHighlights = Array.Empty<string>();
            trendPoints = Array.Empty<ProgressTrendPointVm>();
            return;
        }

        selectedPatientId = patient.Id;
        selectedPatient = patient;
        goalHighlights = patient.Goals;
        trendErrorMessage = null;
        await LoadSelectedPatientTrendPointsAsync(patient);
    }

    private async Task SelectPatientFromAlert(string patientId)
    {
        await SelectPatient(patientId);
        activeTab = ProgressTrackingTab.Patients;
    }

    private void ClearSelectedPatient()
    {
        selectedPatientId = null;
        selectedPatient = null;
        goalHighlights = Array.Empty<string>();
        trendPoints = Array.Empty<ProgressTrendPointVm>();
        trendErrorMessage = null;
    }

    private async Task HandleFilterStateChanged(ProgressTrackingFilterState next)
    {
        filterState.DateRange = next.DateRange;
        filterState.ProgramStatus = next.ProgramStatus;
        filterState.TreatmentPhase = next.TreatmentPhase;
        await ReloadAsync();
    }

    private async Task HandleQuickAction(string action)
    {
        switch (action)
        {
            case "export-summary":
                NavigationManager.NavigateTo("/export-center?template=progress-summary");
                quickActionStatus = "Opened progress summary export.";
                break;
            case "open-export-center":
                NavigationManager.NavigateTo("/export-center");
                quickActionStatus = "Opened export center.";
                break;
            case "refresh-data":
                await ReloadAsync();
                return;
            default:
                quickActionStatus = "Action unavailable.";
                break;
        }
    }

    private async Task SetActiveTab(ProgressTrackingTab tab)
    {
        activeTab = tab;

        if (tab == ProgressTrackingTab.Trends && selectedPatient is not null && trendPoints.Count == 0)
        {
            await LoadSelectedPatientTrendPointsAsync(selectedPatient);
        }
    }

    private async Task LoadSelectedPatientTrendPointsAsync(
        ProgressTrackingPatientVm? patient,
        CancellationToken cancellationToken = default)
    {
        trendCts?.Cancel();
        trendCts?.Dispose();
        trendCts = null;

        if (patient is null || patient.RecentNoteIds.Count == 0)
        {
            trendPoints = Array.Empty<ProgressTrendPointVm>();
            trendErrorMessage = null;
            return;
        }

        var localCts = CancellationTokenSource.CreateLinkedTokenSource(cancellationToken);
        trendCts = localCts;

        try
        {
            trendPoints = Array.Empty<ProgressTrendPointVm>();
            trendErrorMessage = null;
            var points = await aggregationService!.LoadTrendPointsAsync(patient.RecentNoteIds, localCts.Token);
            if (!localCts.IsCancellationRequested && string.Equals(selectedPatientId, patient.Id, StringComparison.OrdinalIgnoreCase))
            {
                trendPoints = points.ToList();
            }
        }
        catch (OperationCanceledException)
        {
            // Ignore cancellations from a newer selection/filter change.
        }
        catch
        {
            trendPoints = Array.Empty<ProgressTrendPointVm>();
            trendErrorMessage = "Unable to load outcome trend data from the backend. Please retry.";
            quickActionStatus = trendErrorMessage;
        }
        finally
        {
            if (ReferenceEquals(trendCts, localCts))
            {
                trendCts = null;
            }

            localCts.Dispose();
        }
    }

    private void CancelLoadTokens()
    {
        loadCts?.Cancel();
        loadCts?.Dispose();
        loadCts = null;

        trendCts?.Cancel();
        trendCts?.Dispose();
        trendCts = null;
    }

    private void ClearDerivedState()
    {
        filteredPatients.Clear();
        visibleMetrics.Clear();
        clinicalAlerts.Clear();
        providerProgress.Clear();
        goalHighlights = Array.Empty<string>();
        trendPoints = Array.Empty<ProgressTrendPointVm>();
        selectedPatient = null;
        overviewSummary = string.Empty;
        trendErrorMessage = null;
    }

    private static List<ProgressTrackingMetricVm> BuildMetrics(IReadOnlyList<ProgressTrackingPatientVm> patients)
    {
        var totalPatients = patients.Count;
        var activePatients = patients.Count(patient => string.Equals(patient.StatusLabel, "Active", StringComparison.OrdinalIgnoreCase));
        var dischargedPatients = patients.Count(patient => string.Equals(patient.StatusLabel, "Discharged", StringComparison.OrdinalIgnoreCase));
        var scoredPatients = patients.Where(patient => patient.HasOutcomeScore).ToList();
        int? averageScore = scoredPatients.Count == 0
            ? null
            : (int)Math.Round(scoredPatients.Average(patient => patient.CurrentScore));

        return new List<ProgressTrackingMetricVm>
        {
            new()
            {
                Label = "Patients",
                Value = totalPatients.ToString(),
                Subtitle = "In current filter",
                BadgeText = "Updated",
                BadgeVariant = "default"
            },
            new()
            {
                Label = "Active Programs",
                Value = activePatients.ToString(),
                Subtitle = "Ongoing treatment",
                BadgeText = "On Track",
                BadgeVariant = "success"
            },
            new()
            {
                Label = "Discharged",
                Value = dischargedPatients.ToString(),
                Subtitle = "Completed care",
                BadgeText = "Outcomes logged",
                BadgeVariant = "info"
            },
            new()
            {
                Label = "Avg Outcome Score",
                Value = averageScore?.ToString(CultureInfo.InvariantCulture) ?? "—",
                Subtitle = scoredPatients.Count == 0
                    ? "No score data available"
                    : "Across filtered patients",
                TrendText = scoredPatients.Count == 0 ? null : $"{scoredPatients.Count} scored patients",
                BadgeText = scoredPatients.Count == 0 ? "No scores" : "Improving",
                BadgeVariant = scoredPatients.Count == 0 ? "default" : "warning"
            }
        };
    }

    private static string GetTabId(ProgressTrackingTab tab)
    {
        return $"progress-tracking-panel-tab-{tab.ToString().ToLowerInvariant()}";
    }

    private static string GetPanelId(ProgressTrackingTab tab)
    {
        return $"progress-tracking-panel-{tab.ToString().ToLowerInvariant()}";
    }
}
