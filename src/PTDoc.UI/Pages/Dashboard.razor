@page "/"
@using PTDoc.Application.Services
@using PTDoc.Application.Dashboard
@using PTDoc.Application.DTOs
@using PTDoc.UI.Components.Dashboard
@using PTDoc.UI.Services
@inject IPatientService PatientService
@inject IAppointmentService AppointmentService
@inject INoteService NoteService
@inject INotificationCenterService NotificationCenterService
@inject IToastService ToastService
@rendermode InteractiveServer
@implements IDisposable

<PageTitle>Dashboard - PTDoc</PageTitle>

<div class="dashboard-container">
    <GlobalPageHeader />

    <!-- Quick Action Buttons -->
    <div class="quick-actions-section">
        <button type="button" class="action-btn action-btn-primary" @onclick="HandleAddPatient" aria-label="Add new patient">
            <div class="action-btn-content">
                <div class="action-icon-container action-icon-primary">
                    <svg class="action-icon" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M8 3.33337V12.6667" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M3.33334 8H12.6667" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M8 14.6667C11.6819 14.6667 14.6667 11.6819 14.6667 8C14.6667 4.3181 11.6819 1.33337 8 1.33337C4.3181 1.33337 1.33334 4.3181 1.33334 8C1.33334 11.6819 4.3181 14.6667 8 14.6667Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </div>
                <div class="action-text-container">
                    <div class="action-title">Add Patient</div>
                    <div class="action-description">Create new patient profile</div>
                </div>
            </div>
            <svg class="action-arrow" width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M6 12L10 8L6 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        </button>

        <button type="button" class="action-btn action-btn-info" @onclick="HandleSendIntake" aria-label="Send intake form to patient">
            <div class="action-btn-content">
                <div class="action-icon-container action-icon-info">
                    <svg class="action-icon" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M14.6667 2L7.33334 9.33333" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M14.6667 2L10 14.6667L7.33334 9.33333L2 6.66667L14.6667 2Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </div>
                <div class="action-text-container">
                    <div class="action-title">Send Intake</div>
                    <div class="action-description">Email intake form to patient</div>
                </div>
            </div>
            <svg class="action-arrow" width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M6 12L10 8L6 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        </button>
    </div>

    <!-- Main Dashboard Content Grid -->
    <div class="dashboard-main-content">
        <!-- Left Column: Dashboard Grid, Notifications & Appointments -->
        <div class="dashboard-left-column">
            <OverviewSection PatientsToday="@_patientsToday"
                             Appointments="@_appointmentsToday"
                             NotesDue="@_notesDue"
                             Pending="@_pendingItems"
                             Drafts="@_draftNotes"
                             Unsigned="@_unsignedNotesNeedingSignature"
                             Intakes="@_incompleteIntakes" />
            <NotificationsSection Notifications="@_notificationItems"
                                  UrgentCount="@_urgentNotificationCount" />
        </div>

        <!-- Right Column: Supplemental Cards -->
        <div class="dashboard-right-column">
            <RecentNotesCard Notes="@_recentNotes" />
            <RecentActivityCard Activities="@_recentActivities"
                                IsLoading="@_isDashboardLoading"
                                HasError="@_dashboardLoadFailed"
                                OnRetry="LoadDashboardSnapshotAsync" />
        </div>
    </div>

</div>

<!-- Add Patient Modal -->
<AddPatientModal IsOpen="@isAddPatientModalOpen" 
                 IsOpenChanged="@((value) => isAddPatientModalOpen = value)"
                 OnSubmit="@HandlePatientSubmit" />

<!-- Send Intake Modal -->
<SendIntakeModal IsOpen="@isSendIntakeModalOpen"
                 IsOpenChanged="@((value) => isSendIntakeModalOpen = value)"
                 AvailablePatients="@availablePatients"
                 OnSubmit="@HandleIntakeSubmit" />

@code {
    private bool isAddPatientModalOpen = false;
    private bool isSendIntakeModalOpen = false;
    private System.Timers.Timer? _autoRefreshTimer;

    private bool _isDashboardLoading;
    private bool _dashboardLoadFailed;
    private int _patientsToday;
    private int _appointmentsToday;
    private int _notesDue;
    private int _pendingItems;
    private int _draftNotes;
    private int _unsignedNotesNeedingSignature;
    private int _incompleteIntakes;
    private int _urgentNotificationCount;
    private List<NoteListItemApiResponse> _recentNotes = [];
    private List<RecentActivity> _recentActivities = [];
    private List<NotificationCenterItem> _notificationItems = [];
    private List<SendIntakeModal.PatientOption> availablePatients = new();

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadDashboardSnapshotAsync(), LoadAvailablePatientsAsync());
        SetupAutoRefresh();
    }

    private async Task LoadAvailablePatientsAsync()
    {
        try
        {
            var patients = await PatientService.SearchAsync(query: null, take: 200);
            availablePatients = patients
                .Select(p => new SendIntakeModal.PatientOption
                {
                    Id = p.Id.ToString(),
                    Name = $"{p.FirstName} {p.LastName}",
                    Email = p.Email,
                    PhoneNumber = p.Phone
                })
                .ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[Dashboard] Error loading patient list: {ex.Message}");
        }
    }

    private async Task LoadDashboardSnapshotAsync()
    {
        _isDashboardLoading = true;
        _dashboardLoadFailed = false;
        StateHasChanged();

        try
        {
            var today = DateTime.UtcNow.Date;
            var notesTask = NoteService.GetNotesAsync(take: 50);
            var appointmentsTask = AppointmentService.GetOverviewAsync(today, today.AddDays(1).AddTicks(-1));
            var notificationsTask = NotificationCenterService.GetStateAsync();

            await Task.WhenAll(notesTask, appointmentsTask, notificationsTask);

            var notes = (await notesTask)
                .OrderByDescending(note => note.LastModifiedUtc)
                .ToList();
            var appointments = (await appointmentsTask).Appointments
                .OrderBy(appointment => appointment.StartTimeUtc)
                .ToList();
            var notifications = (await notificationsTask).Notifications
                .OrderByDescending(notification => notification.Timestamp)
                .ToList();

            _recentNotes = [.. notes.Take(5)];
            _notificationItems = [.. notifications.Take(4)];

            var unsignedNotes = notes.Where(note => !note.IsSigned).ToList();
            _patientsToday = appointments
                .Select(appointment => appointment.PatientRecordId)
                .Distinct()
                .Count();
            _appointmentsToday = appointments.Count;
            _notesDue = unsignedNotes.Count(note => note.DateOfService.Date == today);
            _pendingItems = notifications.Count(notification => !notification.IsRead);
            _draftNotes = unsignedNotes.Count;
            _unsignedNotesNeedingSignature = unsignedNotes.Count(note => note.DateOfService.Date < today);
            _incompleteIntakes = notifications.Count(notification =>
                !notification.IsRead &&
                string.Equals(notification.Type, "intake", StringComparison.OrdinalIgnoreCase));
            _urgentNotificationCount = notifications.Count(notification => notification.IsUrgent && !notification.IsRead);
            _recentActivities = BuildRecentActivities(notes, appointments);
        }
        catch (Exception ex)
        {
            _dashboardLoadFailed = true;
            Console.WriteLine($"Error loading dashboard snapshot: {ex.Message}");
        }
        finally
        {
            _isDashboardLoading = false;
            StateHasChanged();
        }
    }

    private void SetupAutoRefresh()
    {
        _autoRefreshTimer = new System.Timers.Timer(5 * 60 * 1000); // 5 minutes
        _autoRefreshTimer.Elapsed += async (sender, e) =>
        {
            await InvokeAsync(LoadDashboardSnapshotAsync);
        };
        _autoRefreshTimer.Start();
    }

    private void HandleAddPatient()
    {
        isAddPatientModalOpen = true;
    }

    private void HandleSendIntake()
    {
        isSendIntakeModalOpen = true;
    }

    private async Task HandlePatientSubmit(AddPatientModal.PatientFormData formData)
    {
        try
        {
            var request = new PTDoc.Application.DTOs.CreatePatientRequest
            {
                FirstName = formData.FirstName,
                LastName = formData.LastName,
                DateOfBirth = formData.DateOfBirth ?? DateTime.Today,
                Email = formData.Email,
                Phone = formData.PhoneNumber
            };
            var created = await PatientService.CreateAsync(request);
            ToastService.ShowSuccess($"Patient {created.FirstName} {created.LastName} created.");
            await Task.WhenAll(LoadDashboardSnapshotAsync(), LoadAvailablePatientsAsync());
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[Dashboard] Error creating patient: {ex.Message}");
            ToastService.ShowError("Failed to create patient. Please try again.");
        }
    }

    private async Task HandleIntakeSubmit(SendIntakeModal.IntakeFormData formData)
    {
        try
        {
            await Task.WhenAll(LoadDashboardSnapshotAsync(), LoadAvailablePatientsAsync());
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[Dashboard] Error refreshing intake state: {ex.Message}");
        }
    }

    private static List<RecentActivity> BuildRecentActivities(
        IReadOnlyList<NoteListItemApiResponse> notes,
        IReadOnlyList<AppointmentListItemResponse> appointments)
    {
        var noteActivities = notes.Select(note => new RecentActivity
        {
            Id = note.Id.ToString("N"),
            Type = note.IsSigned ? ActivityType.NoteCompleted : ActivityType.NoteUpdated,
            Description = note.IsSigned
                ? $"Signed {note.NoteType}"
                : $"Updated {note.NoteType}",
            PatientId = note.PatientId.ToString(),
            PatientName = note.PatientName,
            Timestamp = note.LastModifiedUtc
        });

        var appointmentActivities = appointments.Select(appointment => new RecentActivity
        {
            Id = appointment.Id.ToString("N"),
            Type = string.Equals(appointment.AppointmentStatus, "checked in", StringComparison.OrdinalIgnoreCase)
                ? ActivityType.AppointmentCheckedIn
                : ActivityType.AppointmentScheduled,
            Description = string.Equals(appointment.AppointmentStatus, "checked in", StringComparison.OrdinalIgnoreCase)
                ? $"Checked in {appointment.AppointmentType} appointment"
                : $"Scheduled {appointment.AppointmentType} appointment",
            PatientId = appointment.PatientRecordId.ToString(),
            PatientName = appointment.PatientName,
            Timestamp = appointment.StartTimeUtc
        });

        return noteActivities
            .Concat(appointmentActivities)
            .OrderByDescending(activity => activity.Timestamp)
            .Take(10)
            .ToList();
    }

    public void Dispose()
    {
        _autoRefreshTimer?.Stop();
        _autoRefreshTimer?.Dispose();
    }
}
