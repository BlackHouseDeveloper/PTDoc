@page "/"
@attribute [Authorize(Policy = AuthorizationPolicies.ClinicalStaff)]
@using PTDoc.Application.Services
@using PTDoc.Application.Dashboard
@using PTDoc.Application.DTOs
@using PTDoc.UI.Components.Dashboard
@using PTDoc.UI.Services
@inject IPatientService PatientService
@inject IIntakeService IntakeService
@inject IDashboardAlertService DashboardAlertService
@inject IToastService ToastService
@inject ILogger<Dashboard> Logger
@rendermode InteractiveServer
@implements IDisposable

<PageTitle>Dashboard - PTDoc</PageTitle>

<div class="dashboard-container">
    <GlobalPageHeader />

    <!-- Quick Action Buttons -->
    <div class="quick-actions-section">
        <AuthorizeView Policy="@AuthorizationPolicies.PatientWrite">
            <Authorized>
                <button type="button" class="action-btn action-btn-primary" @onclick="HandleAddPatient" aria-label="Add new patient">
                    <div class="action-btn-content">
                        <div class="action-icon-container action-icon-primary">
                            <svg class="action-icon" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                <path d="M8 3.33337V12.6667" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                <path d="M3.33334 8H12.6667" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                <path d="M8 14.6667C11.6819 14.6667 14.6667 11.6819 14.6667 8C14.6667 4.3181 11.6819 1.33337 8 1.33337C4.3181 1.33337 1.33334 4.3181 1.33334 8C1.33334 11.6819 4.3181 14.6667 8 14.6667Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </div>
                        <div class="action-text-container">
                            <div class="action-title">Add Patient</div>
                            <div class="action-description">Create new patient profile</div>
                        </div>
                    </div>
                    <svg class="action-arrow" width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M6 12L10 8L6 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </button>
            </Authorized>
        </AuthorizeView>

        <AuthorizeView Policy="@AuthorizationPolicies.IntakeWrite">
            <Authorized>
                <button type="button" class="action-btn action-btn-info" @onclick="HandleSendIntakeAsync" aria-label="Send intake form to patient">
                    <div class="action-btn-content">
                        <div class="action-icon-container action-icon-info">
                            <svg class="action-icon" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                <path d="M14.6667 2L7.33334 9.33333" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                <path d="M14.6667 2L10 14.6667L7.33334 9.33333L2 6.66667L14.6667 2Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </div>
                        <div class="action-text-container">
                            <div class="action-title">Send Intake</div>
                            <div class="action-description">Email intake form to patient</div>
                        </div>
                    </div>
                    <svg class="action-arrow" width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M6 12L10 8L6 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </button>
            </Authorized>
        </AuthorizeView>
    </div>

    @if (_isDashboardLoading && !_hasLoadedDashboard)
    {
        <section class="dashboard-state" role="status" aria-live="polite" data-testid="dashboard-loading">
            <div class="dashboard-state__card">
                <h2>Loading dashboard…</h2>
                <p>Fetching patient, activity, and note data from the API.</p>
            </div>
        </section>
    }
    else if (_dashboardLoadFailed && !HasDashboardContent)
    {
        <section class="dashboard-state" data-testid="dashboard-error">
            <div class="dashboard-state__card dashboard-state__card--error" role="alert">
                <h2>Dashboard unavailable</h2>
                <p>@_dashboardErrorMessage</p>
                <button type="button" class="btn btn--primary" @onclick="RetryDashboardAsync">Retry</button>
            </div>
        </section>
    }
    else if (_hasLoadedDashboard && !HasDashboardContent)
    {
        <section class="dashboard-state" data-testid="dashboard-empty">
            <div class="dashboard-state__card">
                <h2>No dashboard activity yet</h2>
                <p>Patients, appointments, notes, and alerts will appear here once the API returns clinic activity.</p>
                <button type="button" class="btn btn--primary" @onclick="RetryDashboardAsync">Refresh</button>
            </div>
        </section>
    }
    else
    {
        @if (_dashboardLoadFailed)
        {
            <section class="dashboard-inline-alert" role="alert" data-testid="dashboard-inline-error">
                <span>@_dashboardErrorMessage</span>
                <button type="button" class="btn btn--secondary" @onclick="RetryDashboardAsync">Retry</button>
            </section>
        }

        <!-- Main Dashboard Content Grid -->
        <div class="dashboard-main-content">
            <!-- Left Column: Dashboard Grid, Notifications & Appointments -->
            <div class="dashboard-left-column">
                <OverviewSection PatientsToday="@_patientsToday"
                                 Appointments="@_appointmentsToday"
                                 NotesDue="@_notesDue"
                                 Pending="@_pendingItems"
                                 Drafts="@_draftNotes"
                                 Unsigned="@_unsignedNotesNeedingSignature"
                                 Intakes="@_incompleteIntakes" />
                <NotificationsSection Alerts="@_dashboardAlerts" />
            </div>

            <!-- Right Column: Supplemental Cards -->
            <div class="dashboard-right-column">
                <RecentActivityCard Activities="@_recentActivities"
                                    IsLoading="@_isRecentActivityLoading"
                                    HasError="@_recentActivityLoadFailed"
                                    ErrorMessage="@_recentActivityErrorMessage"
                                    OnRetry="RetryRecentActivityAsync" />
                <RecentlyEditedPOCsCard Items="@_recentPlansOfCare" />
            </div>
        </div>
    }
</div>

<!-- Add Patient Modal -->
<AddPatientModal IsOpen="@isAddPatientModalOpen" 
                 IsOpenChanged="@((value) => isAddPatientModalOpen = value)"
                 OnSubmit="@HandlePatientSubmit" />

<!-- Send Intake Modal -->
<SendIntakeModal IsOpen="@isSendIntakeModalOpen"
                 IsOpenChanged="@HandleSendIntakeOpenChanged"
                 AvailablePatients="@availablePatients"
                 InitialPatientId="@initialSendIntakePatientId"
                 OnSubmit="@HandleIntakeSubmit" />

@code {
    private bool isAddPatientModalOpen = false;
    private bool isSendIntakeModalOpen = false;
    private string? initialSendIntakePatientId;
    private System.Timers.Timer? _autoRefreshTimer;

    private bool _isRecentActivityLoading;
    private bool _recentActivityLoadFailed;
    private string? _recentActivityErrorMessage;
    private bool _isDashboardLoading = true;
    private bool _dashboardLoadFailed;
    private bool _hasLoadedDashboard;
    private string? _dashboardErrorMessage;
    private CancellationTokenSource? _dashboardCts;
    private bool _isDisposed;
    private bool _isLoadingAvailablePatients;
    private int _patientsToday;
    private int _appointmentsToday;
    private int _notesDue;
    private int _pendingItems;
    private int _draftNotes;
    private int _unsignedNotesNeedingSignature;
    private int _incompleteIntakes;
    private List<NoteListItemApiResponse> _recentNotes = [];
    private List<DashboardPlanOfCareSummaryResponse> _recentPlansOfCare = [];
    private List<RecentActivity> _recentActivities = [];
    private List<DashboardAlertItemResponse> _dashboardAlerts = [];
    private List<SendIntakeModal.PatientOption> availablePatients = new();
    private bool HasDashboardContent =>
        _patientsToday > 0 ||
        _appointmentsToday > 0 ||
        _notesDue > 0 ||
        _pendingItems > 0 ||
        _draftNotes > 0 ||
        _unsignedNotesNeedingSignature > 0 ||
        _incompleteIntakes > 0 ||
        _recentNotes.Count > 0 ||
        _recentPlansOfCare.Count > 0 ||
        _recentActivities.Count > 0 ||
        _dashboardAlerts.Count > 0;

    protected override async Task OnInitializedAsync()
    {
        await RetryDashboardAsync();
        SetupAutoRefresh();
    }

    private async Task LoadAvailablePatientsAsync()
    {
        if (_isLoadingAvailablePatients)
        {
            return;
        }

        try
        {
            _isLoadingAvailablePatients = true;
            var patients = await IntakeService.SearchEligiblePatientsAsync(take: 200);
            availablePatients = patients
                .Select(p => new SendIntakeModal.PatientOption
                {
                    Id = p.Id.ToString(),
                    Name = p.DisplayName,
                    Email = p.Email,
                    PhoneNumber = p.Phone
                })
                .ToList();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "[Dashboard] Error loading patient list");
            ToastService.ShowError("Unable to load eligible patients for intake invites.");
        }
        finally
        {
            _isLoadingAvailablePatients = false;
        }
    }

    private async Task RetryDashboardAsync()
    {
        await LoadDashboardSnapshotAsync();
    }

    private async Task LoadDashboardSnapshotAsync()
    {
        if (_isDashboardLoading && _hasLoadedDashboard)
        {
            return;
        }

        _dashboardCts?.Cancel();
        _dashboardCts?.Dispose();
        _dashboardCts = new CancellationTokenSource();

        _isDashboardLoading = true;
        _isRecentActivityLoading = true;
        _dashboardLoadFailed = false;
        _dashboardErrorMessage = null;
        _recentActivityLoadFailed = false;
        _recentActivityErrorMessage = null;
        await InvokeStateHasChangedAsync();

        try
        {
            var snapshot = await DashboardAlertService.GetSnapshotAsync(_dashboardCts.Token);
            ApplySnapshot(snapshot);
            _hasLoadedDashboard = true;
        }
        catch (OperationCanceledException) when (_isDisposed || _dashboardCts.IsCancellationRequested)
        {
            return;
        }
        catch (Exception ex)
        {
            _dashboardLoadFailed = true;
            _dashboardErrorMessage = ToUserFacingDashboardError(ex, "The dashboard could not be loaded right now.");
            Logger.LogWarning(ex, "[Dashboard] Error loading dashboard snapshot");
        }
        finally
        {
            _isDashboardLoading = false;
            _isRecentActivityLoading = false;
            await InvokeStateHasChangedAsync();
        }
    }

    private async Task RetryRecentActivityAsync() => await LoadDashboardSnapshotAsync();

    private void SetupAutoRefresh()
    {
        _autoRefreshTimer = new System.Timers.Timer(5 * 60 * 1000); // 5 minutes
        _autoRefreshTimer.Elapsed += async (sender, e) =>
        {
            if (!_isDisposed)
            {
                await InvokeAsync(LoadDashboardSnapshotAsync);
            }
        };
        _autoRefreshTimer.Start();
    }

    private void HandleAddPatient()
    {
        isAddPatientModalOpen = true;
    }

    private async Task HandleSendIntakeAsync()
    {
        initialSendIntakePatientId = null;
        if (availablePatients.Count == 0)
        {
            await LoadAvailablePatientsAsync();
        }

        isSendIntakeModalOpen = true;
    }

    private async Task<bool> HandlePatientSubmit(AddPatientModal.PatientFormData formData)
    {
        if (!formData.DateOfBirth.HasValue)
        {
            ToastService.ShowError("Date of birth is required.");
            return false;
        }

        try
        {
            var request = new PTDoc.Application.DTOs.CreatePatientRequest
            {
                FirstName = formData.FirstName,
                LastName = formData.LastName,
                DateOfBirth = formData.DateOfBirth.Value,
                Email = formData.Email,
                Phone = formData.PhoneNumber
            };
            var created = await PatientService.CreateAsync(request);
            ToastService.ShowSuccess($"Patient {created.FirstName} {created.LastName} created.");
            await RetryDashboardAsync();

            if (formData.SubmitIntent == AddPatientModal.PatientSubmitIntent.AddPatientAndSendIntake)
            {
                await PrepareSendIntakeForPatientAsync(created);
            }

            return true;
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "[Dashboard] Error creating patient");
            ToastService.ShowError(ToUserFacingDashboardError(ex, "Failed to create patient. Please try again."));
            return false;
        }
    }

    private async Task HandleIntakeSubmit(SendIntakeModal.IntakeFormData formData)
    {
        try
        {
            initialSendIntakePatientId = null;
            await RetryDashboardAsync();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "[Dashboard] Error refreshing intake state");
        }
    }

    private async Task PrepareSendIntakeForPatientAsync(PatientResponse patient)
    {
        initialSendIntakePatientId = patient.Id.ToString("D");
        await LoadAvailablePatientsAsync();
        UpsertAvailablePatient(ToPatientOption(patient));
        isSendIntakeModalOpen = true;
        await InvokeStateHasChangedAsync();
    }

    private Task HandleSendIntakeOpenChanged(bool value)
    {
        isSendIntakeModalOpen = value;
        if (!value)
        {
            initialSendIntakePatientId = null;
        }

        return Task.CompletedTask;
    }

    private void UpsertAvailablePatient(SendIntakeModal.PatientOption patient)
    {
        availablePatients.RemoveAll(existing => string.Equals(existing.Id, patient.Id, StringComparison.Ordinal));
        availablePatients.Insert(0, patient);
    }

    private static SendIntakeModal.PatientOption ToPatientOption(PatientResponse patient) => new()
    {
        Id = patient.Id.ToString("D"),
        Name = $"{patient.FirstName} {patient.LastName}".Trim(),
        Email = patient.Email,
        PhoneNumber = patient.Phone
    };

    private void ApplySnapshot(DashboardSnapshotResponse snapshot)
    {
        _patientsToday = snapshot.Overview.PatientsToday;
        _appointmentsToday = snapshot.Overview.AppointmentsToday;
        _notesDue = snapshot.Overview.NotesDueToday;
        _pendingItems = snapshot.Overview.PendingItems;
        _draftNotes = snapshot.Overview.DraftNotes;
        _unsignedNotesNeedingSignature = snapshot.Overview.UnsignedNotes;
        _incompleteIntakes = snapshot.Overview.IncompleteIntakes;
        _dashboardAlerts = snapshot.Alerts.ToList();
        _recentNotes = snapshot.RecentNotes.ToList();
        _recentPlansOfCare = snapshot.RecentPlansOfCare.ToList();
        _recentActivities = snapshot.RecentActivities.Select(ToRecentActivity).ToList();
    }

    private static string ToUserFacingDashboardError(Exception exception, string fallback)
    {
        if (exception is HttpRequestException httpException &&
            !string.IsNullOrWhiteSpace(httpException.Message) &&
            !httpException.Message.StartsWith("Response status code", StringComparison.OrdinalIgnoreCase))
        {
            return httpException.Message;
        }

        return fallback;
    }

    private static RecentActivity ToRecentActivity(DashboardRecentActivityResponse activity)
    {
        return new RecentActivity
        {
            Id = activity.Id,
            Type = Enum.TryParse<ActivityType>(activity.Type, ignoreCase: true, out var parsedType)
                ? parsedType
                : ActivityType.NoteUpdated,
            Description = activity.Description,
            PatientId = activity.PatientId,
            PatientName = activity.PatientName,
            Timestamp = activity.Timestamp
        };
    }

    private async Task InvokeStateHasChangedAsync()
    {
        if (!_isDisposed)
        {
            await InvokeAsync(StateHasChanged);
        }
    }

    public void Dispose()
    {
        _isDisposed = true;
        _dashboardCts?.Cancel();
        _dashboardCts?.Dispose();
        _autoRefreshTimer?.Stop();
        _autoRefreshTimer?.Dispose();
    }
}
