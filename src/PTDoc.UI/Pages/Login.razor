@page "/login"
@page "/signup"
@page "/forgot-password"
@layout AuthLayout
@rendermode InteractiveServer
@inherits LoginBase

<PageTitle>@AuthPageTitle</PageTitle>


<div class="auth-shell">
  <button type="button" 
          class="theme-toggle login-theme-toggle" 
          aria-label="@(isDarkTheme ? "Switch to light theme" : "Switch to dark theme")"
          title="@(isDarkTheme ? "Switch to light theme" : "Switch to dark theme")"
          style="position: absolute; top: 24px; right: 24px;"
          @onclick="ToggleTheme">
    <span class="theme-icon theme-icon-light" aria-hidden="true"></span>
    <span class="theme-icon theme-icon-dark" aria-hidden="true"></span>
  </button>
  
  <div class="auth-brand">PTDoc</div>

  <div class="auth-card" aria-live="polite">
    <header class="auth-card-header">
      <p class="auth-welcome">Welcome</p>
      <div class="auth-tabs" role="tablist">
        <button type="button"
                role="tab"
                class="auth-tab @(authMode == AuthMode.Login ? "active" : "")"
                aria-selected="@(authMode == AuthMode.Login ? "true" : "false")"
                @onclick="() => SwitchMode(AuthMode.Login)">
          Login
        </button>
        @if (UserService.SupportsSelfServiceRegistration)
        {
          <button type="button"
                  role="tab"
                  class="auth-tab @(authMode == AuthMode.SignUp ? "active" : "")"
                  aria-selected="@(authMode == AuthMode.SignUp ? "true" : "false")"
                  @onclick="() => SwitchMode(AuthMode.SignUp)">
            Sign Up
          </button>
        }
      </div>
    </header>

    @if (isPendingApprovalNotice)
    {
      <div class="auth-info-alert" role="status" aria-live="polite">
        <span class="auth-info-icon auth-icon-pending" aria-hidden="true"></span>
        <div class="auth-info-content">
          <strong>Account pending approval</strong>
          <p>Your registration is awaiting admin approval. You will be able to sign in once your clinic administrator activates your account.</p>
        </div>
      </div>
    }

    @if (!string.IsNullOrEmpty(errorMessage))
    {
      <div class="auth-alert" role="alert">
        <span class="auth-alert-title">@AuthFailureTitle</span>
        <span>@errorMessage</span>
      </div>
    }

    @if (authMode == AuthMode.Login)
    {
      <EditForm FormName="LoginForm" Model="loginModel" OnValidSubmit="HandleLogin" class="auth-form" aria-busy="@isLoading">
        <DataAnnotationsValidator />

        @if (supportsExternalIdentityLogin)
        {
          <div class="auth-info-alert">
            <span class="auth-info-icon auth-icon-info" aria-hidden="true"></span>
            <div class="auth-info-content">
              <strong>Single sign-on available</strong>
              <p>You can sign in with your PTDoc credentials or continue with @UserService.IdentityProviderDisplayName.</p>
            </div>
          </div>
        }

        <div class="auth-field">
          <label for="username">Username or Email</label>
          <InputText id="username"
                     class="auth-input"
                     placeholder="Enter your username or email"
                     autocomplete="username"
                     autocapitalize="none"
                     autocorrect="off"
                     spellcheck="false"
                     @bind-Value="loginModel.Username" />
        </div>

        <div class="auth-field">
          <label for="pin">4-Digit PIN</label>
          <InputText id="pin"
                     type="password"
                     class="auth-input"
                     placeholder="Enter 4-digit PIN"
                     autocomplete="current-password"
                     maxlength="4"
                     aria-describedby="pin-error"
                     @bind-Value="loginModel.Pin" />
          <ValidationMessage id="pin-error" For="@(() => loginModel.Pin)" class="auth-validation" />
        </div>

        <div class="auth-actions">
          <button type="button" class="auth-link" disabled="@(isLoading || isExternalLoginRedirecting)" @onclick="() => SwitchMode(AuthMode.ForgotPassword)">Forgot PIN?</button>
        </div>

        <button type="submit" class="auth-primary" disabled="@(isLoading || isExternalLoginRedirecting)">
          @if (isLoading)
          {
            <span>Authenticating...</span>
          }
          else
          {
            <span>Login</span>
          }
        </button>

        @if (supportsExternalIdentityLogin)
        {
          <button type="button" class="auth-primary auth-secondary" disabled="@(isLoading || isExternalLoginRedirecting)" @onclick="HandleExternalLogin">
            @if (isExternalLoginRedirecting)
            {
              <span>Redirecting...</span>
            }
            else
            {
              <span>Continue with @UserService.IdentityProviderDisplayName</span>
            }
          </button>
        }
      </EditForm>
    }
    else if (authMode == AuthMode.ForgotPassword)
    {
      @if (showPasswordResetConfirmation)
      {
        <div class="auth-info-alert" role="status" aria-live="polite">
          <span class="auth-info-icon auth-icon-info" aria-hidden="true"></span>
          <div class="auth-info-content">
            <strong>Request received</strong>
            <p>@PasswordResetConfirmationMessage</p>
          </div>
        </div>
        <button type="button" class="auth-primary" @onclick="() => SwitchMode(AuthMode.Login)">
          Return to Login
        </button>
      }
      else
      {
        <EditForm @key="forgotPasswordFormKey" FormName="ForgotPasswordForm" Model="forgotPasswordModel" OnValidSubmit="HandleForgotPassword" class="auth-form" aria-busy="@isLoading">
          <DataAnnotationsValidator />

          <div class="auth-field">
            <label for="resetChannel">Send reset link by</label>
            <InputSelect id="resetChannel"
                         class="auth-input auth-select"
                         @bind-Value="forgotPasswordModel.Channel"
                         @bind-Value:after="OnForgotPasswordChannelChangedAfterBind">
              <option value="email">Email</option>
              <option value="sms">SMS</option>
            </InputSelect>
          </div>

          <div class="auth-field">
            <label for="resetContact">@ForgotContactLabel</label>
            <InputText id="resetContact"
                       class="auth-input"
                       placeholder="@ForgotContactPlaceholder"
                       autocomplete="@ForgotContactAutocomplete"
                       autocapitalize="none"
                       autocorrect="off"
                       spellcheck="false"
                       @bind-Value="forgotPasswordModel.Contact" />
            <ValidationMessage For="@(() => forgotPasswordModel.Contact)" class="auth-validation" />
          </div>

          <button type="submit" class="auth-primary" disabled="@isLoading">
            @if (isLoading)
            {
              <span>Sending...</span>
            }
            else
            {
              <span>Send Secure Link</span>
            }
          </button>

          <button type="button" class="auth-link" disabled="@isLoading" @onclick="() => SwitchMode(AuthMode.Login)">
            Return to Login
          </button>
        </EditForm>
      }
    }
    else
    {
      @if (showPendingConfirmation)
      {
        <div class="auth-info-alert" role="status">
          <span class="auth-info-icon auth-icon-info" aria-hidden="true"></span>
          <div class="auth-info-content">
            <strong>@registrationConfirmationTitle</strong>
            <p>@registrationConfirmationMessage</p>
          </div>
        </div>
        <button type="button" class="auth-primary" @onclick="() => SwitchMode(AuthMode.Login)">
          Return to Login
        </button>
      }
      else
      {
      <EditForm FormName="SignUpForm" Model="signUpModel" OnValidSubmit="HandleSignUp" class="auth-form" aria-busy="@isLoading">
        <DataAnnotationsValidator />

        <div class="auth-field">
          <label for="fullName">
            Full Legal Name
            <span class="auth-required" aria-label="required">*</span>
            <span class="auth-info-icon auth-icon-info" title="Enter your full legal name (first and last name) exactly as it appears on your professional license" aria-hidden="true"></span>
          </label>
          <InputText id="fullName"
                     class="auth-input"
                     placeholder="e.g., Sarah Johnson"
                     autocomplete="name"
                     @bind-Value="signUpModel.FullName" />
          <ValidationMessage For="@(() => signUpModel.FullName)" class="auth-validation" />
        </div>

        <div class="auth-field">
          <label for="dateOfBirth">
            Date of Birth
            <span class="auth-required" aria-label="required">*</span>
            <span class="auth-info-icon auth-icon-info" title="You must be at least 18 years old to create an account" aria-hidden="true"></span>
          </label>
          <input id="dateOfBirth"
                 type="date"
                 class="auth-input"
                 value="@DateOfBirthInputValue"
                 autocomplete="bday"
                 aria-describedby="dateOfBirth-help"
                 @oninput="OnDateOfBirthChanged"
                 @onchange="OnDateOfBirthChanged" />
          <p id="dateOfBirth-help" class="auth-field-hint">Use YYYY-MM-DD or pick a date from the calendar.</p>
          <ValidationMessage For="@(() => signUpModel.DateOfBirth)" class="auth-validation" />
        </div>

        <div class="auth-field">
          <label for="email">
            Professional Email Address
            <span class="auth-required" aria-label="required">*</span>
          </label>
          <InputText id="email"
                     type="email"
                     class="auth-input"
                     placeholder="email@example.com"
                     autocomplete="email"
                     @bind-Value="signUpModel.Email" />
          <ValidationMessage For="@(() => signUpModel.Email)" class="auth-validation" />
        </div>

        <div class="auth-field">
          <label for="roleKey">
            Role
            <span class="auth-required" aria-label="required">*</span>
            <span class="auth-info-icon auth-icon-info" title="Select your role for clinic onboarding" aria-hidden="true"></span>
          </label>
          <InputSelect id="roleKey"
                       class="auth-input auth-select"
                       @bind-Value="signUpModel.RoleKey"
                       @bind-Value:after="OnRoleChangedAfterBind">
            <option value="">Select role</option>
            @foreach (var role in roles)
            {
              <option value="@role.Key">@role.DisplayName</option>
            }
          </InputSelect>
          <ValidationMessage For="@(() => signUpModel.RoleKey)" class="auth-validation" />
        </div>

        <div class="auth-field">
          <label for="clinicId">
            Clinic
            <span class="auth-required" aria-label="required">*</span>
          </label>
          <InputSelect id="clinicId"
                       class="auth-input auth-select"
                       @bind-Value="signUpModel.ClinicId">
            <option value="">Select clinic</option>
            @foreach (var clinic in clinics)
            {
              <option value="@clinic.Id">@clinic.Name</option>
            }
          </InputSelect>
          <ValidationMessage For="@(() => signUpModel.ClinicId)" class="auth-validation" />
        </div>

        <div class="auth-field">
          <label for="pinSignup">
            4-Digit PIN
            <span class="auth-required" aria-label="required">*</span>
          </label>
          <InputText id="pinSignup"
                     type="password"
                     class="auth-input"
                     placeholder="Enter 4-digit PIN"
                     maxlength="4"
                     autocomplete="new-password"
                     @bind-Value="signUpModel.Pin" />
          <ValidationMessage For="@(() => signUpModel.Pin)" class="auth-validation" />
        </div>

        <div class="auth-field">
          <label for="confirmPinSignup">
            Confirm PIN
            <span class="auth-required" aria-label="required">*</span>
          </label>
          <InputText id="confirmPinSignup"
                     type="password"
                     class="auth-input"
                     placeholder="Confirm 4-digit PIN"
                     maxlength="4"
                     autocomplete="new-password"
                     @bind-Value="signUpModel.ConfirmPin" />
          <ValidationMessage For="@(() => signUpModel.ConfirmPin)" class="auth-validation" />
        </div>

        @if (isPtaFieldsActive)
        {
          <div class="auth-field">
            <label for="licenseNumber">
              License Number
              <span class="auth-required" aria-label="required">*</span>
              <span class="auth-info-icon auth-icon-info" title="Enter your PT/PTA license number exactly as shown on your license" aria-hidden="true"></span>
            </label>
            <InputText id="licenseNumber"
                       class="auth-input"
                       placeholder="e.g., PT123456 or PTA-2024-001234"
                       @bind-Value="signUpModel.LicenseNumber" />
            <ValidationMessage For="@(() => signUpModel.LicenseNumber)" class="auth-validation" />
          </div>

          <div class="auth-field">
            <label for="licenseState">
              License State
              <span class="auth-required" aria-label="required">*</span>
              <span class="auth-info-icon auth-icon-info" title="Select the U.S. state where your PT/PTA license was issued" aria-hidden="true"></span>
            </label>
            <InputSelect id="licenseState"
                         class="auth-input auth-select"
                         @bind-Value="signUpModel.LicenseState">
              <option value="">Select state</option>
              @foreach (var state in UsStates)
              {
                <option value="@state.Code">@state.Name</option>
              }
            </InputSelect>
            <ValidationMessage For="@(() => signUpModel.LicenseState)" class="auth-validation" />
          </div>
        }

        <div class="auth-info-alert">
          <span class="auth-info-icon auth-icon-info" aria-hidden="true"></span>
          <div class="auth-info-content">
            <strong>Account Approval:</strong>
            <p>Your credentials will be generated after sign-up. PT and PTA registrations include license details for admin review before activation.</p>
          </div>
        </div>

        <button type="submit" class="auth-primary" disabled="@(isLoading || isSubmitting)">
          @if (isLoading)
          {
            <span>Creating Account...</span>
          }
          else
          {
            <span>Create Account</span>
          }
        </button>

        <p class="auth-disclaimer">
          By creating an account, you agree to maintain HIPAA compliance and professional standards.
        </p>
      </EditForm>
      }
    }
  </div>

  <footer class="auth-footnote" aria-live="polite">
    <span><span class="auth-footnote-icon auth-icon-lock" aria-hidden="true"></span> HIPAA-compliant secure access</span>
    <span>Protected health information</span>
  </footer>
</div>
