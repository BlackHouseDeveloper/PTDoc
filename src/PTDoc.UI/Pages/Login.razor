@page "/login"
@page "/signup"
@page "/forgot-password"
@layout AuthLayout
@rendermode InteractiveServer
@inherits LoginBase

<PageTitle>@AuthPageTitle</PageTitle>


<div class="auth-shell">
  <button type="button" 
          class="theme-toggle login-theme-toggle" 
          aria-label="@(isDarkTheme ? "Switch to light theme" : "Switch to dark theme")"
          title="@(isDarkTheme ? "Switch to light theme" : "Switch to dark theme")"
          style="position: absolute; top: 24px; right: 24px;"
          @onclick="ToggleTheme">
    <span class="theme-icon theme-icon-light" aria-hidden="true"></span>
    <span class="theme-icon theme-icon-dark" aria-hidden="true"></span>
  </button>
  
  <div class="auth-brand">PTDoc</div>

  <div class="auth-card" aria-live="polite">
    <header class="auth-card-header">
      <p class="auth-welcome">Welcome</p>
      <div class="auth-tabs" role="tablist">
        <button type="button"
                role="tab"
                class="auth-tab @(authMode == AuthMode.Login ? "active" : "")"
                aria-selected="@(authMode == AuthMode.Login ? "true" : "false")"
                @onclick="() => SwitchMode(AuthMode.Login)">
          Login
        </button>
        @if (UserService.SupportsSelfServiceRegistration)
        {
          <button type="button"
                  role="tab"
                  class="auth-tab @(authMode == AuthMode.SignUp ? "active" : "")"
                  aria-selected="@(authMode == AuthMode.SignUp ? "true" : "false")"
                  @onclick="() => SwitchMode(AuthMode.SignUp)">
            Sign Up
          </button>
        }
      </div>
    </header>

    @if (isPendingApprovalNotice)
    {
      <div class="auth-info-alert" role="status" aria-live="polite">
        <span class="auth-info-icon auth-icon-pending" aria-hidden="true"></span>
        <div class="auth-info-content">
          <strong>Account pending approval</strong>
          <p>Your account has been created and is waiting for administrator approval.</p>
        </div>
      </div>
    }

    @if (!string.IsNullOrEmpty(errorMessage))
    {
      <div class="auth-alert" role="alert">
        <span class="auth-alert-title">@AuthFailureTitle</span>
        <span>@errorMessage</span>
      </div>
    }

    @if (authMode == AuthMode.Login)
    {
      <form method="post"
            action="/auth/login"
            class="auth-form"
            aria-busy="@isLoading"
            data-testid="login-form"
            novalidate
            @onsubmit="HandleLoginSubmitAsync"
            @onsubmit:preventDefault="true">
        <input type="hidden" name="returnUrl" value="@LoginReturnUrl" />
        @if (supportsExternalIdentityLogin)
        {
          <div class="auth-info-alert">
            <span class="auth-info-icon auth-icon-info" aria-hidden="true"></span>
            <div class="auth-info-content">
              <strong>Single sign-on available</strong>
              <p>You can sign in with your PTDoc credentials or continue with @UserService.IdentityProviderDisplayName.</p>
            </div>
          </div>
        }

        <div class="auth-field">
          <label for="username">Username or Email</label>
          <input id="username"
                 name="username"
                 type="text"
                 class="@BuildLoginInputClass(nameof(loginModel.Username))"
                 placeholder="Enter your username or email"
                 autocomplete="username"
                 autocapitalize="none"
                 autocorrect="off"
                 spellcheck="false"
                 aria-invalid="@HasLoginFieldError(nameof(loginModel.Username))"
                 aria-describedby="@(HasLoginFieldError(nameof(loginModel.Username)) ? "username-validation" : null)"
                 @bind="loginModel.Username"
                 @bind:event="oninput" />
          @if (GetLoginFieldError(nameof(loginModel.Username)) is { } usernameError)
          {
            <p id="username-validation" class="auth-validation" role="alert">@usernameError</p>
          }
        </div>

        <div class="auth-field">
          <label for="pin">4-Digit PIN</label>
          <input id="pin"
                 name="pin"
                 type="password"
                 class="@BuildLoginInputClass(nameof(loginModel.Pin))"
                 placeholder="Enter 4-digit PIN"
                 autocomplete="current-password"
                 inputmode="numeric"
                 pattern="[0-9]{4}"
                 maxlength="4"
                 aria-invalid="@HasLoginFieldError(nameof(loginModel.Pin))"
                 aria-describedby="@(HasLoginFieldError(nameof(loginModel.Pin)) ? "pin-validation" : null)"
                 @bind="loginModel.Pin"
                 @bind:event="oninput" />
          @if (GetLoginFieldError(nameof(loginModel.Pin)) is { } pinError)
          {
            <p id="pin-validation" class="auth-validation" role="alert">@pinError</p>
          }
        </div>

        <div class="auth-actions">
          <button type="button" class="auth-link" disabled="@(isLoading || isExternalLoginRedirecting)" @onclick="() => SwitchMode(AuthMode.ForgotPassword)">Forgot PIN?</button>
        </div>

        <button type="submit" class="auth-primary" disabled="@(isLoading || isExternalLoginRedirecting)">
          @if (isLoading)
          {
            <span>Authenticating...</span>
          }
          else
          {
            <span>Login</span>
          }
        </button>

        @if (supportsExternalIdentityLogin)
        {
          <button type="button" class="auth-primary auth-secondary" disabled="@(isLoading || isExternalLoginRedirecting)" @onclick="HandleExternalLogin">
            @if (isExternalLoginRedirecting)
            {
              <span>Redirecting...</span>
            }
            else
            {
              <span>Continue with @UserService.IdentityProviderDisplayName</span>
            }
          </button>
        }
      </form>
    }
    else if (authMode == AuthMode.ForgotPassword)
    {
      @if (showPasswordResetConfirmation)
      {
        <div class="auth-info-alert" role="status" aria-live="polite">
          <span class="auth-info-icon auth-icon-info" aria-hidden="true"></span>
          <div class="auth-info-content">
            <strong>Request received</strong>
            <p>@PasswordResetConfirmationMessage</p>
          </div>
        </div>
        <button type="button" class="auth-primary" @onclick="() => SwitchMode(AuthMode.Login)">
          Return to Login
        </button>
      }
      else
      {
        <EditForm @key="forgotPasswordFormKey" FormName="ForgotPasswordForm" Model="forgotPasswordModel" OnValidSubmit="HandleForgotPassword" class="auth-form" aria-busy="@isLoading">
          <DataAnnotationsValidator />

          <div class="auth-field">
            <label for="resetChannel">Send reset link by</label>
            <InputSelect id="resetChannel"
                         class="auth-input auth-select"
                         @bind-Value="forgotPasswordModel.Channel"
                         @bind-Value:after="OnForgotPasswordChannelChangedAfterBind">
              <option value="email">Email</option>
              <option value="sms">SMS</option>
            </InputSelect>
          </div>

          <div class="auth-field">
            <label for="resetContact">@ForgotContactLabel</label>
            <InputText id="resetContact"
                       class="auth-input"
                       placeholder="@ForgotContactPlaceholder"
                       autocomplete="@ForgotContactAutocomplete"
                       autocapitalize="none"
                       autocorrect="off"
                       spellcheck="false"
                       @bind-Value="forgotPasswordModel.Contact" />
            <ValidationMessage For="@(() => forgotPasswordModel.Contact)" class="auth-validation" />
          </div>

          <button type="submit" class="auth-primary" disabled="@isLoading">
            @if (isLoading)
            {
              <span>Sending...</span>
            }
            else
            {
              <span>Send Secure Link</span>
            }
          </button>

          <button type="button" class="auth-link" disabled="@isLoading" @onclick="() => SwitchMode(AuthMode.Login)">
            Return to Login
          </button>
        </EditForm>
      }
    }
    else
    {
      @if (showPendingConfirmation)
      {
        <div class="auth-info-alert" role="status">
          <span class="auth-info-icon auth-icon-info" aria-hidden="true"></span>
          <div class="auth-info-content">
            <strong>@registrationConfirmationTitle</strong>
            <p>@registrationConfirmationMessage</p>
          </div>
        </div>
        <button type="button" class="auth-primary" @onclick="() => SwitchMode(AuthMode.Login)">
          Return to Login
        </button>
      }
      else
      {
      <EditForm @key="signUpFormKey"
                id="signup-form"
                FormName="SignUpForm"
                EditContext="signUpEditContext"
                OnValidSubmit="HandleSignUp"
                OnInvalidSubmit="HandleInvalidSignUpSubmit"
                class="auth-form"
                aria-busy="@isLoading"
                novalidate
                data-testid="signup-form">
        <DataAnnotationsValidator />

        @if (HasSignUpValidationErrors)
        {
          <div class="auth-alert" role="alert" data-testid="signup-validation-summary">
            <span class="auth-alert-title">Please correct the highlighted fields</span>
            <span>Review the messages below and submit again.</span>
          </div>
        }

        <div class="auth-field">
          <label for="fullName">
            Full Legal Name
            <span class="auth-required" aria-label="required">*</span>
            <span class="auth-info-icon auth-icon-info" aria-hidden="true"></span>
          </label>
          <input id="fullName"
                 name="fullName"
                 type="text"
                 class="@BuildSignUpInputClass(nameof(signUpModel.FullName))"
                     placeholder="e.g., Sarah Johnson"
                     autocomplete="name"
                 aria-invalid="@(HasSignUpFieldError(nameof(signUpModel.FullName)) ? "true" : "false")"
                 aria-describedby="@BuildSignUpAriaDescribedBy(nameof(signUpModel.FullName), "fullName-help", "fullName-validation")"
                 @bind="signUpModel.FullName"
                 @bind:event="oninput"
                 @bind:after="() => OnSignUpTextFieldChanged(nameof(signUpModel.FullName))" />
          <p id="fullName-help" class="auth-field-hint">Enter your full legal name (first and last name) exactly as it appears on your professional license.</p>
          <ValidationMessage For="@(() => signUpModel.FullName)" id="fullName-validation" class="auth-validation" role="alert" />
        </div>

        <div class="auth-field">
          <label for="dateOfBirth">
            Date of Birth
            <span class="auth-required" aria-label="required">*</span>
            <span class="auth-info-icon auth-icon-info" aria-hidden="true"></span>
          </label>
          <input id="dateOfBirth"
                 type="date"
                 class="@BuildSignUpInputClass(nameof(signUpModel.DateOfBirth))"
                 value="@DateOfBirthInputValue"
                 autocomplete="bday"
                 aria-invalid="@(HasSignUpFieldError(nameof(signUpModel.DateOfBirth)) ? "true" : "false")"
                 aria-describedby="@BuildSignUpAriaDescribedBy(nameof(signUpModel.DateOfBirth), "dateOfBirth-help", "dateOfBirth-validation")"
                 @oninput="OnDateOfBirthChanged"
                 @onchange="OnDateOfBirthChanged" />
          <p id="dateOfBirth-help" class="auth-field-hint">You must be at least 18 years old to create an account. Use YYYY-MM-DD or pick a date from the calendar.</p>
          <ValidationMessage For="@(() => signUpModel.DateOfBirth)" id="dateOfBirth-validation" class="auth-validation" role="alert" />
        </div>

        <div class="auth-field">
          <label for="email">
            Professional Email Address
            <span class="auth-required" aria-label="required">*</span>
          </label>
          <input id="email"
                 name="email"
                 type="email"
                 class="@BuildSignUpInputClass(nameof(signUpModel.Email))"
                     placeholder="email@example.com"
                     autocomplete="email"
                 autocapitalize="none"
                 autocorrect="off"
                 spellcheck="false"
                 aria-invalid="@(HasSignUpFieldError(nameof(signUpModel.Email)) ? "true" : "false")"
                 aria-describedby="@BuildSignUpAriaDescribedBy(nameof(signUpModel.Email), null, "email-validation")"
                 @bind="signUpModel.Email"
                 @bind:event="oninput"
                 @bind:after="() => OnSignUpTextFieldChanged(nameof(signUpModel.Email))" />
          <ValidationMessage For="@(() => signUpModel.Email)" id="email-validation" class="auth-validation" role="alert" />
        </div>

        <div class="auth-field">
          <label for="roleKey">
            Role
            <span class="auth-required" aria-label="required">*</span>
            <span class="auth-info-icon auth-icon-info" aria-hidden="true"></span>
          </label>
          <InputSelect id="roleKey"
                       class="@BuildSignUpSelectClass(nameof(signUpModel.RoleKey))"
                       aria-invalid="@(HasSignUpFieldError(nameof(signUpModel.RoleKey)) ? "true" : "false")"
                       aria-describedby="@BuildSignUpAriaDescribedBy(nameof(signUpModel.RoleKey), "roleKey-help", "roleKey-validation")"
                       @bind-Value="signUpModel.RoleKey"
                       @bind-Value:after="OnRoleChangedAfterBind">
            <option value="">Select role</option>
            @foreach (var role in roles)
            {
              <option value="@role.Key">@role.DisplayName</option>
            }
          </InputSelect>
          <p id="roleKey-help" class="auth-field-hint">Select your role for clinic onboarding.</p>
          <ValidationMessage For="@(() => signUpModel.RoleKey)" id="roleKey-validation" class="auth-validation" role="alert" />
        </div>

        <div class="auth-field">
          <label for="clinicId">
            Clinic
            <span class="auth-required" aria-label="required">*</span>
          </label>
          <InputSelect id="clinicId"
                       class="@BuildSignUpSelectClass(nameof(signUpModel.ClinicId))"
                       aria-invalid="@(HasSignUpFieldError(nameof(signUpModel.ClinicId)) ? "true" : "false")"
                       aria-describedby="@BuildSignUpAriaDescribedBy(nameof(signUpModel.ClinicId), null, "clinicId-validation")"
                       @bind-Value="signUpModel.ClinicId">
            <option value="">Select clinic</option>
            @foreach (var clinic in clinics)
            {
              <option value="@clinic.Id">@clinic.Name</option>
            }
          </InputSelect>
          <ValidationMessage For="@(() => signUpModel.ClinicId)" id="clinicId-validation" class="auth-validation" role="alert" />
        </div>

        <div class="auth-field">
          <label for="pinSignup">
            4-Digit PIN
            <span class="auth-required" aria-label="required">*</span>
          </label>
          <input id="pinSignup"
                 name="pin"
                 type="password"
                 class="@BuildSignUpInputClass(nameof(signUpModel.Pin))"
                     placeholder="Enter 4-digit PIN"
                     maxlength="4"
                     autocomplete="new-password"
                 inputmode="numeric"
                 pattern="[0-9]{4}"
                 aria-invalid="@(HasSignUpFieldError(nameof(signUpModel.Pin)) ? "true" : "false")"
                 aria-describedby="@BuildSignUpAriaDescribedBy(nameof(signUpModel.Pin), null, "pinSignup-validation")"
                 @bind="signUpModel.Pin"
                 @bind:event="oninput"
                 @bind:after="() => OnSignUpTextFieldChanged(nameof(signUpModel.Pin))" />
          <ValidationMessage For="@(() => signUpModel.Pin)" id="pinSignup-validation" class="auth-validation" role="alert" />
        </div>

        <div class="auth-field">
          <label for="confirmPinSignup">
            Confirm PIN
            <span class="auth-required" aria-label="required">*</span>
          </label>
          <input id="confirmPinSignup"
                 name="confirmPin"
                 type="password"
                 class="@BuildSignUpInputClass(nameof(signUpModel.ConfirmPin))"
                     placeholder="Confirm 4-digit PIN"
                     maxlength="4"
                     autocomplete="new-password"
                 inputmode="numeric"
                 pattern="[0-9]{4}"
                 aria-invalid="@(HasSignUpFieldError(nameof(signUpModel.ConfirmPin)) ? "true" : "false")"
                 aria-describedby="@BuildSignUpAriaDescribedBy(nameof(signUpModel.ConfirmPin), null, "confirmPinSignup-validation")"
                 @bind="signUpModel.ConfirmPin"
                 @bind:event="oninput"
                 @bind:after="() => OnSignUpTextFieldChanged(nameof(signUpModel.ConfirmPin))" />
          <ValidationMessage For="@(() => signUpModel.ConfirmPin)" id="confirmPinSignup-validation" class="auth-validation" role="alert" />
        </div>

        @if (isPtaFieldsActive)
        {
          <div class="auth-field">
            <label for="licenseNumber">
              License Number
              <span class="auth-required" aria-label="required">*</span>
              <span class="auth-info-icon auth-icon-info" aria-hidden="true"></span>
            </label>
            <input id="licenseNumber"
                   name="licenseNumber"
                   type="text"
                   class="@BuildSignUpInputClass(nameof(signUpModel.LicenseNumber))"
                       placeholder="e.g., PT123456 or PTA-2024-001234"
                   aria-invalid="@(HasSignUpFieldError(nameof(signUpModel.LicenseNumber)) ? "true" : "false")"
                   aria-describedby="@BuildSignUpAriaDescribedBy(nameof(signUpModel.LicenseNumber), "licenseNumber-help", "licenseNumber-validation")"
                   @bind="signUpModel.LicenseNumber"
                   @bind:event="oninput"
                   @bind:after="() => OnSignUpTextFieldChanged(nameof(signUpModel.LicenseNumber))" />
            <p id="licenseNumber-help" class="auth-field-hint">Enter your PT/PTA license number exactly as shown on your license.</p>
            <ValidationMessage For="@(() => signUpModel.LicenseNumber)" id="licenseNumber-validation" class="auth-validation" role="alert" />
          </div>

          <div class="auth-field">
            <label for="licenseState">
              License State
              <span class="auth-required" aria-label="required">*</span>
              <span class="auth-info-icon auth-icon-info" aria-hidden="true"></span>
            </label>
            <InputSelect id="licenseState"
                         class="@BuildSignUpSelectClass(nameof(signUpModel.LicenseState))"
                         aria-invalid="@(HasSignUpFieldError(nameof(signUpModel.LicenseState)) ? "true" : "false")"
                         aria-describedby="@BuildSignUpAriaDescribedBy(nameof(signUpModel.LicenseState), "licenseState-help", "licenseState-validation")"
                         @bind-Value="signUpModel.LicenseState">
              <option value="">Select state</option>
              @foreach (var state in UsStates)
              {
                <option value="@state.Code">@state.Name</option>
              }
            </InputSelect>
            <p id="licenseState-help" class="auth-field-hint">Select the U.S. state where your PT/PTA license was issued.</p>
            <ValidationMessage For="@(() => signUpModel.LicenseState)" id="licenseState-validation" class="auth-validation" role="alert" />
          </div>
        }

        <div class="auth-info-alert">
          <span class="auth-info-icon auth-icon-info" aria-hidden="true"></span>
          <div class="auth-info-content">
            <strong>Account Approval:</strong>
            <p>Your credentials will be generated after sign-up. PT and PTA registrations include license details for admin review before activation.</p>
          </div>
        </div>

        <button type="submit" class="auth-primary" disabled="@(isLoading || isSubmitting)">
          @if (isLoading)
          {
            <span>Creating Account...</span>
          }
          else
          {
            <span>Create Account</span>
          }
        </button>

        <p class="auth-disclaimer">
          By creating an account, you agree to maintain HIPAA compliance and professional standards.
        </p>
      </EditForm>
      }
    }
  </div>

  <footer class="auth-footnote" aria-live="polite">
    <span><span class="auth-footnote-icon auth-icon-lock" aria-hidden="true"></span> HIPAA-compliant secure access</span>
    <span>Protected health information</span>
  </footer>
</div>
