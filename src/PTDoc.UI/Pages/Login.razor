@page "/login"
@page "/signup"
@layout AuthLayout
@rendermode InteractiveServer
@inherits LoginBase

<PageTitle>@(authMode == AuthMode.Login ? "Login" : "Sign Up")</PageTitle>


<div class="auth-shell">
  <button type="button" 
          class="theme-toggle login-theme-toggle" 
          aria-label="@(isDarkTheme ? "Switch to light theme" : "Switch to dark theme")"
          title="@(isDarkTheme ? "Switch to light theme" : "Switch to dark theme")"
          style="position: absolute; top: 24px; right: 24px;"
          @onclick="ToggleTheme">
    <span class="theme-icon theme-icon-light" aria-hidden="true"></span>
    <span class="theme-icon theme-icon-dark" aria-hidden="true"></span>
  </button>
  
  <div class="auth-brand">PT Docs+</div>

  <div class="auth-card" aria-live="polite">
    <header class="auth-card-header">
      <p class="auth-welcome">Welcome</p>
      <div class="auth-tabs" role="tablist">
        <button type="button"
                role="tab"
                class="auth-tab @(authMode == AuthMode.Login ? "active" : "")"
                aria-selected="@(authMode == AuthMode.Login ? "true" : "false")"
                @onclick="() => SwitchMode(AuthMode.Login)">
          Login
        </button>
        @if (UserService.SupportsSelfServiceRegistration)
        {
          <button type="button"
                  role="tab"
                  class="auth-tab @(authMode == AuthMode.SignUp ? "active" : "")"
                  aria-selected="@(authMode == AuthMode.SignUp ? "true" : "false")"
                  @onclick="() => SwitchMode(AuthMode.SignUp)">
            Sign Up
          </button>
        }
      </div>
    </header>

    @if (isPendingApprovalNotice)
    {
      <div class="auth-info-alert" role="status" aria-live="polite">
        <span class="auth-info-icon">⏳</span>
        <div class="auth-info-content">
          <strong>Account pending approval</strong>
          <p>Your registration is awaiting admin approval. You will be able to sign in once your clinic administrator activates your account.</p>
        </div>
      </div>
    }

    @if (!string.IsNullOrEmpty(errorMessage))
    {
      <div class="auth-alert" role="alert">
        <span class="auth-alert-title">@(authMode == AuthMode.Login ? "Login failed" : "Sign up failed")</span>
        <span>@errorMessage</span>
      </div>
    }

    @if (authMode == AuthMode.Login)
    {
      <EditForm FormName="LoginForm" Model="loginModel" OnValidSubmit="HandleLogin" class="auth-form" aria-busy="@isLoading">
        <DataAnnotationsValidator />

        @if (supportsExternalIdentityLogin)
        {
          <div class="auth-info-alert">
            <span class="auth-info-icon">ℹ️</span>
            <div class="auth-info-content">
              <strong>Single sign-on available</strong>
              <p>You can sign in with your PT Docs+ credentials or continue with @UserService.IdentityProviderDisplayName.</p>
            </div>
          </div>
        }

        <div class="auth-field">
          <label for="username">Username</label>
          <InputText id="username"
                     class="auth-input"
                     placeholder="Enter your username"
                     autocomplete="off"
                     @bind-Value="loginModel.Username" />
        </div>

        <div class="auth-field">
          <label for="pin">4-Digit PIN</label>
          <InputText id="pin"
                     type="password"
                     class="auth-input"
                     placeholder="Enter 4-digit PIN"
                     autocomplete="off"
                     maxlength="4"
                     aria-describedby="pin-error"
                     @bind-Value="loginModel.Pin" />
          <ValidationMessage id="pin-error" For="@(() => loginModel.Pin)" class="auth-validation" />
        </div>

        <div class="auth-actions">
          <button type="button" class="auth-link" disabled="@(isLoading || isExternalLoginRedirecting)">Forgot PIN?</button>
        </div>

        <button type="submit" class="auth-primary" disabled="@(isLoading || isExternalLoginRedirecting)">
          @if (isLoading)
          {
            <span>Authenticating...</span>
          }
          else
          {
            <span>Login</span>
          }
        </button>

        @if (supportsExternalIdentityLogin)
        {
          <button type="button" class="auth-primary auth-secondary" disabled="@(isLoading || isExternalLoginRedirecting)" @onclick="HandleExternalLogin">
            @if (isExternalLoginRedirecting)
            {
              <span>Redirecting...</span>
            }
            else
            {
              <span>Continue with @UserService.IdentityProviderDisplayName</span>
            }
          </button>
        }
      </EditForm>
    }
    else
    {
      @if (showPendingConfirmation)
      {
        <div class="auth-info-alert" role="status">
          <span class="auth-info-icon">ℹ️</span>
          <div class="auth-info-content">
            <strong>Registration submitted</strong>
            <p>Your account is pending admin approval. You can sign in once your clinic administrator activates access.</p>
          </div>
        </div>
        <button type="button" class="auth-primary" @onclick="() => SwitchMode(AuthMode.Login)">
          Return to Login
        </button>
      }
      else
      {
      <EditForm FormName="SignUpForm" Model="signUpModel" OnValidSubmit="HandleSignUp" class="auth-form" aria-busy="@isLoading">
        <DataAnnotationsValidator />

        <div class="auth-field">
          <label for="fullName">
            Full Legal Name
            <span class="auth-required" aria-label="required">*</span>
            <span class="auth-info-icon" title="Enter your full legal name (first and last name) exactly as it appears on your professional license">ⓘ</span>
          </label>
          <InputText id="fullName"
                     class="auth-input"
                     placeholder="e.g., Sarah Johnson"
                     autocomplete="name"
                     @bind-Value="signUpModel.FullName" />
          <ValidationMessage For="@(() => signUpModel.FullName)" class="auth-validation" />
        </div>

        <div class="auth-field">
          <label for="dateOfBirth">
            Date of Birth
            <span class="auth-required" aria-label="required">*</span>
            <span class="auth-info-icon" title="You must be at least 18 years old to create an account">ⓘ</span>
          </label>
          <InputDate id="dateOfBirth"
                     class="auth-input"
                     placeholder="Select your date of birth"
                     @bind-Value="signUpModel.DateOfBirth" />
          <ValidationMessage For="@(() => signUpModel.DateOfBirth)" class="auth-validation" />
        </div>

        <div class="auth-field">
          <label for="email">
            Professional Email Address
            <span class="auth-required" aria-label="required">*</span>
          </label>
          <InputText id="email"
                     type="email"
                     class="auth-input"
                     placeholder="email@example.com"
                     autocomplete="email"
                     @bind-Value="signUpModel.Email" />
          <ValidationMessage For="@(() => signUpModel.Email)" class="auth-validation" />
        </div>

        <div class="auth-field">
          <label for="roleKey">
            Role
            <span class="auth-required" aria-label="required">*</span>
            <span class="auth-info-icon" title="Select your role for clinic onboarding">ⓘ</span>
          </label>
          <InputSelect id="roleKey"
                       class="auth-input auth-select"
                       @bind-Value="signUpModel.RoleKey"
                       @bind-Value:after="OnRoleChangedAfterBind">
            <option value="">Select role</option>
            @foreach (var role in roles)
            {
              <option value="@role.Key">@role.DisplayName</option>
            }
          </InputSelect>
          <ValidationMessage For="@(() => signUpModel.RoleKey)" class="auth-validation" />
        </div>

        <div class="auth-field">
          <label for="clinicId">
            Clinic
            <span class="auth-required" aria-label="required">*</span>
          </label>
          <InputSelect id="clinicId"
                       class="auth-input auth-select"
                       @bind-Value="signUpModel.ClinicId">
            <option value="">Select clinic</option>
            @foreach (var clinic in clinics)
            {
              <option value="@clinic.Id">@clinic.Name</option>
            }
          </InputSelect>
          <ValidationMessage For="@(() => signUpModel.ClinicId)" class="auth-validation" />
        </div>

        <div class="auth-field">
          <label for="pinSignup">
            4-Digit PIN
            <span class="auth-required" aria-label="required">*</span>
          </label>
          <InputText id="pinSignup"
                     type="password"
                     class="auth-input"
                     placeholder="Enter 4-digit PIN"
                     maxlength="4"
                     autocomplete="new-password"
                     @bind-Value="signUpModel.Pin" />
          <ValidationMessage For="@(() => signUpModel.Pin)" class="auth-validation" />
        </div>

        <div class="auth-field">
          <label for="confirmPinSignup">
            Confirm PIN
            <span class="auth-required" aria-label="required">*</span>
          </label>
          <InputText id="confirmPinSignup"
                     type="password"
                     class="auth-input"
                     placeholder="Confirm 4-digit PIN"
                     maxlength="4"
                     autocomplete="new-password"
                     @bind-Value="signUpModel.ConfirmPin" />
          <ValidationMessage For="@(() => signUpModel.ConfirmPin)" class="auth-validation" />
        </div>

        @if (isPtaFieldsActive)
        {
          <div class="auth-field">
            <label for="licenseType">
              License Type
              <span class="auth-required" aria-label="required">*</span>
              <span class="auth-info-icon" title="Select PT (Physical Therapist) or PTA (Physical Therapist Assistant)">ⓘ</span>
            </label>
            <InputSelect id="licenseType"
                         class="auth-input auth-select"
                         @bind-Value="signUpModel.LicenseType">
              <option value="">Select license type</option>
              <option value="PT">PT (Physical Therapist)</option>
              <option value="PTA">PTA (Physical Therapist Assistant)</option>
            </InputSelect>
          </div>

          <div class="auth-field">
            <label for="licenseNumber">
              License Number
              <span class="auth-required" aria-label="required">*</span>
              <span class="auth-info-icon" title="Enter your PT/PTA license number exactly as shown on your license">ⓘ</span>
            </label>
            <InputText id="licenseNumber"
                       class="auth-input"
                       placeholder="e.g., PT123456 or PTA-2024-001234"
                       @bind-Value="signUpModel.LicenseNumber" />
            <ValidationMessage For="@(() => signUpModel.LicenseNumber)" class="auth-validation" />
          </div>

          <div class="auth-field">
            <label for="licenseState">
              License State
              <span class="auth-required" aria-label="required">*</span>
              <span class="auth-info-icon" title="Select the U.S. state where your PT/PTA license was issued">ⓘ</span>
            </label>
            <InputSelect id="licenseState"
                         class="auth-input auth-select"
                         @bind-Value="signUpModel.LicenseState">
              <option value="">Select state</option>
              @foreach (var state in UsStates)
              {
                <option value="@state.Code">@state.Name</option>
              }
            </InputSelect>
            <ValidationMessage For="@(() => signUpModel.LicenseState)" class="auth-validation" />
          </div>
        }

        <div class="auth-info-alert">
          <span class="auth-info-icon">ℹ️</span>
          <div class="auth-info-content">
            <strong>License Verification:</strong>
            <p>Your credentials will be automatically generated after sign-up. In a production environment, license information would be verified against state licensing boards.</p>
          </div>
        </div>

        <button type="submit" class="auth-primary" disabled="@(isLoading || isSubmitting)">
          @if (isLoading)
          {
            <span>Creating Account...</span>
          }
          else
          {
            <span>Create Professional Account</span>
          }
        </button>

        <p class="auth-disclaimer">
          By creating an account, you agree to maintain HIPAA compliance and professional standards.
        </p>
      </EditForm>
      }
    }
  </div>

  <footer class="auth-footnote" aria-live="polite">
    <span>🔒 HIPAA-compliant secure access</span>
    <span>Protected health information</span>
  </footer>
</div>
