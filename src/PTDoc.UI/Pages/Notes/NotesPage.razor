@page "/notes"
@attribute [Authorize(Policy = AuthorizationPolicies.NoteRead)]
@inject NavigationManager NavigationManager
@rendermode InteractiveServer
@using PTDoc.Application.Configurations.Header
@using PTDoc.Application.Services
@using PTDoc.Application.DTOs
@using PTDoc.Core.Models
@using PTDoc.UI.Components.Notes.Models
@using System.Security.Claims
@using System.Text.Json
@inject INoteService NoteService
@inject IToastService ToastService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ILogger<NotesPage> Logger
@implements IDisposable

<PageTitle>Clinical Notes - PTDoc</PageTitle>

<div class="notes-page" data-testid="notes-page">
    <GlobalPageHeader
        Configuration="pageHeaderConfiguration"
        ShowBackButton="true"
        BackRoute="/"
        BackButtonAriaLabel="Back to dashboard"
        TestId="notes-header"
    />

    <div class="notes-page-content-shell">
        <div class="notes-page-content">
            <NotesFilterBar
                State="filterState"
                NoteTypes="noteTypes"
                Patients="patients"
                Statuses="statuses"
                OnStateChanged="HandleFilterChanged"
            />

            @if (_isLoading)
            {
                <section class="notes-page-state" role="status" aria-live="polite" data-testid="notes-loading-state">
                    <p class="notes-page-state-title">Loading notes</p>
                    <p class="notes-page-state-description">Retrieving recent clinical documentation.</p>
                </section>
            }
            else if (!string.IsNullOrWhiteSpace(_loadErrorMessage))
            {
                <section class="notes-page-state notes-page-state-error" role="alert" data-testid="notes-error-state">
                    <p class="notes-page-state-title">Unable to load notes</p>
                    <p class="notes-page-state-description">@_loadErrorMessage</p>
                    <button type="button" class="notes-page-state-button" @onclick="RetryLoadNotesAsync">Retry</button>
                </section>
            }
            else
            {
                @if (notesNeedingAttention.Count > 0)
                {
                    <NotesNeedsAttentionBanner
                        Items="notesNeedingAttention"
                        OnFixNow="HandleResolveAttentionNote"
                        OnView="HandleViewNote"
                    />
                }

                <NotesRecentSection
                    Items="regularRecentNotes"
                    OnView="HandleViewNote"
                    OnEdit="HandleEditNote"
                    OnDownloadPdf="HandleDownloadPdf"
                />
            }
        </div>
    </div>
</div>

@code {
    private readonly NotesFilterState filterState = new();
    private readonly HeaderConfiguration pageHeaderConfiguration = new()
    {
        Route = "/notes",
        Title = "Clinical Notes",
        Subtitle = "Manage patient documentation",
        ShowSyncControls = false,
        ShowStatusBadge = false
    };
    private readonly List<NoteListItemVm> notes = new();
    private readonly List<string> noteTypes = new();
    private readonly List<string> patients = new();
    private readonly List<string> statuses = new() { "Draft", "Pending Co-Sign", "Submitted", "Unsigned", "Needs Attention" };

    private List<NoteListItemVm> notesNeedingAttention = new();
    private List<NoteListItemVm> regularRecentNotes = new();
    private CancellationTokenSource _cts = new();
    private CancellationTokenSource? _filterDebounceCts;
    private ClaimsPrincipal _user = new(new ClaimsIdentity());
    private bool _isLoading = true;
    private string? _loadErrorMessage;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        _user = authState.User;
        ApplyQueryFilters();
        await LoadNotesAsync(_cts.Token);
        BuildFilterOptions();
        ApplyFilters();
    }

    private async Task LoadNotesAsync(CancellationToken cancellationToken)
    {
        _isLoading = true;
        _loadErrorMessage = null;
        StateHasChanged();

        try
        {
            var dateRange = ResolveDateRange(filterState.DateRange);
            var result = await NoteService.GetNotesAsync(
                patientId: null,
                noteType: NormalizeAllFilterValue(filterState.NoteType),
                status: NormalizeAllFilterValue(filterState.Status),
                take: 200,
                cancellationToken: cancellationToken,
                search: NormalizeAllFilterValue(filterState.SearchQuery),
                dateRangeStart: dateRange.Start,
                dateRangeEnd: dateRange.End);

            notes.Clear();
            notes.AddRange(result.Select(ToVm));
        }
        catch (OperationCanceledException) when (cancellationToken.IsCancellationRequested)
        {
            return;
        }
        catch (Exception ex)
        {
            notes.Clear();
            _loadErrorMessage = "Notes could not be retrieved. Retry when the connection is available.";
            Logger.LogError(ex, "Failed to load clinical notes.");
            ToastService.ShowError("Failed to load notes. Retry when the connection is available.");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task RetryLoadNotesAsync()
    {
        ResetLoadCancellation();
        await LoadNotesAsync(_cts.Token);
        BuildFilterOptions();
        ApplyFilters();
    }

    private NoteListItemVm ToVm(NoteListItemApiResponse dto)
    {
        string[] cptCodes;
        try
        {
            cptCodes = JsonSerializer.Deserialize<string[]>(dto.CptCodesJson) ?? Array.Empty<string>();
        }
        catch
        {
            cptCodes = Array.Empty<string>();
        }

        var noteStatus = dto.NoteStatus ?? (dto.IsSigned ? NoteStatus.Signed : NoteStatus.Draft);

        return new NoteListItemVm
        {
            Id = dto.Id.ToString(),
            PatientId = dto.PatientId.ToString(),
            PatientName = dto.PatientName,
            NoteType = dto.NoteType,
            Status = GetDisplayStatus(noteStatus, dto.IsSigned),
            CreatedDate = dto.DateOfService,
            LastModified = dto.LastModifiedUtc,
            CreatedBy = string.Empty,
            Summary = string.Empty,
            CptCodes = cptCodes,
            AttentionReason = GetAttentionReason(noteStatus),
            IsUnsigned = !dto.IsSigned,
            IsPendingCoSign = noteStatus == NoteStatus.PendingCoSign,
            CanEdit = CanEditNote(noteStatus, dto.NoteType),
            CanResolveAttention = CanResolveAttention(noteStatus, dto.NoteType),
            CanDownloadPdf = CanDownloadPdf(noteStatus),
            ReadOnlyReason = GetReadOnlyReason(noteStatus, dto.NoteType)
        };
    }

    private bool CanEditNote(NoteStatus noteStatus, string noteType)
    {
        if (noteStatus != NoteStatus.Draft)
        {
            return false;
        }

        if (_user.IsInRole(Roles.PT))
        {
            return true;
        }

        return _user.IsInRole(Roles.PTA)
            && noteType.Contains("Daily", StringComparison.OrdinalIgnoreCase);
    }

    private bool CanResolveAttention(NoteStatus noteStatus, string noteType)
    {
        if (noteStatus == NoteStatus.PendingCoSign)
        {
            return _user.IsInRole(Roles.PT);
        }

        return CanEditNote(noteStatus, noteType);
    }

    private bool CanDownloadPdf(NoteStatus noteStatus)
    {
        return noteStatus == NoteStatus.Signed
            && (_user.IsInRole(Roles.PT)
            || _user.IsInRole(Roles.PTA)
            || _user.IsInRole(Roles.Admin));
    }

    private string? GetReadOnlyReason(NoteStatus noteStatus, string noteType)
    {
        if (CanEditNote(noteStatus, noteType))
        {
            return null;
        }

        if (_user.IsInRole(Roles.Admin) || _user.IsInRole(Roles.Owner) || _user.IsInRole(Roles.Billing))
        {
            return "Read-only";
        }

        if (noteStatus == NoteStatus.Signed)
        {
            return "Signed";
        }

        if (noteStatus == NoteStatus.PendingCoSign)
        {
            return "Co-sign pending";
        }

        return "View only";
    }

    private static string GetDisplayStatus(NoteStatus noteStatus, bool isSigned) => noteStatus switch
    {
        NoteStatus.PendingCoSign => "Pending Co-Sign",
        NoteStatus.Signed => "Submitted",
        NoteStatus.Draft => "Draft",
        _ => isSigned ? "Submitted" : "Draft"
    };

    private static string? GetAttentionReason(NoteStatus noteStatus) => noteStatus switch
    {
        NoteStatus.PendingCoSign => "Awaiting PT co-signature before the note can be fully finalized.",
        _ => null
    };

    private void BuildFilterOptions()
    {
        noteTypes.Clear();
        patients.Clear();

        noteTypes.AddRange(notes.Select(n => n.NoteType).Distinct(StringComparer.OrdinalIgnoreCase).OrderBy(value => value));
        patients.AddRange(notes.Select(n => n.PatientName).Distinct(StringComparer.OrdinalIgnoreCase).OrderBy(value => value));

        AddSelectedOptionIfMissing(noteTypes, filterState.NoteType);
        AddSelectedOptionIfMissing(patients, filterState.Patient);
    }

    private static void AddSelectedOptionIfMissing(List<string> options, string? selectedValue)
    {
        if (string.IsNullOrWhiteSpace(selectedValue) ||
            string.Equals(selectedValue, "all", StringComparison.OrdinalIgnoreCase) ||
            options.Contains(selectedValue, StringComparer.OrdinalIgnoreCase))
        {
            return;
        }

        options.Add(selectedValue);
        options.Sort(StringComparer.OrdinalIgnoreCase);
    }

    private async Task HandleFilterChanged(NotesFilterState next)
    {
        var searchChanged = !string.Equals(filterState.SearchQuery, next.SearchQuery, StringComparison.Ordinal);
        filterState.SearchQuery = next.SearchQuery;
        filterState.NoteType = next.NoteType;
        filterState.Patient = next.Patient;
        filterState.Status = next.Status;
        filterState.DateRange = next.DateRange;

        if (searchChanged)
        {
            await DebouncedReloadNotesAsync();
            return;
        }

        await ReloadNotesForFiltersAsync();
    }

    private void ApplyFilters()
    {
        var filtered = notes
            .Where(MatchesSearch)
            .Where(MatchesNoteType)
            .Where(MatchesPatient)
            .Where(MatchesStatus)
            .Where(MatchesDateRange)
            .OrderByDescending(note => note.CreatedDate)
            .ToList();

        notesNeedingAttention = filtered.Where(note => note.NeedsAttention).ToList();
        regularRecentNotes = filtered.Where(note => !note.NeedsAttention).ToList();
    }

    private async Task ReloadNotesForFiltersAsync()
    {
        _filterDebounceCts?.Cancel();
        ResetLoadCancellation();
        await LoadNotesAsync(_cts.Token);
        BuildFilterOptions();
        ApplyFilters();
    }

    private async Task DebouncedReloadNotesAsync()
    {
        _filterDebounceCts?.Cancel();
        _filterDebounceCts?.Dispose();
        _filterDebounceCts = new CancellationTokenSource();
        var debounceToken = _filterDebounceCts.Token;

        try
        {
            await Task.Delay(250, debounceToken);
        }
        catch (OperationCanceledException) when (debounceToken.IsCancellationRequested)
        {
            return;
        }

        ResetLoadCancellation();
        await LoadNotesAsync(_cts.Token);
        BuildFilterOptions();
        ApplyFilters();
    }

    private bool MatchesSearch(NoteListItemVm note)
    {
        if (string.IsNullOrWhiteSpace(filterState.SearchQuery))
        {
            return true;
        }

        var query = filterState.SearchQuery.Trim();
        return note.PatientName.Contains(query, StringComparison.OrdinalIgnoreCase)
            || note.NoteType.Contains(query, StringComparison.OrdinalIgnoreCase)
            || note.Summary.Contains(query, StringComparison.OrdinalIgnoreCase);
    }

    private bool MatchesNoteType(NoteListItemVm note)
    {
        return filterState.NoteType == "all" || string.Equals(note.NoteType, filterState.NoteType, StringComparison.OrdinalIgnoreCase);
    }

    private bool MatchesPatient(NoteListItemVm note)
    {
        return filterState.Patient == "all" || string.Equals(note.PatientName, filterState.Patient, StringComparison.OrdinalIgnoreCase);
    }

    private bool MatchesStatus(NoteListItemVm note)
    {
        if (filterState.Status == "all")
        {
            return true;
        }

        if (string.Equals(filterState.Status, "Needs Attention", StringComparison.OrdinalIgnoreCase))
        {
            return note.NeedsAttention;
        }

        if (string.Equals(filterState.Status, "Unsigned", StringComparison.OrdinalIgnoreCase))
        {
            return note.IsUnsigned;
        }

        return string.Equals(note.Status, filterState.Status, StringComparison.OrdinalIgnoreCase);
    }

    private bool MatchesDateRange(NoteListItemVm note)
    {
        if (filterState.DateRange == "all")
        {
            return true;
        }

        var ageInDays = (DateTime.UtcNow.Date - note.CreatedDate.Date).Days;

        return filterState.DateRange switch
        {
            "today" => ageInDays == 0,
            "week" => ageInDays <= 7,
            "month" => ageInDays <= 30,
            _ => true
        };
    }

    private static (DateTime? Start, DateTime? End) ResolveDateRange(string? dateRange)
    {
        var today = DateTime.UtcNow.Date;
        return dateRange switch
        {
            "today" => (today, today),
            "week" => (today.AddDays(-7), today),
            "month" => (today.AddDays(-30), today),
            _ => (null, null)
        };
    }

    private static string? NormalizeAllFilterValue(string? value)
    {
        return string.IsNullOrWhiteSpace(value) || string.Equals(value, "all", StringComparison.OrdinalIgnoreCase)
            ? null
            : value.Trim();
    }

    private void ApplyQueryFilters()
    {
        var queryValues = ParseQuery(NavigationManager.ToAbsoluteUri(NavigationManager.Uri).Query);

        if (queryValues.TryGetValue("status", out var status) && IsAllowedStatus(status))
        {
            filterState.Status = status;
        }

        if (queryValues.TryGetValue("dateRange", out var dateRange) && IsAllowedDateRange(dateRange))
        {
            filterState.DateRange = dateRange;
        }

        if (queryValues.TryGetValue("noteType", out var noteType) && !string.IsNullOrWhiteSpace(noteType))
        {
            filterState.NoteType = noteType;
        }

        if (queryValues.TryGetValue("patient", out var patient) && !string.IsNullOrWhiteSpace(patient))
        {
            filterState.Patient = patient;
        }

        if (queryValues.TryGetValue("search", out var search) && !string.IsNullOrWhiteSpace(search))
        {
            filterState.SearchQuery = search;
        }
    }

    private bool IsAllowedStatus(string status) =>
        string.Equals(status, "all", StringComparison.OrdinalIgnoreCase) ||
        statuses.Contains(status, StringComparer.OrdinalIgnoreCase);

    private static bool IsAllowedDateRange(string dateRange) =>
        string.Equals(dateRange, "all", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(dateRange, "today", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(dateRange, "week", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(dateRange, "month", StringComparison.OrdinalIgnoreCase);

    private static Dictionary<string, string> ParseQuery(string query)
    {
        var values = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
        if (string.IsNullOrWhiteSpace(query))
        {
            return values;
        }

        foreach (var pair in query.TrimStart('?').Split('&', StringSplitOptions.RemoveEmptyEntries))
        {
            var parts = pair.Split('=', 2);
            if (parts.Length == 0 || string.IsNullOrWhiteSpace(parts[0]))
            {
                continue;
            }

            var key = Uri.UnescapeDataString(parts[0].Replace("+", " ", StringComparison.Ordinal));
            var value = parts.Length > 1
                ? Uri.UnescapeDataString(parts[1].Replace("+", " ", StringComparison.Ordinal))
                : string.Empty;

            values[key] = value;
        }

        return values;
    }

    private void HandleResolveAttentionNote(NoteListItemVm note)
    {
        NavigateToNoteWorkspace(note, note.IsPendingCoSign ? "review" : null);
    }

    private void HandleViewNote(NoteListItemVm note)
    {
        NavigateToNoteWorkspace(note);
    }

    private void HandleEditNote(NoteListItemVm note)
    {
        NavigateToNoteWorkspace(note);
    }

    private void HandleDownloadPdf(NoteListItemVm note)
    {
        if (!note.CanDownloadPdf)
        {
            var message = string.Equals(note.Status, "Submitted", StringComparison.OrdinalIgnoreCase)
                ? "Your role does not have permission to export note PDFs."
                : "Only submitted notes can be exported as PDFs.";
            ToastService.ShowWarning(message);
            return;
        }

        // PDF export is handled in the note workspace. Navigate there to download.
        NavigateToNoteWorkspace(note, "review");
    }

    private void NavigateToNoteWorkspace(NoteListItemVm note, string? requestedSection = null)
    {
        if (string.IsNullOrWhiteSpace(note.PatientId))
        {
            return;
        }

        if (!string.IsNullOrWhiteSpace(note.Id))
        {
            var uri = $"/patient/{Uri.EscapeDataString(note.PatientId)}/note/{Uri.EscapeDataString(note.Id)}";
            if (!string.IsNullOrWhiteSpace(requestedSection))
            {
                uri = $"{uri}?section={Uri.EscapeDataString(requestedSection)}";
            }

            NavigationManager.NavigateTo(uri);
            return;
        }

        NavigationManager.NavigateTo($"/patient/{Uri.EscapeDataString(note.PatientId)}/new-note");
    }

    public void Dispose()
    {
        _filterDebounceCts?.Cancel();
        _filterDebounceCts?.Dispose();
        _cts.Cancel();
        _cts.Dispose();
    }

    private void ResetLoadCancellation()
    {
        _cts.Cancel();
        _cts.Dispose();
        _cts = new CancellationTokenSource();
    }
}
