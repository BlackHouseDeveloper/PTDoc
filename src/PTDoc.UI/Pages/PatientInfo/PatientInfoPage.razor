@page "/patient/info"
@page "/patient/{Id}/info"
@attribute [Authorize]
@rendermode InteractiveServer
@using PTDoc.UI.Components.PatientInfo
@using PTDoc.UI.Components.PatientInfo.Models
@using PTDoc.Application.Services
@using PTDoc.Application.DTOs
@using System.Globalization
@using System.Text.Json
@using System.Text.Json.Serialization
@inject NavigationManager Navigation
@inject IPatientService PatientService
@inject IToastService ToastService
@implements IDisposable

<PageTitle>Patient &amp; Payer Information - PTDoc</PageTitle>

<div class="pi-page">
    <div class="pi-page-container">

        <PatientInfoPageHeader Title="Patient &amp; Payer Information"
                               Subtitle="@Vm.PatientDisplayName"
                               OnBack="HandleBack" />

        @if (isPatientUnavailable)
        {
            <section class="pi-page-state" role="status" aria-live="polite">
                <h2>@unavailableTitle</h2>
                <p>@unavailableMessage</p>
                <button type="button" class="btn btn-primary" @onclick="HandleBackToPatients">Back to Patients</button>
            </section>
        }
        else
        {
        <div class="pi-page-panels">

            <PatientPayerInformationPanel
                Model="@Vm.PatientPayer"
                ModelChanged="@(m => { Vm.PatientPayer = m; })"
                ProviderTypeOptions="@ProviderTypeOptions"
                InsurancePriorityOptions="@InsurancePriorityOptions"
                YearTypeOptions="@YearTypeOptions"
                FieldErrors="@GetPanelErrors("payer")"
                OnAnyFieldChanged="HandleFieldChanged" />

            <AdditionalAuthorizationSettingsPanel
                Model="@Vm.AdditionalSettings"
                ModelChanged="@(m => { Vm.AdditionalSettings = m; })"
                AuthorizationStatusOptions="@AuthorizationStatusOptions"
                AuthorizationTypeOptions="@AuthorizationTypeOptions"
                FieldErrors="@GetPanelErrors("additionalSettings")"
                OnAnyFieldChanged="HandleFieldChanged" />

            <AuthorizationDetailsPanel
                Model="@Vm.Authorization"
                ModelChanged="@(m => { Vm.Authorization = m; })"
                AuthorizationRequired="@Vm.AdditionalSettings.AuthorizationRequired"
                FieldErrors="@GetPanelErrors("auth")"
                OnAnyFieldChanged="HandleFieldChanged" />

            <AuthorizationReferralHistoryPanel
                Model="@Vm.AuthorizationReferralHistory"
                ModelChanged="@(m => { Vm.AuthorizationReferralHistory = m; })"
                FieldErrors="@GetPanelErrors("authHistory")"
                ValidationMessage="@AuthorizationHistoryValidationMessage"
                OnAnyFieldChanged="HandleFieldChanged" />

            <VisitTrackingUtilizationPanel
                Model="@Vm.Utilization"
                ModelChanged="@(m => { Vm.Utilization = m; })"
                FieldErrors="@GetPanelErrors("utilization")"
                OnAnyFieldChanged="HandleFieldChanged" />

            <SupportingDocumentationPanel
                Model="@Vm.SupportingDocs"
                ModelChanged="@(m => { Vm.SupportingDocs = m; })"
                FieldErrors="@GetPanelErrors("supportingDocs")"
                OnAnyFieldChanged="HandleFieldChanged" />

        </div>

        <PatientInfoActionRow IsDirty="@Vm.IsDirty"
                              IsSaving="@Vm.IsSaving"
                              HasValidationErrors="@HasPageErrors"
                              OnSave="HandleSave"
                              OnBack="HandleBack" />
        }

    </div>
</div>

@code {
    [Parameter] public string? Id { get; set; }

    private PatientInfoPageVm Vm { get; set; } = new();
    private IDisposable? _navGuard;
    private PayerInfoStorage? loadedPayerInfo;
    private bool isPatientUnavailable;
    private string unavailableTitle = "Patient not found";
    private string unavailableMessage = "The selected patient record could not be loaded.";

    private static readonly JsonSerializerOptions SerializerOptions = new()
    {
        PropertyNamingPolicy = JsonNamingPolicy.CamelCase,
        PropertyNameCaseInsensitive = true,
        DefaultIgnoreCondition = JsonIgnoreCondition.WhenWritingNull
    };

    // ── Dropdown option lists ────────────────────────────────────────────────
    // These are clinical constants used for select UIs, not API-driven data.
    private IReadOnlyList<PatientInfoSelectOptionVm> ProviderTypeOptions { get; } = new[]
    {
        new PatientInfoSelectOptionVm("commercial", "Commercial"),
        new PatientInfoSelectOptionVm("medicare", "Medicare"),
        new PatientInfoSelectOptionVm("medicaid", "Medicaid"),
        new PatientInfoSelectOptionVm("tricare", "TRICARE"),
        new PatientInfoSelectOptionVm("workers_comp", "Workers' Compensation"),
        new PatientInfoSelectOptionVm("motor_vehicle", "Motor Vehicle"),
        new PatientInfoSelectOptionVm("liability", "Liability"),
        new PatientInfoSelectOptionVm("self_pay", "Self-Pay"),
    };

    private IReadOnlyList<PatientInfoSelectOptionVm> InsurancePriorityOptions { get; } = new[]
    {
        new PatientInfoSelectOptionVm("primary", "Primary Insurance"),
        new PatientInfoSelectOptionVm("secondary", "Secondary Insurance"),
    };

    private IReadOnlyList<PatientInfoSelectOptionVm> YearTypeOptions { get; } = new[]
    {
        new PatientInfoSelectOptionVm("plan_year", "Plan Year"),
        new PatientInfoSelectOptionVm("calendar_year", "Calendar Year"),
    };

    private IReadOnlyList<PatientInfoSelectOptionVm> AuthorizationStatusOptions { get; } = new[]
    {
        new PatientInfoSelectOptionVm("active", "Active"),
        new PatientInfoSelectOptionVm("pending", "Pending"),
        new PatientInfoSelectOptionVm("expired", "Expired"),
        new PatientInfoSelectOptionVm("denied", "Denied"),
    };

    private IReadOnlyList<PatientInfoSelectOptionVm> AuthorizationTypeOptions { get; } = new[]
    {
        new PatientInfoSelectOptionVm("initial", "Initial Authorization"),
        new PatientInfoSelectOptionVm("re_auth", "Re-Authorization"),
        new PatientInfoSelectOptionVm("continuing", "Continuing Care"),
        new PatientInfoSelectOptionVm("pcp_referral", "PCP Referral"),
        new PatientInfoSelectOptionVm("prescription", "Prescription"),
        new PatientInfoSelectOptionVm("plan_of_care", "Plan of Care"),
        new PatientInfoSelectOptionVm("other", "Other"),
    };

    // ── Lifecycle ────────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        await LoadPatientAsync();
        _navGuard = Navigation.RegisterLocationChangingHandler(OnLocationChanging);
    }

    private async Task LoadPatientAsync()
    {
        if (string.IsNullOrWhiteSpace(Id))
        {
            Navigation.NavigateTo("/patients", replace: true);
            return;
        }

        if (!Guid.TryParse(Id, out var patientGuid))
        {
            Navigation.NavigateTo("/patients", replace: true);
            return;
        }

        var patient = await PatientService.GetByIdAsync(patientGuid);
        if (patient is null)
        {
            ToastService.ShowError("Patient not found.");
            SetPatientUnavailable("Patient not found.", "The selected patient record could not be found or is no longer available.");
            return;
        }

        PayerInfoStorage? payer = null;
        if (!string.IsNullOrWhiteSpace(patient.PayerInfoJson) && patient.PayerInfoJson != "{}")
        {
            try { payer = JsonSerializer.Deserialize<PayerInfoStorage>(patient.PayerInfoJson, SerializerOptions); }
            catch { /* ignore – treat as empty */ }
        }
        loadedPayerInfo = payer;

        Vm = new PatientInfoPageVm
        {
            PatientDisplayName = patient.FirstName + " " + patient.LastName,
            PatientPayer = new PatientPayerInfoVm
            {
                PatientName = patient.FirstName + " " + patient.LastName,
                DateOfBirthText = patient.DateOfBirth == default ? string.Empty : patient.DateOfBirth.ToString("M/d/yyyy"),
                InsuranceCompanyName = payer?.InsuranceCompanyName ?? string.Empty,
                MemberIdPolicyNumber = payer?.MemberIdPolicyNumber ?? string.Empty,
                GroupNumber = payer?.GroupNumber ?? string.Empty,
                SecondaryInsuranceCompanyName = payer?.SecondaryInsuranceCompanyName ?? string.Empty,
                SecondaryMemberIdPolicyNumber = ResolveSecondaryMemberIdPolicyNumber(payer),
                SecondaryGroupNumber = payer?.SecondaryGroupNumber ?? string.Empty,
                DeductibleAmount = payer?.DeductibleAmount ?? string.Empty,
                DeductibleMet = payer?.DeductibleMet ?? string.Empty,
                OutOfPocketMaximum = payer?.OutOfPocketMaximum ?? string.Empty,
                OutOfPocketMet = payer?.OutOfPocketMet ?? string.Empty,
                CopayAmount = payer?.CopayAmount ?? string.Empty,
                CoinsurancePercent = payer?.CoinsurancePercent ?? string.Empty,
                ProviderType = NormalizeProviderType(payer?.ProviderType),
                InsurancePriority = NormalizeInsurancePriority(payer?.InsurancePriority),
                YearType = payer?.YearType ?? string.Empty,
                EffectiveStartDate = payer?.EffectiveStartDate ?? string.Empty,
                EffectiveEndDate = payer?.EffectiveEndDate ?? string.Empty,
            },
            Authorization = new AuthorizationDetailsVm
            {
                AuthorizationNumber = payer?.AuthorizationNumber ?? string.Empty,
                DateAuthorizationReceived = payer?.DateAuthorizationReceived ?? string.Empty,
                AuthorizationStartDate = payer?.AuthorizationStartDate ?? string.Empty,
                AuthorizationEndDate = payer?.AuthorizationEndDate ?? string.Empty,
                NumberOfVisitsOrUnitsAuthorized = payer?.NumberOfVisitsOrUnitsAuthorized ?? string.Empty,
            },
            AuthorizationReferralHistory = CloneAuthorizationReferralHistory(payer?.AuthorizationReferralHistory),
            Utilization = new UtilizationVm
            {
                VisitsUsed = payer?.VisitsUsed ?? string.Empty,
                VisitsRemaining = payer?.VisitsRemaining ?? string.Empty,
                VisitLimitType = payer?.VisitLimitType ?? string.Empty,
                VisitLimitPeriod = payer?.VisitLimitPeriod ?? string.Empty,
                TotalVisitLimit = payer?.TotalVisitLimit ?? string.Empty,
                DateOfFirstVisitUnderAuthorization = payer?.DateOfFirstVisitUnderAuthorization ?? string.Empty,
                NotesComments = payer?.NotesComments ?? string.Empty,
            },
            SupportingDocs = new SupportingDocumentationVm
            {
                PrimaryCareProviderName = payer?.PrimaryCareProviderName ?? string.Empty,
                ReferringPhysicianName = payer?.ReferringPhysicianName ?? string.Empty,
                PhysicianNpiNumber = payer?.PhysicianNpiNumber ?? string.Empty,
                CaseManagerAdjusterContactInfo = ResolveCaseManagerAdjusterContactInfoForDisplay(payer),
            },
            AdditionalSettings = new AdditionalAuthorizationSettingsVm
            {
                AuthorizationRequired = payer?.AuthorizationRequired ?? string.Empty,
                AuthorizationStatus = payer?.AuthorizationStatus ?? string.Empty,
                AuthorizationType = payer?.AuthorizationType ?? string.Empty,
                ReAuthorizationDueDate = payer?.ReAuthorizationDueDate ?? string.Empty,
                VisitAlertThreshold = payer?.VisitAlertThreshold ?? string.Empty,
            },
            IsDirty = false,
            IsSaving = false,
        };
        isPatientUnavailable = false;
    }

    private void SetPatientUnavailable(string title, string message)
    {
        isPatientUnavailable = true;
        unavailableTitle = title;
        unavailableMessage = message;
        loadedPayerInfo = null;
        Vm = new PatientInfoPageVm { PatientDisplayName = "Patient unavailable" };
    }

    private void HandleBackToPatients()
    {
        Navigation.NavigateTo("/patients");
    }

    private static string FormatAdjusterContactInfo(PayerInfoStorage? payer)
    {
        if (payer is null)
        {
            return string.Empty;
        }

        var parts = new[]
        {
            payer.AdjusterName,
            payer.AdjusterPhone,
            payer.AdjusterEmail,
            string.IsNullOrWhiteSpace(payer.AdjusterFax) ? null : $"Fax: {payer.AdjusterFax}"
        }
        .Where(value => !string.IsNullOrWhiteSpace(value))
        .Select(value => value!.Trim())
        .ToArray();

        return parts.Length == 0 ? string.Empty : string.Join(" | ", parts);
    }

    private static string ResolveSecondaryMemberIdPolicyNumber(PayerInfoStorage? payer) =>
        FirstNonWhiteSpace(payer?.SecondaryMemberIdPolicyNumber, payer?.SecondaryMemberOrPolicyNumber);

    private static string ResolveCaseManagerAdjusterContactInfoForDisplay(PayerInfoStorage? payer)
    {
        var storedValue = FirstNonWhiteSpace(payer?.CaseManagerAdjusterContactInfo);
        return storedValue.Length > 0 ? storedValue : FormatAdjusterContactInfo(payer);
    }

    private static string FirstNonWhiteSpace(params string?[] values)
    {
        foreach (var value in values)
        {
            if (!string.IsNullOrWhiteSpace(value))
            {
                return value.Trim();
            }
        }

        return string.Empty;
    }

    private static string NormalizeProviderType(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        return value.Trim().ToLowerInvariant() switch
        {
            "commercial" => "commercial",
            "medicare" => "medicare",
            "medicaid" => "medicaid",
            "tricare" => "tricare",
            "workers_comp" or "workers compensation" or "workers' compensation" or "workers_compensation" => "workers_comp",
            "motor_vehicle" or "motor vehicle" => "motor_vehicle",
            "liability" => "liability",
            "self_pay" or "self pay" or "self-pay" => "self_pay",
            _ => value.Trim()
        };
    }

    private static string NormalizeInsurancePriority(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        return value.Trim().ToLowerInvariant() switch
        {
            "primary" or "primary insurance" => "primary",
            "secondary" or "secondary insurance" => "secondary",
            _ => value.Trim()
        };
    }

    private static List<AuthorizationReferralHistoryEntryVm> CloneAuthorizationReferralHistory(
        IEnumerable<AuthorizationReferralHistoryEntryVm>? entries)
    {
        if (entries is null)
        {
            return new List<AuthorizationReferralHistoryEntryVm>();
        }

        return entries
            .Select(entry => new AuthorizationReferralHistoryEntryVm
            {
                EntryId = string.IsNullOrWhiteSpace(entry.EntryId) ? Guid.NewGuid().ToString("N") : entry.EntryId,
                RecordType = entry.RecordType ?? string.Empty,
                ReferenceNumber = entry.ReferenceNumber ?? string.Empty,
                Status = entry.Status ?? string.Empty,
                StartDate = entry.StartDate ?? string.Empty,
                EndDate = entry.EndDate ?? string.Empty,
                VisitsOrUnitsAuthorized = entry.VisitsOrUnitsAuthorized ?? string.Empty,
                Notes = entry.Notes ?? string.Empty
            })
            .ToList();
    }

    // ── Event handlers ───────────────────────────────────────────────────────

    private void HandleFieldChanged()
    {
        Vm.IsDirty = true;
        RunUiValidation();
        StateHasChanged();
    }

    private async Task HandleSave()
    {
        if (!Vm.IsDirty || HasPageErrors || Vm.IsSaving) return;

        if (!Guid.TryParse(Id, out var patientGuid))
        {
            ToastService.ShowError("Cannot save: invalid patient ID.");
            return;
        }

        Vm.IsSaving = true;
        StateHasChanged();

        try
        {
            var payerInfo = new PayerInfoStorage
            {
                InsuranceCompanyName = Vm.PatientPayer.InsuranceCompanyName,
                MemberIdPolicyNumber = Vm.PatientPayer.MemberIdPolicyNumber,
                GroupNumber = Vm.PatientPayer.GroupNumber,
                SecondaryInsuranceCompanyName = Vm.PatientPayer.SecondaryInsuranceCompanyName,
                SecondaryMemberIdPolicyNumber = Vm.PatientPayer.SecondaryMemberIdPolicyNumber,
                SecondaryMemberOrPolicyNumber = Vm.PatientPayer.SecondaryMemberIdPolicyNumber,
                SecondaryGroupNumber = Vm.PatientPayer.SecondaryGroupNumber,
                DeductibleAmount = Vm.PatientPayer.DeductibleAmount,
                DeductibleMet = Vm.PatientPayer.DeductibleMet,
                OutOfPocketMaximum = Vm.PatientPayer.OutOfPocketMaximum,
                OutOfPocketMet = Vm.PatientPayer.OutOfPocketMet,
                CopayAmount = Vm.PatientPayer.CopayAmount,
                CoinsurancePercent = Vm.PatientPayer.CoinsurancePercent,
                ProviderType = NormalizeProviderType(Vm.PatientPayer.ProviderType),
                InsurancePriority = NormalizeInsurancePriority(Vm.PatientPayer.InsurancePriority),
                YearType = Vm.PatientPayer.YearType,
                EffectiveStartDate = Vm.PatientPayer.EffectiveStartDate,
                EffectiveEndDate = Vm.PatientPayer.EffectiveEndDate,
                AuthorizationNumber = Vm.Authorization.AuthorizationNumber,
                DateAuthorizationReceived = Vm.Authorization.DateAuthorizationReceived,
                AuthorizationStartDate = Vm.Authorization.AuthorizationStartDate,
                AuthorizationEndDate = Vm.Authorization.AuthorizationEndDate,
                NumberOfVisitsOrUnitsAuthorized = Vm.Authorization.NumberOfVisitsOrUnitsAuthorized,
                AuthorizationReferralHistory = CloneAuthorizationReferralHistory(Vm.AuthorizationReferralHistory),
                VisitsUsed = Vm.Utilization.VisitsUsed,
                VisitsRemaining = Vm.Utilization.VisitsRemaining,
                VisitLimitType = Vm.Utilization.VisitLimitType,
                VisitLimitPeriod = Vm.Utilization.VisitLimitPeriod,
                TotalVisitLimit = Vm.Utilization.TotalVisitLimit,
                DateOfFirstVisitUnderAuthorization = Vm.Utilization.DateOfFirstVisitUnderAuthorization,
                NotesComments = Vm.Utilization.NotesComments,
                CaseManagerAdjusterContactInfo = ResolveCaseManagerAdjusterContactInfoForSave(),
                AdjusterName = loadedPayerInfo?.AdjusterName,
                AdjusterPhone = loadedPayerInfo?.AdjusterPhone,
                AdjusterEmail = loadedPayerInfo?.AdjusterEmail,
                AdjusterFax = loadedPayerInfo?.AdjusterFax,
                PrimaryCareProviderName = Vm.SupportingDocs.PrimaryCareProviderName,
                ReferringPhysicianName = Vm.SupportingDocs.ReferringPhysicianName,
                PhysicianNpiNumber = Vm.SupportingDocs.PhysicianNpiNumber,
                AuthorizationRequired = Vm.AdditionalSettings.AuthorizationRequired,
                AuthorizationStatus = Vm.AdditionalSettings.AuthorizationStatus,
                AuthorizationType = Vm.AdditionalSettings.AuthorizationType,
                ReAuthorizationDueDate = Vm.AdditionalSettings.ReAuthorizationDueDate,
                VisitAlertThreshold = Vm.AdditionalSettings.VisitAlertThreshold,
            };

            var updateRequest = new UpdatePatientRequest
            {
                PayerInfoJson = JsonSerializer.Serialize(payerInfo, SerializerOptions)
            };

            await PatientService.UpdateAsync(patientGuid, updateRequest);
            loadedPayerInfo = payerInfo;
            Vm.IsDirty = false;
            ToastService.ShowSuccess("Patient information saved.");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[PatientInfo] Save failed: {ex.Message}");
            ToastService.ShowError("Failed to save. Please try again.");
        }
        finally
        {
            Vm.IsSaving = false;
            StateHasChanged();
        }
    }

    private string? ResolveCaseManagerAdjusterContactInfoForSave()
    {
        var enteredValue = string.IsNullOrWhiteSpace(Vm.SupportingDocs.CaseManagerAdjusterContactInfo)
            ? null
            : Vm.SupportingDocs.CaseManagerAdjusterContactInfo.Trim();
        if (!string.IsNullOrWhiteSpace(loadedPayerInfo?.CaseManagerAdjusterContactInfo))
        {
            return enteredValue;
        }

        var derivedValue = FormatAdjusterContactInfo(loadedPayerInfo);
        return string.Equals(enteredValue, derivedValue, StringComparison.Ordinal)
            ? null
            : enteredValue;
    }

    private void HandleBack()
    {
        if (!string.IsNullOrWhiteSpace(Id))
        {
            Navigation.NavigateTo($"/patient/{Uri.EscapeDataString(Id)}");
            return;
        }
        Navigation.NavigateTo("/patients");
    }

    private ValueTask OnLocationChanging(LocationChangingContext context)
    {
        if (Vm.IsDirty)
        {
            context.PreventNavigation();
            ToastService.ShowWarning("You have unsaved changes. Save or discard them before leaving.");
        }
        return ValueTask.CompletedTask;
    }

    public void Dispose() => _navGuard?.Dispose();

    /// <summary>
    /// Internal DTO for serializing all payer and authorization fields into
    /// <see cref="PatientResponse.PayerInfoJson"/>.
    /// </summary>
    private sealed class PayerInfoStorage
    {
        public string? InsuranceCompanyName { get; set; }
        public string? MemberIdPolicyNumber { get; set; }
        public string? GroupNumber { get; set; }
        public string? SecondaryInsuranceCompanyName { get; set; }
        public string? SecondaryMemberIdPolicyNumber { get; set; }
        public string? SecondaryMemberOrPolicyNumber { get; set; }
        public string? SecondaryGroupNumber { get; set; }
        public string? DeductibleAmount { get; set; }
        public string? DeductibleMet { get; set; }
        public string? OutOfPocketMaximum { get; set; }
        public string? OutOfPocketMet { get; set; }
        public string? CopayAmount { get; set; }
        public string? CoinsurancePercent { get; set; }
        public string? ProviderType { get; set; }
        public string? InsurancePriority { get; set; }
        public string? YearType { get; set; }
        public string? EffectiveStartDate { get; set; }
        public string? EffectiveEndDate { get; set; }
        public string? AuthorizationNumber { get; set; }
        public string? DateAuthorizationReceived { get; set; }
        public string? AuthorizationStartDate { get; set; }
        public string? AuthorizationEndDate { get; set; }
        public string? NumberOfVisitsOrUnitsAuthorized { get; set; }
        public List<AuthorizationReferralHistoryEntryVm>? AuthorizationReferralHistory { get; set; }
        public string? VisitsUsed { get; set; }
        public string? VisitsRemaining { get; set; }
        public string? VisitLimitType { get; set; }
        public string? VisitLimitPeriod { get; set; }
        public string? TotalVisitLimit { get; set; }
        public string? DateOfFirstVisitUnderAuthorization { get; set; }
        public string? NotesComments { get; set; }
        public string? CaseManagerAdjusterContactInfo { get; set; }
        public string? AdjusterName { get; set; }
        public string? AdjusterPhone { get; set; }
        public string? AdjusterEmail { get; set; }
        public string? AdjusterFax { get; set; }
        public string? PrimaryCareProviderName { get; set; }
        public string? ReferringPhysicianName { get; set; }
        public string? PhysicianNpiNumber { get; set; }
        public string? AuthorizationRequired { get; set; }
        public string? AuthorizationStatus { get; set; }
        public string? AuthorizationType { get; set; }
        public string? ReAuthorizationDueDate { get; set; }
        public string? VisitAlertThreshold { get; set; }
    }

    // ── Validation ───────────────────────────────────────────────────────────

    // Field-level UI validation before the save request is sent to the API.
    // Server-side validation errors are shown via ToastService.ShowError in HandleSave.

    private bool HasPageErrors => Vm.FieldErrors.Count > 0;
    private string AuthorizationHistoryValidationMessage =>
        Vm.FieldErrors.Keys.Any(key => key.StartsWith("authHistory[", StringComparison.Ordinal))
            ? "Authorization / PCP referral history has date or numeric issues to correct before saving."
            : string.Empty;

    private Dictionary<string, string> GetPanelErrors(string panel)
    {
        var keys = panel switch
        {
            "payer" => new HashSet<string>(StringComparer.Ordinal)
            {
                "deductibleAmount",
                "deductibleMet",
                "oopMax",
                "oopMet",
                "copayAmount",
                "coinsurancePercent"
            },
            "additionalSettings" => new HashSet<string>(StringComparer.Ordinal)
            {
                "alertThreshold"
            },
            "auth" => new HashSet<string>(StringComparer.Ordinal)
            {
                "authStart",
                "authEnd",
                "authUnits"
            },
            "utilization" => new HashSet<string>(StringComparer.Ordinal)
            {
                "visitsUsed",
                "visitsRemaining",
                "totalVisitLimit"
            },
            "supportingDocs" => new HashSet<string>(StringComparer.Ordinal)
            {
                "npi"
            },
            _ => null
        };

        if (string.Equals(panel, "authHistory", StringComparison.Ordinal))
        {
            return Vm.FieldErrors
                .Where(error => error.Key.StartsWith("authHistory[", StringComparison.Ordinal))
                .ToDictionary(error => error.Key, error => error.Value, StringComparer.Ordinal);
        }

        return keys is null
            ? Vm.FieldErrors
            : Vm.FieldErrors
                .Where(error => keys.Contains(error.Key))
                .ToDictionary(error => error.Key, error => error.Value, StringComparer.Ordinal);
    }

    private void RunUiValidation()
    {
        Vm.FieldErrors.Clear();
        ValidateNumericField("visitsUsed", Vm.Utilization.VisitsUsed);
        ValidateNumericField("visitsRemaining", Vm.Utilization.VisitsRemaining);
        ValidateNumericField("totalVisitLimit", Vm.Utilization.TotalVisitLimit);
        ValidateNumericField("authUnits", Vm.Authorization.NumberOfVisitsOrUnitsAuthorized);
        ValidateNumericField("alertThreshold", Vm.AdditionalSettings.VisitAlertThreshold);
        ValidateNumericField("deductibleAmount", Vm.PatientPayer.DeductibleAmount);
        ValidateNumericField("deductibleMet", Vm.PatientPayer.DeductibleMet);
        ValidateNumericField("oopMax", Vm.PatientPayer.OutOfPocketMaximum);
        ValidateNumericField("oopMet", Vm.PatientPayer.OutOfPocketMet);
        ValidateNumericField("copayAmount", Vm.PatientPayer.CopayAmount);
        ValidateNumericField("coinsurancePercent", Vm.PatientPayer.CoinsurancePercent);
        ValidateAuthorizationDateRange();
        ValidateAuthorizationReferralHistory();
        ValidateNpi("npi", Vm.SupportingDocs.PhysicianNpiNumber);
    }

    private void ValidateNumericField(string key, string value)
    {
        if (string.IsNullOrWhiteSpace(value)) return;
        if (!decimal.TryParse(value, out var n) || n < 0)
        {
            Vm.FieldErrors[key] = "Must be a non-negative number.";
        }
    }

    private void ValidateNpi(string key, string value)
    {
        if (string.IsNullOrWhiteSpace(value)) return;
        // Basic format check: NPI must be exactly 10 digits (HIPAA standard).
        if (value.Trim().Length != 10 || !value.Trim().All(char.IsDigit))
        {
            Vm.FieldErrors[key] = "NPI must be exactly 10 digits.";
        }
    }

    private void ValidateAuthorizationDateRange()
    {
        if (string.IsNullOrWhiteSpace(Vm.Authorization.AuthorizationStartDate) ||
            string.IsNullOrWhiteSpace(Vm.Authorization.AuthorizationEndDate))
        {
            return;
        }

        var startParsed = DateTime.TryParse(
            Vm.Authorization.AuthorizationStartDate,
            CultureInfo.InvariantCulture,
            DateTimeStyles.None,
            out var start);
        var endParsed = DateTime.TryParse(
            Vm.Authorization.AuthorizationEndDate,
            CultureInfo.InvariantCulture,
            DateTimeStyles.None,
            out var end);

        if (!startParsed || !endParsed || start <= end)
        {
            return;
        }

        Vm.FieldErrors["authStart"] = "Authorization / Referral Start Date must be on or before Authorization / Referral End Date.";
        Vm.FieldErrors["authEnd"] = "Authorization / Referral End Date must be on or after Authorization / Referral Start Date.";
    }

    private void ValidateAuthorizationReferralHistory()
    {
        var parsedRanges = new List<(int Index, DateTime Start, DateTime End)>();

        for (var index = 0; index < Vm.AuthorizationReferralHistory.Count; index++)
        {
            var entry = Vm.AuthorizationReferralHistory[index];
            ValidateNumericField($"authHistory[{index}].units", entry.VisitsOrUnitsAuthorized);

            var hasStart = !string.IsNullOrWhiteSpace(entry.StartDate);
            var hasEnd = !string.IsNullOrWhiteSpace(entry.EndDate);
            var startParsed = DateTime.TryParse(
                entry.StartDate,
                CultureInfo.InvariantCulture,
                DateTimeStyles.None,
                out var start);
            var endParsed = DateTime.TryParse(
                entry.EndDate,
                CultureInfo.InvariantCulture,
                DateTimeStyles.None,
                out var end);

            if (hasStart && !startParsed)
            {
                Vm.FieldErrors[$"authHistory[{index}].start"] = "Use a valid date.";
            }

            if (hasEnd && !endParsed)
            {
                Vm.FieldErrors[$"authHistory[{index}].end"] = "Use a valid date.";
            }

            if (startParsed && endParsed)
            {
                if (start > end)
                {
                    Vm.FieldErrors[$"authHistory[{index}].start"] = "Start date must be on or before end date.";
                    Vm.FieldErrors[$"authHistory[{index}].end"] = "End date must be on or after start date.";
                    continue;
                }

                parsedRanges.Add((index, start.Date, end.Date));
            }
        }

        for (var left = 0; left < parsedRanges.Count; left++)
        {
            for (var right = left + 1; right < parsedRanges.Count; right++)
            {
                var first = parsedRanges[left];
                var second = parsedRanges[right];
                if (first.Start <= second.End && second.Start <= first.End)
                {
                    Vm.FieldErrors[$"authHistory[{first.Index}].start"] = "History date ranges cannot overlap.";
                    Vm.FieldErrors[$"authHistory[{second.Index}].start"] = "History date ranges cannot overlap.";
                }
            }
        }
    }
}
