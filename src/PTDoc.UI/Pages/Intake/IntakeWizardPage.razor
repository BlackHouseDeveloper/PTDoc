    private static IntakeConsentPacket CloneConsentPacket(IntakeConsentPacket? packet)
    {
        if (packet is null)
        {
            return new IntakeConsentPacket();
        }

        var json = JsonSerializer.Serialize(packet);
        var clone = JsonSerializer.Deserialize<IntakeConsentPacket>(json) ?? new IntakeConsentPacket();
        clone.AuthorizedContacts ??= new List<AuthorizedContact>();
        clone.RevokedConsentKeys ??= new List<string>();
        return clone;
    }

    private static void SetRevoked(IntakeConsentPacket packet, string key, bool revoked)
    {
        packet.RevokedConsentKeys ??= new List<string>();
        if (revoked)
        {
            if (!packet.RevokedConsentKeys.Contains(key, StringComparer.OrdinalIgnoreCase))
            {
                packet.RevokedConsentKeys.Add(key);
            }

            return;
        }

        packet.RevokedConsentKeys.RemoveAll(existing => string.Equals(existing, key, StringComparison.OrdinalIgnoreCase));
    }

    private static bool IsConsentRevoked(IntakeConsentPacket packet, string key)
    {
        return packet.RevokedConsentKeys.Any(existing => string.Equals(existing, key, StringComparison.OrdinalIgnoreCase));
    }

    private static string GetStepTitle(IntakeStep step)
    {
        return step switch
        {
            IntakeStep.Demographics => "Demographics",
            IntakeStep.PainAssessment => "Medical History / Pain Assessment",
            IntakeStep.PainDetails => "Pain Details",
            _ => "Review"
        };
    }

    private static int? ExtractLegacyPainSeverity(IReadOnlyDictionary<string, object> painDetailDrafts)
    {
        foreach (var draft in painDetailDrafts.Values)
        {
            if (TryFindLegacyPainSeverity(draft, out var value))
            {
                return Math.Clamp(value, 0, 10);
            }
        }

        return null;
    }

    private static bool TryFindLegacyPainSeverity(object? value, out int result)
    {
        switch (value)
        {
            case null:
                result = default;
                return false;
            case int intValue:
                result = intValue;
                return true;
            case long longValue when longValue is >= int.MinValue and <= int.MaxValue:
                result = (int)longValue;
                return true;
            case JsonElement jsonElement:
                return TryFindLegacyPainSeverity(jsonElement, out result);
            default:
                result = default;
                return false;
        }
    }

    private static bool TryFindLegacyPainSeverity(JsonElement element, out int result)
    {
        switch (element.ValueKind)
        {
            case JsonValueKind.Number when element.TryGetInt32(out result):
                return true;
            case JsonValueKind.Object:
                foreach (var property in element.EnumerateObject())
                {
                    if (TryFindLegacyPainSeverity(property.Value, out result))
                    {
                        return true;
                    }
                }

                break;
            case JsonValueKind.Array:
                foreach (var item in element.EnumerateArray())
                {
                    if (TryFindLegacyPainSeverity(item, out result))
                    {
                        return true;
                    }
                }

                break;
        }

        result = default;
        return false;
    }

    private static string? SerializeSelectedRegions(IntakeWizardState state)
    {
        if (state.SelectedBodyRegions.Count > 0)
        {
            return string.Join('|', state.SelectedBodyRegions.Select(region => region.ToString()));
        }

        return state.SelectedBodyRegion;
    }

    private static HashSet<PTDoc.Core.Models.BodyRegion> DeserializeSelectedRegions(string? serialized)
    {
        var result = new HashSet<PTDoc.Core.Models.BodyRegion>();

        if (string.IsNullOrWhiteSpace(serialized))
        {
            return result;
        }

        foreach (var value in serialized.Split('|', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
        {
            if (Enum.TryParse<PTDoc.Core.Models.BodyRegion>(value, out var parsed))
            {
                result.Add(parsed);
            }
        }

        return result;
    }
