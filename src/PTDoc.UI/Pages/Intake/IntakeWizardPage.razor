@page "/intake"
@page "/intake/{PatientId:guid}"
@rendermode InteractiveServer

@using System.Net
@using System.Text.Json
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Routing
@using PTDoc.Application.Configurations.Header
@using PTDoc.Application.Intake
@using PTDoc.Application.ReferenceData
@using PTDoc.Application.Services
@using PTDoc.UI.Components.Auth
@using PTDoc.UI.Components.Intake
@using PTDoc.UI.Components.Intake.Models
@using PTDoc.UI.Components.Intake.Steps

@inject IIntakeService IntakeService
@inject IIntakeReferenceDataCatalogService IntakeReferenceData
@inject PTDoc.Core.Services.IIntakeDemographicsValidationService DemographicsValidationService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager
@implements IDisposable

<PageTitle>Patient Intake - PTDocs +</PageTitle>

<div class="intake-page" data-testid="intake-page">
    <GlobalPageHeader Configuration="@HeaderConfiguration" />

    <div class="intake-page__shell">
        <PainProgressBar CurrentStep="@State.CurrentStep" />

        <main class="intake-page__content" aria-live="polite">
            @if (_showDraftUnavailable)
            {
                <section class="intake-page__not-found">
                    <h2>@_draftUnavailableTitle</h2>
                    <p>@_draftUnavailableMessage</p>
                    @if (!string.IsNullOrWhiteSpace(_draftUnavailableDetail))
                    {
                        <p>@_draftUnavailableDetail</p>
                    }
                </section>
            }
            else
            {
                @if (ShowClinicianPatientSelector)
                {
                    <RoleGate Roles="@ClinicianSelectorRoles">
                        <ClinicianPatientSelector SelectedPatientId="@State.PatientId"
                                                 SelectedPatientIdChanged="HandleClinicianPatientSelectedAsync"
                                                 Disabled="@(_isLoadingDraft || _isSavingDraft || State.IsSubmitting)" />
                    </RoleGate>
                }

                @if (_isLoadingDraft)
                {
                    <section class="intake-page__notice" role="status" aria-live="polite">
                        <p>Loading intake draft…</p>
                    </section>
                }

                @if (!string.IsNullOrWhiteSpace(ReadOnlyNoticeMessage))
                {
                    <section class="intake-page__notice" role="status">
                        <p>@ReadOnlyNoticeMessage</p>
                    </section>
                }

                <fieldset class="intake-page__fieldset" disabled="@IsInteractionLocked">
                    @switch (State.CurrentStep)
                    {
                        case IntakeStep.Demographics:
                            <DemographicsStep State="@State" ValidationMessage="@_validationMessage" ValidationErrors="@_demographicsValidationErrors" OnContinue="HandleDemographicsContinueAsync" OnStateChanged="HandleStateChangedAsync" />
                            break;
                        case IntakeStep.PainAssessment:
                            <PainAssessmentStep2 State="@State" OnBack="HandleBackAsync" OnContinue="HandlePainAssessmentContinueAsync" OnStateChanged="HandleStateChangedAsync" />
                            break;
                        case IntakeStep.PainDetails:
                            <PainDetailsStep State="@State"
                                             OnBack="HandleBackAsync"
                                             OnContinue="HandlePainDetailsContinueAsync"
                                             OnStateChanged="HandleStateChangedAsync"
                                             ShowOutcomeMeasureRecommendations="@CanViewOutcomeMeasureRecommendations" />
                            break;
                        case IntakeStep.Review:
                            <ReviewStep State="@State"
                                        ValidationMessage="@_validationMessage"
                                        OnBack="HandleBackAsync"
                                        OnSubmit="HandleSubmitAsync"
                                        OnEditStep="HandleEditStepAsync"
                                        ShowOutcomeMeasureRecommendations="@CanViewOutcomeMeasureRecommendations" />
                            break;
                        default:
                            <DemographicsStep State="@State" ValidationMessage="@_validationMessage" ValidationErrors="@_demographicsValidationErrors" OnContinue="HandleDemographicsContinueAsync" OnStateChanged="HandleStateChangedAsync" />
                            break;
                    }
                </fieldset>
            }
        </main>
    </div>
</div>

@code {
    [Parameter] public Guid? PatientId { get; set; }
    [SupplyParameterFromQuery(Name = "mode")] public string? Mode { get; set; }

    private IntakeWizardState State { get; set; } = new();
    private Guid? _loadedPatientId;
    private bool _showDraftUnavailable;
    private bool _canSelectPatient;
    private bool _canManageDrafts;
    private bool _canViewOutcomeMeasureRecommendations;
    private bool _isLoadingDraft;
    private bool _isSavingDraft;
    private string? _validationMessage;
    private string _draftUnavailableTitle = "Intake Unavailable";
    private string _draftUnavailableMessage = "We could not load an intake draft for this patient.";
    private string? _draftUnavailableDetail;
    private IDisposable? _navGuard;
    private IReadOnlyDictionary<string, string> _demographicsValidationErrors = new Dictionary<string, string>(StringComparer.Ordinal);
    private string ClinicianSelectorRoles => $"{Roles.PT},{Roles.PTA},{Roles.Admin},{Roles.Owner},{Roles.FrontDesk}";
    private bool ShowClinicianPatientSelector => _canSelectPatient && !State.IsPatientMode && !PatientId.HasValue;
    private bool CanViewOutcomeMeasureRecommendations => !State.IsPatientMode && _canViewOutcomeMeasureRecommendations;
    private bool CanEditDraft => !State.IsLocked && (State.IsPatientMode || _canManageDrafts);
    private bool IsInteractionLocked => _isLoadingDraft || _isSavingDraft || State.IsSubmitting || !CanEditDraft;
    private string? ReadOnlyNoticeMessage => State.IsLocked
        ? "This intake has been submitted and locked. Editing is disabled."
        : (!CanEditDraft && !State.IsPatientMode && _loadedPatientId.HasValue
            ? "Your role has read-only access to this intake."
            : null);

    protected override void OnInitialized()
    {
        _navGuard = NavigationManager.RegisterLocationChangingHandler(OnLocationChanging);
    }

    protected override async Task OnParametersSetAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var isAuthenticated = user.Identity?.IsAuthenticated == true;

        _canSelectPatient = isAuthenticated &&
            (user.IsInRole(Roles.PT) ||
             user.IsInRole(Roles.PTA) ||
             user.IsInRole(Roles.Admin) ||
             user.IsInRole(Roles.Owner) ||
             user.IsInRole(Roles.FrontDesk));

        _canManageDrafts = isAuthenticated &&
            (user.IsInRole(Roles.PT) ||
             user.IsInRole(Roles.PTA) ||
             user.IsInRole(Roles.Admin) ||
             user.IsInRole(Roles.FrontDesk));

        _canViewOutcomeMeasureRecommendations = isAuthenticated &&
            (user.IsInRole(Roles.PT) ||
             user.IsInRole(Roles.PTA) ||
             user.IsInRole(Roles.Admin) ||
             user.IsInRole(Roles.Owner));

        State.IsPatientMode = string.Equals(Mode, "patient", StringComparison.OrdinalIgnoreCase) ||
            !isAuthenticated ||
            user.IsInRole(Roles.Patient);

        if (PatientId.HasValue)
        {
            await LoadDraftAsync(PatientId.Value);
            return;
        }

        if (_loadedPatientId.HasValue)
        {
            State = new IntakeWizardState
            {
                CurrentStep = IntakeStep.Demographics,
                IsPatientMode = State.IsPatientMode
            };

            _loadedPatientId = null;
            ClearDraftUnavailableState();
            _validationMessage = null;
            _demographicsValidationErrors = new Dictionary<string, string>(StringComparer.Ordinal);
        }
    }

    private async Task LoadDraftAsync(Guid patientId)
    {
        if (_loadedPatientId == patientId)
        {
            return;
        }

        _isLoadingDraft = true;
        IntakeResponseDraft? draft;
        try
        {
            draft = await IntakeService.GetDraftByPatientIdAsync(patientId);

            if (draft is null)
            {
                if (!State.IsPatientMode)
                {
                    if (!_canManageDrafts)
                    {
                        SetDraftUnavailableState(
                            title: "Intake Unavailable",
                            message: "Your role can view intake records but cannot create a new draft for this patient.",
                            detail: "Ask a PT, PTA, Admin, or Front Desk user to start the intake workflow.");
                        InitializeBlankState(patientId);
                        _loadedPatientId = patientId;
                        return;
                    }

                    var ensureResult = await IntakeService.EnsureDraftAsync(patientId, new IntakeResponseDraft
                    {
                        PatientId = patientId
                    });

                    if (ensureResult.Status is IntakeEnsureDraftStatus.Created or IntakeEnsureDraftStatus.Existing)
                    {
                        draft = ensureResult.Draft;
                    }
                    else
                    {
                        SetDraftUnavailableState(
                            title: ensureResult.Status == IntakeEnsureDraftStatus.Locked ? "Intake Locked" : "Patient Intake Unavailable",
                            message: ensureResult.ErrorMessage ?? "This patient cannot receive a new intake draft right now.",
                            detail: ensureResult.Status == IntakeEnsureDraftStatus.Locked
                                ? "This patient already has a locked intake record. Create or review the evaluation from the chart instead of starting a new intake."
                                : "Select a different patient or refresh the patient list and try again.");
                        InitializeBlankState(patientId);
                        _loadedPatientId = patientId;
                        return;
                    }
                }
                else
                {
                    SetDraftUnavailableState(
                        title: "Intake Draft Not Found",
                        message: "We could not locate an active intake draft for this patient link.",
                        detail: "If you received this link by email or text, contact your care provider for a new intake invitation.");
                    InitializeBlankState(patientId);
                    _loadedPatientId = patientId;
                    return;
                }
            }

            ClearDraftUnavailableState();
            State = FromDraft(draft!);
            IntakeSupplementalSelectionCanonicalizer.Canonicalize(State, IntakeReferenceData);
            State.IsPatientMode = string.Equals(Mode, "patient", StringComparison.OrdinalIgnoreCase) || State.IsPatientMode;

            _loadedPatientId = patientId;
            _validationMessage = null;
            _demographicsValidationErrors = new Dictionary<string, string>(StringComparer.Ordinal);
        }
        catch (HttpRequestException ex)
        {
            SetDraftUnavailableState(
                title: "Unable to Load Intake",
                message: ToUserFacingApiError(ex),
                detail: State.IsPatientMode
                    ? "Refresh this page or request a new intake invitation if the problem continues."
                    : "Select a different patient or try again once the connection is restored.");
            InitializeBlankState(patientId);
        }
        catch (Exception)
        {
            SetDraftUnavailableState(
                title: "Unable to Load Intake",
                message: "We could not load this intake right now.",
                detail: State.IsPatientMode
                    ? "Refresh this page or request a new intake invitation if the problem continues."
                    : "Select a different patient or try again once the connection is restored.");
            InitializeBlankState(patientId);
        }
        finally
        {
            _isLoadingDraft = false;
        }
    }

    private async Task HandleDemographicsContinueAsync()
    {
        if (!CanEditDraft)
        {
            _validationMessage = GetReadOnlyDraftMessage();
            return;
        }

        if (_isSavingDraft || _isLoadingDraft || State.IsSubmitting)
        {
            return;
        }

        _validationMessage = null;
        _demographicsValidationErrors = new Dictionary<string, string>(StringComparer.Ordinal);

        var validationResult = DemographicsValidationService.Validate(
            State.FullName,
            State.DateOfBirth,
            State.EmailAddress,
            State.PhoneNumber,
            State.EmergencyContactName,
            State.EmergencyContactPhone);

        if (!validationResult.IsValid)
        {
            _demographicsValidationErrors = validationResult.FieldErrors;
            _validationMessage = validationResult.SummaryMessage;
            return;
        }

        State.CurrentStep = IntakeStep.PainAssessment;

        if (!State.PatientId.HasValue)
        {
            try
            {
                _isSavingDraft = true;
                var patientId = await IntakeService.CreateTemporaryPatientAndDraftIntakeAsync(ToPersistenceDraft());
                State.PatientId = patientId;
                _loadedPatientId = patientId;

                await IntakeService.SaveDraftAsync(ToPersistenceDraft());

                NavigationManager.NavigateTo($"/intake/{patientId}{GetModeQuery()}");
            }
            catch (HttpRequestException ex)
            {
                _validationMessage = ToUserFacingApiError(ex);
            }
            finally
            {
                _isSavingDraft = false;
            }

            return;
        }

        try
        {
            _isSavingDraft = true;
            await IntakeService.SaveDraftAsync(ToPersistenceDraft());
            State.IsDirty = false;
        }
        catch (HttpRequestException ex)
        {
            _validationMessage = ToUserFacingApiError(ex);
        }
        finally
        {
            _isSavingDraft = false;
        }
    }

    private async Task HandlePainAssessmentContinueAsync()
    {
        if (!CanEditDraft)
        {
            _validationMessage = GetReadOnlyDraftMessage();
            return;
        }

        State.CurrentStep = IntakeStep.PainDetails;

        await SaveDraftIfPossibleAsync();
    }

    private async Task HandlePainDetailsContinueAsync()
    {
        if (!CanEditDraft)
        {
            _validationMessage = GetReadOnlyDraftMessage();
            return;
        }

        State.CurrentStep = IntakeStep.Review;

        await SaveDraftIfPossibleAsync();
    }

    private Task HandleBackAsync()
    {
        _validationMessage = null;

        if (State.CurrentStep > IntakeStep.Demographics)
        {
            State.CurrentStep = (IntakeStep)((int)State.CurrentStep - 1);
        }
        return Task.CompletedTask;
    }

    private ValueTask OnLocationChanging(LocationChangingContext context)
    {
        if (!State.IsPatientMode || State.IsLocked || !State.IsDirty || State.IsSubmitting)
        {
            return ValueTask.CompletedTask;
        }

        context.PreventNavigation();
        _validationMessage = "You have unsaved intake changes. Continue through the wizard to save before leaving this page.";
        return new ValueTask(InvokeAsync(StateHasChanged));
    }

    private async Task HandleSubmitAsync()
    {
        _validationMessage = null;

        if (!CanEditDraft)
        {
            _validationMessage = GetReadOnlyDraftMessage();
            return;
        }

        var consentPacket = BuildConsentPacket(State);
        var consentCompleteness = IntakeConsentJson.EvaluateConsentCompleteness(consentPacket);

        if (consentPacket.HipaaAcknowledged != true)
        {
            _validationMessage = "You must acknowledge the HIPAA Privacy Notice before submitting.";
            return;
        }

        if (consentPacket.TreatmentConsentAccepted != true)
        {
            _validationMessage = "You must consent to receive physical therapy treatment before submitting.";
            return;
        }

        if (!HasRequiredReviewConsents(State, consentPacket, consentCompleteness))
        {
            _validationMessage = "Complete the required agreements and ensure HIPAA and treatment consent are not revoked before submitting.";
            return;
        }

        if (State.PatientId is null)
        {
            _validationMessage = "Please complete demographics first to create an intake draft.";
            return;
        }

        State.IsSubmitting = true;

        try
        {
            await IntakeService.SubmitAsync(ToPersistenceDraft());
            State.IsDirty = false;
            State.IsSubmitted = true;
            State.IsLocked = true;
            _validationMessage = "Intake submitted successfully. This form is now locked.";
        }
        catch (HttpRequestException ex)
        {
            _validationMessage = ToUserFacingApiError(ex);
        }
        finally
        {
            State.IsSubmitting = false;
        }
    }

    private Task HandleStateChangedAsync()
    {
        if (!CanEditDraft)
        {
            return Task.CompletedTask;
        }

        State.IsDirty = true;
        return Task.CompletedTask;
    }

    private Task HandleEditStepAsync(PTDoc.Core.Models.IntakeStep step)
    {
        if (CanEditDraft)
        {
            State.CurrentStep = step;
            _validationMessage = null;
        }

        return Task.CompletedTask;
    }

    private async Task SaveDraftIfPossibleAsync()
    {
        if (!State.PatientId.HasValue || !CanEditDraft || _isSavingDraft)
        {
            return;
        }

        _isSavingDraft = true;
        try
        {
            await IntakeService.SaveDraftAsync(ToPersistenceDraft());
            State.IsDirty = false;
        }
        catch (HttpRequestException ex)
        {
            _validationMessage = ToUserFacingApiError(ex);
        }
        finally
        {
            _isSavingDraft = false;
        }
    }

    private static string ToUserFacingApiError(HttpRequestException ex)
    {
        if (!string.IsNullOrWhiteSpace(ex.Message) &&
            !ex.Message.StartsWith("Response status code", StringComparison.OrdinalIgnoreCase))
        {
            return ex.Message;
        }

        return ex.StatusCode switch
        {
            HttpStatusCode.Unauthorized => "Your session has expired or is missing API authorization. Please sign in again.",
            HttpStatusCode.Forbidden => "You do not have permission to modify this intake.",
            HttpStatusCode.NotFound => "We could not find a matching patient or intake draft for this request.",
            HttpStatusCode.Conflict => "This intake is locked and a new draft cannot be created for this patient.",
            _ => "We could not save your intake right now. Please try again."
        };
    }

    public void Dispose()
    {
        _navGuard?.Dispose();
    }

    private Task HandleClinicianPatientSelectedAsync(Guid? selectedPatientId)
    {
        if (!selectedPatientId.HasValue)
        {
            State = new IntakeWizardState
            {
                CurrentStep = IntakeStep.Demographics,
                IsPatientMode = State.IsPatientMode
            };
            _loadedPatientId = null;
            ClearDraftUnavailableState();
            _validationMessage = null;
            _demographicsValidationErrors = new Dictionary<string, string>(StringComparer.Ordinal);
            return Task.CompletedTask;
        }

        NavigationManager.NavigateTo($"/intake/{selectedPatientId.Value}");
        return Task.CompletedTask;
    }

    private string GetModeQuery()
    {
        return State.IsPatientMode ? "?mode=patient" : string.Empty;
    }

    private void InitializeBlankState(Guid patientId)
    {
        State = new IntakeWizardState
        {
            PatientId = patientId,
            IsPatientMode = State.IsPatientMode,
            CurrentStep = IntakeStep.Demographics
        };
    }

    private string GetReadOnlyDraftMessage()
    {
        if (State.IsLocked)
        {
            return "This intake is locked and cannot be modified.";
        }

        return "Your role does not have permission to modify this intake.";
    }

    private void SetDraftUnavailableState(string title, string message, string? detail = null)
    {
        _showDraftUnavailable = true;
        _draftUnavailableTitle = title;
        _draftUnavailableMessage = message;
        _draftUnavailableDetail = detail;
    }

    private void ClearDraftUnavailableState()
    {
        _showDraftUnavailable = false;
        _draftUnavailableTitle = "Intake Unavailable";
        _draftUnavailableMessage = "We could not load an intake draft for this patient.";
        _draftUnavailableDetail = null;
    }

    private static IntakeResponseDraft ToDraft(IntakeWizardState state)
    {
        var consentPacket = BuildConsentPacket(state);
        return new IntakeResponseDraft
        {
            PatientId = state.PatientId,
            CurrentStep = (int)state.CurrentStep,
            ConsentPacket = consentPacket,
            HipaaAcknowledged = consentPacket.HipaaAcknowledged == true,
            ConsentToTreatAcknowledged = consentPacket.TreatmentConsentAccepted == true,
            TermsOfServiceAccepted = state.TermsOfServiceAccepted,
            AccuracyConfirmed = state.AccuracyConfirmed,
            RevokeHipaaPrivacyNotice = IsConsentRevoked(consentPacket, "hipaaAcknowledged"),
            RevokeTreatmentConsent = IsConsentRevoked(consentPacket, "treatmentConsentAccepted"),
            RevokeMarketingCommunications =
                IsConsentRevoked(consentPacket, "communicationCallConsent")
                && IsConsentRevoked(consentPacket, "communicationTextConsent")
                && IsConsentRevoked(consentPacket, "communicationEmailConsent"),
            RevokePhiRelease = IsConsentRevoked(consentPacket, "phiReleaseAuthorized"),
            AllowPhoneCalls = consentPacket.CommunicationCallConsent == true,
            AllowTextMessages = consentPacket.CommunicationTextConsent == true,
            AllowEmailMessages = consentPacket.CommunicationEmailConsent == true,
            DryNeedlingEligible = consentPacket.DryNeedlingConsentAccepted == true,
            PelvicFloorTherapyEligible = consentPacket.PelvicFloorConsentAccepted == true,
            PhiReleaseAuthorized = consentPacket.PhiReleaseAuthorized == true,
            BillingConsentAuthorized = consentPacket.CreditCardAuthorizationAccepted == true,
            FullName = state.FullName,
            DateOfBirth = state.DateOfBirth,
            SexAtBirth = state.SexAtBirth,
            EmailAddress = state.EmailAddress,
            PhoneNumber = state.PhoneNumber,
            AddressLine1 = state.AddressLine1,
            AddressLine2 = state.AddressLine2,
            City = state.City,
            StateOrProvince = state.StateOrProvince,
            PostalCode = state.PostalCode,
            EmergencyContactName = state.EmergencyContactName,
            EmergencyContactPhone = state.EmergencyContactPhone,
            InsuranceCompanyName = state.InsuranceCompanyName,
            MemberOrPolicyNumber = state.MemberOrPolicyNumber,
            GroupNumber = state.GroupNumber,
            PayerType = state.PayerType,
            InsuranceCoverageType = state.InsuranceCoverageType,
            HasCurrentMedications = state.HasCurrentMedications,
            HasOtherMedicalConditions = state.HasOtherMedicalConditions,
            UsesAssistiveDevices = state.UsesAssistiveDevices,
            HasPreviousSurgeriesOrInjuries = state.HasPreviousSurgeriesOrInjuries,
            MedicalHistoryNotes = state.MedicalHistoryNotes,
            SelectedBodyRegion = SerializeSelectedRegions(state),
            PainSeverityScore = state.PainSeverityScore,
            PainDetailDrafts = state.PainDetailDrafts.ToDictionary(pair => pair.Key, pair => pair.Value, StringComparer.OrdinalIgnoreCase),
            StructuredData = state.StructuredData,
            SelectedComorbidities = state.SelectedComorbidities.ToHashSet(StringComparer.OrdinalIgnoreCase),
            SelectedAssistiveDevices = state.SelectedAssistiveDevices.ToHashSet(StringComparer.OrdinalIgnoreCase),
            SelectedLivingSituations = state.SelectedLivingSituations.ToHashSet(StringComparer.OrdinalIgnoreCase),
            SelectedHouseLayoutOptions = state.SelectedHouseLayoutOptions.ToHashSet(StringComparer.OrdinalIgnoreCase),
            RecommendedOutcomeMeasures = state.RecommendedOutcomeMeasures.ToHashSet(StringComparer.OrdinalIgnoreCase),
            IsSubmitted = state.IsSubmitted,
            IsLocked = state.IsLocked
        };
    }

    private IntakeResponseDraft ToPersistenceDraft()
    {
        IntakeSupplementalSelectionCanonicalizer.Canonicalize(State, IntakeReferenceData);
        return ToDraft(State);
    }

    private static IntakeWizardState FromDraft(IntakeResponseDraft draft)
    {
        var consentPacket = BuildConsentPacket(draft);
        return new IntakeWizardState
        {
            PatientId = draft.PatientId,
            CurrentStep = Enum.IsDefined(typeof(IntakeStep), draft.CurrentStep)
                ? (IntakeStep)draft.CurrentStep
                : IntakeStep.Demographics,
            ConsentPacket = consentPacket,
            HipaaAcknowledged = consentPacket.HipaaAcknowledged == true,
            ConsentToTreatAcknowledged = consentPacket.TreatmentConsentAccepted == true,
            AccuracyConfirmed = consentPacket.FinalAttestationAccepted ?? draft.AccuracyConfirmed,
            RevokeHipaaPrivacyNotice = IsConsentRevoked(consentPacket, "hipaaAcknowledged"),
            RevokeTreatmentConsent = IsConsentRevoked(consentPacket, "treatmentConsentAccepted"),
            RevokeMarketingCommunications =
                IsConsentRevoked(consentPacket, "communicationCallConsent")
                && IsConsentRevoked(consentPacket, "communicationTextConsent")
                && IsConsentRevoked(consentPacket, "communicationEmailConsent"),
            RevokePhiRelease = IsConsentRevoked(consentPacket, "phiReleaseAuthorized"),
            AllowPhoneCalls = consentPacket.CommunicationCallConsent ?? draft.AllowPhoneCalls,
            AllowTextMessages = consentPacket.CommunicationTextConsent ?? draft.AllowTextMessages,
            AllowEmailMessages = consentPacket.CommunicationEmailConsent ?? draft.AllowEmailMessages,
            DryNeedlingEligible = consentPacket.DryNeedlingConsentAccepted ?? draft.DryNeedlingEligible,
            PelvicFloorTherapyEligible = consentPacket.PelvicFloorConsentAccepted ?? draft.PelvicFloorTherapyEligible,
            PhiReleaseAuthorized = consentPacket.PhiReleaseAuthorized ?? draft.PhiReleaseAuthorized,
            BillingConsentAuthorized = consentPacket.CreditCardAuthorizationAccepted ?? draft.BillingConsentAuthorized,
            TermsOfServiceAccepted = draft.TermsOfServiceAccepted,
            FullName = draft.FullName,
            DateOfBirth = draft.DateOfBirth,
            EmailAddress = draft.EmailAddress,
            PhoneNumber = draft.PhoneNumber,
            AddressLine1 = draft.AddressLine1,
            AddressLine2 = draft.AddressLine2,
            City = draft.City,
            StateOrProvince = draft.StateOrProvince,
            PostalCode = draft.PostalCode,
            EmergencyContactName = draft.EmergencyContactName,
            EmergencyContactPhone = draft.EmergencyContactPhone,
            InsuranceCompanyName = draft.InsuranceCompanyName,
            MemberOrPolicyNumber = draft.MemberOrPolicyNumber,
            GroupNumber = draft.GroupNumber,
            PayerType = draft.PayerType,
            InsuranceCoverageType = draft.InsuranceCoverageType,
            HasCurrentMedications = draft.HasCurrentMedications,
            HasOtherMedicalConditions = draft.HasOtherMedicalConditions,
            UsesAssistiveDevices = draft.UsesAssistiveDevices,
            HasPreviousSurgeriesOrInjuries = draft.HasPreviousSurgeriesOrInjuries,
            MedicalHistoryNotes = draft.MedicalHistoryNotes,
            SelectedBodyRegion = draft.SelectedBodyRegion,
            SelectedBodyRegions = DeserializeSelectedRegions(draft.SelectedBodyRegion),
            PainSeverityScore = draft.PainSeverityScore ?? ExtractLegacyPainSeverity(draft.PainDetailDrafts),
            PainDetailDrafts = draft.PainDetailDrafts.ToDictionary(pair => pair.Key, pair => pair.Value, StringComparer.OrdinalIgnoreCase),
            StructuredData = draft.StructuredData,
            SelectedComorbidities = draft.SelectedComorbidities.ToHashSet(StringComparer.OrdinalIgnoreCase),
            SelectedAssistiveDevices = draft.SelectedAssistiveDevices.ToHashSet(StringComparer.OrdinalIgnoreCase),
            SelectedLivingSituations = draft.SelectedLivingSituations.ToHashSet(StringComparer.OrdinalIgnoreCase),
            SelectedHouseLayoutOptions = draft.SelectedHouseLayoutOptions.ToHashSet(StringComparer.OrdinalIgnoreCase),
            RecommendedOutcomeMeasures = draft.RecommendedOutcomeMeasures.ToHashSet(StringComparer.OrdinalIgnoreCase),
            IsSubmitted = draft.IsSubmitted,
            IsLocked = draft.IsLocked
        };
    }

    private HeaderConfiguration HeaderConfiguration => new()
    {
        Route = "/intake",
        Title = State.CurrentStep == IntakeStep.Review ? "Patient Intake Review" : "Patient Intake",
        Subtitle = $"Step {(int)State.CurrentStep + 1} of 4 • {GetStepTitle(State.CurrentStep)}",
        ShowSyncControls = false,
        ShowStatusBadge = false
    };

    private static bool HasRequiredReviewConsents(
        IntakeWizardState state,
        IntakeConsentPacket consentPacket,
        (bool IsComplete, List<string> Missing, List<string> Revoked) consentCompleteness)
    {
        return consentCompleteness.IsComplete
            && state.TermsOfServiceAccepted
            && (consentPacket.FinalAttestationAccepted ?? state.AccuracyConfirmed);
    }

    private static IntakeConsentPacket BuildConsentPacket(IntakeWizardState state)
    {
        var packet = CloneConsentPacket(state.ConsentPacket);
        packet.HipaaAcknowledged ??= state.HipaaAcknowledged;
        packet.TreatmentConsentAccepted ??= state.ConsentToTreatAcknowledged;
        packet.PhiReleaseAuthorized ??= state.PhiReleaseAuthorized;
        packet.CommunicationCallConsent ??= state.AllowPhoneCalls;
        packet.CommunicationTextConsent ??= state.AllowTextMessages;
        packet.CommunicationEmailConsent ??= state.AllowEmailMessages;
        packet.DryNeedlingConsentAccepted ??= state.DryNeedlingEligible;
        packet.PelvicFloorConsentAccepted ??= state.PelvicFloorTherapyEligible;
        packet.CreditCardAuthorizationAccepted ??= state.BillingConsentAuthorized;
        packet.FinalAttestationAccepted ??= state.AccuracyConfirmed;
        packet.CommunicationPhoneNumber = string.IsNullOrWhiteSpace(state.PhoneNumber)
            ? packet.CommunicationPhoneNumber
            : state.PhoneNumber;
        packet.CommunicationEmail = string.IsNullOrWhiteSpace(state.EmailAddress)
            ? packet.CommunicationEmail
            : state.EmailAddress;
        SetRevoked(packet, "hipaaAcknowledged", state.RevokeHipaaPrivacyNotice);
        SetRevoked(packet, "treatmentConsentAccepted", state.RevokeTreatmentConsent);
        SetRevoked(packet, "phiReleaseAuthorized", state.RevokePhiRelease);
        SetRevoked(packet, "communicationCallConsent", state.RevokeMarketingCommunications);
        SetRevoked(packet, "communicationTextConsent", state.RevokeMarketingCommunications);
        SetRevoked(packet, "communicationEmailConsent", state.RevokeMarketingCommunications);
        return packet;
    }

