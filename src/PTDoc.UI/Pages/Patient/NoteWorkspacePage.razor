    private async Task HandleSaveAsync()
    {
        if (!CanPersistDraft)
        {
            if (_hasSaveConflict)
            {
                _showSaveConflict = true;
                SetStatusMessage("Reload the latest note before saving again.", "error");
            }
            else if (!string.IsNullOrWhiteSpace(GetReadOnlySaveMessage()))
            {
                SetStatusMessage(GetReadOnlySaveMessage()!, "error", showToast: true, toastTitle: "Save unavailable");
            }
            return;
        }

        var flushedAutosave = DraftAutosaveService.IsDirty;
        var saveSucceeded = flushedAutosave
            ? await DraftAutosaveService.FlushAsync()
            : await PersistDraftAsync(showFeedback: true, CancellationToken.None);

        if (saveSucceeded &&
            !DraftAutosaveService.IsDirty &&
            !_note.IsDirty &&
            _warningValidationMessages.Count == 0 &&
            !_requiresOverride)
        {
            SetStatusMessage("Draft saved.", "success", showToast: flushedAutosave, toastTitle: "Draft saved");
        }
        else if (saveSucceeded && (DraftAutosaveService.IsDirty || _note.IsDirty))
        {
            SetStatusMessage("Newer changes are still being saved.", "info");
        }
        else if (!saveSucceeded)
        {
            var message = DraftAutosaveService.LastErrorMessage
                ?? _lastSaveFailureMessage
                ?? "Unable to save draft right now. Please retry.";
            SetStatusMessage(message, "error");
        }
    }

    private async Task HandleSaveSafelyAsync()
    {
        try
        {
            await HandleSaveAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(
                ex,
                "Manual draft save failed (noteType={NoteType}, noteIdPresent={HasNoteId})",
                _note.NoteType,
                _note.NoteId.HasValue);
            _note.MarkSaveError();
            SetStatusMessage(
                GetUserFacingMessage(ex, "Unable to save draft right now. Please retry."),
                "error",
                showToast: true,
                toastTitle: "Save failed");
        }
    }

    private async Task<DraftAutosaveSaveResult> AutosaveSaveAsync(CancellationToken cancellationToken)
    {
        var saved = await PersistDraftAsync(showFeedback: false, cancellationToken);
        return saved
            ? DraftAutosaveSaveResult.Succeeded()
            : DraftAutosaveSaveResult.Failed(_lastSaveFailureMessage);
    }

    private async Task<bool> PersistDraftAsync(
        bool showFeedback,
        CancellationToken cancellationToken,
        OverrideSubmission? overrideSubmission = null)
    {
        if (!_patientGuid.HasValue || !CanPersistDraft)
        {
            return false;
        }

        await _persistGate.WaitAsync(cancellationToken);
        DateTimeOffset? savingStateStartedAt = null;
        try
        {
            if (!_patientGuid.HasValue || !CanPersistDraft)
            {
                return false;
            }

            _lastSaveFailureMessage = null;
            _dateOfService = ResolveDateOfService();
            var saveGeneration = _editGeneration;
            _note.StartSaving();
            savingStateStartedAt = DateTimeOffset.UtcNow;
            await InvokeAsync(StateHasChanged);

            var saveResult = await NoteWorkspaceService.SaveDraftAsync(
                BuildDraft(_patientGuid.Value, overrideSubmission),
                cancellationToken);
            await EnsureMinimumVisibleSavingStateAsync(savingStateStartedAt.Value, cancellationToken);
            ApplyValidationDetails(
                saveResult.Errors,
                saveResult.Warnings,
                saveResult.RequiresOverride,
                saveResult.RuleType,
                saveResult.IsOverridable,
                saveResult.OverrideRequirements);

            if (!saveResult.Success)
            {
                _note.MarkSaveError();
                if (saveResult.IsConflict)
                {
                    _hasSaveConflict = true;
                    _showSaveConflict = true;
                }
                var message = saveResult.ErrorMessage ?? "Unable to save draft right now. Please retry.";
                _lastSaveFailureMessage = message;
                if (showFeedback || saveResult.Errors.Count > 0 || saveResult.Warnings.Count > 0)
                {
                    SetStatusMessage(
                        message,
                        "error",
                        showToast: showFeedback,
                        toastTitle: "Save failed");
                }

                return false;
            }

            var hasNewerEdits = _editGeneration != saveGeneration;
            if (!hasNewerEdits && saveResult.Payload is not null)
            {
                ApplyWorkspaceState(
                    saveResult.NoteId,
                    saveResult.LastModifiedUtc,
                    saveResult.Payload.WorkspaceNoteType,
                    _dateOfService,
                    saveResult.IsReEvaluation,
                    saveResult.Status,
                    saveResult.Payload,
                    resetAutosave: false);
            }
            else
            {
                _currentNoteId = saveResult.NoteId;
                _lastModifiedUtc = saveResult.LastModifiedUtc == default ? _lastModifiedUtc : saveResult.LastModifiedUtc;
                _note.NoteId = saveResult.NoteId;
                _note.Mode = NoteMode.Existing;
                _note.Status = saveResult.Status;
                if (!hasNewerEdits)
                {
                    _note.MarkSaved();
                }
            }

            await EnsureSavedNoteRouteAsync(saveResult.NoteId, preserveLocalEdits: hasNewerEdits);

            ApplyWorkspaceNotice();
            _lastSaveFailureMessage = null;
            _lastAutosaveToastMessage = null;

            if (hasNewerEdits)
            {
                SetStatusMessage("Newer changes are still being saved.", "info");
            }
            else if (saveResult.Warnings.Count > 0)
            {
                SetStatusMessage(
                    saveResult.ErrorMessage ?? (overrideSubmission is null
                        ? "Draft saved with warnings."
                        : "Draft saved with PT override and warnings."),
                    "info",
                    showToast: showFeedback,
                    toastTitle: "Draft saved");
            }
            else if (showFeedback)
            {
                SetStatusMessage(
                    overrideSubmission is null
                        ? "Draft saved."
                        : "Draft saved with PT override.",
                    "success",
                    showToast: true,
                    toastTitle: "Draft saved");
            }
            else
            {
                ClearStatusMessage();
            }

            return true;
        }
        catch (OperationCanceledException)
        {
            throw;
        }
        catch (Exception ex)
        {
            if (savingStateStartedAt.HasValue)
            {
                await EnsureMinimumVisibleSavingStateAsync(savingStateStartedAt.Value, cancellationToken);
            }

            _note.MarkSaveError();
            var message = GetUserFacingMessage(ex, "Unable to save draft right now. Please retry.");
            _lastSaveFailureMessage = message;
            SetStatusMessage(message, "error", showToast: showFeedback, toastTitle: "Save failed");
            return false;
        }
        finally
        {
            await InvokeAsync(StateHasChanged);
            _persistGate.Release();
        }
    }

    private static async Task EnsureMinimumVisibleSavingStateAsync(DateTimeOffset savingStateStartedAt, CancellationToken cancellationToken)
    {
        var remaining = MinimumVisibleSavingStateDuration - (DateTimeOffset.UtcNow - savingStateStartedAt);
        if (remaining > TimeSpan.Zero)
        {
            try
            {
                await Task.Delay(remaining, cancellationToken);
            }
            catch (OperationCanceledException) when (cancellationToken.IsCancellationRequested)
            {
                // Cancellation should skip the cosmetic delay without discarding an API result already received.
            }
        }
    }

    private async Task<bool> EnsureDraftPersistedAsync(bool forceIfClean = false)
    {
        if (_hasSaveConflict)
        {
            _showSaveConflict = true;
            SetStatusMessage("Reload the latest note before leaving this workspace.", "error");
            return false;
        }

        if (!CanSaveDraft)
        {
            return true;
        }

        if (DraftAutosaveService.IsDirty || DraftAutosaveService.IsSaving)
        {
            return await DraftAutosaveService.FlushAsync();
        }

        if (forceIfClean || !_note.NoteId.HasValue)
        {
            return await PersistDraftAsync(showFeedback: false, CancellationToken.None);
        }

        return true;
    }

    private async Task<bool> PromptForIncompleteDocumentationAsync(
        string? navigationTarget = null,
        string? noteTypeChange = null,
        SoapSection? sectionChange = null)
    {
        if (!CanSaveDraft)
        {
            return false;
        }

        if (!sectionChange.HasValue)
        {
            var saved = await EnsureDraftPersistedAsync(forceIfClean: !_note.NoteId.HasValue);
            if (!saved)
            {
                SetStatusMessage(
                    "Unable to save the draft before leaving this page. Resolve the error and try again.",
                    "error",
                    showToast: true,
                    toastTitle: "Save failed");
                await InvokeAsync(StateHasChanged);
                return true;
            }
        }

        var completion = CurrentCompletionState;
        if (completion.IsComplete)
        {
            return false;
        }

        _pendingNavigationTarget = navigationTarget;
        _pendingNoteTypeChange = noteTypeChange;
        _pendingSectionChange = sectionChange;
        _showIncompleteNoteModal = true;
        await InvokeAsync(StateHasChanged);
        return true;
    }

