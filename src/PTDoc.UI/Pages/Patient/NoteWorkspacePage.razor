    {
        Skipped,
        Applied,
        Missing,
        Failed
    }

    protected override async Task OnInitializedAsync()
    {
        _navGuard = NavigationManager.RegisterLocationChangingHandler(OnLocationChangingAsync);
        DraftAutosaveService.StateChanged += HandleAutosaveStateChanged;
        DraftAutosaveService.Configure(AutosaveSaveAsync, () => CanPersistDraft);

        await LoadWorkspaceAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await UpdateBeforeUnloadGuardAsync();

        if (!string.IsNullOrWhiteSpace(_pendingMissingFieldSelector))
        {
            var selector = _pendingMissingFieldSelector;
            _pendingMissingFieldSelector = null;
            await FocusMissingRequiredFieldAsync(selector);
        }
    }

    private async Task LoadWorkspaceAsync()
    {
        _isInitialLoading = true;
        _initialLoadError = null;
        _workspaceNotice = null;
        ClearValidationDetails();
        ClearStatusMessage();
        DraftAutosaveService.Reset();
        _hasSaveConflict = false;
        _showSaveConflict = false;
        StateHasChanged();

        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            _user = authState.User;

            var routeNoteId = ResolveRouteNoteId(NoteId);
            _currentNoteId = routeNoteId ?? Guid.Empty;
            _patientGuid = Guid.TryParse(PatientId, out var parsedPatientId) ? parsedPatientId : null;

            if (!_patientGuid.HasValue)
            {
                _initialLoadError = "A valid patient identifier is required to open this workspace.";
                return;
            }

            InitializeNote(routeNoteId);
            await LoadPatientContextAsync(_patientGuid.Value);

            if (routeNoteId.HasValue)
            {
                await LoadExistingNoteAsync(_patientGuid.Value, routeNoteId.Value);
            }
            else
            {
                var autoStartedEvaluation = await TryStartSeededEvaluationNoteAsync();
                if (!autoStartedEvaluation)
                {
                    if (IsEvaluationNoteType(_note.NoteType))
                    {
                        await TryApplyEvaluationSeedAsync(showMissingNotice: false);
                    }
                    else
                    {
                        var carryForwardResult = await TryApplyCarryForwardSeedCoreAsync(_note.NoteType, showMissingNotice: false);
                        if (carryForwardResult == SeedApplicationResult.Missing && ShouldApplyAppointmentDailyEvaluationFallback())
                        {
                            await TryStartSeededEvaluationNoteFromAppointmentDailyAsync();
                        }
                    }
                }
            }

            if (CanReadHep)
            {
                await LoadHepSummaryAsync();
            }

            ApplyWorkspaceNotice();
            ApplyRequestedSection();
        }
        catch (HttpRequestException ex)
        {
            _initialLoadError = GetUserFacingMessage(ex, "The note workspace could not be loaded right now.");
        }
        catch (Exception ex)
        {
            _initialLoadError = GetUserFacingMessage(ex, "The note workspace could not be loaded right now.");
        }
        finally
        {
            _isInitialLoading = false;
            StateHasChanged();
        }
    }

    private void InitializeNote(Guid? routeNoteId)
    {
        _note = new SoapNoteVm
        {
            NoteId = routeNoteId,
            PatientId = PatientId,
            PatientName = string.Empty,
            PatientDob = null,
            NoteType = ResolveInitialNoteType(),
            IsReEvaluation = false,
            Mode = routeNoteId.HasValue ? NoteMode.Existing : NoteMode.New,
            ActiveSection = SoapSection.Subjective,
            SaveState = NoteSaveState.Unsaved,
            Status = NoteStatus.Draft,
            IsDirty = false
        };

        _dryNeedling = new DryNeedlingVm();
        _sourceAppointmentId = ResolveRequestedAppointmentId();
        _dateOfService = ResolveRequestedDateOfService() ?? DateTime.UtcNow;
        _isDarkMode = false;
        _lastEditableSection = SoapSection.Plan;
        _pendingClinicalSummary = null;
        _lastModifiedUtc = null;
        _editGeneration = 0;
        _hasSaveConflict = false;
        _showSaveConflict = false;
        _hasAppliedEvaluationSeed = false;
        _hasAttemptedEvaluationSeed = false;
        _hepPrograms = [];
        _hepTracking = [];
        _hepSummaryUnavailable = null;
        _attemptedCarryForwardSeedNoteTypes = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
    }

    private async Task LoadHepSummaryAsync()
    {
        if (!_patientGuid.HasValue || !CanReadHep)
        {
            return;
        }
        try
        {
            _hepPrograms = await Integrations.GetHepProgramsAsync(_patientGuid.Value);
            var current = _hepPrograms
                .Where(item => item.Status is HepProgramStatus.Synced or HepProgramStatus.Conflict)
                .OrderByDescending(item => item.UpdatedAtUtc)
                .FirstOrDefault();
            _hepTracking = current is null
                ? []
                : await Integrations.GetHepTrackingAsync(current.Id);
            _hepSummaryUnavailable = null;
        }
        catch (Exception)
        {
            _hepPrograms = [];
            _hepTracking = [];
            _hepSummaryUnavailable = "The HEP summary is temporarily unavailable.";
        }
    }

    private async Task CopyHepTrackingSnapshotAsync()
    {
        if (!CanPersistDraft || _hepTracking.Count == 0)
        {
            return;
        }
        var reviewedAt = DateTime.UtcNow;
        var latestActivity = _hepTracking.Max(item => item.ActivityAtUtc);
        var codes = _hepTracking.Select(item => item.Code).Distinct(StringComparer.OrdinalIgnoreCase).Count();
        var snapshot = $"Wibbi tracking reviewed {reviewedAt:yyyy-MM-dd HH:mm} UTC: {_hepTracking.Count} provider-reported observation(s) across {codes} tracking field(s); latest patient activity {latestActivity:yyyy-MM-dd HH:mm} UTC. Provider-derived tracking requires clinician interpretation.";
        _note.Plan.HomeExerciseProgramNotes = string.IsNullOrWhiteSpace(_note.Plan.HomeExerciseProgramNotes)
            ? snapshot
            : $"{_note.Plan.HomeExerciseProgramNotes.Trim()}\n{snapshot}";
        await HandlePlanChanged(_note.Plan);
        ToastService.ShowSuccess("A timestamped HEP tracking snapshot was copied into this draft.");
    }

    private string ResolveInitialNoteType()
    {
        if (TryResolveRequestedNoteType(out var requestedNoteType))
        {
            return requestedNoteType;
        }

        return GetDefaultNoteType();
    }

    private string GetDefaultNoteType() => IsPtaUser ? "Daily Treatment Note" : "Progress Note";

    private async Task LoadExistingNoteAsync(Guid patientId, Guid noteId)
    {
        var result = await NoteWorkspaceService.LoadAsync(patientId, noteId);
        if (!result.Success)
        {
            throw new HttpRequestException(result.ErrorMessage ?? "Unable to load note data.");
        }

        ApplyWorkspaceState(result.NoteId, result.LastModifiedUtc, result.WorkspaceNoteType, result.DateOfService, result.IsReEvaluation, result.Status, result.Payload);
    }

    private void ApplyWorkspaceState(
        Guid noteId,
        DateTime lastModifiedUtc,
        string workspaceNoteType,
        DateTime dateOfService,
        bool isReEvaluation,
        NoteStatus status,
        NoteWorkspacePayload? payload,
        bool resetAutosave = true)
    {
        _currentNoteId = noteId;
        _lastModifiedUtc = lastModifiedUtc == default ? null : lastModifiedUtc;
        _note.NoteId = noteId;
        _note.Mode = NoteMode.Existing;
        _note.NoteType = string.IsNullOrWhiteSpace(workspaceNoteType) ? _note.NoteType : workspaceNoteType;
        _note.IsReEvaluation = isReEvaluation;
        _note.Subjective = payload?.Subjective ?? new SubjectiveVm();
        _note.Objective = payload?.Objective ?? new ObjectiveVm();
        SyncSelectedBodyPart(GetSelectedBodyPart());
        _note.Assessment = payload?.Assessment ?? new AssessmentWorkspaceVm();
        _note.Plan = payload?.Plan ?? new PlanVm();
        _note.BillingSettings = payload?.BillingSettings ?? new BillingModifierSettingsVm();
        _note.DailyTreatment = payload?.DailyTreatment ?? new DailyTreatmentVm();
        _note.ProgressSubjective = payload?.ProgressSubjective ?? new ProgressSubjectiveVm();
        _note.DischargeSubjective = payload?.DischargeSubjective ?? new DischargeSubjectiveVm();
        _note.StructuredWorkspacePayload = payload?.StructuredPayload;
        _dryNeedling = payload?.DryNeedling ?? new DryNeedlingVm();
        _note.Status = status;
        if (!CurrentSoapSections.Contains(_note.ActiveSection))
        {
            _note.MoveTo(SoapSection.Subjective);
            _lastEditableSection = SoapSection.Subjective;
        }
        _note.IsDirty = false;
        _note.MarkSaved();
        _pendingClinicalSummary = null;
        _dateOfService = dateOfService == default ? DateTime.UtcNow : dateOfService;
        if (resetAutosave)
        {
            DraftAutosaveService.Reset();
            _editGeneration = 0;
        }
        ClearValidationDetails();
    }

