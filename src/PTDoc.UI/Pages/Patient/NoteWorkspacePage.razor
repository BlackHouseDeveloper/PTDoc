            .Distinct(StringComparer.OrdinalIgnoreCase));
    }

    private IReadOnlyList<AiStructuredInput> GetAssessmentSubjectiveAiInputs()
    {
        var selectedBodyPart = GetSelectedBodyPart();
        var inputs = new List<AiStructuredInput>();

        AddAiInput(inputs, "Problems", JoinValues(_note.Subjective.Problems), selectedBodyPart);
        AddAiInput(inputs, "Other problem", _note.Subjective.OtherProblem, selectedBodyPart);
        AddAiInput(inputs, "Locations", JoinValues(_note.Subjective.Locations), selectedBodyPart);
        AddAiInput(inputs, "Other location", _note.Subjective.OtherLocation, selectedBodyPart);

        if (_note.Subjective.IsPainScoreDocumented)
        {
            AddAiInput(inputs, "Pain scores", $"current {_note.Subjective.CurrentPainScore}/10, best {_note.Subjective.BestPainScore}/10, worst {_note.Subjective.WorstPainScore}/10", selectedBodyPart);
        }

        AddAiInput(inputs, "Pain frequency", _note.Subjective.PainFrequency, selectedBodyPart);
        AddAiInput(inputs, "Known cause", _note.Subjective.KnownCause, selectedBodyPart);
        AddAiInput(inputs, "Prior functional level", JoinValues(_note.Subjective.PriorFunctionalLevel), selectedBodyPart);
        AddAiInput(inputs, "Current level of function", _note.Subjective.CurrentLevelOfFunction, selectedBodyPart);
        AddAiInput(inputs, "Functional limitations", JoinValues(_note.Subjective.FunctionalLimitations), selectedBodyPart);
        AddAiInput(inputs, "Additional functional limitations", _note.Subjective.AdditionalFunctionalLimitations, selectedBodyPart);

        foreach (var limitation in _note.Subjective.StructuredFunctionalLimitations)
        {
            var bodyPart = string.IsNullOrWhiteSpace(limitation.BodyPart)
                ? selectedBodyPart
                : limitation.BodyPart;

            if (!ShouldIncludeAiInputForSelectedBodyPart(bodyPart, selectedBodyPart))
            {
                continue;
            }

            AddAiInput(
                inputs,
                string.IsNullOrWhiteSpace(limitation.Category) ? "Functional limitation" : $"Functional limitation - {limitation.Category}",
                FormatStructuredFunctionalLimitation(limitation),
                bodyPart);
        }

        return inputs;
    }

    private IReadOnlyList<AiStructuredInput> GetAssessmentObjectiveAiInputs()
    {
        var selectedBodyPart = GetSelectedBodyPart();
        var inputs = new List<AiStructuredInput>();

        foreach (var metric in _note.Objective.Metrics)
        {
            AddAiInput(inputs, $"Objective metric - {metric.MetricType}", FormatObjectiveMetric(metric), selectedBodyPart);
        }

        foreach (var metric in _note.StructuredWorkspacePayload?.Objective.Metrics ?? Enumerable.Empty<ObjectiveMetricInputV2>())
        {
            var bodyPart = metric.BodyPart == BodyPart.Other ? selectedBodyPart : GetBodyPartDisplayLabel(metric.BodyPart);
            if (!ShouldIncludeAiInputForSelectedBodyPart(bodyPart, selectedBodyPart))
            {
                continue;
            }

            AddAiInput(inputs, $"Objective metric - {metric.MetricType}", FormatObjectiveMetric(metric), bodyPart);
        }

        AddAiInput(inputs, "Special tests", JoinValues(_note.Objective.SpecialTests.Select(FormatSpecialTest)), selectedBodyPart);
        AddAiInput(inputs, "Outcome measures", JoinValues(_note.Objective.OutcomeMeasures.Select(FormatOutcomeMeasure)), selectedBodyPart);
        AddAiInput(inputs, "Tender muscles", JoinValues(_note.Objective.TenderMuscles), selectedBodyPart);
        AddAiInput(inputs, "Primary gait pattern", _note.Objective.PrimaryGaitPattern, selectedBodyPart);
        AddAiInput(inputs, "Gait deviations", JoinValues(_note.Objective.GaitDeviations), selectedBodyPart);
        AddAiInput(inputs, "Gait observations", _note.Objective.AdditionalGaitObservations, selectedBodyPart);
        AddAiInput(inputs, "Posture findings", JoinValues(_note.Objective.PostureFindings), selectedBodyPart);
        AddAiInput(inputs, "Other posture finding", _note.Objective.OtherPostureFinding, selectedBodyPart);
        AddAiInput(inputs, "Clinical observation notes", _note.Objective.ClinicalObservationNotes, selectedBodyPart);

        return DeduplicateAiInputs(inputs);
    }

    private IReadOnlyList<AiStructuredInput> GetPlanAiInputs()
    {
        var selectedBodyPart = GetSelectedBodyPart();
