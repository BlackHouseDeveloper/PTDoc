    private async Task HandleRegenerateSummaryAsync()
    {
        if (IsWorkspaceReadOnly)
        {
            return;
        }

        if (!_note.NoteId.HasValue)
        {
            SetStatusMessage("Save the note before generating an AI plan summary.", "error", showToast: true, toastTitle: "AI generation unavailable");
            return;
        }

        if (!HasConcreteBodyPart(GetSelectedBodyPart()))
        {
            SetStatusMessage("Select a body part before generating an AI plan summary.", "error", showToast: true, toastTitle: "AI generation unavailable");
            return;
        }

        _isRegeneratingSummary = true;
        ClearStatusMessage();
        StateHasChanged();

        try
        {
            var result = await AiService.GeneratePlanOfCareAsync(new PlanOfCareGenerationRequest
            {
                NoteId = _note.NoteId ?? Guid.Empty,
                Diagnosis = GetDiagnosisSummary(),
                SelectedBodyPart = GetSelectedBodyPart(),
                AssessmentSummary = GetAssessmentSummary(),
                Goals = GetGoalsSummary(),
                Precautions = GetPrecautionsSummary(),
                StructuredInputs = GetPlanAiInputs(),
                IsNoteSigned = _note.Status != NoteStatus.Draft
            });

            if (!result.Success)
            {
                SetStatusMessage(result.ErrorMessage ?? "Unable to generate a clinical summary.", "error", showToast: true, toastTitle: "AI generation failed");
                return;
            }

            _pendingClinicalSummary = result.GeneratedText;
            SetStatusMessage("Clinical summary regenerated. Review and accept it before applying it to the note.", "success", showToast: true, toastTitle: "AI generation complete");
        }
        catch (Exception ex)
        {
            Logger.LogError(
                ex,
                "Clinical summary regeneration failed (noteType={NoteType}, noteIdPresent={HasNoteId})",
                _note.NoteType,
                _note.NoteId.HasValue);
            SetStatusMessage("Unable to generate a clinical summary.", "error", showToast: true, toastTitle: "AI generation failed");
        }
        finally
        {
            _isRegeneratingSummary = false;
        }
    }

    private async Task HandleAcceptPendingSummaryAsync()
    {
        if (string.IsNullOrWhiteSpace(_pendingClinicalSummary))
        {
            return;
        }

        if (!_note.NoteId.HasValue)
        {
            SetStatusMessage("Save the note before accepting AI-generated summary content.", "error", showToast: true, toastTitle: "AI acceptance unavailable");
            return;
        }

        try
        {
            var acceptance = await NoteWorkspaceService.AcceptAiSuggestionAsync(
                _note.NoteId.Value,
                section: "plan",
                generatedText: _pendingClinicalSummary,
                generationType: "ClinicalSummary");

            if (!acceptance.Success)
            {
                SetStatusMessage(acceptance.ErrorMessage ?? "Unable to accept AI-generated summary content.", "error", showToast: true, toastTitle: "AI acceptance failed");
                return;
            }

            _note.Plan.ClinicalSummary = _pendingClinicalSummary;
            _pendingClinicalSummary = null;
            MarkUnsaved();
            SetStatusMessage("Clinical summary accepted. Save the note to keep the updated summary.", "success", showToast: true, toastTitle: "AI content accepted");
        }
        catch (Exception ex)
        {
            Logger.LogError(
                ex,
                "Clinical summary acceptance failed (noteType={NoteType}, noteIdPresent={HasNoteId})",
                _note.NoteType,
                _note.NoteId.HasValue);
            SetStatusMessage("Unable to accept AI-generated summary content.", "error", showToast: true, toastTitle: "AI acceptance failed");
        }
    }

    private Task HandleDiscardPendingSummaryAsync()
    {
        if (!HasPendingClinicalSummary)
        {
            return Task.CompletedTask;
        }

        _pendingClinicalSummary = null;
        SetStatusMessage("Regenerated clinical summary discarded.", "info");
        return Task.CompletedTask;
    }

    private async Task HandleRegenerateGoalsAsync()
    {
        if (IsWorkspaceReadOnly)
        {
            return;
        }

        _isRegeneratingGoals = true;
        ClearStatusMessage();
        StateHasChanged();

        try
        {
            var result = await AiService.GenerateGoalNarrativesAsync(new GoalNarrativesGenerationRequest
            {
                NoteId = _note.NoteId ?? Guid.Empty,
                Diagnosis = GetDiagnosisSummary(),
                FunctionalLimitations = GetFunctionalLimitationsSummary(),
                ShortTermGoals = GetGoalsSummary(),
                LongTermGoals = GetGoalsSummary(),
                IsNoteSigned = _note.Status != NoteStatus.Draft
            });

            if (!result.Success)
            {
                SetStatusMessage(result.ErrorMessage ?? "Unable to generate AI treatment goals.", "error", showToast: true, toastTitle: "AI generation failed");
                return;
            }

            foreach (var description in ParseGoalSuggestions(result.GeneratedText))
            {
                if (_note.Assessment.Goals.Any(goal => string.Equals(goal.Description, description, StringComparison.OrdinalIgnoreCase)))
                {
                    continue;
                }

                _note.Assessment.Goals.Add(new SmartGoalEntry
                {
                    Description = description,
                    IsAiSuggested = true,
                    IsAccepted = false,
                    Timeframe = GoalTimeframe.ShortTerm,
                    Status = GoalStatus.Active
                });
            }

            MarkUnsaved();
            SetStatusMessage("AI treatment goals regenerated. Review and accept the suggested goals before saving.", "success", showToast: true, toastTitle: "AI generation complete");
        }
        catch (Exception ex)
        {
            Logger.LogError(
                ex,
                "AI treatment goal regeneration failed (noteType={NoteType}, noteIdPresent={HasNoteId})",
                _note.NoteType,
                _note.NoteId.HasValue);
            SetStatusMessage("Unable to generate AI treatment goals.", "error", showToast: true, toastTitle: "AI generation failed");
        }
        finally
        {
            _isRegeneratingGoals = false;
        }
    }

