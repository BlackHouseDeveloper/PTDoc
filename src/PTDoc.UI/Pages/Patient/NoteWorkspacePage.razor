@page "/patient/{PatientId}/note/{NoteId}"
@page "/patient/{PatientId}/notes/{NoteId}"
@page "/patient/{PatientId}/new-note"
@attribute [Authorize]
@rendermode InteractiveServer
@implements IAsyncDisposable

@using System.Globalization
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Routing
@using PTDoc.Application.AI
@using PTDoc.Application.Compliance
@using PTDoc.Application.Services
@using PTDoc.Core.Models
@using PTDoc.UI.Components.Notes
@using PTDoc.UI.Components.Notes.Models
@using PTDoc.UI.Components.Notes.Workspace
@using PTDoc.UI.Components.Notes.Workspace.DailyTreatment
@using PTDoc.UI.Components.Notes.Workspace.DischargeNote
@using PTDoc.UI.Components.Notes.Workspace.DryNeedling
@using PTDoc.UI.Components.Notes.Workspace.ProgressNote
@using PTDoc.UI.Services

@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject INoteWorkspaceService NoteWorkspaceService
@inject IPatientService PatientService
@inject IAiClinicalGenerationService AiService
@inject DraftAutosaveService DraftAutosaveService
@inject IJSRuntime JS

<PageTitle>SOAP Workspace - PTDoc</PageTitle>

@if (_isInitialLoading)
{
    <section class="note-workspace note-workspace__state" role="status" aria-live="polite" data-testid="note-workspace-loading">
        <div class="note-workspace__state-card">
            <h2>Loading note workspace…</h2>
            <p>Fetching the patient and note details from the API.</p>
        </div>
    </section>
}
else if (!string.IsNullOrWhiteSpace(_initialLoadError))
{
    <section class="note-workspace note-workspace__state" data-testid="note-workspace-load-error">
        <div class="note-workspace__state-card note-workspace__state-card--error" role="alert">
            <h2>Unable to load note workspace</h2>
            <p>@_initialLoadError</p>
            <div class="note-workspace__state-actions">
                <button type="button" class="btn btn--primary" @onclick="HandleReloadAsync">Retry</button>
                <button type="button" class="btn btn--secondary" @onclick="HandleBack">Back to Patient</button>
            </div>
        </div>
    </section>
}
else
{
    <div class="note-workspace" data-testid="note-workspace-page">
        @if (!string.IsNullOrWhiteSpace(_workspaceNotice))
        {
            <div class="note-workspace__alert note-workspace__alert--info" role="status" data-testid="note-workspace-notice">
                @_workspaceNotice
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(_statusMessage))
        {
            <div class="note-workspace__alert @GetAlertToneClass()" role="alert" data-testid="note-workspace-alert">
                @_statusMessage
            </div>
        }

        @if (_blockingValidationMessages.Count > 0)
        {
            <div class="note-workspace__alert note-workspace__alert--error" role="alert" data-testid="note-workspace-blocking-errors">
                <strong>Blocking errors</strong>
                <ul class="note-workspace__alert-list">
                    @foreach (var message in _blockingValidationMessages)
                    {
                        <li>@message</li>
                    }
                </ul>
            </div>
        }

        @if (_warningValidationMessages.Count > 0)
        {
            <div class="note-workspace__alert note-workspace__alert--info" role="status" data-testid="note-workspace-warnings">
                <strong>Warnings</strong>
                <ul class="note-workspace__alert-list">
                    @foreach (var message in _warningValidationMessages)
                    {
                        <li>@message</li>
                    }
                </ul>
            </div>
        }

        @if (_requiresOverride)
        {
            <div class="note-workspace__alert note-workspace__alert--info" role="status" data-testid="note-workspace-override-required">
                A PT compliance override is required before this note can be finalized.
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(DraftAutosaveService.LastErrorMessage))
        {
            <div class="note-workspace__alert note-workspace__alert--error" role="alert" data-testid="note-workspace-autosave-error">
                Autosave failed: @DraftAutosaveService.LastErrorMessage
            </div>
        }

        @if (IsDryNeedlingNote)
        {
            <PatientContextHeader PatientName="@DisplayPatientName" PatientDob="@_note.PatientDob" />

            <DryNeedlingNoteView IsReadOnly="@IsWorkspaceReadOnly"
                                 DisableSave="@DisableSaveAction"
                                 DisableSubmit="@DisableSubmitAction"
                                 AllowSubmitWhenReadOnly="@CanSubmitCurrentNote"
                                 Vm="@_dryNeedling"
                                 VmChanged="HandleDryNeedlingChanged"
                                 OnSave="HandleSaveAsync"
                                 OnSubmit="HandleSubmitAsync" />
        }
        else
        {
            @if (!IsReviewSection)
            {
                <PatientContextHeader PatientName="@DisplayPatientName" PatientDob="@_note.PatientDob" />

                <NoteTypeContainer NoteType="@_note.NoteType"
                                   NoteTypeChanged="HandleNoteTypeChanged"
                                   NoteTypes="@AvailableNoteTypes"
                                   Disabled="@(IsWorkspaceReadOnly || AvailableNoteTypes.Count <= 1)" />
            }

            <SoapTabNav ActiveSection="@_note.ActiveSection"
                        ActiveSectionChanged="HandleSectionChanged" />

            <div id="soap-tab-panel" class="note-workspace__panel" role="tabpanel" aria-live="polite">
                @switch (_note.ActiveSection)
                {
                    case SoapSection.Subjective:
                        if (IsProgressNote)
                        {
                            <ProgressSubjectiveSection Vm="@_note.Subjective"
                                                      VmChanged="HandleSubjectiveChanged"
                                                      IsReadOnly="@IsWorkspaceReadOnly" />
                        }
                        else if (IsDailyTreatment || IsDischargeNote)
                        {
                            <SubjectiveSection Vm="@_note.Subjective"
                                               VmChanged="HandleSubjectiveChanged"
                                               IsReadOnly="@IsWorkspaceReadOnly"
                                               IsDarkMode="@_isDarkMode" />
                        }
                        else
                        {
                            <SubjectiveTab Vm="@_note.Subjective"
                                           VmChanged="HandleSubjectiveChanged"
                                           IsReadOnly="@IsWorkspaceReadOnly" />
                        }
                        break;

                    case SoapSection.Objective:
                        if (IsDailyTreatment || IsProgressNote)
                        {
                            <BaselineComparisonCard IsDarkMode="@_isDarkMode" />
                        }
                        <ObjectiveTab Vm="@_note.Objective"
                                      VmChanged="HandleObjectiveChanged"
                                      IsReadOnly="@IsWorkspaceReadOnly"
                                      PatientId="@PatientId"
                                      GoalCount="@GoalCount"
                                      GoalProgressPercent="@GoalsMetPercent"
                                      ShortTermGoalCount="@ShortTermGoalCount"
                                      LongTermGoalCount="@LongTermGoalCount"
                                      GoalItems="@GoalItems"
                                      GoalHints="@GoalHints" />
                        break;

                    case SoapSection.Assessment:
                        if (IsDailyTreatment || IsProgressNote)
                        {
                            <AssessmentSection Vm="@_note.Assessment"
                                               VmChanged="HandleAssessmentChanged"
                                               IsReadOnly="@IsWorkspaceReadOnly"
                                               IsDarkMode="@_isDarkMode"
                                               NoteId="@(_note.NoteId ?? Guid.Empty)"
                                               ChiefComplaint="@GetChiefComplaintText()"
                                               ExaminationFindings="@GetExaminationFindingsText()" />
                        }
                        else if (IsDischargeNote)
                        {
                            <FinalOutcomesSummaryCard />
                            <GoalAchievementSummaryCard />
                            <AssessmentWorkspaceSection NoteId="@(_note.NoteId ?? Guid.Empty)"
                                                        Vm="@_note.Assessment"
                                                        VmChanged="HandleAssessmentChanged"
                                                        IsReadOnly="@IsWorkspaceReadOnly"
                                                        ShowSmartGoals="false"
                                                        ChiefComplaint="@GetChiefComplaintText()"
                                                        ExaminationFindings="@GetExaminationFindingsText()" />
                        }
                        else
                        {
                            <AssessmentWorkspaceSection NoteId="@(_note.NoteId ?? Guid.Empty)"
                                                        Vm="@_note.Assessment"
                                                        VmChanged="HandleAssessmentChanged"
                                                        IsReadOnly="@IsWorkspaceReadOnly"
                                                        ChiefComplaint="@GetChiefComplaintText()"
                                                        ExaminationFindings="@GetExaminationFindingsText()" />
                        }
                        break;

                    case SoapSection.Plan:
                        if (IsDailyTreatment)
                        {
                            <PlanSection Vm="@_note.Plan"
                                         VmChanged="HandlePlanChanged"
                                         IsReadOnly="@IsWorkspaceReadOnly"
                                         IsDarkMode="@_isDarkMode"
                                         NoteId="@(_note.NoteId ?? Guid.Empty)"
                                         DiagnosisSummary="@GetDiagnosisSummary()"
                                         AssessmentSummary="@GetAssessmentSummary()"
                                         GoalsSummary="@GetGoalsSummary()"
                                         PrecautionsSummary="@GetPrecautionsSummary()" />
                        }
                        else if (IsDischargeNote)
                        {
                            <DischargePlanSection Vm="@_note.Plan"
                                                  VmChanged="HandlePlanChanged"
                                                  IsReadOnly="@IsWorkspaceReadOnly" />
                        }
                        else
                        {
                            <PlanTab NoteId="@(_note.NoteId ?? Guid.Empty)"
                                     Vm="@_note.Plan"
                                     VmChanged="HandlePlanChanged"
                                     IsReadOnly="@IsWorkspaceReadOnly"
                                     DiagnosisSummary="@GetDiagnosisSummary()"
                                     AssessmentSummary="@GetAssessmentSummary()"
                                     GoalsSummary="@GetGoalsSummary()"
                                     PrecautionsSummary="@GetPrecautionsSummary()" />
                        }
                        break;

                    case SoapSection.Review:
                        <SoapReviewPage Note="@_note"
                                        DateOfService="@_dateOfService"
                                        IsReadOnly="@IsWorkspaceReadOnly"
                                        IsRegeneratingSummary="@_isRegeneratingSummary"
                                        IsRegeneratingGoals="@_isRegeneratingGoals"
                                        IsSubmitting="@_isSubmittingNote"
                                        CanSubmit="@CanSubmitCurrentNote"
                                        CanExportPdf="@CanExportPdf"
                                        OnEditSection="HandleEditSection"
                                        OnBackToEdit="HandleBackToEdit"
                                        OnRegenerateSummary="HandleRegenerateSummaryAsync"
                                        OnRegenerateGoals="HandleRegenerateGoalsAsync"
                                        OnExportPdf="HandleExportPdfAsync"
                                        OnSubmit="HandleSubmitAsync" />
                        break;
                }
            </div>

            @if (!IsReviewSection)
            {
                <SoapStickyFooter NoteType="@_note.NoteType"
                                  ActiveSection="@_note.ActiveSection"
                                  SaveState="@_note.SaveState"
                                  IsReadOnly="@IsWorkspaceReadOnly"
                                  DisableSave="@DisableSaveAction"
                                  DisableSubmit="@DisableSubmitAction"
                                  AllowSubmitWhenReadOnly="@CanSubmitCurrentNote"
                                  OnBack="HandleBack"
                                  OnPrevSection="HandlePrevSection"
                                  OnNextSection="HandleNextSection"
                                  OnGoalsClick="HandleGoalsClick"
                                  OnReviewClick="HandleReviewClick"
                                  OnSave="HandleSaveAsync"
                                  OnSubmit="HandleSubmitAsync" />
            }
        }
    </div>
}

@if (_showSignatureConsent)
{
    <div class="signature-consent-overlay" role="dialog" aria-modal="true" aria-labelledby="sig-consent-title" data-testid="signature-consent-dialog">
        <div class="signature-consent-dialog">
            <h2 id="sig-consent-title" class="signature-consent-dialog__title">Electronic Signature — Consent &amp; Intent</h2>
            <p class="signature-consent-dialog__body">
                By signing this clinical note electronically you attest that the documentation and billing
                accurately reflect medically necessary services rendered and that the recorded time and units
                are correct to the best of your knowledge.
            </p>
            <label class="signature-consent-dialog__checkbox-label">
                <input type="checkbox" @bind="_consentAccepted" data-testid="sig-consent-checkbox" />
                I consent to the use of an electronic signature and understand it carries the same legal
                weight as a handwritten signature.
            </label>
            <label class="signature-consent-dialog__checkbox-label">
                <input type="checkbox" @bind="_intentConfirmed" data-testid="sig-intent-checkbox" />
                I confirm my intent to sign this clinical note.
            </label>
            <div class="signature-consent-dialog__actions">
                <button class="btn btn--secondary"
                        @onclick="HandleConsentCancelAsync"
                        data-testid="sig-consent-cancel">Cancel</button>
                <button class="btn btn--primary"
                        disabled="@(!_consentAccepted || !_intentConfirmed || _isSubmittingNote)"
                        @onclick="HandleConsentConfirmAsync"
                        data-testid="sig-consent-confirm">Sign Note</button>
            </div>
        </div>
    </div>
}

@code {
    [SupplyParameterFromQuery(Name = "section")] public string? RequestedSection { get; set; }

    [Parameter, EditorRequired] public string PatientId { get; set; } = string.Empty;
    [Parameter] public string? NoteId { get; set; }

    private readonly string[] _allNoteTypes =
    [
        "Evaluation Note",
        "Progress Note",
        "Discharge Note",
        "Dry Needling Note",
        "Daily Treatment Note"
    ];

    private readonly SemaphoreSlim _persistGate = new(1, 1);

    private SoapNoteVm _note = new();
    private DryNeedlingVm _dryNeedling = new();
    private ClaimsPrincipal _user = new(new ClaimsIdentity());
    private Guid _currentNoteId;
    private Guid? _patientGuid;
    private string? _initialLoadError;
    private string? _workspaceNotice;
    private string? _statusMessage;
    private string _statusTone = "info";
    private DateTime _dateOfService = DateTime.UtcNow;
    private bool _isDarkMode;
    private bool _isRegeneratingSummary;
    private bool _isRegeneratingGoals;
    private bool _isInitialLoading = true;
    private bool _isSubmittingNote;
    private SoapSection _lastEditableSection = SoapSection.Plan;
    private bool _showSignatureConsent;
    private bool _consentAccepted;
    private bool _intentConfirmed;
    private string? _allowedNavigationTarget;
    private IDisposable? _navGuard;
    private bool _disposed;
    private List<string> _blockingValidationMessages = [];
    private List<string> _warningValidationMessages = [];
    private bool _requiresOverride;

    private bool IsDailyTreatment => string.Equals(_note.NoteType, "Daily Treatment Note", StringComparison.OrdinalIgnoreCase);
    private bool IsProgressNote => string.Equals(_note.NoteType, "Progress Note", StringComparison.OrdinalIgnoreCase);
    private bool IsDischargeNote => string.Equals(_note.NoteType, "Discharge Note", StringComparison.OrdinalIgnoreCase);
    private bool IsDryNeedlingNote => string.Equals(_note.NoteType, "Dry Needling Note", StringComparison.OrdinalIgnoreCase);
    private bool IsReviewSection => _note.ActiveSection == SoapSection.Review;

    private bool IsPtUser => _user.IsInRole(Roles.PT);
    private bool IsPtaUser => _user.IsInRole(Roles.PTA);
    private bool IsAdminUser => _user.IsInRole(Roles.Admin);
    private bool IsOwnerUser => _user.IsInRole(Roles.Owner);
    private bool IsBillingUser => _user.IsInRole(Roles.Billing);

    private string DisplayPatientName => string.IsNullOrWhiteSpace(_note.PatientName) ? "Unknown Patient" : _note.PatientName;

    private IReadOnlyList<string> AvailableNoteTypes
    {
        get
        {
            var baseTypes = IsPtaUser
                ? new[] { "Daily Treatment Note" }
                : _allNoteTypes;

            if (string.IsNullOrWhiteSpace(_note.NoteType) ||
                baseTypes.Any(type => string.Equals(type, _note.NoteType, StringComparison.OrdinalIgnoreCase)))
            {
                return baseTypes;
            }

            return [_note.NoteType, .. baseTypes];
        }
    }

    private IReadOnlyList<SmartGoalEntry> VisibleGoals => _note.Assessment.Goals
        .Where(goal => !string.IsNullOrWhiteSpace(goal.Description) && (!goal.IsAiSuggested || goal.IsAccepted))
        .OrderBy(goal => goal.Timeframe)
        .ThenBy(goal => goal.Description, StringComparer.OrdinalIgnoreCase)
        .ToList();

    private IReadOnlyList<PatientGoalItem> GoalItems => VisibleGoals
        .Select(goal => new PatientGoalItem
        {
            Name = goal.Description.Trim(),
            Type = goal.Timeframe == GoalTimeframe.LongTerm ? "LT" : "ST",
            Category = goal.Category ?? string.Empty,
            Timeline = goal.Timeframe == GoalTimeframe.LongTerm ? "Long-term goal" : "Short-term goal",
            ProgressPercent = goal.Status == GoalStatus.Met ? 100 : 0,
            TargetDescription = GetGoalStatusDescription(goal.Status),
            Timeframe = goal.Timeframe,
            Status = goal.Status,
            HasQuantitativeProgress = goal.Status == GoalStatus.Met
        })
        .ToList();

    private IReadOnlyList<string> GoalHints => GoalCount == 0
        ? Array.Empty<string>()
        : new[]
        {
            "Compare today’s objective findings against the tracked goals.",
            "Update goal status when the patient has clearly met or deferred a target.",
            "Document measurable changes that support your assessment and plan."
        };

    private int GoalCount => GoalItems.Count;
    private int GoalsMetPercent => GoalCount == 0 ? 0 : (int)Math.Round((double)GoalItems.Count(goal => goal.Status == GoalStatus.Met) / GoalCount * 100);
    private int ShortTermGoalCount => GoalItems.Count(goal => goal.Timeframe == GoalTimeframe.ShortTerm);
    private int LongTermGoalCount => GoalItems.Count(goal => goal.Timeframe == GoalTimeframe.LongTerm);

    private bool IsWorkspaceReadOnly => !CanEditCurrentDraft;
    private bool CanEditCurrentDraft => _note.Status == NoteStatus.Draft && HasDraftWritePermissionForNoteType(_note.NoteType);
    private bool CanFinalizePendingCoSign => _note.Status == NoteStatus.PendingCoSign && IsPtUser;
    private bool CanSubmitCurrentNote => !_isInitialLoading && !_isSubmittingNote && (CanSignDraftNote || CanFinalizePendingCoSign);
    private bool CanSignDraftNote => _note.Status == NoteStatus.Draft && HasSignPermissionForNoteType(_note.NoteType);
    private bool CanSaveDraft => !_isInitialLoading && !_isSubmittingNote && CanEditCurrentDraft && _patientGuid.HasValue;
    private bool DisableSaveAction => !CanSaveDraft || DraftAutosaveService.IsSaving;
    private bool DisableSubmitAction => !CanSubmitCurrentNote || DraftAutosaveService.IsSaving;
    private bool CanExportPdf => IsPtUser || IsPtaUser || IsAdminUser;

    protected override async Task OnInitializedAsync()
    {
        _navGuard = NavigationManager.RegisterLocationChangingHandler(OnLocationChangingAsync);
        DraftAutosaveService.StateChanged += HandleAutosaveStateChanged;
        DraftAutosaveService.Configure(AutosaveSaveAsync, () => CanSaveDraft);

        await LoadWorkspaceAsync();
    }

    private async Task LoadWorkspaceAsync()
    {
        _isInitialLoading = true;
        _initialLoadError = null;
        _workspaceNotice = null;
        ClearValidationDetails();
        ClearStatusMessage();
        DraftAutosaveService.Reset();
        StateHasChanged();

        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            _user = authState.User;

            var routeNoteId = ResolveRouteNoteId(NoteId);
            _currentNoteId = routeNoteId ?? Guid.Empty;
            _patientGuid = Guid.TryParse(PatientId, out var parsedPatientId) ? parsedPatientId : null;

            if (!_patientGuid.HasValue)
            {
                _initialLoadError = "A valid patient identifier is required to open this workspace.";
                return;
            }

            InitializeNote(routeNoteId);
            await LoadPatientContextAsync(_patientGuid.Value);

            if (routeNoteId.HasValue)
            {
                await LoadExistingNoteAsync(_patientGuid.Value, routeNoteId.Value);
            }

            ApplyWorkspaceNotice();
            ApplyRequestedSection();
        }
        catch (HttpRequestException ex)
        {
            _initialLoadError = GetUserFacingMessage(ex, "The note workspace could not be loaded right now.");
        }
        catch (Exception ex)
        {
            _initialLoadError = GetUserFacingMessage(ex, "The note workspace could not be loaded right now.");
        }
        finally
        {
            _isInitialLoading = false;
            StateHasChanged();
        }
    }

    private void InitializeNote(Guid? routeNoteId)
    {
        _note = new SoapNoteVm
        {
            NoteId = routeNoteId,
            PatientId = PatientId,
            PatientName = string.Empty,
            PatientDob = null,
            NoteType = GetDefaultNoteType(),
            Mode = routeNoteId.HasValue ? NoteMode.Existing : NoteMode.New,
            ActiveSection = SoapSection.Subjective,
            SaveState = NoteSaveState.Unsaved,
            Status = NoteStatus.Draft,
            IsDirty = false
        };

        _dryNeedling = new DryNeedlingVm();
        _dateOfService = DateTime.UtcNow;
        _isDarkMode = false;
        _lastEditableSection = SoapSection.Plan;
    }

    private string GetDefaultNoteType() => IsPtaUser ? "Daily Treatment Note" : "Progress Note";

    private async Task LoadExistingNoteAsync(Guid patientId, Guid noteId)
    {
        var result = await NoteWorkspaceService.LoadAsync(patientId, noteId);
        if (!result.Success)
        {
            throw new HttpRequestException(result.ErrorMessage ?? "Unable to load note data.");
        }

        ApplyWorkspaceState(result.NoteId, result.WorkspaceNoteType, result.DateOfService, result.Status, result.Payload);
    }

    private void ApplyWorkspaceState(
        Guid noteId,
        string workspaceNoteType,
        DateTime dateOfService,
        NoteStatus status,
        NoteWorkspacePayload? payload)
    {
        _currentNoteId = noteId;
        _note.NoteId = noteId;
        _note.Mode = NoteMode.Existing;
        _note.NoteType = string.IsNullOrWhiteSpace(workspaceNoteType) ? _note.NoteType : workspaceNoteType;
        _note.Subjective = payload?.Subjective ?? new SubjectiveVm();
        _note.Objective = payload?.Objective ?? new ObjectiveVm();
        _note.Assessment = payload?.Assessment ?? new AssessmentWorkspaceVm();
        _note.Plan = payload?.Plan ?? new PlanVm();
        _dryNeedling = payload?.DryNeedling ?? new DryNeedlingVm();
        _note.Status = status;
        _note.IsDirty = false;
        _note.MarkSaved();
        _dateOfService = dateOfService == default ? DateTime.UtcNow : dateOfService;
        DraftAutosaveService.Reset();
        ClearValidationDetails();
    }

    private async Task HandleReloadAsync()
    {
        await LoadWorkspaceAsync();
    }

    private void ApplyRequestedSection()
    {
        var requestedSection = ResolveRequestedSection(RequestedSection);
        if (!requestedSection.HasValue || requestedSection.Value == _note.ActiveSection)
        {
            return;
        }

        if (requestedSection == SoapSection.Review && _note.ActiveSection != SoapSection.Review)
        {
            _lastEditableSection = _note.ActiveSection;
        }
        else if (requestedSection != SoapSection.Review)
        {
            _lastEditableSection = requestedSection.Value;
        }

        _note.MoveTo(requestedSection.Value);
    }

    private static Guid? ResolveRouteNoteId(string? routeNoteId)
    {
        if (!string.IsNullOrWhiteSpace(routeNoteId) && Guid.TryParse(routeNoteId, out var parsed))
        {
            return parsed;
        }

        return null;
    }

    private static SoapSection? ResolveRequestedSection(string? value) => value?.Trim().ToLowerInvariant() switch
    {
        "subjective" => SoapSection.Subjective,
        "objective" => SoapSection.Objective,
        "assessment" => SoapSection.Assessment,
        "plan" => SoapSection.Plan,
        "review" => SoapSection.Review,
        _ => null
    };

    private async Task HandleSectionChanged(SoapSection next)
    {
        if (next == SoapSection.Review && !await EnsureDraftPersistedAsync(forceIfClean: !_note.NoteId.HasValue))
        {
            return;
        }

        if (next == SoapSection.Review)
        {
            if (_note.ActiveSection != SoapSection.Review)
            {
                _lastEditableSection = _note.ActiveSection;
            }
        }
        else
        {
            _lastEditableSection = next;
        }

        _note.MoveTo(next);
        ClearStatusMessage();
    }

    private Task HandleNoteTypeChanged(string value)
    {
        if (!CanEditCurrentDraft)
        {
            return Task.CompletedTask;
        }

        _note.NoteType = value;
        MarkUnsaved();
        ApplyWorkspaceNotice();
        return Task.CompletedTask;
    }

    private Task HandleSubjectiveChanged(SubjectiveVm vm)
    {
        _note.Subjective = vm;
        MarkUnsaved();
        return Task.CompletedTask;
    }

    private Task HandleObjectiveChanged(ObjectiveVm vm)
    {
        _note.Objective = vm;
        MarkUnsaved();
        return Task.CompletedTask;
    }

    private Task HandleAssessmentChanged(AssessmentWorkspaceVm vm)
    {
        _note.Assessment = vm;
        MarkUnsaved();
        return Task.CompletedTask;
    }

    private Task HandlePlanChanged(PlanVm vm)
    {
        _note.Plan = vm;
        MarkUnsaved();
        return Task.CompletedTask;
    }

    private Task HandleDryNeedlingChanged(DryNeedlingVm vm)
    {
        _dryNeedling = vm;
        MarkUnsaved();
        return Task.CompletedTask;
    }

    private void HandleBack()
    {
        NavigationManager.NavigateTo($"/patient/{PatientId}");
    }

    private async Task HandlePrevSection()
    {
        var previous = GetAdjacentSection(-1);
        if (previous.HasValue)
        {
            await HandleSectionChanged(previous.Value);
        }
    }

    private async Task HandleNextSection()
    {
        var next = GetAdjacentSection(1);
        if (next.HasValue)
        {
            await HandleSectionChanged(next.Value);
        }
    }

    private SoapSection? GetAdjacentSection(int direction)
    {
        var sections = Enum.GetValues<SoapSection>();
        var index = Array.IndexOf(sections, _note.ActiveSection);
        var nextIndex = index + direction;
        if (nextIndex < 0 || nextIndex >= sections.Length)
        {
            return null;
        }

        return sections[nextIndex];
    }

    private Task HandleGoalsClick()
    {
        _lastEditableSection = SoapSection.Objective;
        _note.MoveTo(SoapSection.Objective);
        return Task.CompletedTask;
    }

    private async Task HandleReviewClick()
    {
        await HandleSectionChanged(SoapSection.Review);
    }

    private Task HandleBackToEdit()
    {
        _note.MoveTo(_lastEditableSection);
        ClearStatusMessage();
        return Task.CompletedTask;
    }

    private Task HandleEditSection(SoapSection section)
    {
        _lastEditableSection = section;
        _note.MoveTo(section);
        ClearStatusMessage();
        return Task.CompletedTask;
    }

    private async Task HandleRegenerateSummaryAsync()
    {
        if (IsWorkspaceReadOnly)
        {
            return;
        }

        _isRegeneratingSummary = true;
        ClearStatusMessage();
        StateHasChanged();

        try
        {
            var result = await AiService.GeneratePlanOfCareAsync(new PlanOfCareGenerationRequest
            {
                NoteId = _note.NoteId ?? Guid.Empty,
                Diagnosis = GetDiagnosisSummary(),
                AssessmentSummary = GetAssessmentSummary(),
                Goals = GetGoalsSummary(),
                Precautions = GetPrecautionsSummary(),
                IsNoteSigned = _note.Status != NoteStatus.Draft
            });

            if (!result.Success)
            {
                SetStatusMessage(result.ErrorMessage ?? "Unable to generate a clinical summary.", "error");
                return;
            }

            _note.Plan.ClinicalSummary = result.GeneratedText;
            MarkUnsaved();
            SetStatusMessage("Clinical summary regenerated. Save the note to keep the updated summary.", "success");
        }
        finally
        {
            _isRegeneratingSummary = false;
        }
    }

    private async Task HandleRegenerateGoalsAsync()
    {
        if (IsWorkspaceReadOnly)
        {
            return;
        }

        _isRegeneratingGoals = true;
        ClearStatusMessage();
        StateHasChanged();

        try
        {
            var result = await AiService.GenerateGoalNarrativesAsync(new GoalNarrativesGenerationRequest
            {
                NoteId = _note.NoteId ?? Guid.Empty,
                Diagnosis = GetDiagnosisSummary(),
                FunctionalLimitations = GetFunctionalLimitationsSummary(),
                ShortTermGoals = GetGoalsSummary(),
                LongTermGoals = GetGoalsSummary(),
                IsNoteSigned = _note.Status != NoteStatus.Draft
            });

            if (!result.Success)
            {
                SetStatusMessage(result.ErrorMessage ?? "Unable to generate AI treatment goals.", "error");
                return;
            }

            foreach (var description in ParseGoalSuggestions(result.GeneratedText))
            {
                if (_note.Assessment.Goals.Any(goal => string.Equals(goal.Description, description, StringComparison.OrdinalIgnoreCase)))
                {
                    continue;
                }

                _note.Assessment.Goals.Add(new SmartGoalEntry
                {
                    Description = description,
                    IsAiSuggested = true,
                    IsAccepted = false,
                    Timeframe = GoalTimeframe.ShortTerm,
                    Status = GoalStatus.Active
                });
            }

            MarkUnsaved();
            SetStatusMessage("AI treatment goals regenerated. Review and accept the suggested goals before saving.", "success");
        }
        finally
        {
            _isRegeneratingGoals = false;
        }
    }

    private async Task HandleExportPdfAsync()
    {
        if (!CanExportPdf)
        {
            SetStatusMessage("Your role does not have permission to export note PDFs.", "error");
            return;
        }

        if (!_note.NoteId.HasValue)
        {
            SetStatusMessage("Save and submit the note before exporting PDF.", "error");
            return;
        }

        var result = await NoteWorkspaceService.ExportPdfAsync(_note.NoteId.Value);
        if (!result.Success)
        {
            SetStatusMessage(result.ErrorMessage ?? "Unable to export the note as PDF.", "error");
            return;
        }

        var base64 = Convert.ToBase64String(result.Content);
        await JS.InvokeVoidAsync("open", $"data:{result.ContentType};base64,{base64}", "_blank");
        SetStatusMessage("PDF export opened in a new browser tab.", "success");
    }

    private async Task HandleSaveAsync()
    {
        if (!CanSaveDraft)
        {
            if (!string.IsNullOrWhiteSpace(GetReadOnlySaveMessage()))
            {
                SetStatusMessage(GetReadOnlySaveMessage()!, "error");
            }
            return;
        }

        var saveSucceeded = DraftAutosaveService.IsDirty
            ? await DraftAutosaveService.FlushAsync()
            : await PersistDraftAsync(showFeedback: false, CancellationToken.None);

        if (saveSucceeded && _warningValidationMessages.Count == 0 && !_requiresOverride)
        {
            SetStatusMessage("Draft saved.", "success");
        }
    }

    private async Task<bool> AutosaveSaveAsync(CancellationToken cancellationToken)
    {
        return await PersistDraftAsync(showFeedback: false, cancellationToken);
    }

    private async Task<bool> PersistDraftAsync(bool showFeedback, CancellationToken cancellationToken)
    {
        if (!_patientGuid.HasValue || !CanSaveDraft)
        {
            return false;
        }

        await _persistGate.WaitAsync(cancellationToken);
        try
        {
            if (!_patientGuid.HasValue || !CanSaveDraft)
            {
                return false;
            }

            _dateOfService = ResolveDateOfService();
            _note.StartSaving();
            await InvokeAsync(StateHasChanged);

            var saveResult = await NoteWorkspaceService.SaveDraftAsync(BuildDraft(_patientGuid.Value), cancellationToken);
            ApplyValidationDetails(saveResult.Errors, saveResult.Warnings, saveResult.RequiresOverride);

            if (!saveResult.Success)
            {
                _note.MarkSaveError();
                if (showFeedback || saveResult.Errors.Count > 0 || saveResult.Warnings.Count > 0)
                {
                    SetStatusMessage(saveResult.ErrorMessage ?? "Unable to save draft right now. Please retry.", saveResult.Errors.Count > 0 ? "error" : "info");
                }

                return false;
            }

            if (saveResult.Payload is not null)
            {
                ApplyWorkspaceState(
                    saveResult.NoteId,
                    saveResult.Payload.WorkspaceNoteType,
                    _dateOfService,
                    saveResult.Status,
                    saveResult.Payload);
            }
            else
            {
                _currentNoteId = saveResult.NoteId;
                _note.NoteId = saveResult.NoteId;
                _note.Mode = NoteMode.Existing;
                _note.Status = saveResult.Status;
                _note.MarkSaved();
            }

            ApplyWorkspaceNotice();

            if (saveResult.Warnings.Count > 0)
            {
                SetStatusMessage(saveResult.ErrorMessage ?? "Draft saved with warnings.", "info");
            }
            else if (showFeedback)
            {
                SetStatusMessage("Draft saved.", "success");
            }
            else
            {
                ClearStatusMessage();
            }

            return true;
        }
        catch (OperationCanceledException)
        {
            throw;
        }
        catch (Exception ex)
        {
            _note.MarkSaveError();
            SetStatusMessage(GetUserFacingMessage(ex, "Unable to save draft right now. Please retry."), "error");
            return false;
        }
        finally
        {
            await InvokeAsync(StateHasChanged);
            _persistGate.Release();
        }
    }

    private async Task<bool> EnsureDraftPersistedAsync(bool forceIfClean = false)
    {
        if (!CanSaveDraft)
        {
            return true;
        }

        if (DraftAutosaveService.IsDirty || DraftAutosaveService.IsSaving)
        {
            return await DraftAutosaveService.FlushAsync();
        }

        if (forceIfClean || !_note.NoteId.HasValue)
        {
            return await PersistDraftAsync(showFeedback: false, CancellationToken.None);
        }

        return true;
    }

    private async Task HandleSubmitAsync()
    {
        if (!CanSubmitCurrentNote)
        {
            SetStatusMessage(GetReadOnlySubmitMessage(), "error");
            return;
        }

        if (!CanFinalizePendingCoSign)
        {
            var submitValidationMessage = ValidateForSubmit();
            if (!string.IsNullOrWhiteSpace(submitValidationMessage))
            {
                _note.MarkSaveError();
                SetStatusMessage(submitValidationMessage, "error");
                return;
            }

            var saveSucceeded = await EnsureDraftPersistedAsync(forceIfClean: true);
            if (!saveSucceeded || !_note.NoteId.HasValue)
            {
                if (!_note.NoteId.HasValue)
                {
                    SetStatusMessage("Unable to submit because the note ID is missing.", "error");
                }

                return;
            }
        }
        else if (!_note.NoteId.HasValue)
        {
            SetStatusMessage("This note must be saved before PT finalization can continue.", "error");
            return;
        }

        _consentAccepted = false;
        _intentConfirmed = false;
        _showSignatureConsent = true;
    }

    private Task HandleConsentCancelAsync()
    {
        _showSignatureConsent = false;
        _consentAccepted = false;
        _intentConfirmed = false;
        return Task.CompletedTask;
    }

    private async Task HandleConsentConfirmAsync()
    {
        if (!_consentAccepted || !_intentConfirmed || !_note.NoteId.HasValue || _isSubmittingNote)
        {
            return;
        }

        _showSignatureConsent = false;
        _isSubmittingNote = true;
        var wasPendingCoSignFinalization = CanFinalizePendingCoSign;
        ClearValidationDetails();
        ClearStatusMessage();
        StateHasChanged();

        try
        {
            var submitResult = await NoteWorkspaceService.SubmitAsync(
                _note.NoteId.Value,
                consentAccepted: _consentAccepted,
                intentConfirmed: _intentConfirmed);

            if (!submitResult.Success)
            {
                ApplyValidationFailures(submitResult.ValidationFailures);
                _note.MarkSaveError();
                SetStatusMessage(submitResult.ErrorMessage ?? "Unable to submit note.", "error");
                return;
            }

            if (_patientGuid.HasValue)
            {
                await LoadExistingNoteAsync(_patientGuid.Value, _note.NoteId.Value);
            }
            else
            {
                _note.Status = submitResult.Status;
                _note.IsDirty = false;
                _note.MarkSaved();
            }

            ApplyWorkspaceNotice();
            ClearValidationDetails();
            SetStatusMessage(
                submitResult.RequiresCoSign
                    ? "Note submitted. PT co-sign is still required before the documentation workflow is fully complete."
                    : (wasPendingCoSignFinalization
                        ? "Pending co-sign note finalized successfully."
                        : "Note submitted successfully."),
                submitResult.RequiresCoSign ? "info" : "success");
        }
        finally
        {
            _isSubmittingNote = false;
            _consentAccepted = false;
            _intentConfirmed = false;
        }
    }

    private NoteWorkspaceDraft BuildDraft(Guid patientId)
    {
        var payload = new NoteWorkspacePayload
        {
            WorkspaceNoteType = _note.NoteType,
            Subjective = _note.Subjective,
            Objective = _note.Objective,
            Assessment = _note.Assessment,
            Plan = _note.Plan,
            DryNeedling = _dryNeedling
        };

        return new NoteWorkspaceDraft
        {
            NoteId = _note.NoteId,
            PatientId = patientId,
            WorkspaceNoteType = _note.NoteType,
            DateOfService = ResolveDateOfService(),
            IsExistingNote = _note.Mode == NoteMode.Existing && _note.NoteId.HasValue,
            Payload = payload
        };
    }

    private DateTime ResolveDateOfService()
    {
        if (IsDryNeedlingNote && _dryNeedling.DateOfTreatment.HasValue)
        {
            return _dryNeedling.DateOfTreatment.Value;
        }

        return _dateOfService == default ? DateTime.UtcNow : _dateOfService;
    }

    private string? ValidateForSubmit()
    {
        if (CanFinalizePendingCoSign)
        {
            return null;
        }

        if (IsDryNeedlingNote)
        {
            if (_dryNeedling.DateOfTreatment is null)
            {
                return "Date of treatment is required before submit.";
            }

            if (string.IsNullOrWhiteSpace(_dryNeedling.Location))
            {
                return "Location of needling is required before submit.";
            }

            if (string.IsNullOrWhiteSpace(_dryNeedling.NeedlingType))
            {
                return "Type of needling is required before submit.";
            }

            return null;
        }

        if (!_note.CanSubmit(out var message))
        {
            return message;
        }

        if (IsDischargeNote)
        {
            if (string.IsNullOrWhiteSpace(_note.Plan.PrimaryDischargeReason))
            {
                return "Primary discharge reason is required before submit.";
            }

            if (string.IsNullOrWhiteSpace(_note.Plan.DischargeRecommendations))
            {
                return "Discharge recommendations are required before submit.";
            }

            if (_note.Plan.CompletedDischargeChecklistItems.Count == 0)
            {
                return "Complete at least one end-of-care checklist item before submit.";
            }
        }

        return null;
    }

    private void MarkUnsaved()
    {
        if (!CanEditCurrentDraft)
        {
            return;
        }

        ClearValidationDetails();
        ClearStatusMessage();
        _note.MarkDirty();
        DraftAutosaveService.MarkDirty();
    }

    private string GetAlertToneClass() => $"note-workspace__alert--{_statusTone}";

    private void SetStatusMessage(string message, string tone)
    {
        _statusMessage = message;
        _statusTone = tone;
    }

    private void ClearStatusMessage()
    {
        _statusMessage = null;
        _statusTone = "info";
    }

    private void ClearValidationDetails()
    {
        _blockingValidationMessages = [];
        _warningValidationMessages = [];
        _requiresOverride = false;
    }

    private void ApplyValidationDetails(IEnumerable<string>? blockingMessages, IEnumerable<string>? warningMessages, bool requiresOverride)
    {
        _blockingValidationMessages = (blockingMessages ?? [])
            .Where(message => !string.IsNullOrWhiteSpace(message))
            .Select(message => message.Trim())
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        _warningValidationMessages = (warningMessages ?? [])
            .Where(message => !string.IsNullOrWhiteSpace(message))
            .Select(message => message.Trim())
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        _requiresOverride = requiresOverride;
    }

    private void ApplyValidationFailures(IEnumerable<RuleEvaluationResult>? validationFailures)
    {
        if (validationFailures is null)
        {
            ClearValidationDetails();
            return;
        }

        _blockingValidationMessages = validationFailures
            .Where(failure => failure.Blocking || failure.Severity == ValidationSeverity.Error)
            .Select(failure => failure.Message)
            .Where(message => !string.IsNullOrWhiteSpace(message))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        _warningValidationMessages = validationFailures
            .Where(failure => !failure.Blocking && failure.Severity != ValidationSeverity.Error)
            .Select(failure => failure.Message)
            .Where(message => !string.IsNullOrWhiteSpace(message))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        _requiresOverride = false;
    }

    private string GetChiefComplaintText()
    {
        if (_note.Subjective.Problems.Count == 0)
        {
            return _note.Subjective.OtherProblem ?? string.Empty;
        }

        return string.Join(", ", _note.Subjective.Problems.OrderBy(v => v));
    }

    private string GetExaminationFindingsText()
    {
        var parts = new List<string>();

        if (!string.IsNullOrWhiteSpace(_note.Objective.PrimaryGaitPattern))
        {
            parts.Add($"Primary gait pattern: {_note.Objective.PrimaryGaitPattern}");
        }

        if (_note.Objective.GaitDeviations.Count > 0)
        {
            parts.Add($"Deviations: {string.Join(", ", _note.Objective.GaitDeviations.OrderBy(v => v))}");
        }

        if (!string.IsNullOrWhiteSpace(_note.Objective.AdditionalGaitObservations))
        {
            parts.Add(_note.Objective.AdditionalGaitObservations);
        }

        return string.Join(" | ", parts);
    }

    private async Task LoadPatientContextAsync(Guid patientId)
    {
        var patient = await PatientService.GetByIdAsync(patientId);
        if (patient is null)
        {
            return;
        }

        _note.PatientName = $"{patient.FirstName} {patient.LastName}".Trim();
        _note.PatientDob = patient.DateOfBirth.ToString("M/d/yyyy", CultureInfo.InvariantCulture);
    }

    private string GetDiagnosisSummary()
    {
        if (_note.Assessment.DiagnosisCodes.Count > 0)
        {
            return string.Join(", ", _note.Assessment.DiagnosisCodes.Select(code => $"{code.Code} {code.Description}".Trim()));
        }

        return string.IsNullOrWhiteSpace(_note.Assessment.AssessmentNarrative)
            ? "Physical therapy plan of care"
            : _note.Assessment.AssessmentNarrative;
    }

    private string GetAssessmentSummary() =>
        string.IsNullOrWhiteSpace(_note.Assessment.AssessmentNarrative)
            ? GetChiefComplaintText()
            : _note.Assessment.AssessmentNarrative;

    private string GetGoalsSummary() =>
        _note.Assessment.Goals.Count == 0
            ? string.Empty
            : string.Join("; ", _note.Assessment.Goals.Select(goal => goal.Description).Where(description => !string.IsNullOrWhiteSpace(description)));

    private string GetPrecautionsSummary() =>
        string.IsNullOrWhiteSpace(_note.Plan.FollowUpInstructions)
            ? string.Empty
            : _note.Plan.FollowUpInstructions!;

    private string GetFunctionalLimitationsSummary()
    {
        if (!string.IsNullOrWhiteSpace(_note.Assessment.FunctionalLimitations))
        {
            return _note.Assessment.FunctionalLimitations;
        }

        if (_note.Subjective.FunctionalLimitations.Count > 0)
        {
            return string.Join(", ", _note.Subjective.FunctionalLimitations.OrderBy(value => value));
        }

        return GetChiefComplaintText();
    }

    private static IReadOnlyList<string> ParseGoalSuggestions(string generatedText)
    {
        var parsed = generatedText
            .Split(['\r', '\n'], StringSplitOptions.RemoveEmptyEntries)
            .Select(line => line.Trim())
            .Select(line => line.TrimStart('-', '*', '•', ' ', '\t'))
            .Where(line => !string.IsNullOrWhiteSpace(line))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        return parsed.Count == 0 && !string.IsNullOrWhiteSpace(generatedText)
            ? [generatedText.Trim()]
            : parsed;
    }

    private static string GetGoalStatusDescription(GoalStatus status) => status switch
    {
        GoalStatus.Met => "Goal marked as met.",
        GoalStatus.Archived => "Goal archived from the active plan.",
        _ => "Goal remains active."
    };

    private bool HasDraftWritePermissionForNoteType(string noteType)
    {
        if (IsPtUser)
        {
            return true;
        }

        if (IsPtaUser)
        {
            return string.Equals(noteType, "Daily Treatment Note", StringComparison.OrdinalIgnoreCase);
        }

        return false;
    }

    private bool HasSignPermissionForNoteType(string noteType)
    {
        if (IsPtUser)
        {
            return true;
        }

        if (IsPtaUser)
        {
            return string.Equals(noteType, "Daily Treatment Note", StringComparison.OrdinalIgnoreCase);
        }

        return false;
    }

    private void ApplyWorkspaceNotice()
    {
        if (_note.Status == NoteStatus.Signed)
        {
            _workspaceNotice = "This note has been signed and is read-only.";
            return;
        }

        if (_note.Status == NoteStatus.PendingCoSign)
        {
            _workspaceNotice = IsPtUser
                ? "This note is awaiting PT finalization. Content is read-only until it is signed."
                : "This note is awaiting PT co-sign and is read-only.";
            return;
        }

        if (IsBillingUser || IsOwnerUser)
        {
            _workspaceNotice = "Your role has read-only access to clinical notes.";
            return;
        }

        if (IsAdminUser)
        {
            _workspaceNotice = "Admin access is read-only for note content. PDF export remains available.";
            return;
        }

        if (IsPtaUser && !IsDailyTreatment)
        {
            _workspaceNotice = "PTA users can only edit and sign daily treatment notes.";
            return;
        }

        _workspaceNotice = null;
    }

    private string? GetReadOnlySaveMessage()
    {
        if (_note.Status == NoteStatus.Signed)
        {
            return "Signed notes cannot be edited.";
        }

        if (_note.Status == NoteStatus.PendingCoSign)
        {
            return "Pending co-sign notes are read-only.";
        }

        if (IsPtaUser && !IsDailyTreatment)
        {
            return "PTA users can only save daily treatment notes.";
        }

        if (IsAdminUser || IsOwnerUser || IsBillingUser)
        {
            return "Your role does not have permission to edit note content.";
        }

        return "This note cannot be edited right now.";
    }

    private string GetReadOnlySubmitMessage()
    {
        if (_note.Status == NoteStatus.Signed)
        {
            return "This note has already been signed.";
        }

        if (_note.Status == NoteStatus.PendingCoSign && !IsPtUser)
        {
            return "This note is awaiting PT co-sign and cannot be finalized by your role.";
        }

        if (IsPtaUser && !IsDailyTreatment)
        {
            return "PTA users can only sign daily treatment notes.";
        }

        if (IsAdminUser || IsOwnerUser || IsBillingUser)
        {
            return "Your role does not have permission to sign notes.";
        }

        return "This note cannot be submitted from the current state.";
    }

    private void HandleAutosaveStateChanged()
    {
        _note.IsDirty = DraftAutosaveService.IsDirty;

        if (DraftAutosaveService.IsSaving)
        {
            _note.SaveState = NoteSaveState.Saving;
        }
        else if (!string.IsNullOrWhiteSpace(DraftAutosaveService.LastErrorMessage))
        {
            _note.SaveState = NoteSaveState.Error;
        }
        else if (DraftAutosaveService.IsDirty)
        {
            _note.SaveState = NoteSaveState.Unsaved;
        }
        else if (DraftAutosaveService.LastSavedAt.HasValue)
        {
            _note.SaveState = NoteSaveState.Saved;
        }

        _ = InvokeAsync(StateHasChanged);
    }

    private async ValueTask OnLocationChangingAsync(LocationChangingContext context)
    {
        if (_allowedNavigationTarget is not null &&
            string.Equals(_allowedNavigationTarget, context.TargetLocation, StringComparison.OrdinalIgnoreCase))
        {
            _allowedNavigationTarget = null;
            return;
        }

        if (!CanSaveDraft || (!DraftAutosaveService.IsDirty && !DraftAutosaveService.IsSaving))
        {
            return;
        }

        context.PreventNavigation();

        var saved = await EnsureDraftPersistedAsync();
        if (!saved)
        {
            SetStatusMessage("Unable to save the draft before leaving this page. Resolve the error and try again.", "error");
            await InvokeAsync(StateHasChanged);
            return;
        }

        _allowedNavigationTarget = context.TargetLocation;
        await InvokeAsync(() => NavigationManager.NavigateTo(context.TargetLocation));
    }

    private static string GetUserFacingMessage(Exception exception, string fallback)
    {
        if (exception is HttpRequestException httpException)
        {
            if (!string.IsNullOrWhiteSpace(httpException.Message) &&
                !httpException.Message.StartsWith("Response status code", StringComparison.OrdinalIgnoreCase))
            {
                return httpException.Message;
            }
        }

        return fallback;
    }

    public async ValueTask DisposeAsync()
    {
        if (_disposed)
        {
            return;
        }

        _disposed = true;
        _navGuard?.Dispose();
        DraftAutosaveService.StateChanged -= HandleAutosaveStateChanged;

        try
        {
            if (CanSaveDraft && (DraftAutosaveService.IsDirty || DraftAutosaveService.IsSaving))
            {
                await EnsureDraftPersistedAsync();
            }
        }
        catch
        {
        }

        await DraftAutosaveService.DisposeAsync();
        _persistGate.Dispose();
    }
}
