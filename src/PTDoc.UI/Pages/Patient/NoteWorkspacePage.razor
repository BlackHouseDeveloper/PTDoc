        AddAiInput(inputs, "Patient personal goals", _note.Assessment.PatientPersonalGoals, selectedBodyPart);
        AddAiInput(inputs, "Recovery barriers", JoinValues(_note.Assessment.BarriersToRecovery), selectedBodyPart);
        AddAiInput(inputs, "Overall prognosis", _note.Assessment.OverallPrognosis, selectedBodyPart);
        AddAiInput(inputs, "Treatment frequency", _note.Plan.TreatmentFrequency, selectedBodyPart);
        AddAiInput(inputs, "Treatment duration", _note.Plan.TreatmentDuration, selectedBodyPart);
