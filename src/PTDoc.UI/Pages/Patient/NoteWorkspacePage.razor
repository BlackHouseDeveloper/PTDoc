@page "/patient/{PatientId}/note/{NoteId}"
@page "/patient/{PatientId}/notes/{NoteId}"
@page "/patient/{PatientId}/new-note"
@attribute [Authorize(Policy = AuthorizationPolicies.NoteRead)]
@rendermode InteractiveServer
@implements IAsyncDisposable

@using System.Globalization
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Routing
@using PTDoc.Application.AI
@using PTDoc.Application.Compliance
@using PTDoc.Application.Notes.Workspace
@using PTDoc.Application.Services
@using PTDoc.Core.Models
@using PTDoc.UI.Components.Notes
@using PTDoc.UI.Components.Notes.Models
@using PTDoc.UI.Components.Notes.Workspace
@using PTDoc.UI.Components.Notes.Workspace.DailyTreatment
@using PTDoc.UI.Components.Notes.Workspace.DischargeNote
@using PTDoc.UI.Components.Notes.Workspace.DryNeedling
@using PTDoc.UI.Components.Notes.Workspace.ProgressNote
@using PTDoc.UI.Services

@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject INoteWorkspaceService NoteWorkspaceService
@inject IPatientService PatientService
@inject IAiClinicalGenerationService AiService
@inject DraftAutosaveService DraftAutosaveService
@inject IJSRuntime JS

<PageTitle>SOAP Workspace - PTDoc</PageTitle>

@if (_isInitialLoading)
{
    <section class="note-workspace note-workspace__state" role="status" aria-live="polite" data-testid="note-workspace-loading">
        <div class="note-workspace__state-card">
            <h2>Loading note workspace…</h2>
            <p>Fetching the patient and note details from the API.</p>
        </div>
    </section>
}
else if (!string.IsNullOrWhiteSpace(_initialLoadError))
{
    <section class="note-workspace note-workspace__state" data-testid="note-workspace-load-error">
        <div class="note-workspace__state-card note-workspace__state-card--error" role="alert">
            <h2>Unable to load note workspace</h2>
            <p>@_initialLoadError</p>
            <div class="note-workspace__state-actions">
                <button type="button" class="btn btn--primary" @onclick="HandleReloadAsync">Retry</button>
                <button type="button" class="btn btn--secondary" @onclick="HandleBack">Back to Patient</button>
            </div>
        </div>
    </section>
}
else
{
    <div class="note-workspace" data-testid="note-workspace-page">
        @{
            var subjectiveSeedChips = GetSubjectiveSeedChips();
            var objectiveSeedChips = GetObjectiveSeedChips();
        }

        @if (!string.IsNullOrWhiteSpace(_workspaceNotice))
        {
            <div class="note-workspace__alert note-workspace__alert--info" role="status" data-testid="note-workspace-notice">
                @_workspaceNotice
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(_statusMessage))
        {
            <div class="note-workspace__alert @GetAlertToneClass()" role="alert" data-testid="note-workspace-alert">
                @_statusMessage
            </div>
        }

        @if (_blockingValidationMessages.Count > 0)
        {
            <div class="note-workspace__alert note-workspace__alert--error" role="alert" data-testid="note-workspace-blocking-errors">
                <strong>Blocking errors</strong>
                <ul class="note-workspace__alert-list">
                    @foreach (var message in _blockingValidationMessages)
                    {
                        <li>@message</li>
                    }
                </ul>
            </div>
        }

        @if (_warningValidationMessages.Count > 0)
        {
            <div class="note-workspace__alert note-workspace__alert--info" role="status" data-testid="note-workspace-warnings">
                <strong>Warnings</strong>
                <ul class="note-workspace__alert-list">
                    @foreach (var message in _warningValidationMessages)
                    {
                        <li>@message</li>
                    }
                </ul>
            </div>
        }

        @if (_requiresOverride)
        {
            <section class="note-workspace__override-panel"
                     role="status"
                     aria-live="polite"
                     data-testid="note-workspace-override-panel">
                <div class="note-workspace__override-header">
                    <div class="note-workspace__override-copy">
                        <h2 class="note-workspace__override-title">PT Compliance Override Required</h2>
                        <p class="note-workspace__override-text">@GetOverrideSummaryText()</p>
                    </div>

                    @if (_overrideRuleType.HasValue)
                    {
                        <span class="note-workspace__seed-badge note-workspace__seed-badge--locked"
                              data-testid="note-workspace-override-rule">
                            Rule: @GetComplianceRuleDisplayLabel(_overrideRuleType.Value)
                        </span>
                    }
                </div>

                @if (_overrideRequirements.Count > 0)
                {
                    <ul class="note-workspace__override-list">
                        @foreach (var requirement in _overrideRequirements)
                        {
                            <li>@requirement.Message</li>
                        }
                    </ul>
                }

                @if (!string.IsNullOrWhiteSpace(GetOverrideAttestationText()))
                {
                    <p class="note-workspace__override-attestation" data-testid="note-workspace-override-attestation">
                        @GetOverrideAttestationText()
                    </p>
                }

                @if (CanCurrentUserApplyOverride)
                {
                    <div class="note-workspace__override-form">
                        <label class="note-workspace__override-label" for="note-workspace-override-reason">
                            PT justification
                        </label>
                        <textarea id="note-workspace-override-reason"
                                  class="note-workspace__override-textarea"
                                  @bind="_overrideReason"
                                  @bind:event="oninput"
                                  maxlength="1000"
                                  data-testid="note-workspace-override-reason"></textarea>
                        <p class="note-workspace__override-help">
                            Document the clinical justification for proceeding with this draft despite the compliance warning.
                        </p>
                        <div class="note-workspace__override-actions">
                            <button type="button"
                                    class="btn btn--primary"
                                    disabled="@(!CanApplyOverrideSubmission)"
                                    @onclick="HandleOverrideSaveAsync"
                                    data-testid="note-workspace-override-save">
                                Apply PT Override and Save
                            </button>
                        </div>
                    </div>
                }
                else
                {
                    <p class="note-workspace__override-help note-workspace__override-help--readonly"
                       data-testid="note-workspace-override-readonly">
                        @GetOverrideReadonlyMessage()
                    </p>
                }
            </section>
        }

        @if (!string.IsNullOrWhiteSpace(DraftAutosaveService.LastErrorMessage))
        {
            <div class="note-workspace__alert note-workspace__alert--error" role="alert" data-testid="note-workspace-autosave-error">
                Autosave failed: @DraftAutosaveService.LastErrorMessage
            </div>
        }

        @if (ShouldShowSeedSummary(subjectiveSeedChips, objectiveSeedChips))
        {
            <section class="note-workspace__seed-summary" data-testid="note-workspace-seed-summary" aria-label="Prefilled structured context">
                <div class="note-workspace__seed-summary-header">
                    <div class="note-workspace__seed-summary-copy">
                        <h2 class="note-workspace__seed-summary-title">Prefilled Structured Context</h2>
                        <p class="note-workspace__seed-summary-text">@GetSeedSummaryText()</p>
                    </div>

                    <div class="note-workspace__seed-summary-badges">
                        <span class="note-workspace__seed-badge note-workspace__seed-badge--source" data-testid="note-workspace-seed-source">
                            @GetSeedSourceBadgeText()
                        </span>
                        <span class="@GetSeedStateBadgeClass()" data-testid="note-workspace-seed-state">
                            @GetSeedStateBadgeText()
                        </span>
                    </div>
                </div>

                @if (subjectiveSeedChips.Count > 0)
                {
                    <div class="note-workspace__seed-group" data-testid="note-workspace-seed-subjective">
                        <div class="note-workspace__seed-group-label">Subjective</div>
                        <div class="note-workspace__seed-chip-list">
                            @foreach (var chip in subjectiveSeedChips)
                            {
                                <span class="note-workspace__seed-chip">@chip</span>
                            }
                        </div>
                    </div>
                }

                @if (objectiveSeedChips.Count > 0)
                {
                    <div class="note-workspace__seed-group" data-testid="note-workspace-seed-objective">
                        <div class="note-workspace__seed-group-label">Objective</div>
                        <div class="note-workspace__seed-chip-list">
                            @foreach (var chip in objectiveSeedChips)
                            {
                                <span class="note-workspace__seed-chip">@chip</span>
                            }
                        </div>
                    </div>
                }
            </section>
        }

        @if (IsDryNeedlingNote)
        {
            <PatientContextHeader PatientName="@DisplayPatientName" PatientDob="@_note.PatientDob" />

            <DryNeedlingNoteView IsReadOnly="@IsWorkspaceReadOnly"
                                 DisableSave="@DisableSaveAction"
                                 DisableSubmit="@DisableSubmitAction"
                                 AllowSubmitWhenReadOnly="@CanSubmitCurrentNote"
                                 Vm="@_dryNeedling"
                                 VmChanged="HandleDryNeedlingChanged"
                                 OnSave="HandleSaveAsync"
                                 OnSubmit="HandleSubmitAsync" />
        }
        else
        {
            @if (!IsReviewSection)
            {
                <PatientContextHeader PatientName="@DisplayPatientName" PatientDob="@_note.PatientDob" />

                <NoteTypeContainer NoteType="@_note.NoteType"
                                   NoteTypeChanged="HandleNoteTypeChanged"
                                   NoteTypes="@AvailableNoteTypes"
                                   Disabled="@(IsWorkspaceReadOnly || AvailableNoteTypes.Count <= 1)" />
            }

            <SoapTabNav ActiveSection="@_note.ActiveSection"
                        IsReadOnly="@IsWorkspaceReadOnly"
                        ActiveSectionChanged="HandleSectionChanged" />

            <div id="soap-tab-panel" class="note-workspace__panel" role="tabpanel" aria-live="polite">
                @switch (_note.ActiveSection)
                {
                    case SoapSection.Subjective:
                        if (IsProgressNote)
                        {
                            <ProgressSubjectiveSection Vm="@_note.Subjective"
                                                      VmChanged="HandleSubjectiveChanged"
                                                      IsReadOnly="@IsWorkspaceReadOnly" />
                        }
                        else if (IsDailyTreatment || IsDischargeNote)
                        {
                            <SubjectiveSection Vm="@_note.Subjective"
                                               VmChanged="HandleSubjectiveChanged"
                                               IsReadOnly="@IsWorkspaceReadOnly"
                                               IsDarkMode="@_isDarkMode" />
                        }
                        else
                        {
                            <SubjectiveTab Vm="@_note.Subjective"
                                           VmChanged="HandleSubjectiveChanged"
                                           IsReadOnly="@IsWorkspaceReadOnly" />
                        }
                        break;

                    case SoapSection.Objective:
                        if (IsDailyTreatment || IsProgressNote)
                        {
                            <BaselineComparisonCard IsDarkMode="@_isDarkMode" />
                        }
                        <ObjectiveTab Vm="@_note.Objective"
                                      VmChanged="HandleObjectiveChanged"
                                      IsReadOnly="@IsWorkspaceReadOnly"
                                      PatientId="@PatientId"
                                      GoalCount="@GoalCount"
                                      GoalProgressPercent="@GoalsMetPercent"
                                      ShortTermGoalCount="@ShortTermGoalCount"
                                      LongTermGoalCount="@LongTermGoalCount"
                                      GoalItems="@GoalItems"
                                      GoalHints="@GoalHints" />
                        break;

                    case SoapSection.Assessment:
                        if (IsDailyTreatment || IsProgressNote)
                        {
                            <AssessmentSection Vm="@_note.Assessment"
                                               VmChanged="HandleAssessmentChanged"
                                               IsReadOnly="@IsWorkspaceReadOnly"
                                               IsDarkMode="@_isDarkMode"
                                               NoteId="@(_note.NoteId ?? Guid.Empty)"
                                               ChiefComplaint="@GetChiefComplaintText()"
                                               ExaminationFindings="@GetExaminationFindingsText()" />
                        }
                        else if (IsDischargeNote)
                        {
                            <FinalOutcomesSummaryCard />
                            <GoalAchievementSummaryCard />
                            <AssessmentWorkspaceSection NoteId="@(_note.NoteId ?? Guid.Empty)"
                                                        Vm="@_note.Assessment"
                                                        VmChanged="HandleAssessmentChanged"
                                                        IsReadOnly="@IsWorkspaceReadOnly"
                                                        ShowSmartGoals="false"
                                                        ChiefComplaint="@GetChiefComplaintText()"
                                                        ExaminationFindings="@GetExaminationFindingsText()" />
                        }
                        else
                        {
                            <AssessmentWorkspaceSection NoteId="@(_note.NoteId ?? Guid.Empty)"
                                                        Vm="@_note.Assessment"
                                                        VmChanged="HandleAssessmentChanged"
                                                        IsReadOnly="@IsWorkspaceReadOnly"
                                                        ChiefComplaint="@GetChiefComplaintText()"
                                                        ExaminationFindings="@GetExaminationFindingsText()" />
                        }
                        break;

                    case SoapSection.Plan:
                        if (IsDailyTreatment)
                        {
                            <PlanSection Vm="@_note.Plan"
                                         VmChanged="HandlePlanChanged"
                                         IsReadOnly="@IsWorkspaceReadOnly"
                                         IsDarkMode="@_isDarkMode"
                                         NoteId="@(_note.NoteId ?? Guid.Empty)"
                                         DiagnosisSummary="@GetDiagnosisSummary()"
                                         AssessmentSummary="@GetAssessmentSummary()"
                                         GoalsSummary="@GetGoalsSummary()"
                                         PrecautionsSummary="@GetPrecautionsSummary()" />
                        }
                        else if (IsDischargeNote)
                        {
                            <DischargePlanSection Vm="@_note.Plan"
                                                  VmChanged="HandlePlanChanged"
                                                  IsReadOnly="@IsWorkspaceReadOnly" />
                        }
                        else
                        {
                            <PlanTab NoteId="@(_note.NoteId ?? Guid.Empty)"
                                     Vm="@_note.Plan"
                                     VmChanged="HandlePlanChanged"
                                     IsReadOnly="@IsWorkspaceReadOnly"
                                     SelectedBodyPart="@GetSelectedBodyPart()"
                                     DiagnosisSummary="@GetDiagnosisSummary()"
                                     AssessmentSummary="@GetAssessmentSummary()"
                                     GoalsSummary="@GetGoalsSummary()"
                                     PrecautionsSummary="@GetPrecautionsSummary()" />
                        }
                        break;

                    case SoapSection.Review:
                        <SoapReviewPage Note="@_note"
                                        DateOfService="@_dateOfService"
                                        IsReadOnly="@IsWorkspaceReadOnly"
                                        IsRegeneratingSummary="@_isRegeneratingSummary"
                                        IsRegeneratingGoals="@_isRegeneratingGoals"
                                        IsSubmitting="@_isSubmittingNote"
                                        CanSubmit="@CanSubmitCurrentNote"
                                        CanExportPdf="@CanExportPdf"
                                        OnEditSection="HandleEditSection"
                                        OnBackToEdit="HandleBackToEdit"
                                        OnRegenerateSummary="HandleRegenerateSummaryAsync"
                                        OnRegenerateGoals="HandleRegenerateGoalsAsync"
                                        OnExportPdf="HandleExportPdfAsync"
                                        OnSubmit="HandleSubmitAsync" />
                        break;
                }
            </div>

            @if (!IsReviewSection)
            {
                <SoapStickyFooter NoteType="@_note.NoteType"
                                  ActiveSection="@_note.ActiveSection"
                                  SaveState="@_note.SaveState"
                                  IsReadOnly="@IsWorkspaceReadOnly"
                                  DisableSave="@DisableSaveAction"
                                  DisableSubmit="@DisableSubmitAction"
                                  AllowSubmitWhenReadOnly="@CanSubmitCurrentNote"
                                  OnBack="HandleBack"
                                  OnPrevSection="HandlePrevSection"
                                  OnNextSection="HandleNextSection"
                                  OnGoalsClick="HandleGoalsClick"
                                  OnReviewClick="HandleReviewClick"
                                  OnSave="HandleSaveAsync"
                                  OnSubmit="HandleSubmitAsync" />
            }
        }
    </div>
}

@if (_showSignatureConsent)
{
    <div class="signature-consent-overlay" role="dialog" aria-modal="true" aria-labelledby="sig-consent-title" data-testid="signature-consent-dialog">
        <div class="signature-consent-dialog">
            <h2 id="sig-consent-title" class="signature-consent-dialog__title">Electronic Signature — Consent &amp; Intent</h2>
            <p class="signature-consent-dialog__body">
                By signing this clinical note electronically you attest that the documentation and billing
                accurately reflect medically necessary services rendered and that the recorded time and units
                are correct to the best of your knowledge.
            </p>
            <label class="signature-consent-dialog__checkbox-label">
                <input type="checkbox" @bind="_consentAccepted" data-testid="sig-consent-checkbox" />
                I consent to the use of an electronic signature and understand it carries the same legal
                weight as a handwritten signature.
            </label>
            <label class="signature-consent-dialog__checkbox-label">
                <input type="checkbox" @bind="_intentConfirmed" data-testid="sig-intent-checkbox" />
                I confirm my intent to sign this clinical note.
            </label>
            <div class="signature-consent-dialog__actions">
                <button class="btn btn--secondary"
                        @onclick="HandleConsentCancelAsync"
                        data-testid="sig-consent-cancel">Cancel</button>
                <button class="btn btn--primary"
                        disabled="@(!_consentAccepted || !_intentConfirmed || _isSubmittingNote)"
                        @onclick="HandleConsentConfirmAsync"
                        data-testid="sig-consent-confirm">Sign Note</button>
            </div>
        </div>
    </div>
}

@code {
    [SupplyParameterFromQuery(Name = "section")] public string? RequestedSection { get; set; }
    [SupplyParameterFromQuery(Name = "noteType")] public string? RequestedNoteType { get; set; }

    [Parameter, EditorRequired] public string PatientId { get; set; } = string.Empty;
    [Parameter] public string? NoteId { get; set; }

    private readonly string[] _allNoteTypes =
    [
        "Evaluation Note",
        "Progress Note",
        "Discharge Note",
        "Dry Needling Note",
        "Daily Treatment Note"
    ];

    private readonly SemaphoreSlim _persistGate = new(1, 1);

    private SoapNoteVm _note = new();
    private DryNeedlingVm _dryNeedling = new();
    private ClaimsPrincipal _user = new(new ClaimsIdentity());
    private Guid _currentNoteId;
    private Guid? _patientGuid;
    private string? _initialLoadError;
    private string? _workspaceNotice;
    private string? _statusMessage;
    private string _statusTone = "info";
    private DateTime _dateOfService = DateTime.UtcNow;
    private bool _isDarkMode;
    private bool _isRegeneratingSummary;
    private bool _isRegeneratingGoals;
    private bool _isInitialLoading = true;
    private bool _isSubmittingNote;
    private SoapSection _lastEditableSection = SoapSection.Plan;
    private bool _showSignatureConsent;
    private bool _consentAccepted;
    private bool _intentConfirmed;
    private bool _hasAppliedEvaluationSeed;
    private bool _hasAttemptedEvaluationSeed;
    private HashSet<string> _attemptedCarryForwardSeedNoteTypes = new(StringComparer.OrdinalIgnoreCase);
    private string? _allowedNavigationTarget;
    private IDisposable? _navGuard;
    private bool _disposed;
    private List<string> _blockingValidationMessages = [];
    private List<string> _warningValidationMessages = [];
    private bool _requiresOverride;
    private ComplianceRuleType? _overrideRuleType;
    private bool _isOverridable;
    private List<OverrideRequirement> _overrideRequirements = [];
    private string _overrideReason = string.Empty;

    private bool IsDailyTreatment => string.Equals(_note.NoteType, "Daily Treatment Note", StringComparison.OrdinalIgnoreCase);
    private bool IsProgressNote => string.Equals(_note.NoteType, "Progress Note", StringComparison.OrdinalIgnoreCase);
    private bool IsDischargeNote => string.Equals(_note.NoteType, "Discharge Note", StringComparison.OrdinalIgnoreCase);
    private bool IsDryNeedlingNote => string.Equals(_note.NoteType, "Dry Needling Note", StringComparison.OrdinalIgnoreCase);
    private bool IsReviewSection => _note.ActiveSection == SoapSection.Review;

    private bool IsPtUser => _user.IsInRole(Roles.PT);
    private bool IsPtaUser => _user.IsInRole(Roles.PTA);
    private bool IsAdminUser => _user.IsInRole(Roles.Admin);
    private bool IsOwnerUser => _user.IsInRole(Roles.Owner);
    private bool IsBillingUser => _user.IsInRole(Roles.Billing);

    private string DisplayPatientName => string.IsNullOrWhiteSpace(_note.PatientName) ? "Unknown Patient" : _note.PatientName;

    private IReadOnlyList<string> AvailableNoteTypes
    {
        get
        {
            var baseTypes = IsPtaUser
                ? new[] { "Daily Treatment Note" }
                : _allNoteTypes;

            if (string.IsNullOrWhiteSpace(_note.NoteType) ||
                baseTypes.Any(type => string.Equals(type, _note.NoteType, StringComparison.OrdinalIgnoreCase)))
            {
                return baseTypes;
            }

            return [_note.NoteType, .. baseTypes];
        }
    }

    private IReadOnlyList<SmartGoalEntry> VisibleGoals => _note.Assessment.Goals
        .Where(goal => !string.IsNullOrWhiteSpace(goal.Description) && (!goal.IsAiSuggested || goal.IsAccepted))
        .OrderBy(goal => goal.Timeframe)
        .ThenBy(goal => goal.Description, StringComparer.OrdinalIgnoreCase)
        .ToList();

    private IReadOnlyList<PatientGoalItem> GoalItems => VisibleGoals
        .Select(goal => new PatientGoalItem
        {
            Name = goal.Description.Trim(),
            Type = goal.Timeframe == GoalTimeframe.LongTerm ? "LT" : "ST",
            Category = goal.Category ?? string.Empty,
            Timeline = goal.Timeframe == GoalTimeframe.LongTerm ? "Long-term goal" : "Short-term goal",
            ProgressPercent = goal.Status == GoalStatus.Met ? 100 : 0,
            TargetDescription = GetGoalStatusDescription(goal.Status),
            Timeframe = goal.Timeframe,
            Status = goal.Status,
            HasQuantitativeProgress = goal.Status == GoalStatus.Met
        })
        .ToList();

    private IReadOnlyList<string> GoalHints => GoalCount == 0
        ? Array.Empty<string>()
        : new[]
        {
            "Compare today’s objective findings against the tracked goals.",
            "Update goal status when the patient has clearly met or deferred a target.",
            "Document measurable changes that support your assessment and plan."
        };

    private int GoalCount => GoalItems.Count;
    private int GoalsMetPercent => GoalCount == 0 ? 0 : (int)Math.Round((double)GoalItems.Count(goal => goal.Status == GoalStatus.Met) / GoalCount * 100);
    private int ShortTermGoalCount => GoalItems.Count(goal => goal.Timeframe == GoalTimeframe.ShortTerm);
    private int LongTermGoalCount => GoalItems.Count(goal => goal.Timeframe == GoalTimeframe.LongTerm);
    private WorkspaceSeedContextV2? CurrentSeedContext => _note.StructuredWorkspacePayload?.SeedContext is { Kind: not WorkspaceSeedKind.None } context
        ? context
        : null;

    private bool IsWorkspaceReadOnly => !CanEditCurrentDraft;
    private bool CanEditCurrentDraft => _note.Status == NoteStatus.Draft && HasDraftWritePermissionForNoteType(_note.NoteType);
    private bool CanFinalizePendingCoSign => _note.Status == NoteStatus.PendingCoSign && IsPtUser;
    private bool CanSubmitCurrentNote => !_isInitialLoading && !_isSubmittingNote && (CanSignDraftNote || CanFinalizePendingCoSign);
    private bool CanSignDraftNote => _note.Status == NoteStatus.Draft && HasSignPermissionForNoteType(_note.NoteType);
    private bool CanSaveDraft => !_isInitialLoading && !_isSubmittingNote && CanEditCurrentDraft && _patientGuid.HasValue;
    private bool CanCurrentUserApplyOverride => CanSaveDraft && IsPtUser && _requiresOverride && _isOverridable && _overrideRuleType.HasValue;
    private bool CanApplyOverrideSubmission =>
        CanCurrentUserApplyOverride &&
        !DraftAutosaveService.IsSaving &&
        !string.IsNullOrWhiteSpace(_overrideReason);
    private bool DisableSaveAction => !CanSaveDraft || DraftAutosaveService.IsSaving;
    private bool DisableSubmitAction => !CanSubmitCurrentNote || DraftAutosaveService.IsSaving;
    private bool CanExportPdf => IsPtUser || IsPtaUser || IsAdminUser;

    protected override async Task OnInitializedAsync()
    {
        _navGuard = NavigationManager.RegisterLocationChangingHandler(OnLocationChangingAsync);
        DraftAutosaveService.StateChanged += HandleAutosaveStateChanged;
        DraftAutosaveService.Configure(AutosaveSaveAsync, () => CanSaveDraft);

        await LoadWorkspaceAsync();
    }

    private async Task LoadWorkspaceAsync()
    {
        _isInitialLoading = true;
        _initialLoadError = null;
        _workspaceNotice = null;
        ClearValidationDetails();
        ClearStatusMessage();
        DraftAutosaveService.Reset();
        StateHasChanged();

        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            _user = authState.User;

            var routeNoteId = ResolveRouteNoteId(NoteId);
            _currentNoteId = routeNoteId ?? Guid.Empty;
            _patientGuid = Guid.TryParse(PatientId, out var parsedPatientId) ? parsedPatientId : null;

            if (!_patientGuid.HasValue)
            {
                _initialLoadError = "A valid patient identifier is required to open this workspace.";
                return;
            }

            InitializeNote(routeNoteId);
            await LoadPatientContextAsync(_patientGuid.Value);

            if (routeNoteId.HasValue)
            {
                await LoadExistingNoteAsync(_patientGuid.Value, routeNoteId.Value);
            }
            else
            {
                var autoStartedEvaluation = await TryStartSeededEvaluationNoteAsync();
                if (!autoStartedEvaluation)
                {
                    if (IsEvaluationNoteType(_note.NoteType))
                    {
                        await TryApplyEvaluationSeedAsync(showMissingNotice: false);
                    }
                    else
                    {
                        await TryApplyCarryForwardSeedAsync(_note.NoteType, showMissingNotice: false);
                    }
                }
            }

            ApplyWorkspaceNotice();
            ApplyRequestedSection();
        }
        catch (HttpRequestException ex)
        {
            _initialLoadError = GetUserFacingMessage(ex, "The note workspace could not be loaded right now.");
        }
        catch (Exception ex)
        {
            _initialLoadError = GetUserFacingMessage(ex, "The note workspace could not be loaded right now.");
        }
        finally
        {
            _isInitialLoading = false;
            StateHasChanged();
        }
    }

    private void InitializeNote(Guid? routeNoteId)
    {
        _note = new SoapNoteVm
        {
            NoteId = routeNoteId,
            PatientId = PatientId,
            PatientName = string.Empty,
            PatientDob = null,
            NoteType = ResolveInitialNoteType(),
            Mode = routeNoteId.HasValue ? NoteMode.Existing : NoteMode.New,
            ActiveSection = SoapSection.Subjective,
            SaveState = NoteSaveState.Unsaved,
            Status = NoteStatus.Draft,
            IsDirty = false
        };

        _dryNeedling = new DryNeedlingVm();
        _dateOfService = DateTime.UtcNow;
        _isDarkMode = false;
        _lastEditableSection = SoapSection.Plan;
        _hasAppliedEvaluationSeed = false;
        _hasAttemptedEvaluationSeed = false;
        _attemptedCarryForwardSeedNoteTypes = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
    }

    private string ResolveInitialNoteType()
    {
        if (TryResolveRequestedNoteType(out var requestedNoteType))
        {
            return requestedNoteType;
        }

        return GetDefaultNoteType();
    }

    private string GetDefaultNoteType() => IsPtaUser ? "Daily Treatment Note" : "Progress Note";

    private async Task LoadExistingNoteAsync(Guid patientId, Guid noteId)
    {
        var result = await NoteWorkspaceService.LoadAsync(patientId, noteId);
        if (!result.Success)
        {
            throw new HttpRequestException(result.ErrorMessage ?? "Unable to load note data.");
        }

        ApplyWorkspaceState(result.NoteId, result.WorkspaceNoteType, result.DateOfService, result.Status, result.Payload);
    }

    private void ApplyWorkspaceState(
        Guid noteId,
        string workspaceNoteType,
        DateTime dateOfService,
        NoteStatus status,
        NoteWorkspacePayload? payload)
    {
        _currentNoteId = noteId;
        _note.NoteId = noteId;
        _note.Mode = NoteMode.Existing;
        _note.NoteType = string.IsNullOrWhiteSpace(workspaceNoteType) ? _note.NoteType : workspaceNoteType;
        _note.Subjective = payload?.Subjective ?? new SubjectiveVm();
        _note.Objective = payload?.Objective ?? new ObjectiveVm();
        _note.Assessment = payload?.Assessment ?? new AssessmentWorkspaceVm();
        _note.Plan = payload?.Plan ?? new PlanVm();
        _note.StructuredWorkspacePayload = payload?.StructuredPayload;
        _dryNeedling = payload?.DryNeedling ?? new DryNeedlingVm();
        _note.Status = status;
        _note.IsDirty = false;
        _note.MarkSaved();
        _dateOfService = dateOfService == default ? DateTime.UtcNow : dateOfService;
        DraftAutosaveService.Reset();
        ClearValidationDetails();
    }

    private async Task HandleReloadAsync()
    {
        await LoadWorkspaceAsync();
    }

    private void ApplyRequestedSection()
    {
        var requestedSection = ResolveRequestedSection(RequestedSection);
        if (!requestedSection.HasValue || requestedSection.Value == _note.ActiveSection)
        {
            return;
        }

        if (requestedSection == SoapSection.Review && _note.ActiveSection != SoapSection.Review)
        {
            _lastEditableSection = _note.ActiveSection;
        }
        else if (requestedSection != SoapSection.Review)
        {
            _lastEditableSection = requestedSection.Value;
        }

        _note.MoveTo(requestedSection.Value);
    }

    private static Guid? ResolveRouteNoteId(string? routeNoteId)
    {
        if (!string.IsNullOrWhiteSpace(routeNoteId) && Guid.TryParse(routeNoteId, out var parsed))
        {
            return parsed;
        }

        return null;
    }

    private static SoapSection? ResolveRequestedSection(string? value) => value?.Trim().ToLowerInvariant() switch
    {
        "subjective" => SoapSection.Subjective,
        "objective" => SoapSection.Objective,
        "assessment" => SoapSection.Assessment,
        "plan" => SoapSection.Plan,
        "review" => SoapSection.Review,
        _ => null
    };

    private async Task HandleSectionChanged(SoapSection next)
    {
        if (next == SoapSection.Review && !await EnsureDraftPersistedAsync(forceIfClean: !_note.NoteId.HasValue))
        {
            return;
        }

        if (next == SoapSection.Review)
        {
            if (_note.ActiveSection != SoapSection.Review)
            {
                _lastEditableSection = _note.ActiveSection;
            }
        }
        else
        {
            _lastEditableSection = next;
        }

        _note.MoveTo(next);
        ClearStatusMessage();
    }

    private async Task HandleNoteTypeChanged(string value)
    {
        if (!CanEditCurrentDraft)
        {
            return;
        }

        if (string.Equals(_note.NoteType, value, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        var shouldTryEvaluationSeed = _note.Mode == NoteMode.New
            && !_note.NoteId.HasValue
            && !_note.IsDirty
            && !_hasAppliedEvaluationSeed
            && !_hasAttemptedEvaluationSeed
            && !IsEvaluationNoteType(_note.NoteType)
            && IsEvaluationNoteType(value);

        var shouldTryCarryForwardSeed = _note.Mode == NoteMode.New
            && !_note.NoteId.HasValue
            && !_note.IsDirty
            && !IsEvaluationNoteType(value)
            && !_attemptedCarryForwardSeedNoteTypes.Contains(value);

        _note.NoteType = value;

        if (shouldTryEvaluationSeed)
        {
            await TryApplyEvaluationSeedAsync(showMissingNotice: true);

            if (!_note.IsDirty)
            {
                MarkUnsaved();
            }
        }
        else if (shouldTryCarryForwardSeed)
        {
            var carryForwardApplied = await TryApplyCarryForwardSeedAsync(value, showMissingNotice: true);
            if (!carryForwardApplied && !_note.IsDirty)
            {
                MarkUnsaved();
            }
        }
        else
        {
            MarkUnsaved();
        }

        ApplyWorkspaceNotice();
    }

