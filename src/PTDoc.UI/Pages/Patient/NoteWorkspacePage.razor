    private async Task UpdateBeforeUnloadGuardAsync()
    {
        try
        {
            var shouldGuard = CanSaveDraft && (DraftAutosaveService.IsDirty || DraftAutosaveService.IsSaving || !CurrentCompletionState.IsComplete);
            if (_lastBeforeUnloadShouldGuard.HasValue && _lastBeforeUnloadShouldGuard.Value == shouldGuard)
            {
                return;
            }

            var module = await GetNoteGuardModuleAsync();
            if (module is null)
            {
                return;
            }

            await module.InvokeVoidAsync(
                "setIncompleteNoteBeforeUnload",
                _beforeUnloadGuardKey,
                shouldGuard);
            _lastBeforeUnloadShouldGuard = shouldGuard;
        }
        catch (Exception ex)
        {
            Logger.LogDebug(ex, "Unable to update note beforeunload guard.");
        }
    }

