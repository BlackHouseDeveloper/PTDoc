    private void ApplyRequestedSection()
    {
        var requestedSection = ResolveRequestedSection(RequestedSection);
        if (!requestedSection.HasValue || requestedSection.Value == _note.ActiveSection)
        {
            return;
        }

        if (!CurrentSoapSections.Contains(requestedSection.Value))
        {
            return;
        }

        if (requestedSection == SoapSection.Review && _note.ActiveSection != SoapSection.Review)
        {
            _lastEditableSection = _note.ActiveSection;
        }
        else if (requestedSection != SoapSection.Review)
        {
            _lastEditableSection = requestedSection.Value;
        }

        _note.MoveTo(requestedSection.Value);
    }

    private static Guid? ResolveRouteNoteId(string? routeNoteId)
    {
        if (!string.IsNullOrWhiteSpace(routeNoteId) && Guid.TryParse(routeNoteId, out var parsed))
        {
            return parsed;
        }

        return null;
    }

    private static SoapSection? ResolveRequestedSection(string? value) => value?.Trim().ToLowerInvariant() switch
    {
        "subjective" => SoapSection.Subjective,
        "objective" => SoapSection.Objective,
        "interventions" => SoapSection.Interventions,
        "assessment" => SoapSection.Assessment,
        "plan" => SoapSection.Plan,
        "review" => SoapSection.Review,
        _ => null
    };

    private Guid? ResolveRequestedAppointmentId()
    {
        return !string.IsNullOrWhiteSpace(RequestedAppointmentId) && Guid.TryParse(RequestedAppointmentId, out var parsed)
            ? parsed
            : null;
    }

    private DateTime? ResolveRequestedDateOfService()
    {
        if (string.IsNullOrWhiteSpace(RequestedDateOfService))
        {
            return null;
        }

        return DateTime.TryParse(
            RequestedDateOfService,
            CultureInfo.InvariantCulture,
            DateTimeStyles.AssumeLocal,
            out var parsed)
            ? parsed.Date
            : null;
    }

    private async Task HandleSectionChanged(SoapSection next)
    {
        if (!_isNavigatingToMissingField && next != _note.ActiveSection && await PromptForIncompleteDocumentationAsync(sectionChange: next))
        {
            return;
        }

        await ApplySectionChangedCoreAsync(next);
    }

    private async Task ApplySectionChangedCoreAsync(SoapSection next)
    {
        if (next == SoapSection.Review && !await EnsureDraftPersistedAsync(forceIfClean: !_note.NoteId.HasValue))
        {
            return;
        }

        if (next == SoapSection.Review)
        {
            if (_note.ActiveSection != SoapSection.Review)
            {
                _lastEditableSection = _note.ActiveSection;
            }
        }
        else
        {
            _lastEditableSection = next;
        }

        _note.MoveTo(next);
        ClearStatusMessage();
    }

    private async Task HandleSectionChangedSafelyAsync(SoapSection next)
    {
        try
        {
            await HandleSectionChanged(next);
        }
        catch (Exception ex)
        {
            Logger.LogError(
                ex,
                "Note section change failed (noteType={NoteType}, noteIdPresent={HasNoteId}, section={Section})",
                _note.NoteType,
                _note.NoteId.HasValue,
                next);
            SetStatusMessage(
                GetUserFacingMessage(ex, "Unable to open that note section right now. Please retry."),
                "error",
                showToast: true,
                toastTitle: "Section unavailable");
        }
    }

    private async Task HandleNoteTypeChanged(string value)
    {
        if (!CanEditCurrentDraft)
        {
            return;
        }

        if (string.Equals(_note.NoteType, value, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        if (await PromptForIncompleteDocumentationAsync(noteTypeChange: value))
        {
            return;
        }

        await ApplyNoteTypeChangedCoreAsync(value);
    }

    private async Task ApplyNoteTypeChangedCoreAsync(string value)
    {
        var shouldTryEvaluationSeed = _note.Mode == NoteMode.New
            && !_note.NoteId.HasValue
            && !_note.IsDirty
            && !_hasAppliedEvaluationSeed
            && !_hasAttemptedEvaluationSeed
            && !IsEvaluationNoteType(_note.NoteType)
            && IsEvaluationNoteType(value);

        var shouldTryCarryForwardSeed = _note.Mode == NoteMode.New
            && !_note.NoteId.HasValue
            && !_note.IsDirty
            && !IsEvaluationNoteType(value)
            && !_attemptedCarryForwardSeedNoteTypes.Contains(value);

        _note.NoteType = value;
        if (!CurrentSoapSections.Contains(_note.ActiveSection))
        {
            _note.MoveTo(SoapSection.Subjective);
            _lastEditableSection = SoapSection.Subjective;
        }

        if (shouldTryEvaluationSeed)
        {
            await TryApplyEvaluationSeedAsync(showMissingNotice: true);

            if (!_note.IsDirty)
            {
                MarkUnsaved();
            }
        }
        else if (shouldTryCarryForwardSeed)
        {
            var carryForwardApplied = await TryApplyCarryForwardSeedAsync(value, showMissingNotice: true);
            if (!carryForwardApplied && !_note.IsDirty)
            {
                MarkUnsaved();
            }
        }
        else
        {
            MarkUnsaved();
        }

        ApplyWorkspaceNotice();
    }

