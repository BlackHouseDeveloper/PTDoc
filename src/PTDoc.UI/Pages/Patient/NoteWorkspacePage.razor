    private static void AddAiInput(List<AiStructuredInput> inputs, string label, string? value, string? bodyPart)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return;
        }

        inputs.Add(new AiStructuredInput
        {
            Label = label,
            Value = value.Trim(),
            BodyPart = string.IsNullOrWhiteSpace(bodyPart) ? null : bodyPart.Trim()
        });
    }

    private static IReadOnlyList<AiStructuredInput> DeduplicateAiInputs(IEnumerable<AiStructuredInput> inputs) =>
        inputs
            .GroupBy(input => $"{input.Label}\u001f{input.Value}\u001f{input.BodyPart}", StringComparer.OrdinalIgnoreCase)
            .Select(group => group.First())
            .ToList();

    private static bool ShouldIncludeAiInputForSelectedBodyPart(string? inputBodyPart, string? selectedBodyPart) =>
        string.IsNullOrWhiteSpace(inputBodyPart)
        || string.IsNullOrWhiteSpace(selectedBodyPart)
        || string.Equals(inputBodyPart.Trim(), selectedBodyPart.Trim(), StringComparison.OrdinalIgnoreCase);

    private static bool HasConcreteBodyPart(string? bodyPart) =>
        !string.IsNullOrWhiteSpace(bodyPart)
        && !string.Equals(bodyPart.Trim(), "Other", StringComparison.OrdinalIgnoreCase);

    private static string? JoinValues(IEnumerable<string?> values)
    {
        var joined = string.Join(", ", values.Where(value => !string.IsNullOrWhiteSpace(value)).Select(value => value!.Trim()).Distinct(StringComparer.OrdinalIgnoreCase));
        return string.IsNullOrWhiteSpace(joined) ? null : joined;
    }

    private static string FormatStructuredFunctionalLimitation(FunctionalLimitationEditorEntry limitation)
    {
        var parts = new List<string>();
        AddPart(parts, limitation.Description);
        AddPart(parts, limitation.MeasurePrompt);
        if (limitation.QuantifiedValue.HasValue)
        {
            AddPart(parts, $"{limitation.QuantifiedValue.Value} {limitation.QuantifiedUnit}".Trim());
        }

        AddPart(parts, limitation.Notes);
        return string.Join("; ", parts);
    }

    private static string FormatObjectiveMetric(ObjectiveMetricRowEntry metric)
    {
        var parts = new List<string>();
        AddPart(parts, metric.Name);
        AddPart(parts, metric.Value);
        if (metric.IsWithinNormalLimits)
        {
            AddPart(parts, "within normal limits");
        }

        AddPart(parts, metric.PreviousValue is null ? null : $"previous {metric.PreviousValue}");
        AddPart(parts, metric.NormValue is null ? null : $"norm {metric.NormValue}");
        return string.Join("; ", parts);
    }

    private static string FormatObjectiveMetric(ObjectiveMetricInputV2 metric)
    {
        var parts = new List<string>();
        AddPart(parts, metric.Name);
        AddPart(parts, metric.Value);
        if (metric.IsWithinNormalLimits)
        {
            AddPart(parts, "within normal limits");
        }

        AddPart(parts, metric.PreviousValue is null ? null : $"previous {metric.PreviousValue}");
        AddPart(parts, metric.NormValue is null ? null : $"norm {metric.NormValue}");
        return string.Join("; ", parts);
    }

    private static string FormatSpecialTest(SpecialTestEntry test)
    {
        var parts = new List<string>();
        AddPart(parts, test.Name);
        AddPart(parts, test.Side);
        AddPart(parts, test.Result);
        AddPart(parts, test.Notes);
        return string.Join(" - ", parts);
    }

    private static string FormatOutcomeMeasure(OutcomeMeasureEntry outcome)
    {
        var parts = new List<string>();
        AddPart(parts, outcome.Name);
        AddPart(parts, outcome.Score);
        AddPart(parts, outcome.Date?.ToString("MM/dd/yyyy", CultureInfo.InvariantCulture));
        return string.Join(" - ", parts);
    }

    private static string FormatIntervention(GeneralInterventionEntry intervention)
    {
        var parts = new List<string>();
        AddPart(parts, intervention.Name);
        AddPart(parts, intervention.Category);
        AddPart(parts, intervention.Notes);
        return string.Join(" - ", parts);
    }

    private static void AddPart(List<string> parts, string? value)
    {
        if (!string.IsNullOrWhiteSpace(value))
        {
            parts.Add(value.Trim());
        }
    }

    private string GetExaminationFindingsText()
    {
        var parts = new List<string>();

        if (_note.Objective.Metrics.Count > 0)
        {
            parts.Add($"Metrics: {string.Join(", ", _note.Objective.Metrics.Where(metric => !string.IsNullOrWhiteSpace(metric.Name)).Select(metric => $"{metric.Name} {metric.Value}".Trim()).Where(value => !string.IsNullOrWhiteSpace(value)))}");
        }

        if (_note.Objective.SpecialTests.Count > 0)
        {
            parts.Add($"Special tests: {string.Join(", ", _note.Objective.SpecialTests.Where(test => !string.IsNullOrWhiteSpace(test.Name)).Select(test => $"{test.Name} {test.Result}".Trim()))}");
        }

        if (_note.Objective.TenderMuscles.Count > 0)
        {
            parts.Add($"Tender muscles: {string.Join(", ", _note.Objective.TenderMuscles.OrderBy(v => v))}");
        }

        if (!string.IsNullOrWhiteSpace(_note.Objective.PrimaryGaitPattern))
        {
            parts.Add($"Primary gait pattern: {_note.Objective.PrimaryGaitPattern}");
        }

        if (_note.Objective.GaitDeviations.Count > 0)
        {
            parts.Add($"Deviations: {string.Join(", ", _note.Objective.GaitDeviations.OrderBy(v => v))}");
        }

        if (!string.IsNullOrWhiteSpace(_note.Objective.AdditionalGaitObservations))
        {
            parts.Add(_note.Objective.AdditionalGaitObservations);
        }

        if (!string.IsNullOrWhiteSpace(_note.Objective.ClinicalObservationNotes))
        {
            parts.Add(_note.Objective.ClinicalObservationNotes);
        }

        return string.Join(" | ", parts);
    }

    private bool ShouldShowSeedSummary(IReadOnlyList<string> subjectiveSeedChips, IReadOnlyList<string> objectiveSeedChips) =>
        !IsDryNeedlingNote
        && CurrentSeedContext is not null
        && (subjectiveSeedChips.Count > 0 || objectiveSeedChips.Count > 0);

    private IReadOnlyList<string> GetSubjectiveSeedChips()
    {
        var payload = _note.StructuredWorkspacePayload;
        if (payload is null || CurrentSeedContext is null)
        {
            return Array.Empty<string>();
        }

        var chips = new List<string>();
        var subjective = payload.Subjective;
        var normalizedAssistiveDevices = SubjectiveCatalogNormalizer.ParseAssistiveDeviceSelections(subjective.AssistiveDevice);
        var normalizedLivingSituations = SubjectiveCatalogNormalizer.NormalizeLivingSituationLabels(subjective.LivingSituation);
        var normalizedHouseLayout = SubjectiveCatalogNormalizer.ParseHouseLayoutSelections(subjective.OtherLivingSituation);
        var normalizedComorbidities = SubjectiveCatalogNormalizer.NormalizeComorbidityLabels(subjective.Comorbidities);
        var normalizedMedications = SubjectiveCatalogNormalizer.ParseMedicationSelections(subjective.Medications);

        if (subjective.IsPainScoreDocumented)
        {
            chips.Add($"Pain {subjective.CurrentPainScore}/10");
        }

        chips.AddRange(subjective.Locations
            .OrderBy(value => value, StringComparer.OrdinalIgnoreCase)
            .Select(value => $"Location: {value}"));

        if (!string.IsNullOrWhiteSpace(subjective.OtherLocation))
        {
            chips.Add($"Location: {subjective.OtherLocation.Trim()}");
        }

        if (subjective.AssistiveDevice.UsesAssistiveDevice == true)
        {
            if (!normalizedAssistiveDevices.HasSelections)
            {
                chips.Add("Assistive device in use");
            }

            chips.AddRange(normalizedAssistiveDevices.SelectedLabels
                .OrderBy(value => value, StringComparer.OrdinalIgnoreCase)
                .Select(value => $"Assistive device: {value}"));

            if (!string.IsNullOrWhiteSpace(normalizedAssistiveDevices.OtherText))
            {
                chips.Add($"Assistive device: {normalizedAssistiveDevices.OtherText.Trim()}");
            }
        }

        chips.AddRange(normalizedLivingSituations
            .OrderBy(value => value, StringComparer.OrdinalIgnoreCase)
            .Select(value => $"Living: {value}"));

        chips.AddRange(normalizedHouseLayout.SelectedLabels
            .OrderBy(value => value, StringComparer.OrdinalIgnoreCase)
            .Select(value => $"Home layout: {value}"));

        if (!string.IsNullOrWhiteSpace(normalizedHouseLayout.OtherText))
        {
            chips.Add($"Other living/home: {normalizedHouseLayout.OtherText.Trim()}");
        }

        chips.AddRange(normalizedComorbidities
            .OrderBy(value => value, StringComparer.OrdinalIgnoreCase)
            .Select(value => $"Comorbidity: {value}"));

        if (subjective.TakingMedications == true && !normalizedMedications.HasSelections)
        {
            chips.Add("Taking medications");
        }

        chips.AddRange(SubjectiveCatalogNormalizer.NormalizeMedicationSelectionLabels(normalizedMedications.SelectedLabels)
            .Select(value => $"Medication: {value}"));

        if (!string.IsNullOrWhiteSpace(normalizedMedications.OtherText))
        {
            chips.Add($"Medication: {normalizedMedications.OtherText.Trim()}");
        }

        return chips;
    }

    private IReadOnlyList<string> GetObjectiveSeedChips()
    {
        var payload = _note.StructuredWorkspacePayload;
        if (payload is null || CurrentSeedContext is null)
        {
            return Array.Empty<string>();
        }

        var chips = new List<string>();
        var objective = payload.Objective;

        if (objective.PrimaryBodyPart != BodyPart.Other)
        {
            chips.Add($"Primary body part: {GetBodyPartDisplayLabel(objective.PrimaryBodyPart)}");
        }

        chips.AddRange(objective.RecommendedOutcomeMeasures
            .Where(value => !string.IsNullOrWhiteSpace(value))
            .OrderBy(value => value, StringComparer.OrdinalIgnoreCase)
            .Select(value => $"Outcome measure: {value.Trim()}"));

        return chips;
    }

    private string GetSeedSummaryText()
    {
        return CurrentSeedContext?.Kind switch
        {
            WorkspaceSeedKind.IntakePrefill => "Structured intake responses were copied into this note. Review and refine them here before you save or sign.",
            WorkspaceSeedKind.SignedCarryForward => "Stable clinical context was copied forward from the latest signed note. Document today's findings before finalizing this draft.",
            _ => string.Empty
        };
    }

    private string GetSeedSourceBadgeText()
    {
        if (CurrentSeedContext is null)
        {
            return string.Empty;
        }

        return CurrentSeedContext.Kind switch
        {
            WorkspaceSeedKind.IntakePrefill => CurrentSeedContext.FromLockedSubmittedIntake
                ? $"Source: Submitted intake{FormatSeedReferenceDate(CurrentSeedContext.SourceReferenceDateUtc)}"
                : $"Source: Intake draft{FormatSeedReferenceDate(CurrentSeedContext.SourceReferenceDateUtc)}",
            WorkspaceSeedKind.SignedCarryForward => $"Source: Signed {GetWorkspaceNoteTypeLabel(CurrentSeedContext.SourceNoteType ?? NoteType.ProgressNote)}{FormatSeedReferenceDate(CurrentSeedContext.SourceReferenceDateUtc)}",
            _ => string.Empty
        };
    }

    private string GetSeedStateBadgeText()
    {
        if (_note.Status == NoteStatus.Signed)
        {
            return "State: Locked after signature";
        }

        if (_note.Status == NoteStatus.PendingCoSign)
        {
            return "State: Locked pending PT co-sign";
        }

        return CanEditCurrentDraft ? "State: Editable draft" : "State: Read-only view";
    }

    private string GetSeedStateBadgeClass()
    {
        if (_note.Status == NoteStatus.Signed || _note.Status == NoteStatus.PendingCoSign)
        {
            return "note-workspace__seed-badge note-workspace__seed-badge--locked";
        }

        return CanEditCurrentDraft
            ? "note-workspace__seed-badge note-workspace__seed-badge--editable"
            : "note-workspace__seed-badge note-workspace__seed-badge--readonly";
    }

    private static string GetBodyPartDisplayLabel(BodyPart bodyPart) => bodyPart switch
    {
        BodyPart.PelvicFloor => "Pelvic Floor",
        _ => bodyPart.ToString()
    };

    private static string GetWorkspaceNoteTypeLabel(NoteType noteType) => noteType switch
    {
        NoteType.Evaluation => "Evaluation Note",
        NoteType.ProgressNote => "Progress Note",
        NoteType.Daily => "Daily Treatment Note",
        NoteType.Discharge => "Discharge Note",
        _ => noteType.ToString()
    };

    private static string FormatSeedReferenceDate(DateTime? date)
    {
        return date.HasValue
            ? $" • {date.Value.ToString("MM/dd/yyyy", CultureInfo.InvariantCulture)}"
            : string.Empty;
    }

    private async Task LoadPatientContextAsync(Guid patientId)
    {
        var patient = await PatientService.GetByIdAsync(patientId);
        if (patient is null)
        {
            return;
        }

        _note.PatientName = $"{patient.FirstName} {patient.LastName}".Trim();
        _note.PatientDob = patient.DateOfBirth.ToString("M/d/yyyy", CultureInfo.InvariantCulture);
    }

    private string GetDiagnosisSummary()
    {
        if (_note.Assessment.DiagnosisCodes.Count > 0)
        {
            return string.Join(", ", _note.Assessment.DiagnosisCodes.Select(code => $"{code.Code} {code.Description}".Trim()));
        }

        return string.IsNullOrWhiteSpace(_note.Assessment.AssessmentNarrative)
            ? "Physical therapy plan of care"
            : _note.Assessment.AssessmentNarrative;
    }

    private string GetAssessmentSummary() =>
        string.IsNullOrWhiteSpace(_note.Assessment.AssessmentNarrative)
            ? GetChiefComplaintText()
            : _note.Assessment.AssessmentNarrative;

    private string GetGoalsSummary() =>
        _note.Assessment.Goals.Count == 0
            ? string.Empty
            : string.Join("; ", _note.Assessment.Goals.Select(goal => goal.Description).Where(description => !string.IsNullOrWhiteSpace(description)));

    private string GetPrecautionsSummary() =>
        string.IsNullOrWhiteSpace(_note.Plan.FollowUpInstructions)
            ? string.Empty
            : _note.Plan.FollowUpInstructions!;

    private string GetFunctionalLimitationsSummary()
    {
        if (!string.IsNullOrWhiteSpace(_note.Assessment.FunctionalLimitations))
        {
            return _note.Assessment.FunctionalLimitations;
        }

        if (_note.Subjective.FunctionalLimitations.Count > 0)
        {
            return string.Join(", ", _note.Subjective.FunctionalLimitations.OrderBy(value => value));
        }

        return GetChiefComplaintText();
    }

    private static IReadOnlyList<string> ParseGoalSuggestions(string generatedText)
    {
        var parsed = generatedText
            .Split(['\r', '\n'], StringSplitOptions.RemoveEmptyEntries)
            .Select(line => line.Trim())
            .Select(line => line.TrimStart('-', '*', '•', ' ', '\t'))
            .Where(line => !string.IsNullOrWhiteSpace(line))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        return parsed.Count == 0 && !string.IsNullOrWhiteSpace(generatedText)
            ? [generatedText.Trim()]
            : parsed;
    }

    private static string GetGoalStatusDescription(GoalStatus status) => status switch
    {
        GoalStatus.Met => "Goal marked as met.",
        GoalStatus.Archived => "Goal archived from the active plan.",
        _ => "Goal remains active."
    };

    private bool HasDraftWritePermissionForNoteType(string noteType)
    {
        if (IsPtUser)
        {
            return true;
        }

        if (IsPtaUser)
        {
            return string.Equals(noteType, "Daily Treatment Note", StringComparison.OrdinalIgnoreCase);
        }

        return false;
    }

    private bool HasSignPermissionForNoteType(string noteType)
    {
        if (IsPtUser)
        {
            return true;
        }

        if (IsPtaUser)
        {
            return string.Equals(noteType, "Daily Treatment Note", StringComparison.OrdinalIgnoreCase);
        }

        return false;
    }

    private void ApplyWorkspaceNotice()
    {
        if (_note.Status == NoteStatus.Signed)
        {
            _workspaceNotice = "This note has been signed and is read-only.";
            return;
        }

        if (_note.Status == NoteStatus.PendingCoSign)
        {
            _workspaceNotice = IsPtUser
                ? "This note is awaiting PT finalization. Content is read-only until it is signed."
                : "This note is awaiting PT co-sign and is read-only.";
            return;
        }

        if (IsBillingUser || IsOwnerUser)
        {
            _workspaceNotice = "Your role has read-only access to clinical notes.";
            return;
        }

        if (IsAdminUser)
        {
            _workspaceNotice = "Admin access is read-only for note content. PDF export remains available.";
            return;
        }

        if (IsPtaUser && !IsDailyTreatment)
        {
            _workspaceNotice = "PTA users can only edit and sign daily treatment notes.";
            return;
        }

        _workspaceNotice = null;
    }

    private string? GetReadOnlySaveMessage()
    {
        if (_note.Status == NoteStatus.Signed)
        {
            return "Signed notes cannot be edited.";
        }

        if (_note.Status == NoteStatus.PendingCoSign)
        {
            return "Pending co-sign notes are read-only.";
        }

        if (IsPtaUser && !IsDailyTreatment)
        {
            return "PTA users can only save daily treatment notes.";
        }

        if (IsAdminUser || IsOwnerUser || IsBillingUser)
        {
            return "Your role does not have permission to edit note content.";
        }

        return "This note cannot be edited right now.";
    }

    private string GetReadOnlySubmitMessage()
    {
        if (_note.Status == NoteStatus.Signed)
        {
            return "This note has already been signed.";
        }

        if (_note.Status == NoteStatus.PendingCoSign && !IsPtUser)
        {
            return "This note is awaiting PT co-sign and cannot be finalized by your role.";
        }

        if (IsPtaUser && !IsDailyTreatment)
        {
            return "PTA users can only sign daily treatment notes.";
        }

        if (IsAdminUser || IsOwnerUser || IsBillingUser)
        {
            return "Your role does not have permission to sign notes.";
        }

        return "This note cannot be submitted from the current state.";
    }

    private void HandleAutosaveStateChanged()
    {
        _note.IsDirty = DraftAutosaveService.IsDirty;

        if (DraftAutosaveService.IsSaving)
        {
            _note.SaveState = NoteSaveState.Saving;
        }
        else if (!string.IsNullOrWhiteSpace(DraftAutosaveService.LastErrorMessage))
        {
            var autosaveError = DraftAutosaveService.LastErrorMessage ?? "Unable to save draft.";
            _note.SaveState = NoteSaveState.Error;
            if (!string.Equals(_lastAutosaveToastMessage, autosaveError, StringComparison.Ordinal))
            {
                _lastAutosaveToastMessage = autosaveError;
                ToastService.ShowError(autosaveError, "Draft save failed");
            }
        }
        else if (DraftAutosaveService.IsDirty)
        {
            _note.SaveState = NoteSaveState.Unsaved;
        }
        else if (DraftAutosaveService.LastSavedAt.HasValue)
        {
            _note.SaveState = NoteSaveState.Saved;
            _lastAutosaveToastMessage = null;
        }

        _ = InvokeAsync(StateHasChanged);
    }

    private async ValueTask OnLocationChangingAsync(LocationChangingContext context)
    {
        if (_allowedNavigationTarget is not null &&
            string.Equals(_allowedNavigationTarget, context.TargetLocation, StringComparison.OrdinalIgnoreCase))
        {
            _allowedNavigationTarget = null;
            return;
        }

        if (!CanSaveDraft)
        {
            return;
        }

        var requiresDraftSave = DraftAutosaveService.IsDirty || DraftAutosaveService.IsSaving || !_note.NoteId.HasValue;
        var completion = CurrentCompletionState;
        if (!requiresDraftSave && completion.IsComplete)
        {
            return;
        }

        context.PreventNavigation();

        if (requiresDraftSave && !await EnsureDraftPersistedAsync(forceIfClean: !_note.NoteId.HasValue))
        {
            SetStatusMessage("Unable to save the draft before leaving this page. Resolve the error and try again.", "error", showToast: true, toastTitle: "Save failed");
            await InvokeAsync(StateHasChanged);
            return;
        }

        completion = CurrentCompletionState;
        if (!completion.IsComplete)
        {
            _pendingNavigationTarget = context.TargetLocation;
            _pendingNoteTypeChange = null;
            _pendingSectionChange = null;
            _showIncompleteNoteModal = true;
            await InvokeAsync(StateHasChanged);
            return;
        }

        _allowedNavigationTarget = context.TargetLocation;
        await NavigateAfterGuardAsync(context.TargetLocation);
    }

    private async Task NavigateAfterGuardAsync(string target)
    {
        try
        {
            await InvokeAsync(() => NavigationManager.NavigateTo(target));
        }
        catch (Exception ex) when (IsExpectedNavigationInterruption(ex))
        {
            _allowedNavigationTarget = null;
            Logger.LogDebug(ex, "Guarded note navigation was interrupted while changing location to {Target}.", target);
        }
    }

    private static bool IsExpectedNavigationInterruption(Exception exception) =>
        exception is OperationCanceledException or JSDisconnectedException;

    private static string GetUserFacingMessage(Exception exception, string fallback)
    {
        if (exception is HttpRequestException httpException)
        {
            var message = httpException.Message.Trim();
            if (!string.IsNullOrWhiteSpace(message) &&
                !message.StartsWith("Response status code", StringComparison.OrdinalIgnoreCase))
            {
                return message;
            }
        }

        return fallback;
    }

    public async ValueTask DisposeAsync()
    {
        if (_disposed)
        {
            return;
        }

        _disposed = true;
        _navGuard?.Dispose();
        DraftAutosaveService.StateChanged -= HandleAutosaveStateChanged;

        try
        {
            if (CanSaveDraft && (DraftAutosaveService.IsDirty || DraftAutosaveService.IsSaving))
            {
                await EnsureDraftPersistedAsync();
            }
        }
        catch
        {
        }

        try
        {
            if (_noteGuardModule is not null)
            {
                await _noteGuardModule.InvokeVoidAsync(
                    "setIncompleteNoteBeforeUnload",
                    _beforeUnloadGuardKey,
                    false);
                _lastBeforeUnloadShouldGuard = false;
                await _noteGuardModule.DisposeAsync();
            }
        }
        catch
        {
        }

        try
        {
            if (_navigationModule is not null)
            {
                await _navigationModule.DisposeAsync();
            }
        }
        catch
        {
        }

        await DraftAutosaveService.DisposeAsync();
        _persistGate.Dispose();
    }
}
