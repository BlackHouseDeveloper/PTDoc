    private async Task NavigateToMissingRequiredItemAsync(MissingRequiredItem item)
    {
        _showIncompleteNoteModal = false;
        _pendingNavigationTarget = null;
        _pendingNoteTypeChange = null;
        _pendingSectionChange = null;

        if (!IsDryNeedlingNote && CurrentSoapSections.Contains(item.Section))
        {
            if (item.Section != SoapSection.Review)
            {
                _lastEditableSection = item.Section;
            }

            _isNavigatingToMissingField = true;
            try
            {
                await ApplySectionChangedCoreAsync(item.Section);
            }
            finally
            {
                _isNavigatingToMissingField = false;
            }
        }

        _pendingMissingFieldSelector = item.FieldSelector;
        SetStatusMessage(item.Message, "error");
        await InvokeAsync(StateHasChanged);
    }

    private async Task HandleIncompleteNavigationContinueAsync()
    {
        var target = _pendingNavigationTarget;
        var noteType = _pendingNoteTypeChange;
        var section = _pendingSectionChange;

        _showIncompleteNoteModal = false;
        _pendingNavigationTarget = null;
        _pendingNoteTypeChange = null;
        _pendingSectionChange = null;

        if (!string.IsNullOrWhiteSpace(target))
        {
            _allowedNavigationTarget = target;
            await NavigateAfterGuardAsync(target);
            return;
        }

        if (!string.IsNullOrWhiteSpace(noteType))
        {
            await ApplyNoteTypeChangedCoreAsync(noteType);
            return;
        }

        if (section.HasValue)
        {
            await ApplySectionChangedCoreAsync(section.Value);
        }
    }

