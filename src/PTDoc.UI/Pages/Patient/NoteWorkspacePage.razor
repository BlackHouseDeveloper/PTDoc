    private async Task HandlePrevSection()
    {
        var previous = GetAdjacentSection(-1);
        if (previous.HasValue)
        {
            await HandleSectionChanged(previous.Value);
        }
    }

    private async Task HandleNextSection()
    {
        var next = GetAdjacentSection(1);
        if (next.HasValue)
        {
            await HandleSectionChanged(next.Value);
        }
    }

    private SoapSection? GetAdjacentSection(int direction)
    {
        var sections = Enum.GetValues<SoapSection>();
        var index = Array.IndexOf(sections, _note.ActiveSection);
        var nextIndex = index + direction;
        if (nextIndex < 0 || nextIndex >= sections.Length)
        {
            return null;
        }

        return sections[nextIndex];
    }

