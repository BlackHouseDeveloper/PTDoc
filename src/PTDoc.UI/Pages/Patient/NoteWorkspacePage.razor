        !CanRegenerateReviewSummary && !IsWorkspaceReadOnly && !_note.NoteId.HasValue
            ? "Save the note before generating an AI plan summary."
            : !CanRegenerateReviewSummary && !IsWorkspaceReadOnly && !HasConcreteBodyPart(GetSelectedBodyPart())
                ? "Select a body part before generating an AI plan summary."
            : null;

