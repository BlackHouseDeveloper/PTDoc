    private string GetDailyTreatmentChiefComplaintText()
    {
        var values = new List<string>();

        values.AddRange(_note.Subjective.Locations.OrderBy(value => value));
        AddPart(values, _note.Subjective.OtherLocation);
        AddPart(values, _note.Subjective.OtherProblem);
        AddPart(values, _note.DailyTreatment.SubjectiveUpdate);
        AddPart(values, _note.DailyTreatment.ChangesSinceLastVisit);
        AddPart(values, _note.DailyTreatment.NewOrChangedSymptoms);

        return string.Join("; ", values
            .Select(value => value.Trim())
