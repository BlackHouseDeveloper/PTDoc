    private async Task HandleRegenerateSummaryAsync()
    {
        if (IsWorkspaceReadOnly)
        {
            return;
        }

        _isRegeneratingSummary = true;
        ClearStatusMessage();
        StateHasChanged();

        try
        {
            var result = await AiService.GeneratePlanOfCareAsync(new PlanOfCareGenerationRequest
            {
                NoteId = _note.NoteId ?? Guid.Empty,
                Diagnosis = GetDiagnosisSummary(),
                AssessmentSummary = GetAssessmentSummary(),
                Goals = GetGoalsSummary(),
                Precautions = GetPrecautionsSummary(),
                IsNoteSigned = _note.Status != NoteStatus.Draft
            });

            if (!result.Success)
            {
                SetStatusMessage(result.ErrorMessage ?? "Unable to generate a clinical summary.", "error");
                return;
            }

            _note.Plan.ClinicalSummary = result.GeneratedText;
            MarkUnsaved();
            SetStatusMessage("Clinical summary regenerated. Save the note to keep the updated summary.", "success");
        }
        finally
        {
            _isRegeneratingSummary = false;
        }
    }

    private async Task HandleRegenerateGoalsAsync()
    {
        if (IsWorkspaceReadOnly)
        {
            return;
        }

        _isRegeneratingGoals = true;
        ClearStatusMessage();
        StateHasChanged();

        try
        {
            var result = await AiService.GenerateGoalNarrativesAsync(new GoalNarrativesGenerationRequest
            {
                NoteId = _note.NoteId ?? Guid.Empty,
                Diagnosis = GetDiagnosisSummary(),
                FunctionalLimitations = GetFunctionalLimitationsSummary(),
                ShortTermGoals = GetGoalsSummary(),
                LongTermGoals = GetGoalsSummary(),
                IsNoteSigned = _note.Status != NoteStatus.Draft
            });

            if (!result.Success)
            {
                SetStatusMessage(result.ErrorMessage ?? "Unable to generate AI treatment goals.", "error");
                return;
            }

            foreach (var description in ParseGoalSuggestions(result.GeneratedText))
            {
                if (_note.Assessment.Goals.Any(goal => string.Equals(goal.Description, description, StringComparison.OrdinalIgnoreCase)))
                {
                    continue;
                }

                _note.Assessment.Goals.Add(new SmartGoalEntry
                {
                    Description = description,
                    IsAiSuggested = true,
                    IsAccepted = false,
                    Timeframe = GoalTimeframe.ShortTerm,
                    Status = GoalStatus.Active
                });
            }

            MarkUnsaved();
            SetStatusMessage("AI treatment goals regenerated. Review and accept the suggested goals before saving.", "success");
        }
        finally
        {
            _isRegeneratingGoals = false;
        }
    }

    private async Task HandleExportPdfAsync()
    {
        if (!CanExportPdf)
        {
            SetStatusMessage("Your role does not have permission to export note PDFs.", "error");
            return;
        }

        if (!_note.NoteId.HasValue)
        {
            SetStatusMessage("Save and submit the note before exporting PDF.", "error");
            return;
        }

        var result = await NoteWorkspaceService.ExportPdfAsync(_note.NoteId.Value);
        if (!result.Success)
        {
            SetStatusMessage(result.ErrorMessage ?? "Unable to export the note as PDF.", "error");
            return;
        }

        var base64 = Convert.ToBase64String(result.Content);
        await JS.InvokeVoidAsync("open", $"data:{result.ContentType};base64,{base64}", "_blank");
        SetStatusMessage("PDF export opened in a new browser tab.", "success");
    }

    private async Task HandleSaveAsync()
    {
        if (!CanSaveDraft)
        {
            if (!string.IsNullOrWhiteSpace(GetReadOnlySaveMessage()))
            {
                SetStatusMessage(GetReadOnlySaveMessage()!, "error");
            }
            return;
        }

        var saveSucceeded = DraftAutosaveService.IsDirty
            ? await DraftAutosaveService.FlushAsync()
            : await PersistDraftAsync(showFeedback: false, CancellationToken.None);

        if (saveSucceeded && _warningValidationMessages.Count == 0 && !_requiresOverride)
        {
            SetStatusMessage("Draft saved.", "success");
        }
    }

    private async Task<bool> AutosaveSaveAsync(CancellationToken cancellationToken)
    {
        return await PersistDraftAsync(showFeedback: false, cancellationToken);
    }

    private async Task<bool> PersistDraftAsync(
        bool showFeedback,
        CancellationToken cancellationToken,
        OverrideSubmission? overrideSubmission = null)
    {
        if (!_patientGuid.HasValue || !CanSaveDraft)
        {
            return false;
        }

        await _persistGate.WaitAsync(cancellationToken);
        try
        {
            if (!_patientGuid.HasValue || !CanSaveDraft)
            {
                return false;
            }

            _dateOfService = ResolveDateOfService();
            _note.StartSaving();
            await InvokeAsync(StateHasChanged);

            var saveResult = await NoteWorkspaceService.SaveDraftAsync(
                BuildDraft(_patientGuid.Value, overrideSubmission),
                cancellationToken);
            ApplyValidationDetails(
                saveResult.Errors,
                saveResult.Warnings,
                saveResult.RequiresOverride,
                saveResult.RuleType,
                saveResult.IsOverridable,
                saveResult.OverrideRequirements);

            if (!saveResult.Success)
            {
                _note.MarkSaveError();
                if (showFeedback || saveResult.Errors.Count > 0 || saveResult.Warnings.Count > 0)
                {
                    SetStatusMessage(saveResult.ErrorMessage ?? "Unable to save draft right now. Please retry.", saveResult.Errors.Count > 0 ? "error" : "info");
                }

                return false;
            }

            if (saveResult.Payload is not null)
            {
                ApplyWorkspaceState(
                    saveResult.NoteId,
                    saveResult.Payload.WorkspaceNoteType,
                    _dateOfService,
                    saveResult.Status,
                    saveResult.Payload);
            }
            else
            {
                _currentNoteId = saveResult.NoteId;
                _note.NoteId = saveResult.NoteId;
                _note.Mode = NoteMode.Existing;
                _note.Status = saveResult.Status;
                _note.MarkSaved();
            }

            ApplyWorkspaceNotice();

            if (saveResult.Warnings.Count > 0)
            {
                SetStatusMessage(
                    saveResult.ErrorMessage ?? (overrideSubmission is null
                        ? "Draft saved with warnings."
                        : "Draft saved with PT override and warnings."),
                    "info");
            }
            else if (showFeedback)
            {
                SetStatusMessage(
                    overrideSubmission is null
                        ? "Draft saved."
                        : "Draft saved with PT override.",
                    "success");
            }
            else
            {
                ClearStatusMessage();
            }

            return true;
        }
        catch (OperationCanceledException)
        {
            throw;
        }
        catch (Exception ex)
        {
            _note.MarkSaveError();
            SetStatusMessage(GetUserFacingMessage(ex, "Unable to save draft right now. Please retry."), "error");
            return false;
        }
        finally
        {
            await InvokeAsync(StateHasChanged);
            _persistGate.Release();
        }
    }

    private async Task<bool> EnsureDraftPersistedAsync(bool forceIfClean = false)
    {
        if (!CanSaveDraft)
        {
            return true;
        }

        if (DraftAutosaveService.IsDirty || DraftAutosaveService.IsSaving)
        {
            return await DraftAutosaveService.FlushAsync();
        }

        if (forceIfClean || !_note.NoteId.HasValue)
        {
            return await PersistDraftAsync(showFeedback: false, CancellationToken.None);
        }

        return true;
    }

    private async Task HandleSubmitAsync()
    {
        if (!CanSubmitCurrentNote)
        {
            SetStatusMessage(GetReadOnlySubmitMessage(), "error");
            return;
        }

        if (!CanFinalizePendingCoSign)
        {
            var submitValidationMessage = ValidateForSubmit();
            if (!string.IsNullOrWhiteSpace(submitValidationMessage))
            {
                _note.MarkSaveError();
                SetStatusMessage(submitValidationMessage, "error");
                return;
            }

            var saveSucceeded = await EnsureDraftPersistedAsync(forceIfClean: true);
            if (!saveSucceeded || !_note.NoteId.HasValue)
            {
                if (!_note.NoteId.HasValue)
                {
                    SetStatusMessage("Unable to submit because the note ID is missing.", "error");
                }

                return;
            }
        }
        else if (!_note.NoteId.HasValue)
        {
            SetStatusMessage("This note must be saved before PT finalization can continue.", "error");
            return;
        }

        _consentAccepted = false;
        _intentConfirmed = false;
        _showSignatureConsent = true;
    }

    private Task HandleConsentCancelAsync()
    {
        _showSignatureConsent = false;
        _consentAccepted = false;
        _intentConfirmed = false;
        return Task.CompletedTask;
    }

    private async Task HandleConsentConfirmAsync()
    {
        if (!_consentAccepted || !_intentConfirmed || !_note.NoteId.HasValue || _isSubmittingNote)
        {
            return;
        }

        _showSignatureConsent = false;
        _isSubmittingNote = true;
        var wasPendingCoSignFinalization = CanFinalizePendingCoSign;
        ClearValidationDetails();
        ClearStatusMessage();
        StateHasChanged();

        try
        {
            var submitResult = await NoteWorkspaceService.SubmitAsync(
                _note.NoteId.Value,
                consentAccepted: _consentAccepted,
                intentConfirmed: _intentConfirmed);

            if (!submitResult.Success)
            {
                ApplyValidationFailures(submitResult.ValidationFailures);
                _note.MarkSaveError();
                SetStatusMessage(submitResult.ErrorMessage ?? "Unable to submit note.", "error");
                return;
            }

            if (_patientGuid.HasValue)
            {
                await LoadExistingNoteAsync(_patientGuid.Value, _note.NoteId.Value);
            }
            else
            {
                _note.Status = submitResult.Status;
                _note.IsDirty = false;
                _note.MarkSaved();
            }

            ApplyWorkspaceNotice();
            ClearValidationDetails();
            SetStatusMessage(
                submitResult.RequiresCoSign
                    ? "Note submitted. PT co-sign is still required before the documentation workflow is fully complete."
                    : (wasPendingCoSignFinalization
                        ? "Pending co-sign note finalized successfully."
                        : "Note submitted successfully."),
                submitResult.RequiresCoSign ? "info" : "success");
        }
        finally
        {
            _isSubmittingNote = false;
            _consentAccepted = false;
            _intentConfirmed = false;
        }
    }

    private NoteWorkspaceDraft BuildDraft(Guid patientId)
        => BuildDraft(patientId, overrideSubmission: null);

    private NoteWorkspaceDraft BuildDraft(Guid patientId, OverrideSubmission? overrideSubmission)
    {
        var payload = new NoteWorkspacePayload
        {
            WorkspaceNoteType = _note.NoteType,
            StructuredPayload = _note.StructuredWorkspacePayload,
            Subjective = _note.Subjective,
            Objective = _note.Objective,
            Assessment = _note.Assessment,
            Plan = _note.Plan,
            DryNeedling = _dryNeedling
        };

        return new NoteWorkspaceDraft
        {
            NoteId = _note.NoteId,
            PatientId = patientId,
            WorkspaceNoteType = _note.NoteType,
            DateOfService = ResolveDateOfService(),
            IsExistingNote = _note.Mode == NoteMode.Existing && _note.NoteId.HasValue,
            Override = overrideSubmission,
            Payload = payload
        };
    }

    private async Task HandleOverrideSaveAsync()
    {
        if (!CanCurrentUserApplyOverride)
        {
            return;
        }

        if (!_overrideRuleType.HasValue)
        {
            SetStatusMessage("Override rule metadata is missing for this draft. Please review the note and retry.", "error");
            return;
        }

        if (string.IsNullOrWhiteSpace(_overrideReason))
        {
            SetStatusMessage("A PT override justification is required before saving.", "error");
            return;
        }

        await PersistDraftAsync(
            showFeedback: true,
            CancellationToken.None,
            new OverrideSubmission
            {
                RuleType = _overrideRuleType.Value,
                Reason = _overrideReason.Trim()
            });
    }

    private async Task TryApplyEvaluationSeedAsync(bool showMissingNotice)
    {
        if (!_patientGuid.HasValue
            || _hasAppliedEvaluationSeed
            || _hasAttemptedEvaluationSeed
            || _note.Mode != NoteMode.New
            || _note.NoteId.HasValue
            || _note.IsDirty
            || !IsEvaluationNoteType(_note.NoteType))
        {
            return;
        }

        var seedResult = await NoteWorkspaceService.GetEvaluationSeedAsync(_patientGuid.Value);
        if (!seedResult.Success)
        {
            SetStatusMessage(seedResult.ErrorMessage ?? "Unable to load intake data for Evaluation prefill.", "error");
            return;
        }

        _hasAttemptedEvaluationSeed = true;

        if (!seedResult.HasSeed)
        {
            if (showMissingNotice)
            {
                SetStatusMessage("No intake data is available to prefill this Evaluation note yet.", "info");
            }

            return;
        }

        ApplyEvaluationSeed(seedResult.Payload);
        _hasAppliedEvaluationSeed = true;
        SetStatusMessage(
            seedResult.FromLockedSubmittedIntake
                ? "Evaluation note prefilled from the latest submitted intake."
                : "Evaluation note prefilled from the latest intake draft.",
            "success");
    }

    private async Task<bool> TryStartSeededEvaluationNoteAsync()
    {
        if (!_patientGuid.HasValue
            || _hasAppliedEvaluationSeed
            || _note.Mode != NoteMode.New
            || _note.NoteId.HasValue
            || _note.IsDirty
            || IsPtaUser
            || TryResolveRequestedNoteType(out _))
        {
            return false;
        }

        var seedResult = await NoteWorkspaceService.GetEvaluationSeedAsync(_patientGuid.Value);
        if (!seedResult.Success || !seedResult.HasSeed)
        {
            return false;
        }

        _note.NoteType = "Evaluation Note";
        ApplyEvaluationSeed(seedResult.Payload);
        _hasAppliedEvaluationSeed = true;
        _hasAttemptedEvaluationSeed = true;
        SetStatusMessage(
            seedResult.FromLockedSubmittedIntake
                ? "Started a new Evaluation note with the latest submitted intake prefill."
                : "Started a new Evaluation note with the latest intake draft prefill.",
            "success");
        return true;
    }

    private async Task<bool> TryApplyCarryForwardSeedAsync(string noteType, bool showMissingNotice)
    {
        if (!_patientGuid.HasValue
            || _note.Mode != NoteMode.New
            || _note.NoteId.HasValue
            || _note.IsDirty
            || IsEvaluationNoteType(noteType)
            || !CanApplyCarryForwardSeed(noteType)
            || _attemptedCarryForwardSeedNoteTypes.Contains(noteType))
        {
            return false;
        }

        var seedResult = await NoteWorkspaceService.GetCarryForwardSeedAsync(_patientGuid.Value, noteType);
        if (!seedResult.Success)
        {
            SetStatusMessage(seedResult.ErrorMessage ?? "Unable to load signed note carry-forward data right now.", "error");
            return false;
        }

        _attemptedCarryForwardSeedNoteTypes.Add(noteType);

        if (!seedResult.HasSeed)
        {
            if (showMissingNotice)
            {
                SetStatusMessage($"No signed note carry-forward is available for this {noteType} yet.", "info");
            }

            return false;
        }

        ApplyEvaluationSeed(seedResult.Payload);
        SetStatusMessage(
            $"Started a new {noteType} with carry-forward from the latest signed {seedResult.SourceNoteType}.",
            "success");
        return true;
    }

    private void ApplyEvaluationSeed(NoteWorkspacePayload payload)
    {
        _note.Subjective = payload.Subjective ?? new SubjectiveVm();
        _note.Objective = payload.Objective ?? new ObjectiveVm();
        _note.Assessment = payload.Assessment ?? new AssessmentWorkspaceVm();
        _note.Plan = payload.Plan ?? new PlanVm();
        _note.StructuredWorkspacePayload = payload.StructuredPayload;
        _note.MarkDirty();
        DraftAutosaveService.Reset();
        ClearValidationDetails();
    }

    private DateTime ResolveDateOfService()
    {
        if (IsDryNeedlingNote && _dryNeedling.DateOfTreatment.HasValue)
        {
            return _dryNeedling.DateOfTreatment.Value;
        }

        return _dateOfService == default ? DateTime.UtcNow : _dateOfService;
    }

    private static bool IsEvaluationNoteType(string noteType) =>
        string.Equals(noteType, "Evaluation Note", StringComparison.OrdinalIgnoreCase);

    private static bool CanApplyCarryForwardSeed(string noteType) =>
        string.Equals(noteType, "Progress Note", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(noteType, "Daily Treatment Note", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(noteType, "Discharge Note", StringComparison.OrdinalIgnoreCase);

    private bool TryResolveRequestedNoteType(out string noteType)
    {
        noteType = string.Empty;
        if (string.IsNullOrWhiteSpace(RequestedNoteType))
        {
            return false;
        }

        var allowedNoteTypes = IsPtaUser
            ? new[] { "Daily Treatment Note" }
            : _allNoteTypes;

        noteType = allowedNoteTypes.FirstOrDefault(candidate =>
                       string.Equals(candidate, RequestedNoteType, StringComparison.OrdinalIgnoreCase))
                   ?? string.Empty;

        return !string.IsNullOrWhiteSpace(noteType);
    }

    private string? ValidateForSubmit()
    {
        if (CanFinalizePendingCoSign)
        {
            return null;
        }

        if (IsDryNeedlingNote)
        {
            if (_dryNeedling.DateOfTreatment is null)
            {
                return "Date of treatment is required before submit.";
            }

            if (string.IsNullOrWhiteSpace(_dryNeedling.Location))
            {
                return "Location of needling is required before submit.";
            }

            if (string.IsNullOrWhiteSpace(_dryNeedling.NeedlingType))
            {
                return "Type of needling is required before submit.";
            }

            return null;
        }

        if (!_note.CanSubmit(out var message))
        {
            return message;
        }

        if (IsDischargeNote)
        {
            if (string.IsNullOrWhiteSpace(_note.Plan.PrimaryDischargeReason))
            {
                return "Primary discharge reason is required before submit.";
            }

            if (string.IsNullOrWhiteSpace(_note.Plan.DischargeRecommendations))
            {
                return "Discharge recommendations are required before submit.";
            }

            if (_note.Plan.CompletedDischargeChecklistItems.Count == 0)
            {
                return "Complete at least one end-of-care checklist item before submit.";
            }
        }

        return null;
    }

    private void MarkUnsaved()
    {
        if (!CanEditCurrentDraft)
        {
            return;
        }

        ClearValidationDetails();
        ClearStatusMessage();
        _note.MarkDirty();
        DraftAutosaveService.MarkDirty();
    }

    private string GetAlertToneClass() => $"note-workspace__alert--{_statusTone}";

    private void SetStatusMessage(string message, string tone)
    {
        _statusMessage = message;
        _statusTone = tone;
    }

    private void ClearStatusMessage()
    {
        _statusMessage = null;
        _statusTone = "info";
    }

    private void ClearValidationDetails()
    {
        _blockingValidationMessages = [];
        _warningValidationMessages = [];
        _requiresOverride = false;
        _overrideRuleType = null;
        _isOverridable = false;
        _overrideRequirements = [];
        _overrideReason = string.Empty;
    }

    private void ApplyValidationDetails(
        IEnumerable<string>? blockingMessages,
        IEnumerable<string>? warningMessages,
        bool requiresOverride,
        ComplianceRuleType? ruleType,
        bool isOverridable,
        IEnumerable<OverrideRequirement>? overrideRequirements)
    {
        _blockingValidationMessages = (blockingMessages ?? [])
            .Where(message => !string.IsNullOrWhiteSpace(message))
            .Select(message => message.Trim())
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        _warningValidationMessages = (warningMessages ?? [])
            .Where(message => !string.IsNullOrWhiteSpace(message))
            .Select(message => message.Trim())
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        _overrideRequirements = (overrideRequirements ?? [])
            .Where(requirement => !string.IsNullOrWhiteSpace(requirement.Message) || !string.IsNullOrWhiteSpace(requirement.AttestationText))
            .GroupBy(
                requirement => new
                {
                    requirement.RuleType,
                    Message = requirement.Message?.Trim() ?? string.Empty,
                    AttestationText = requirement.AttestationText?.Trim() ?? string.Empty
                })
            .Select(group => group.First())
            .ToList();

        _overrideRuleType = ruleType ?? _overrideRequirements.FirstOrDefault()?.RuleType;
        _isOverridable = isOverridable || _overrideRequirements.Any(requirement => requirement.IsOverridable);
        _requiresOverride = requiresOverride || _overrideRequirements.Count > 0;

        if (!_requiresOverride)
        {
            _overrideReason = string.Empty;
        }
    }

    private void ApplyValidationFailures(IEnumerable<RuleEvaluationResult>? validationFailures)
    {
        if (validationFailures is null)
        {
            ClearValidationDetails();
            return;
        }

        _blockingValidationMessages = validationFailures
            .Where(failure => failure.Blocking || failure.Severity == ValidationSeverity.Error)
            .Select(failure => failure.Message)
            .Where(message => !string.IsNullOrWhiteSpace(message))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        _warningValidationMessages = validationFailures
            .Where(failure => !failure.Blocking && failure.Severity != ValidationSeverity.Error)
            .Select(failure => failure.Message)
            .Where(message => !string.IsNullOrWhiteSpace(message))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        _requiresOverride = false;
        _overrideRuleType = null;
        _isOverridable = false;
        _overrideRequirements = [];
        _overrideReason = string.Empty;
    }

    private string GetOverrideSummaryText()
    {
        if (_overrideRuleType.HasValue)
        {
            return $"A {GetComplianceRuleDisplayLabel(_overrideRuleType.Value)} warning requires PT attestation before this draft can be saved.";
        }

        return "A PT compliance override is required before this draft can be saved.";
    }

    private string? GetOverrideAttestationText()
    {
        return _overrideRequirements
            .Select(requirement => requirement.AttestationText?.Trim())
            .FirstOrDefault(text => !string.IsNullOrWhiteSpace(text));
    }

    private string GetOverrideReadonlyMessage()
    {
        if (!_overrideRuleType.HasValue || !_isOverridable)
        {
            return "Override metadata is unavailable for this draft. Review the note and retry the save.";
        }

        return "Only a PT can attest and save this override.";
    }

    private static string GetComplianceRuleDisplayLabel(ComplianceRuleType ruleType) => ruleType switch
    {
        ComplianceRuleType.EightMinuteRule => "Eight-minute rule",
        ComplianceRuleType.ProgressNoteRequired => "Progress note required",
        ComplianceRuleType.MissingCoSign => "Missing co-sign",
        ComplianceRuleType.TimeUnitMismatch => "Time and unit mismatch",
        _ => "Compliance override"
    };

    private string GetChiefComplaintText()
    {
        if (_note.Subjective.Problems.Count == 0)
        {
            return _note.Subjective.OtherProblem ?? string.Empty;
        }

        return string.Join(", ", _note.Subjective.Problems.OrderBy(v => v));
    }

    private string GetExaminationFindingsText()
    {
        var parts = new List<string>();

        if (_note.Objective.Metrics.Count > 0)
        {
            parts.Add($"Metrics: {string.Join(", ", _note.Objective.Metrics.Where(metric => !string.IsNullOrWhiteSpace(metric.Name)).Select(metric => $"{metric.Name} {metric.Value}".Trim()).Where(value => !string.IsNullOrWhiteSpace(value)))}");
        }

        if (_note.Objective.SpecialTests.Count > 0)
        {
            parts.Add($"Special tests: {string.Join(", ", _note.Objective.SpecialTests.Where(test => !string.IsNullOrWhiteSpace(test.Name)).Select(test => $"{test.Name} {test.Result}".Trim()))}");
        }

        if (_note.Objective.TenderMuscles.Count > 0)
        {
            parts.Add($"Tender muscles: {string.Join(", ", _note.Objective.TenderMuscles.OrderBy(v => v))}");
        }

        if (!string.IsNullOrWhiteSpace(_note.Objective.PrimaryGaitPattern))
        {
            parts.Add($"Primary gait pattern: {_note.Objective.PrimaryGaitPattern}");
        }

        if (_note.Objective.GaitDeviations.Count > 0)
        {
            parts.Add($"Deviations: {string.Join(", ", _note.Objective.GaitDeviations.OrderBy(v => v))}");
        }

        if (!string.IsNullOrWhiteSpace(_note.Objective.AdditionalGaitObservations))
        {
            parts.Add(_note.Objective.AdditionalGaitObservations);
        }

        if (!string.IsNullOrWhiteSpace(_note.Objective.ClinicalObservationNotes))
        {
            parts.Add(_note.Objective.ClinicalObservationNotes);
        }

        return string.Join(" | ", parts);
    }

    private bool ShouldShowSeedSummary(IReadOnlyList<string> subjectiveSeedChips, IReadOnlyList<string> objectiveSeedChips) =>
        !IsDryNeedlingNote
        && CurrentSeedContext is not null
        && (subjectiveSeedChips.Count > 0 || objectiveSeedChips.Count > 0);

    private IReadOnlyList<string> GetSubjectiveSeedChips()
    {
        var payload = _note.StructuredWorkspacePayload;
        if (payload is null || CurrentSeedContext is null)
        {
            return Array.Empty<string>();
        }

        var chips = new List<string>();
        var subjective = payload.Subjective;

        if (subjective.CurrentPainScore > 0 || subjective.Problems.Contains("Pain"))
        {
            chips.Add($"Pain {subjective.CurrentPainScore}/10");
        }

        chips.AddRange(subjective.Locations
            .OrderBy(value => value, StringComparer.OrdinalIgnoreCase)
            .Select(value => $"Location: {value}"));

        if (!string.IsNullOrWhiteSpace(subjective.OtherLocation))
        {
            chips.Add($"Location: {subjective.OtherLocation.Trim()}");
        }

        if (subjective.AssistiveDevice.UsesAssistiveDevice == true)
        {
            if (subjective.AssistiveDevice.Devices.Count == 0)
            {
                chips.Add("Assistive device in use");
            }
            else
            {
                chips.AddRange(subjective.AssistiveDevice.Devices
                    .OrderBy(value => value, StringComparer.OrdinalIgnoreCase)
                    .Select(value => $"Assistive device: {value}"));
            }
        }

        chips.AddRange(subjective.LivingSituation
            .OrderBy(value => value, StringComparer.OrdinalIgnoreCase)
            .Select(value => $"Living: {value}"));

        if (!string.IsNullOrWhiteSpace(subjective.OtherLivingSituation))
        {
            chips.Add($"Home setup: {subjective.OtherLivingSituation.Trim()}");
        }

        chips.AddRange(subjective.Comorbidities
            .OrderBy(value => value, StringComparer.OrdinalIgnoreCase)
            .Select(value => $"Comorbidity: {value}"));

        chips.AddRange(subjective.Medications
            .Where(entry => !string.IsNullOrWhiteSpace(entry.Name))
            .OrderBy(entry => entry.Name, StringComparer.OrdinalIgnoreCase)
            .Select(entry => $"Medication: {entry.Name.Trim()}"));

        return chips;
    }

    private IReadOnlyList<string> GetObjectiveSeedChips()
    {
        var payload = _note.StructuredWorkspacePayload;
        if (payload is null || CurrentSeedContext is null)
        {
            return Array.Empty<string>();
        }

        var chips = new List<string>();
        var objective = payload.Objective;

        if (objective.PrimaryBodyPart != BodyPart.Other)
        {
            chips.Add($"Primary body part: {GetBodyPartDisplayLabel(objective.PrimaryBodyPart)}");
        }

        chips.AddRange(objective.RecommendedOutcomeMeasures
            .Where(value => !string.IsNullOrWhiteSpace(value))
            .OrderBy(value => value, StringComparer.OrdinalIgnoreCase)
            .Select(value => $"Outcome measure: {value.Trim()}"));

        return chips;
    }

