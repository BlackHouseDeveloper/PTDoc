    private async Task HandlePrevSection()
    {
        var previous = GetAdjacentSection(-1);
        if (previous.HasValue)
        {
            await HandleSectionChangedSafelyAsync(previous.Value);
        }
    }

    private async Task HandleNextSection()
    {
        var next = GetAdjacentSection(1);
        if (next.HasValue)
        {
            await HandleSectionChangedSafelyAsync(next.Value);
        }
    }

    private SoapSection? GetAdjacentSection(int direction)
    {
        var sections = CurrentSoapSections;
        var index = -1;
        for (var i = 0; i < sections.Count; i++)
        {
            if (sections[i] == _note.ActiveSection)
            {
                index = i;
                break;
            }
        }

        if (index < 0)
        {
            return null;
        }

        var nextIndex = index + direction;
        if (nextIndex < 0 || nextIndex >= sections.Count)
        {
            return null;
        }

        return sections[nextIndex];
    }

