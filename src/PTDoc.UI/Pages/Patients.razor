@page "/patients"
@attribute [Authorize(Policy = AuthorizationPolicies.PatientRead)]
@using System.Net
@using PTDoc.Application.Configurations.Header
@using PTDoc.Application.Services
@using PTDoc.Application.DTOs
@using PTDoc.UI.Components.Patients.Models
@inject NavigationManager NavigationManager
@inject IPatientService PatientService
@inject IIntakeService IntakeService
@inject IToastService ToastService
@inject ILogger<Patients> Logger
@rendermode InteractiveServer
@implements IDisposable

<PageTitle>Patients - PTDoc</PageTitle>

<div class="patients-page">
    <GlobalPageHeader Configuration="patientsHeader">
        <AuthorizeView Policy="@AuthorizationPolicies.PatientWrite">
            <Authorized>
                <a href="/patients?action=add"
                   class="global-page-header-primary-action"
                   role="button"
                   @onclick="OpenAddPatientModal">
                    <svg class="global-page-header-primary-action-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M8 3.33337V12.6667" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M3.33334 8H12.6667" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <span>Add Patient</span>
                </a>
            </Authorized>
        </AuthorizeView>
        <AuthorizeView Policy="@AuthorizationPolicies.IntakeWrite">
            <Authorized>
                <button type="button" class="global-page-header-primary-action" @onclick="HandleSendIntakeAsync">
                    <svg class="global-page-header-primary-action-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M14.6667 2L7.33334 9.33333" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M14.6667 2L10 14.6667L7.33334 9.33333L2 6.66667L14.6667 2Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <span>Send Intake</span>
                </button>
            </Authorized>
        </AuthorizeView>
    </GlobalPageHeader>

    <div class="patients-page-body">
        <div class="patients-page-search">
            <PatientSearchInput 
                Value="@searchQuery"
                ValueChanged="@HandleSearchChanged"
                Placeholder="Search by name, MRN, or email"
            />
        </div>

        <div class="patients-page-content" aria-busy="@AriaBusy">
            @if (isLoading && patients.Count == 0)
            {
                <section class="patients-page-state" role="status" aria-live="polite" data-testid="patients-loading-state">
                    @for (var i = 0; i < 6; i++)
                    {
                        <LoadingSkeleton Variant="SkeletonVariant.Rectangle" Size="SkeletonSize.Large" />
                    }
                </section>
            }
            else if (!string.IsNullOrWhiteSpace(loadErrorMessage) && patients.Count == 0)
            {
                <section class="patients-page-state patients-page-state--error" role="alert" data-testid="patients-error-state">
                    <h2>Unable to load patients</h2>
                    <p>@loadErrorMessage</p>
                    <button type="button" class="patients-page-state-button" @onclick="RetryLoadPatientsAsync" disabled="@isLoading">Retry</button>
                </section>
            }
            else
            {
                @if (!string.IsNullOrWhiteSpace(loadErrorMessage))
                {
                    <section class="patients-page-inline-error" role="alert" data-testid="patients-inline-error">
                        <span>@loadErrorMessage</span>
                        <button type="button" class="patients-page-state-button" @onclick="RetryLoadPatientsAsync" disabled="@isLoading">Retry</button>
                    </section>
                }

                <PatientCardSection 
                    Items="@GetFilteredPatients()" 
                    OnCardClick="@HandlePatientClick" 
                />
            }
        </div>
    </div>
</div>

<AddPatientModal 
    @bind-IsOpen="isAddPatientModalOpen"
    OnSubmit="@HandleAddPatient"
/>

<SendIntakeModal
    IsOpen="@isSendIntakeModalOpen"
    IsOpenChanged="@HandleSendIntakeOpenChanged"
    AvailablePatients="@availablePatients"
    InitialPatientId="@initialSendIntakePatientId"
    OnSubmit="@HandleIntakeSubmit" />

@code {
    private readonly HeaderConfiguration patientsHeader = new()
    {
        Route = "/patients",
        Title = "Patients",
        Subtitle = "Patient directory",
        ShowPrimaryAction = false,
        ShowSyncControls = false,
        ShowStatusBadge = false
    };

    private bool isLoading = false;
    private bool isAddPatientModalOpen = false;
    private bool isSendIntakeModalOpen = false;
    private bool isLoadingAvailablePatients = false;
    private string searchQuery = string.Empty;
    private string? initialSendIntakePatientId;
    private PatientResponse? pendingSendIntakePatient;
    private string? loadErrorMessage;
    private List<PatientListItemVm> patients = new();
    private List<SendIntakeModal.PatientOption> availablePatients = new();
    private CancellationTokenSource? _searchCts;
    private int _loadSequence;
    private bool _isPreparingPendingSendIntake;
    private string? _lastAppliedRouteAction;
    private string AriaBusy => isLoading ? "true" : "false";

    protected override async Task OnInitializedAsync()
    {
        ApplyRouteAction();
        await LoadPatientsAsync();
    }

    protected override void OnParametersSet()
    {
        ApplyRouteAction();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (pendingSendIntakePatient is null || isAddPatientModalOpen || _isPreparingPendingSendIntake)
        {
            return;
        }

        var patient = pendingSendIntakePatient;
        pendingSendIntakePatient = null;
        _isPreparingPendingSendIntake = true;

        try
        {
            await PrepareSendIntakeForPatientAsync(patient);
        }
        finally
        {
            _isPreparingPendingSendIntake = false;
        }
    }

    private async Task LoadPatientsAsync(string? query = null, CancellationToken cancellationToken = default)
    {
        var sequence = Interlocked.Increment(ref _loadSequence);
        isLoading = true;
        loadErrorMessage = null;
        StateHasChanged();

        try
        {
            var results = await PatientService.SearchAsync(query: query, take: 200, cancellationToken: cancellationToken);

            if (cancellationToken.IsCancellationRequested || sequence != _loadSequence)
            {
                return;
            }

            patients = results.Select(ToVm).ToList();
        }
        catch (OperationCanceledException) when (cancellationToken.IsCancellationRequested)
        {
            // Superseded by a newer search — ignore stale results.
            return;
        }
        catch (Exception ex)
        {
            if (sequence != _loadSequence)
            {
                return;
            }

            Logger.LogWarning(ex, "Failed to load patient directory.");
            loadErrorMessage = "Patients could not be retrieved. Retry when the connection is available.";
            ToastService.ShowError("Failed to load patients. Retry when the connection is available.");
        }
        finally
        {
            if (sequence == _loadSequence)
            {
                isLoading = false;
                StateHasChanged();
            }
        }
    }

    private async Task HandleSearchChanged(string value)
    {
        searchQuery = value;

        _searchCts?.Cancel();
        _searchCts?.Dispose();
        _searchCts = new CancellationTokenSource();
        var token = _searchCts.Token;

        try
        {
            await LoadPatientsAsync(string.IsNullOrWhiteSpace(value) ? null : value, token);
        }
        catch (TaskCanceledException)
        {
            // Superseded by a newer keystroke — ignore.
        }
    }

    private IReadOnlyList<PatientListItemVm> GetFilteredPatients() => patients;

    private Task RetryLoadPatientsAsync()
        => LoadPatientsAsync(string.IsNullOrWhiteSpace(searchQuery) ? null : searchQuery);

    private void OpenAddPatientModal()
    {
        isAddPatientModalOpen = true;
    }

    private void ApplyRouteAction()
    {
        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        if (string.Equals(_lastAppliedRouteAction, uri.Query, StringComparison.Ordinal))
        {
            return;
        }

        _lastAppliedRouteAction = uri.Query;

        if (TryGetQueryParameter(uri.Query, "action", out var action)
            && string.Equals(action, "add", StringComparison.OrdinalIgnoreCase))
        {
            isAddPatientModalOpen = true;
        }
    }

    private static bool TryGetQueryParameter(string query, string key, out string value)
    {
        value = string.Empty;
        if (string.IsNullOrWhiteSpace(query))
        {
            return false;
        }

        foreach (var pair in query.TrimStart('?').Split('&', StringSplitOptions.RemoveEmptyEntries))
        {
            var parts = pair.Split('=', 2);
            if (parts.Length == 0 || !string.Equals(parts[0], key, StringComparison.OrdinalIgnoreCase))
            {
                continue;
            }

            value = parts.Length > 1 ? Uri.UnescapeDataString(parts[1].Replace("+", " ", StringComparison.Ordinal)) : string.Empty;
            return true;
        }

        return false;
    }

    private async Task HandleSendIntakeAsync()
    {
        initialSendIntakePatientId = null;
        if (availablePatients.Count == 0)
        {
            await LoadAvailablePatientsAsync();
        }

        isSendIntakeModalOpen = true;
    }

    private async Task<bool> HandleAddPatient(AddPatientModal.PatientFormData formData)
    {
        if (!formData.DateOfBirth.HasValue)
        {
            ToastService.ShowError("Date of birth is required.");
            return false;
        }

        try
        {
            var request = new PTDoc.Application.DTOs.CreatePatientRequest
            {
                FirstName = formData.FirstName,
                LastName = formData.LastName,
                DateOfBirth = formData.DateOfBirth.Value,
                Email = formData.Email,
                Phone = formData.PhoneNumber,
                PayerInfoJson = formData.PayerInfoJson,
                ReferringPhysician = string.IsNullOrWhiteSpace(formData.ReferringPhysician) ? null : formData.ReferringPhysician,
                PhysicianNpi = string.IsNullOrWhiteSpace(formData.PhysicianNpi) ? null : formData.PhysicianNpi,
                AuthorizationNumber = string.IsNullOrWhiteSpace(formData.AuthorizationNumber) ? null : formData.AuthorizationNumber
            };
            var created = await PatientService.CreateAsync(request);
            ToastService.ShowSuccess("Patient added.");

            searchQuery = string.Empty;
            await LoadPatientsAsync();
            EnsureCreatedPatientVisible(created);

            if (formData.SubmitIntent == AddPatientModal.PatientSubmitIntent.AddPatientAndSendIntake)
            {
                pendingSendIntakePatient = created;
            }

            return true;
        }
        catch (HttpRequestException ex) when (ex.StatusCode == HttpStatusCode.Forbidden)
        {
            Logger.LogWarning(ex, "Patient creation was forbidden for the current user.");
            ToastService.ShowError("You do not have permission to add patients.");
            return false;
        }
        catch (HttpRequestException ex) when (ex.StatusCode == HttpStatusCode.BadRequest)
        {
            Logger.LogWarning(ex, "Patient creation failed validation.");
            ToastService.ShowError("Review the patient details and try again.");
            return false;
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Patient creation failed.");
            ToastService.ShowError("Failed to add patient. Please try again.");
            return false;
        }
    }

    private void HandlePatientClick(PatientListItemVm patient)
    {
        NavigationManager.NavigateTo($"/patient/{patient.Id}");
    }

    private async Task PrepareSendIntakeForPatientAsync(PatientResponse patient)
    {
        initialSendIntakePatientId = patient.Id.ToString("D");
        await LoadAvailablePatientsAsync();
        UpsertAvailablePatient(ToPatientOption(patient));
        isSendIntakeModalOpen = true;
        StateHasChanged();
    }

    private async Task LoadAvailablePatientsAsync()
    {
        if (isLoadingAvailablePatients)
        {
            return;
        }

        try
        {
            isLoadingAvailablePatients = true;
            var results = await IntakeService.SearchEligiblePatientsAsync(take: 200);
            availablePatients = results.Select(ToPatientOption).ToList();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(
                "Failed to load eligible patients for intake invite workflow. ErrorType={ErrorType}",
                ex.GetType().Name);
            ToastService.ShowError("Unable to load eligible patients for intake invites.");
        }
        finally
        {
            isLoadingAvailablePatients = false;
        }
    }

    private Task HandleSendIntakeOpenChanged(bool value)
    {
        isSendIntakeModalOpen = value;
        if (!value)
        {
            initialSendIntakePatientId = null;
        }

        return Task.CompletedTask;
    }

    private Task HandleIntakeSubmit(SendIntakeModal.IntakeFormData formData)
    {
        initialSendIntakePatientId = null;
        return Task.CompletedTask;
    }

    private void EnsureCreatedPatientVisible(PatientResponse patient)
    {
        var created = ToVm(patient);
        patients.RemoveAll(existing => string.Equals(existing.Id, created.Id, StringComparison.Ordinal));
        patients.Insert(0, created);
    }

    private void UpsertAvailablePatient(SendIntakeModal.PatientOption patient)
    {
        availablePatients.RemoveAll(existing => string.Equals(existing.Id, patient.Id, StringComparison.Ordinal));
        availablePatients.Insert(0, patient);
    }

    private static PatientListItemVm ToVm(PatientListItemResponse p) => new()
    {
        Id = p.Id.ToString(),
        DisplayName = p.DisplayName,
        MedicalRecordNumber = p.MedicalRecordNumber,
        Email = p.Email,
        Phone = p.Phone,
        DateOfBirth = p.DateOfBirth == default ? null : p.DateOfBirth.ToString("MMM d, yyyy"),
        StatusLabel = p.IsArchived ? "Inactive" : "Active",
        StatusVariant = p.IsArchived ? BadgeVariant.Default : BadgeVariant.Success
    };

    private static PatientListItemVm ToVm(PatientResponse p) => new()
    {
        Id = p.Id.ToString("D"),
        DisplayName = BuildDisplayName(p.FirstName, p.LastName),
        MedicalRecordNumber = p.MedicalRecordNumber,
        Email = p.Email,
        Phone = p.Phone,
        DateOfBirth = p.DateOfBirth == default ? null : p.DateOfBirth.ToString("MMM d, yyyy"),
        StatusLabel = p.IsArchived ? "Inactive" : "Active",
        StatusVariant = p.IsArchived ? BadgeVariant.Default : BadgeVariant.Success
    };

    private static SendIntakeModal.PatientOption ToPatientOption(PatientListItemResponse p) => new()
    {
        Id = p.Id.ToString("D"),
        Name = p.DisplayName,
        Email = p.Email,
        PhoneNumber = p.Phone
    };

    private static SendIntakeModal.PatientOption ToPatientOption(PatientResponse p) => new()
    {
        Id = p.Id.ToString("D"),
        Name = BuildDisplayName(p.FirstName, p.LastName),
        Email = p.Email,
        PhoneNumber = p.Phone
    };

    private static string BuildDisplayName(string firstName, string lastName)
        => $"{firstName} {lastName}".Trim();

    public void Dispose()
    {
        _searchCts?.Cancel();
        _searchCts?.Dispose();
    }
}
