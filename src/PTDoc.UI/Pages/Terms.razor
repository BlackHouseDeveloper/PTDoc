@page "/terms"
@page "/terms-and-conditions"
@attribute [AllowAnonymous]
@layout PublicDocumentLayout
@rendermode InteractiveServer

<PageTitle>Terms and Conditions - PTDoc</PageTitle>

<article class="public-policy-page" aria-labelledby="terms-title">
    <header class="public-policy-page__hero">
        <p class="public-policy-page__eyebrow">Terms and Conditions</p>
        <h1 id="terms-title">PTDoc Terms and Conditions</h1>
        <p>
            These terms describe patient-facing use of PTDoc secure intake, communication, and related
            workflow pages made available by participating physical therapy clinics.
        </p>
    </header>

    <section class="public-policy-page__section" aria-labelledby="terms-use-title">
        <h2 id="terms-use-title">Permitted Use</h2>
        <p>
            PTDoc is provided to support healthcare intake, communication, documentation, and clinic
            workflow activities. Patients may use secure intake links only for their own intake
            responses or as otherwise authorized by their clinic.
        </p>
    </section>

    <section class="public-policy-page__section" aria-labelledby="terms-accuracy-title">
        <h2 id="terms-accuracy-title">Patient Responsibilities</h2>
        <ul>
            <li>Provide accurate contact, demographic, health, insurance, and consent information.</li>
            <li>Keep secure intake links and verification codes private.</li>
            <li>Contact the clinic directly for medical advice, urgent care, or emergency concerns.</li>
            <li>Notify the clinic if submitted intake information needs correction.</li>
        </ul>
    </section>

    <section class="public-policy-page__section" aria-labelledby="terms-communications-title">
        <h2 id="terms-communications-title">SMS and Email Communications</h2>
        <p>
            By entering a mobile number in the secure intake workflow and selecting Text Message,
            patients consent to receive transactional SMS messages related to secure intake access and
            care-related workflow notices. Message and data rates may apply. Message frequency varies.
            Reply <strong>STOP</strong> to opt out of SMS messages and <strong>HELP</strong> for help.
        </p>
    </section>

    <section class="public-policy-page__section" aria-labelledby="terms-medical-title">
        <h2 id="terms-medical-title">No Emergency or Medical Advice Service</h2>
        <p>
            PTDoc is not an emergency service and does not replace clinical judgment or direct
            communication with a licensed healthcare professional. Patients should call emergency
            services for urgent or life-threatening symptoms.
        </p>
    </section>

    <section class="public-policy-page__section" aria-labelledby="terms-privacy-title">
        <h2 id="terms-privacy-title">Privacy</h2>
        <p>
            Use of PTDoc is also governed by the <a href="/privacy">PTDoc Privacy Policy</a> and
            applicable clinic privacy notices.
        </p>
        <p>Effective date: July 6, 2026.</p>
    </section>
</article>
