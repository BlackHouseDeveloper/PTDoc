@page "/patient/{id}"
@attribute [Authorize(Policy = AuthorizationPolicies.PatientRead)]
@rendermode InteractiveServer
@inject NavigationManager NavigationManager
@implements IDisposable
@using Microsoft.AspNetCore.Components.Routing
@using PTDoc.Application.Services
@using PTDoc.Application.DTOs
@using PTDoc.UI.Components.Patients.Profile.Models
@inject IPatientService PatientService
@inject INoteService NoteService
@inject IAppointmentService AppointmentService
@inject IIntakeService IntakeService
@inject IToastService ToastService

<PageTitle>Patient Profile - PTDoc</PageTitle>

<div class="patient-profile-page">
    <div class="patient-profile-page-body">
        <div class="patient-profile-page-container">
            @if (isLoading)
            {
                <section class="patient-profile-state" role="status" aria-live="polite">
                    <LoadingSkeleton Variant="SkeletonVariant.Rectangle" Size="SkeletonSize.Large" />
                    <LoadingSkeleton Variant="SkeletonVariant.Rectangle" Size="SkeletonSize.Large" />
                    <LoadingSkeleton Variant="SkeletonVariant.Rectangle" Size="SkeletonSize.Large" />
                </section>
            }
            else if (!string.IsNullOrWhiteSpace(loadErrorMessage))
            {
                <section class="patient-profile-state" role="alert">
                    <div class="patient-profile-state-card">
                        <h2>Patient profile unavailable</h2>
                        <p>@loadErrorMessage</p>
                        <div class="patient-profile-state-actions">
                            <button type="button" class="btn btn--primary" @onclick="ReloadProfileAsync">Retry</button>
                            <button type="button" class="btn btn--secondary" @onclick="HandleBack">Back to Patients</button>
                        </div>
                    </div>
                </section>
            }
            else
            {
                <PatientDemographicsCardEditable Patient="@patient" OnPatientUpdated="ReloadProfileAsync" />

                <PatientPrimaryActionButton
                    Label="Start New Note"
                    Href="@($"/patient/{Uri.EscapeDataString(Id ?? string.Empty)}?action=new-note")" />

                @if (isNoteTypeChooserOpen)
                {
                    <section class="patient-profile-note-chooser"
                             aria-label="Choose note type"
                             data-testid="patient-note-type-chooser">
                        <div>
                            <h2>Choose Note Type</h2>
                            <p>Select the documentation workflow for this patient.</p>
                        </div>
                        <div class="patient-profile-note-chooser__actions">
                            @foreach (var noteType in noteTypeOptions)
                            {
                                <button type="button"
                                        class="btn btn--secondary"
                                        @onclick="() => HandleCreateNoteType(noteType)">
                                    @noteType
                                </button>
                            }
                        </div>
                    </section>
                }

                <PatientClinicalInfoCardEditable
                    Patient="@patient"
                    TimelineEntries="@timelineEntries"
                    RecentNotes="@recentNotes"
                    IsLoading="@timelineLoading"
                    TimelineErrorMessage="@timelineErrorMessage"
                    IntakeStateMessage="@intakeStateMessage"
                    IntakeStatusVariant="@intakeStatusVariant"
                    InitialTab="@selectedProfileTab"
                    OnRetry="ReloadTimelineAsync"
                    OnReviewIntake="HandleReviewIntake"
                    OnViewNote="HandleViewNote"
                    OnEditNote="HandleEditNote" />
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public string Id { get; set; } = default!;

    private PatientProfileVm patient = new();
    private readonly List<TimelineEntry> timelineEntries = new();
    private readonly List<NoteListItemApiResponse> recentNotes = new();
    private bool isLoading = true;
    private bool timelineLoading;
    private string? loadErrorMessage;
    private string? timelineErrorMessage;
    private string? intakeStateMessage;
    private string intakeStatusVariant = "default";
    private string selectedProfileTab = "timeline";
    private string? lastAppliedRouteQuery;
    private Guid currentPatientId;
    private bool isNoteTypeChooserOpen;
    private static readonly TimeSpan TimelineLookbackWindow = TimeSpan.FromDays(180);
    private static readonly string[] noteTypeOptions =
    [
        "Daily Treatment Note",
        "Evaluation Note",
        "Progress Note",
        "Discharge Note",
        "Dry Needling Note"
    ];

    protected override async Task OnInitializedAsync()
    {
        NavigationManager.LocationChanged += HandleLocationChanged;
        ApplyRouteQuery();
        await ReloadProfileAsync();
    }

    protected override void OnParametersSet()
    {
        ApplyRouteQuery();
    }

    private async Task ReloadProfileAsync()
    {
        isLoading = true;
        loadErrorMessage = null;
        timelineErrorMessage = null;
        intakeStateMessage = null;
        intakeStatusVariant = "default";
        timelineEntries.Clear();
        recentNotes.Clear();
        timelineLoading = true;
        StateHasChanged();

        if (!Guid.TryParse(Id, out var patientId))
        {
            NavigationManager.NavigateTo("/patients");
            return;
        }

        try
        {
            currentPatientId = patientId;

            var response = await PatientService.GetByIdAsync(patientId);
            if (response is null)
            {
                NavigationManager.NavigateTo("/patients");
                return;
            }

            patient = new PatientProfileVm
            {
                Id = response.Id.ToString(),
                DisplayName = $"{response.FirstName} {response.LastName}".Trim(),
                DateOfBirth = response.DateOfBirth != default
                    ? response.DateOfBirth.ToString("M/d/yyyy")
                    : null,
                Email = response.Email,
                PhoneNumber = response.Phone,
                Address = BuildAddress(response)
            };

            await ReloadTimelineAsync();
        }
        catch (Exception ex)
        {
            loadErrorMessage = GetUserFacingMessage(ex, "Failed to load patient. Please try again.");
            ToastService.ShowError(loadErrorMessage);
        }
        finally
        {
            isLoading = false;
            timelineLoading = false;
        }
    }

    private static string? BuildAddress(PatientResponse r)
    {
        var parts = new[] { r.AddressLine1, r.AddressLine2, r.City, r.State, r.ZipCode }
            .Where(p => !string.IsNullOrWhiteSpace(p));
        return string.Join(", ", parts) is { Length: > 0 } addr ? addr : null;
    }

    private async Task ReloadTimelineAsync()
    {
        if (currentPatientId == Guid.Empty)
        {
            timelineLoading = false;
            return;
        }

        timelineLoading = true;
        timelineErrorMessage = null;
        intakeStateMessage = null;
        intakeStatusVariant = "default";
        timelineEntries.Clear();
        recentNotes.Clear();
        StateHasChanged();

        var timelineRows = new List<(DateTime TimestampUtc, TimelineEntry Entry)>();
        var errors = new List<string>();

        try
        {
            var notes = await NoteService.GetNotesAsync(patientId: currentPatientId, take: 25);
            recentNotes.AddRange(notes);
            timelineRows.AddRange(notes.Select(CreateNoteTimelineEntry));
        }
        catch (Exception ex)
        {
            errors.Add(GetUserFacingMessage(ex, "Notes could not be loaded."));
        }

        try
        {
            var timelineStartDate = DateTime.UtcNow.Date.Subtract(TimelineLookbackWindow);
            var timelineEndDate = DateTime.UtcNow.Date;
            var appointments = await AppointmentService.GetByPatientAsync(
                currentPatientId,
                timelineStartDate,
                timelineEndDate);

            timelineRows.AddRange(appointments.Select(CreateAppointmentTimelineEntry));
        }
        catch (Exception ex)
        {
            errors.Add(GetUserFacingMessage(ex, "Appointments could not be loaded."));
        }

        try
        {
            var intake = await IntakeService.GetLatestByPatientIdAsync(currentPatientId);
            intakeStateMessage = BuildIntakeStateMessage(intake);
            intakeStatusVariant = BuildIntakeStatusVariant(intake);
            if (intake is not null)
            {
                timelineRows.Add(CreateIntakeTimelineEntry(intake));
            }
        }
        catch (Exception ex)
        {
            errors.Add(GetUserFacingMessage(ex, "Intake status could not be loaded."));
        }

        timelineEntries.AddRange(
            timelineRows
                .OrderByDescending(row => row.TimestampUtc)
                .Select(row => row.Entry));

        timelineErrorMessage = errors.Count == 0 ? null : string.Join(" ", errors);
        timelineLoading = false;
    }

    private static (DateTime TimestampUtc, TimelineEntry Entry) CreateNoteTimelineEntry(NoteListItemApiResponse note)
    {
        var timestampUtc = DateTime.SpecifyKind(note.LastModifiedUtc, DateTimeKind.Utc);
        var localTimestamp = timestampUtc.ToLocalTime();
        var type = MapNoteTimelineType(note.NoteType);

        return (
            timestampUtc,
            new TimelineEntry
            {
                Type = type,
                Title = note.NoteType,
                Description = GetNoteDescription(note),
                Date = localTimestamp.ToString("M/d/yyyy"),
                Time = localTimestamp.ToString("h:mm tt")
            });
    }

    private static (DateTime TimestampUtc, TimelineEntry Entry) CreateAppointmentTimelineEntry(AppointmentListItemResponse appointment)
    {
        var timestampUtc = DateTime.SpecifyKind(appointment.StartTimeUtc, DateTimeKind.Utc);
        var localTimestamp = timestampUtc.ToLocalTime();
        var appointmentType = string.IsNullOrWhiteSpace(appointment.AppointmentType)
            ? "Appointment"
            : appointment.AppointmentType;

        return (
            timestampUtc,
            new TimelineEntry
            {
                Type = "appointment",
                Title = appointmentType,
                Description = BuildAppointmentDescription(appointment),
                Date = localTimestamp.ToString("M/d/yyyy"),
                Time = localTimestamp.ToString("h:mm tt")
            });
    }

    private static (DateTime TimestampUtc, TimelineEntry Entry) CreateIntakeTimelineEntry(IntakeResponseDraft intake)
    {
        var timestampUtc = DateTime.SpecifyKind(
            intake.SubmittedAt ?? intake.LastModifiedUtc ?? DateTime.UtcNow,
            DateTimeKind.Utc);
        var localTimestamp = timestampUtc.ToLocalTime();

        return (
            timestampUtc,
            new TimelineEntry
            {
                Type = "intake",
                Title = BuildIntakeTimelineTitle(intake),
                Description = BuildIntakeStateMessage(intake),
                Date = localTimestamp.ToString("M/d/yyyy"),
                Time = localTimestamp.ToString("h:mm tt")
            });
    }

    private static string BuildIntakeTimelineTitle(IntakeResponseDraft intake)
    {
        if (intake.ReviewedAtUtc.HasValue)
        {
            return "Reviewed Intake";
        }

        return intake.IsSubmitted || intake.IsLocked ? "Submitted Intake" : "Intake Draft";
    }

    private static string MapNoteTimelineType(string noteType)
    {
        if (noteType.Contains("evaluation", StringComparison.OrdinalIgnoreCase))
        {
            return "evaluation";
        }

        if (noteType.Contains("exercise", StringComparison.OrdinalIgnoreCase)
            || noteType.Contains("dry needling", StringComparison.OrdinalIgnoreCase))
        {
            return "exercise";
        }

        return "note";
    }

    private static string GetNoteDescription(NoteListItemApiResponse note)
    {
        if (note.NoteStatus is null)
        {
            return note.IsSigned ? "Signed clinical note" : "Draft note saved";
        }

        return note.NoteStatus.Value switch
        {
            NoteStatus.PendingCoSign => "Pending PT co-sign",
            NoteStatus.Signed => "Signed clinical note",
            NoteStatus.Draft => "Draft note saved",
            _ => note.IsSigned ? "Signed clinical note" : "Draft note saved"
        };
    }

    private static string BuildAppointmentDescription(AppointmentListItemResponse appointment)
    {
        var status = string.IsNullOrWhiteSpace(appointment.AppointmentStatus)
            ? "Scheduled"
            : appointment.AppointmentStatus;

        if (!string.IsNullOrWhiteSpace(appointment.ClinicianName))
        {
            return $"{status} with {appointment.ClinicianName}";
        }

        return status;
    }

    private static string BuildIntakeStateMessage(IntakeResponseDraft? intake)
    {
        if (intake is null)
        {
            return string.Empty;
        }

        if (intake.IsSubmitted && intake.IsLocked)
        {
            return intake.ReviewedAtUtc.HasValue
                ? "Intake reviewed."
                : "Intake submitted and awaiting clinician review.";
        }

        if (intake.IsLocked)
        {
            return "Intake draft is locked.";
        }

        return "Intake draft is in progress.";
    }

    private static string BuildIntakeStatusVariant(IntakeResponseDraft? intake)
    {
        if (intake is null)
        {
            return "default";
        }

        if (intake.IsSubmitted && intake.IsLocked)
        {
            return intake.ReviewedAtUtc.HasValue ? "reviewed" : "submitted";
        }

        if (intake.IsLocked)
        {
            return "locked";
        }

        return "draft";
    }

    private static string GetUserFacingMessage(Exception exception, string fallback)
    {
        return exception switch
        {
            HttpRequestException httpException when !string.IsNullOrWhiteSpace(httpException.Message) => httpException.Message,
            InvalidOperationException invalidOperationException when !string.IsNullOrWhiteSpace(invalidOperationException.Message) => invalidOperationException.Message,
            _ => fallback
        };
    }

    private bool ApplyRouteQuery()
    {
        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        var routeKey = uri.PathAndQuery;
        if (string.Equals(lastAppliedRouteQuery, routeKey, StringComparison.Ordinal))
        {
            return false;
        }

        lastAppliedRouteQuery = routeKey;
        selectedProfileTab = "timeline";
        isNoteTypeChooserOpen = false;

        if (TryGetQueryParameter(uri.Query, "tab", out var tab)
            && IsValidProfileTab(tab))
        {
            selectedProfileTab = tab.ToLowerInvariant();
        }

        if (TryGetQueryParameter(uri.Query, "action", out var action)
            && string.Equals(action, "new-note", StringComparison.OrdinalIgnoreCase))
        {
            isNoteTypeChooserOpen = true;
        }

        return true;
    }

    private static bool IsValidProfileTab(string tab) =>
        string.Equals(tab, "timeline", StringComparison.OrdinalIgnoreCase)
        || string.Equals(tab, "notes", StringComparison.OrdinalIgnoreCase)
        || string.Equals(tab, "documents", StringComparison.OrdinalIgnoreCase)
        || string.Equals(tab, "communications", StringComparison.OrdinalIgnoreCase);

    private static bool TryGetQueryParameter(string query, string key, out string value)
    {
        value = string.Empty;
        if (string.IsNullOrWhiteSpace(query))
        {
            return false;
        }

        foreach (var pair in query.TrimStart('?').Split('&', StringSplitOptions.RemoveEmptyEntries))
        {
            var parts = pair.Split('=', 2);
            if (parts.Length == 0
                || !TryDecodeQueryPart(parts[0], out var decodedKey)
                || !string.Equals(decodedKey, key, StringComparison.OrdinalIgnoreCase))
            {
                continue;
            }

            if (parts.Length <= 1)
            {
                value = string.Empty;
                return true;
            }

            return TryDecodeQueryPart(parts[1], out value);
        }

        return false;
    }

    private static bool TryDecodeQueryPart(string rawValue, out string decodedValue)
    {
        decodedValue = string.Empty;

        try
        {
            decodedValue = Uri.UnescapeDataString(rawValue.Replace("+", " ", StringComparison.Ordinal));
            return !string.IsNullOrWhiteSpace(decodedValue);
        }
        catch (Exception ex) when (ex is UriFormatException or ArgumentException)
        {
            return false;
        }
    }

    private void HandleCreateNoteType(string noteType)
    {
        if (string.IsNullOrWhiteSpace(Id))
        {
            return;
        }

        var encodedNoteType = Uri.EscapeDataString(noteType);
        NavigationManager.NavigateTo($"/patient/{Uri.EscapeDataString(Id)}/new-note?noteType={encodedNoteType}");
    }

    private void HandleReviewIntake()
    {
        if (currentPatientId == Guid.Empty)
        {
            return;
        }

        NavigationManager.NavigateTo($"/intake/{currentPatientId}");
    }

    private void HandleViewNote(NoteListItemApiResponse note)
    {
        NavigationManager.NavigateTo($"/patient/{note.PatientId}/note/{note.Id}");
    }

    private void HandleEditNote(NoteListItemApiResponse note)
    {
        NavigationManager.NavigateTo($"/patient/{note.PatientId}/note/{note.Id}");
    }

    private void HandleBack()
    {
        NavigationManager.NavigateTo("/patients");
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs args)
    {
        _ = InvokeAsync(() =>
        {
            if (ApplyRouteQuery())
            {
                StateHasChanged();
            }
        });
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= HandleLocationChanged;
    }
}
