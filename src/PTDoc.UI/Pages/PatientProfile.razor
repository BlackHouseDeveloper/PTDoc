@page "/patient/{id}"
@attribute [Authorize]
@rendermode InteractiveServer
@inject NavigationManager NavigationManager

<PageTitle>Patient Profile - PTDoc</PageTitle>

<div class="patient-profile-page">
    <div class="patient-profile-page-body">
        <div class="patient-profile-page-container">
            <PatientDemographicsCardEditable Patient="@patient" />
            
            <PatientPrimaryActionButton 
                Label="Start New Note" 
                OnClick="@HandleStartNote" 
            />
            
            <PatientClinicalInfoCardEditable Patient="@patient" />
        </div>
    </div>
</div>

@code {
    [Parameter] public string Id { get; set; } = default!;

    private PatientProfileVm patient = new();

    protected override void OnInitialized()
    {
        // TODO: Replace with IPatientService.GetById(Id)
        LoadSamplePatient();
    }

    private void LoadSamplePatient()
    {
        patient = new PatientProfileVm
        {
            Id = Id,
            DisplayName = "Sarah Johnson",
            DateOfBirth = "3/14/1985",
            Email = "sarah.johnson@email.com",
            PhoneNumber = "(555) 123-4567",
            Address = "123 Main St, Anytown, ST 12345",
            FlagsAndComorbidities = new List<string>
            {
                "Diabetes",
                "Balance Issues",
                "Hypertension"
            },
            PrimaryDiagnosis = "Lower back pain",
            SecondaryDiagnosis = "Sciatica",
            ReferringPhysician = "Dr. Smith",
            InsuranceProvider = "Blue Cross",
            AuthorizationNumber = "AUTH-2024-001"
        };
    }

    private void HandleStartNote()
    {
        if (string.IsNullOrWhiteSpace(Id))
        {
            return;
        }

        var existingNoteId = ResolveExistingNoteIdForPatient(Id);
        if (!string.IsNullOrWhiteSpace(existingNoteId))
        {
            // Existing note context: open note workspace in edit/view mode.
            NavigationManager.NavigateTo($"/patient/{Uri.EscapeDataString(Id)}/note/{Uri.EscapeDataString(existingNoteId)}");
            return;
        }

        // No existing note context: route to patient-scoped new-note flow.
        NavigationManager.NavigateTo($"/patient/{Uri.EscapeDataString(Id)}/new-note");
    }

    private string? ResolveExistingNoteIdForPatient(string patientId)
    {
        // TODO: Fetch notes for patient from API and pick target note using business rule:
        // - if exactly one active draft exists, open it
        // - if multiple notes exist, select most recently modified draft (or prompt user)
        // - if none exist, return null to start a new note

        // Mock: sample mapping for local navigation behavior testing only.
        var mockLatestNotesByPatient = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
        {
            ["PT001"] = "1",
            ["PT002"] = "2",
            ["PT003"] = "3"
        };

        return mockLatestNotesByPatient.TryGetValue(patientId, out var noteId) ? noteId : null;
    }
}
