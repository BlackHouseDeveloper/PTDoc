@* Patient Clinical Info Card - Tabbed interface for timeline, notes, and documents *@
@using PTDoc.Application.DTOs
@using PTDoc.UI.Components.Patients.Profile.Models

<div class="patient-clinical-info-card" data-testid="patient-clinical-info-card">
    @if (!string.IsNullOrWhiteSpace(IntakeStateMessage))
    {
        <section class="patient-clinical-info-intake-callout patient-clinical-info-intake-callout--@IntakeStatusVariant"
                 role="status"
                 aria-label="Patient intake status"
                 data-testid="patient-intake-status">
            <div>
                <p class="patient-clinical-info-intake-eyebrow">Intake status</p>
                <p class="patient-clinical-info-intake-message">@IntakeStateMessage</p>
            </div>
            @if (OnReviewIntake.HasDelegate)
            {
                <button type="button"
                        class="patient-demographics-card-edit-btn"
                        @onclick="ReviewIntakeAsync">
                    Review intake
                </button>
            }
        </section>
    }

    <div class="patient-clinical-info-tabs"
         role="tablist"
         aria-label="Patient profile sections"
         data-testid="patient-profile-tabs">
        <button type="button" 
                class="patient-clinical-info-tab @(selectedTab == "timeline" ? "active" : "")"
                id="patient-profile-tab-timeline"
                role="tab"
                aria-selected="@IsSelectedTab("timeline")"
                aria-controls="patient-profile-panel-timeline"
                data-testid="patient-profile-tab-timeline"
                @onclick="@(() => SelectTab("timeline"))">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="2"/>
                <path d="M8 4V8L11 11" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
            <span>Timeline</span>
        </button>
        <button type="button" 
                class="patient-clinical-info-tab @(selectedTab == "notes" ? "active" : "")"
                id="patient-profile-tab-notes"
                role="tab"
                aria-selected="@IsSelectedTab("notes")"
                aria-controls="patient-profile-panel-notes"
                data-testid="patient-profile-tab-notes"
                @onclick="@(() => SelectTab("notes"))">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M10 2H3.33333C2.59695 2 2 2.59695 2 3.33333V12.6667C2 13.403 2.59695 14 3.33333 14H12.6667C13.403 14 14 13.403 14 12.6667V6L10 2Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M10 2V6H14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span>Notes</span>
        </button>
    </div>

    <div class="patient-clinical-info-content"
         id="@SelectedPanelId"
         role="tabpanel"
         aria-labelledby="@SelectedTabId"
         data-testid="@SelectedPanelTestId">
        @if (selectedTab == "timeline")
        {
            @if (!string.IsNullOrWhiteSpace(TimelineErrorMessage))
            {
                <div class="patient-clinical-info-empty" role="alert">
                    <p>@TimelineErrorMessage</p>
                    @if (OnRetry.HasDelegate)
                    {
                        <button type="button" class="patient-demographics-card-edit-btn" @onclick="RetryTimelineAsync">
                            Retry
                        </button>
                    }
                </div>
            }
            else if (IsLoading)
            {
                <div class="patient-clinical-info-empty" role="status" aria-label="Loading timeline">
                    <LoadingSkeleton Variant="SkeletonVariant.Rectangle" Size="SkeletonSize.Large" />
                    <LoadingSkeleton Variant="SkeletonVariant.Rectangle" Size="SkeletonSize.Medium" />
                    <LoadingSkeleton Variant="SkeletonVariant.Rectangle" Size="SkeletonSize.Medium" />
                </div>
            }
            else if (TimelineEntries.Count == 0 && string.IsNullOrWhiteSpace(TimelineErrorMessage))
            {
                <div class="patient-clinical-info-empty">
                    <p>No recent timeline activity is available for this patient.</p>
                </div>
            }
            else
            {
                <div class="patient-clinical-info-timeline">
                    @foreach (var entry in TimelineEntries)
                    {
                        <div class="patient-clinical-info-timeline-item">
                            <div class="patient-clinical-info-timeline-icon @GetTimelineIconClass(entry.Type)">
                                @((MarkupString)GetTimelineIcon(entry.Type))
                            </div>
                            <div class="patient-clinical-info-timeline-details">
                                <div class="patient-clinical-info-timeline-main">
                                    <div class="patient-clinical-info-timeline-text">
                                        <h4 class="patient-clinical-info-timeline-title">@entry.Title</h4>
                                        <p class="patient-clinical-info-timeline-description">@entry.Description</p>
                                    </div>
                                    <div class="patient-clinical-info-timeline-meta">
                                        <p class="patient-clinical-info-timeline-date">@entry.Date</p>
                                        <p class="patient-clinical-info-timeline-time">@entry.Time</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        }
        else if (selectedTab == "notes")
        {
            @if (RecentNotes.Count == 0)
            {
                <div class="patient-clinical-info-empty">
                    <p>No recent notes are available for this patient.</p>
                </div>
            }
            else
            {
                <div class="patient-clinical-info-notes" aria-label="Recent patient notes">
                    @foreach (var note in RecentNotes)
                    {
                        <article class="patient-clinical-info-note">
                            <div>
                                <h4>@note.NoteType</h4>
                                <p>@(note.NoteStatus?.ToString() ?? (note.IsSigned ? "Signed" : "Draft")) • @note.DateOfService.ToString("M/d/yyyy")</p>
                            </div>
                            <div class="patient-clinical-info-note-actions">
                                <button type="button"
                                        class="patient-demographics-card-edit-btn"
                                        aria-label="View @note.NoteType for this patient"
                                        @onclick="() => ViewNoteAsync(note)">View</button>
                                @if (!note.IsSigned)
                                {
                                    <button type="button"
                                            class="patient-demographics-card-edit-btn"
                                            aria-label="Edit @note.NoteType for this patient"
                                            @onclick="() => EditNoteAsync(note)">Edit</button>
                                }
                            </div>
                        </article>
                    }
                </div>
            }
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired] public PatientProfileVm Patient { get; set; } = null!;
    [Parameter] public IReadOnlyList<TimelineEntry> TimelineEntries { get; set; } = Array.Empty<TimelineEntry>();
    [Parameter] public IReadOnlyList<NoteListItemApiResponse> RecentNotes { get; set; } = Array.Empty<NoteListItemApiResponse>();
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public string? TimelineErrorMessage { get; set; }
    [Parameter] public string? IntakeStateMessage { get; set; }
    [Parameter] public string IntakeStatusVariant { get; set; } = "default";
    [Parameter] public EventCallback OnRetry { get; set; }
    [Parameter] public EventCallback OnReviewIntake { get; set; }
    [Parameter] public EventCallback<NoteListItemApiResponse> OnViewNote { get; set; }
    [Parameter] public EventCallback<NoteListItemApiResponse> OnEditNote { get; set; }

    private string selectedTab = "timeline";

    private void SelectTab(string tab)
    {
        selectedTab = tab;
    }

    private string IsSelectedTab(string tab)
        => string.Equals(selectedTab, tab, StringComparison.Ordinal) ? "true" : "false";

    private string SelectedPanelId => $"patient-profile-panel-{selectedTab}";

    private string SelectedTabId => $"patient-profile-tab-{selectedTab}";

    private string SelectedPanelTestId => $"patient-profile-panel-{selectedTab}";

    private string GetTimelineIconClass(string type)
    {
        return type switch
        {
            "evaluation" => "icon-evaluation",
            "note" => "icon-note",
            "exercise" => "icon-exercise",
            "appointment" => "icon-note",
            "intake" => "icon-default",
            _ => "icon-default"
        };
    }

    private string GetTimelineIcon(string type)
    {
        return type switch
        {
            "evaluation" => @"<svg width=""20"" height=""20"" viewBox=""0 0 20 20"" fill=""none"" xmlns=""http://www.w3.org/2000/svg""><path d=""M10 18C14.4183 18 18 14.4183 18 10C18 5.58172 14.4183 2 10 2C5.58172 2 2 5.58172 2 10C2 14.4183 5.58172 18 10 18Z"" stroke=""currentColor"" stroke-width=""2""/><path d=""M10 6V10L13 13"" stroke=""currentColor"" stroke-width=""2"" stroke-linecap=""round""/></svg>",
            "note" => @"<svg width=""20"" height=""20"" viewBox=""0 0 20 20"" fill=""none"" xmlns=""http://www.w3.org/2000/svg""><path d=""M12 3H4C3.44772 3 3 3.44772 3 4V16C3 16.5523 3.44772 17 4 17H16C16.5523 17 17 16.5523 17 16V8L12 3Z"" stroke=""currentColor"" stroke-width=""2""/><path d=""M12 3V8H17"" stroke=""currentColor"" stroke-width=""2""/></svg>",
            "exercise" => @"<svg width=""20"" height=""20"" viewBox=""0 0 20 20"" fill=""none"" xmlns=""http://www.w3.org/2000/svg""><path d=""M16 6L10 12L6 8L2 12"" stroke=""currentColor"" stroke-width=""2"" stroke-linecap=""round"" stroke-linejoin=""round""/><path d=""M12 6H16V10"" stroke=""currentColor"" stroke-width=""2"" stroke-linecap=""round"" stroke-linejoin=""round""/></svg>",
            "appointment" => @"<svg width=""20"" height=""20"" viewBox=""0 0 20 20"" fill=""none"" xmlns=""http://www.w3.org/2000/svg""><rect x=""3"" y=""4"" width=""14"" height=""13"" rx=""2"" stroke=""currentColor"" stroke-width=""2""/><path d=""M3 8H17"" stroke=""currentColor"" stroke-width=""2"" stroke-linecap=""round""/><path d=""M6 2V5"" stroke=""currentColor"" stroke-width=""2"" stroke-linecap=""round""/><path d=""M14 2V5"" stroke=""currentColor"" stroke-width=""2"" stroke-linecap=""round""/></svg>",
            "intake" => @"<svg width=""20"" height=""20"" viewBox=""0 0 20 20"" fill=""none"" xmlns=""http://www.w3.org/2000/svg""><path d=""M6 3.5H13L16 6.5V16.5C16 17.0523 15.5523 17.5 15 17.5H6C5.44772 17.5 5 17.0523 5 16.5V4.5C5 3.94772 5.44772 3.5 6 3.5Z"" stroke=""currentColor"" stroke-width=""2"" stroke-linejoin=""round""/><path d=""M9 8H13"" stroke=""currentColor"" stroke-width=""2"" stroke-linecap=""round""/><path d=""M9 11H13"" stroke=""currentColor"" stroke-width=""2"" stroke-linecap=""round""/><path d=""M8 8H8.01"" stroke=""currentColor"" stroke-width=""2"" stroke-linecap=""round""/><path d=""M8 11H8.01"" stroke=""currentColor"" stroke-width=""2"" stroke-linecap=""round""/></svg>",
            _ => @"<svg width=""20"" height=""20"" viewBox=""0 0 20 20"" fill=""none"" xmlns=""http://www.w3.org/2000/svg""><circle cx=""10"" cy=""10"" r=""8"" stroke=""currentColor"" stroke-width=""2""/></svg>"
        };
    }

    private Task RetryTimelineAsync() => OnRetry.InvokeAsync();

    private Task ReviewIntakeAsync() => OnReviewIntake.InvokeAsync();

    private Task ViewNoteAsync(NoteListItemApiResponse note) =>
        OnViewNote.HasDelegate ? OnViewNote.InvokeAsync(note) : Task.CompletedTask;

    private Task EditNoteAsync(NoteListItemApiResponse note) =>
        OnEditNote.HasDelegate ? OnEditNote.InvokeAsync(note) : Task.CompletedTask;
}
