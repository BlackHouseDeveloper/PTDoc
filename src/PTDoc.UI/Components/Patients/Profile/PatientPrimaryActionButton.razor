@* Patient Primary Action Button Component - Main action button *@

@if (!string.IsNullOrWhiteSpace(Href))
{
    <a href="@Href"
       class="patient-primary-action-button"
       data-testid="patient-primary-action"
       role="button"
       @onclick="OnClick"
       aria-label="@Label">
        @RenderContent()
    </a>
}
else
{
    <button type="button"
            class="patient-primary-action-button"
            data-testid="patient-primary-action"
            @onclick="OnClick"
            aria-label="@Label">
        @RenderContent()
    </button>
}

@code {
    [Parameter] public string Label { get; set; } = "Start New Note";
    [Parameter] public string? IconSvg { get; set; }
    [Parameter] public string? Href { get; set; }
    [Parameter] public EventCallback OnClick { get; set; }

    protected override void OnInitialized()
    {
        // Default icon for "Start New Note"
        if (string.IsNullOrEmpty(IconSvg))
        {
            IconSvg = @"<svg width=""16"" height=""16"" viewBox=""0 0 16 16"" fill=""none"" xmlns=""http://www.w3.org/2000/svg"">
                <path d=""M8 3.33333V12.6667M3.33333 8H12.6667"" stroke=""currentColor"" stroke-width=""2"" stroke-linecap=""round"" stroke-linejoin=""round""/>
            </svg>";
        }
    }

    private RenderFragment RenderContent() => builder =>
    {
        var sequence = 0;
        if (!string.IsNullOrEmpty(IconSvg))
        {
            builder.OpenElement(sequence++, "span");
            builder.AddAttribute(sequence++, "class", "patient-primary-action-icon");
            builder.AddAttribute(sequence++, "aria-hidden", "true");
            builder.AddContent(sequence++, (MarkupString)IconSvg);
            builder.CloseElement();
        }

        builder.OpenElement(sequence++, "span");
        builder.AddContent(sequence++, Label);
        builder.CloseElement();
    };
}
