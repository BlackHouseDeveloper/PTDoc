@* Patient Card Component - Displays individual patient summary *@

<button type="button"
        class="patient-card"
        data-testid="patient-card-@Patient.Id"
        @onclick="HandleClick"
        aria-label="Open chart for @Patient.DisplayName">
    
    <div class="patient-card-content">
        <div class="patient-card-header">
            <h3 class="patient-card-name">@Patient.DisplayName</h3>
            <StatusBadge 
                Text="@Patient.StatusLabel" 
                Variant="@Patient.StatusVariant" 
            />
        </div>
        
        <div class="patient-card-details">
            @if (!string.IsNullOrEmpty(Patient.DateOfBirth))
            {
                <div class="patient-card-detail-item">
                    <p class="patient-card-detail-label">Date of Birth</p>
                    <p class="patient-card-detail-value" title="@Patient.DateOfBirth">@Patient.DateOfBirth</p>
                </div>
            }
            
            @if (!string.IsNullOrEmpty(Patient.LastVisit))
            {
                <div class="patient-card-detail-item">
                    <p class="patient-card-detail-label">Last Visit</p>
                    <p class="patient-card-detail-value" title="@Patient.LastVisit">@Patient.LastVisit</p>
                </div>
            }

            @if (!string.IsNullOrEmpty(Patient.MedicalRecordNumber))
            {
                <div class="patient-card-detail-item">
                    <p class="patient-card-detail-label">MRN</p>
                    <p class="patient-card-detail-value" title="@Patient.MedicalRecordNumber">@Patient.MedicalRecordNumber</p>
                </div>
            }

            @if (!string.IsNullOrEmpty(Patient.Email))
            {
                <div class="patient-card-detail-item">
                    <p class="patient-card-detail-label">Email</p>
                    <p class="patient-card-detail-value" title="@Patient.Email">@Patient.Email</p>
                </div>
            }

            @if (!string.IsNullOrEmpty(Patient.Phone))
            {
                <div class="patient-card-detail-item">
                    <p class="patient-card-detail-label">Phone</p>
                    <p class="patient-card-detail-value" title="@Patient.Phone">@Patient.Phone</p>
                </div>
            }
        </div>

        <div class="patient-card-action" aria-hidden="true">
            <span>Open chart</span>
            <svg class="patient-card-action-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M6 3.5L10.5 8L6 12.5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
        </div>
    </div>
</button>

@code {
    [Parameter, EditorRequired] public PatientListItemVm Patient { get; set; } = null!;
    [Parameter] public EventCallback<PatientListItemVm> OnOpen { get; set; }

    private async Task HandleClick()
    {
        if (OnOpen.HasDelegate)
        {
            await OnOpen.InvokeAsync(Patient);
        }
    }
}
