@* Patient Card Section Component - Grid layout for patient cards *@

<div class="patient-card-section" data-testid="patients-card-section">
    @if (Items == null || !Items.Any())
    {
        <div class="patient-card-section-empty">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M16 20V18C16 16.3431 14.6569 15 13 15H7C5.34315 15 4 16.3431 4 18V20" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M10 11C11.6569 11 13 9.65685 13 8C13 6.34315 11.6569 5 10 5C8.34315 5 7 6.34315 7 8C7 9.65685 8.34315 11 10 11Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M20 8V14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M23 11H17" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <p class="patient-card-section-empty-text">No patients found</p>
        </div>
    }
    else
    {
        <div class="patient-card-section-grid">
            @foreach (var item in Items)
            {
                @if (ItemTemplate != null)
                {
                    @ItemTemplate(item)
                }
                else
                {
                    <PatientCard Patient="@item" OnOpen="@OnCardClick" />
                }
            }
        </div>
    }
</div>

@code {
    [Parameter] public IReadOnlyList<PatientListItemVm>? Items { get; set; }
    [Parameter] public RenderFragment<PatientListItemVm>? ItemTemplate { get; set; }
    [Parameter] public EventCallback<PatientListItemVm> OnCardClick { get; set; }
}
