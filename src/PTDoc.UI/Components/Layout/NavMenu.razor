@namespace PTDoc.UI.Components.Layout
@using Microsoft.AspNetCore.Components.Routing
@using Microsoft.AspNetCore.Components.Authorization
@using PTDoc.Application.DTOs
@using PTDoc.UI.Services
@inject INavigationBadgeService NavigationBadgeService
@inject INavigationBadgeRefreshNotifier NavigationBadgeRefreshNotifier
@inject ILogger<NavMenu> Logger
@implements IDisposable

<div class="ptdoc-nav-container">
    @if (!IsCompact)
    {
        <div class="ptdoc-nav-brand">
            <NavBarBrand OnNotificationsClick="OnNotificationsClick" NotificationCount="@NotificationCount" />
        </div>
    }

    <div class="ptdoc-nav-scrollable">
        <nav class="ptdoc-nav" aria-label="Main navigation">
            <!-- Primary Navigation -->
            <div class="ptdoc-nav-section">
                <NavLink class="ptdoc-nav-item" href="" Match="NavLinkMatch.All" @onclick="HandleNavigate">
                    <div class="ptdoc-nav-content">
                        <img src="_content/PTDoc.UI/images/nav-home.svg" alt="" class="ptdoc-nav-icon" aria-hidden="true" />
                        <span class="ptdoc-nav-text">Dashboard</span>
                    </div>
                    <div class="ptdoc-nav-indicator" aria-hidden="true"></div>
                </NavLink>

                <AuthorizeView Policy="@PTDoc.Application.Services.AuthorizationPolicies.SchedulingAccess">
                    <Authorized>
                        <NavLink class="ptdoc-nav-item" href="appointments" @onclick="HandleNavigate">
                            <div class="ptdoc-nav-content">
                                <img src="_content/PTDoc.UI/images/nav-appointments.svg" alt="" class="ptdoc-nav-icon" aria-hidden="true" />
                                <span class="ptdoc-nav-text">Appointments</span>
                            </div>
                        </NavLink>
                    </Authorized>
                </AuthorizeView>

                <AuthorizeView Policy="@PTDoc.Application.Services.AuthorizationPolicies.PatientRead">
                    <Authorized>
                        <NavLink class="ptdoc-nav-item" href="patients" @onclick="HandleNavigate">
                            <div class="ptdoc-nav-content">
                                <img src="_content/PTDoc.UI/images/nav-patients.svg" alt="" class="ptdoc-nav-icon" aria-hidden="true" />
                                <span class="ptdoc-nav-text">Patients</span>
                            </div>
                        </NavLink>
                    </Authorized>
                </AuthorizeView>

                <AuthorizeView Policy="@PTDoc.Application.Services.AuthorizationPolicies.PatientHepAccess">
                    <Authorized>
                        <NavLink class="ptdoc-nav-item" href="my-hep" @onclick="HandleNavigate">
                            <div class="ptdoc-nav-content">
                                <img src="_content/PTDoc.UI/images/nav-progress.svg" alt="" class="ptdoc-nav-icon" aria-hidden="true" />
                                <span class="ptdoc-nav-text">My Exercise Program</span>
                            </div>
                        </NavLink>
                    </Authorized>
                </AuthorizeView>

                <AuthorizeView Policy="@PTDoc.Application.Services.AuthorizationPolicies.IntakeRead">
                    <Authorized>
                        <NavLink class="ptdoc-nav-item" href="intake" @onclick="HandleNavigate">
                            <div class="ptdoc-nav-content">
                                <img src="_content/PTDoc.UI/images/nav-intake.svg" alt="" class="ptdoc-nav-icon" aria-hidden="true" />
                                <span class="ptdoc-nav-text">Intake</span>
                            </div>
                            @if (IntakeCount > 0)
                            {
                                <div class="ptdoc-nav-badge" aria-label="@BuildIntakeBadgeLabel(IntakeCount)">@FormatBadgeCount(IntakeCount)</div>
                            }
                        </NavLink>
                    </Authorized>
                </AuthorizeView>

                <AuthorizeView Policy="@PTDoc.Application.Services.AuthorizationPolicies.NoteRead">
                    <Authorized>
                        <NavLink class="ptdoc-nav-item" href="notes" @onclick="HandleNavigate">
                            <div class="ptdoc-nav-content">
                                <img src="_content/PTDoc.UI/images/nav-notes.svg" alt="" class="ptdoc-nav-icon" aria-hidden="true" />
                                <span class="ptdoc-nav-text">Notes</span>
                            </div>
                            @if (NotesCount > 0)
                            {
                                <div class="ptdoc-nav-badge" aria-label="@BuildNotesBadgeLabel(NotesCount)">@FormatBadgeCount(NotesCount)</div>
                            }
                        </NavLink>
                    </Authorized>
                </AuthorizeView>

                <AuthorizeView Policy="@PTDoc.Application.Services.AuthorizationPolicies.ClinicalStaff">
                    <Authorized>
                        <NavLink class="ptdoc-nav-item" href="progress-tracking" @onclick="HandleNavigate">
                            <div class="ptdoc-nav-content">
                                <img src="_content/PTDoc.UI/images/nav-progress.svg" alt="" class="ptdoc-nav-icon" aria-hidden="true" />
                                <span class="ptdoc-nav-text">Progress Tracking</span>
                            </div>
                        </NavLink>
                    </Authorized>
                </AuthorizeView>
            </div>

            <div class="ptdoc-nav-section">
                <AuthorizeView Policy="@PTDoc.Application.Services.AuthorizationPolicies.NoteExport">
                    <Authorized>
                        <div class="ptdoc-nav-section-label" aria-hidden="true">TOOLS</div>

                        <NavLink class="ptdoc-nav-item" href="export-center" @onclick="HandleNavigate">
                            <div class="ptdoc-nav-content">
                                <img src="_content/PTDoc.UI/images/nav-export.svg" alt="" class="ptdoc-nav-icon" aria-hidden="true" />
                                <span class="ptdoc-nav-text">Export Center</span>
                            </div>
                        </NavLink>
                    </Authorized>
                </AuthorizeView>

                <AuthorizeView Policy="@PTDoc.Application.Services.AuthorizationPolicies.FaxRead">
                    <Authorized>
                        <NavLink class="ptdoc-nav-item" href="fax-center" @onclick="HandleNavigate">
                            <div class="ptdoc-nav-content">
                                <img src="_content/PTDoc.UI/images/nav-export.svg" alt="" class="ptdoc-nav-icon" aria-hidden="true" />
                                <span class="ptdoc-nav-text">Fax Center</span>
                            </div>
                        </NavLink>
                    </Authorized>
                </AuthorizeView>
            </div>

            <div class="ptdoc-nav-section">
                <AuthorizeView Roles="Admin,Owner">
                    <Authorized>
                        <div class="ptdoc-nav-section-label" aria-hidden="true">ADMIN</div>

                        <NavLink class="ptdoc-nav-item" href="settings" @onclick="HandleNavigate">
                            <div class="ptdoc-nav-content">
                                <img src="_content/PTDoc.UI/images/nav-settings.svg" alt="" class="ptdoc-nav-icon" aria-hidden="true" />
                                <span class="ptdoc-nav-text">Settings</span>
                            </div>
                        </NavLink>
                    </Authorized>
                </AuthorizeView>
            </div>
        </nav>
    </div>

    <!-- Logout Button -->
    <AuthorizeView>
        <Authorized>
            <div class="ptdoc-nav-footer">
                <a href="/logout" class="ptdoc-nav-logout-btn" aria-label="Logout" @onclick="HandleNavigate">
                    <img src="_content/PTDoc.UI/images/nav-logout.svg" alt="" aria-hidden="true" />
                    <span>Logout</span>
                </a>
            </div>
        </Authorized>
    </AuthorizeView>
</div>

@code {
    [Parameter]
    public bool IsCompact { get; set; }

    [Parameter]
    public EventCallback OnNotificationsClick { get; set; }

    [Parameter]
    public EventCallback OnNavigate { get; set; }

    private NavigationBadgeCountsResponse? _badgeCounts;
    private CancellationTokenSource? _badgeCts;
    private bool _isDisposed;

    private int IntakeCount => _badgeCounts?.IntakeCount ?? 0;
    private int NotesCount => _badgeCounts?.NotesCount ?? 0;
    private int NotificationCount => _badgeCounts?.NotificationsCount ?? 0;

    protected override async Task OnInitializedAsync()
    {
        NavigationBadgeRefreshNotifier.RefreshRequested += OnBadgeRefreshRequested;
        await LoadBadgeCountsAsync();
    }

    private async Task HandleNavigate()
    {
        await OnNavigate.InvokeAsync();
    }

    private void OnBadgeRefreshRequested()
    {
        _ = InvokeAsync(LoadBadgeCountsAsync);
    }

    private async Task LoadBadgeCountsAsync()
    {
        _badgeCts?.Cancel();
        _badgeCts?.Dispose();
        var badgeCts = new CancellationTokenSource();
        _badgeCts = badgeCts;

        try
        {
            var badgeCounts = await NavigationBadgeService.GetCountsAsync(badgeCts.Token);
            if (_isDisposed || !ReferenceEquals(_badgeCts, badgeCts))
            {
                return;
            }

            _badgeCounts = badgeCounts;
            await InvokeAsync(StateHasChanged);
        }
        catch (OperationCanceledException) when (_isDisposed || badgeCts.IsCancellationRequested)
        {
            return;
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Navigation badge counts could not be loaded.");
            // Keep the last successful counts on refresh failure; initial failures still render no badges.
        }
    }

    private static string FormatBadgeCount(int count) => count > 99 ? "99+" : count.ToString();
    private static string BuildIntakeBadgeLabel(int count) =>
        count == 1 ? "1 intake item needing action" : $"{count} intake items needing action";

    private static string BuildNotesBadgeLabel(int count) =>
        count == 1 ? "1 note needing attention" : $"{count} notes needing attention";

    public void Dispose()
    {
        _isDisposed = true;
        NavigationBadgeRefreshNotifier.RefreshRequested -= OnBadgeRefreshRequested;
        _badgeCts?.Cancel();
        _badgeCts?.Dispose();
    }
}
