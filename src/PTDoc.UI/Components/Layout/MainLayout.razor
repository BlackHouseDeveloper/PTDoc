@namespace PTDoc.UI.Components.Layout
@using Microsoft.JSInterop
@using PTDoc.UI.Components
@inject IJSRuntime JS
@implements IAsyncDisposable

@inherits LayoutComponentBase

<div class="page">
    <GlobalHeader @bind-IsMenuOpen="isMenuOpen" />

    <div class="page-content">
        @if (ShouldRenderSidebar)
        {
            <div class="sidebar @GetSidebarClass()">
                <NavMenu IsCompact="IsCompactSidebar" OnNotificationsClick="OpenNotificationsModal" OnNavigate="CloseMenuOnMobileAsync" />
            </div>
        }

        @if (isMobileLayout && isMenuOpen)
        {
            <div class="sidebar-backdrop"
                 aria-hidden="true"
                 @onclick="CloseMenuAsync"></div>
        }

        <main>
            <article class="content">
                @Body
            </article>
        </main>
    </div>
</div>

<NotificationsModal @bind-IsOpen="isNotificationsModalOpen" />

<ToastContainer />

<ViewportDiagnosticsOverlay />

@code {
    private bool isMenuOpen;
    private bool isNotificationsModalOpen;
    private IJSObjectReference? layoutModule;
    private DotNetObjectReference<MainLayout>? layoutReference;
    private bool isMobileLayout;

    private bool ShouldRenderSidebar => !isMobileLayout || isMenuOpen;
    private bool IsCompactSidebar => !isMobileLayout && !isMenuOpen;

    private string GetSidebarClass()
    {
        var cssClass = isMenuOpen ? "open" : "closed";
        return cssClass;
    }

    private void OpenNotificationsModal()
    {
        isNotificationsModalOpen = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        try
        {
            layoutModule = await JS.InvokeAsync<IJSObjectReference>("import", "./_content/PTDoc.UI/js/layout.js");
            layoutReference = DotNetObjectReference.Create(this);
            isMobileLayout = await layoutModule.InvokeAsync<bool>("initializeMobileLayout", layoutReference);
            isMenuOpen = !isMobileLayout;
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Layout JS interop error: {ex.Message}");
        }
    }

    private async Task CloseMenuOnMobileAsync()
    {
        if (!isMobileLayout)
        {
            return;
        }

        await CloseMenuAsync();
    }

    private Task CloseMenuAsync()
    {
        isMenuOpen = false;
        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task OnMobileLayoutChanged(bool isMobile)
    {
        if (isMobileLayout == isMobile)
        {
            return Task.CompletedTask;
        }

        isMobileLayout = isMobile;
        isMenuOpen = !isMobileLayout;
        return InvokeAsync(StateHasChanged);
    }

    public async ValueTask DisposeAsync()
    {
        if (layoutModule is not null)
        {
            try
            {
                await layoutModule.InvokeVoidAsync("disposeMobileLayout");
                await layoutModule.DisposeAsync();
            }
            catch (Microsoft.JSInterop.JSDisconnectedException)
            {
                // The Blazor Server circuit can disconnect before component disposal completes.
            }
            catch (ObjectDisposedException)
            {
                // Ignore disposal races during circuit teardown.
            }
        }

        layoutReference?.Dispose();
    }
}

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
