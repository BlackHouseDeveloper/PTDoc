@namespace PTDoc.UI.Components.Layout
@using PTDoc.UI.Components
@inject IJSRuntime JS
@implements IAsyncDisposable

@inherits LayoutComponentBase


<div class="page">
    <GlobalHeader @bind-IsMenuOpen="isMenuOpen" />
    
    <div class="page-content">
        <div class="sidebar @GetSidebarClass()">
            <NavMenu OnNotificationsClick="OpenNotificationsModal" OnNavigate="CloseMenuOnMobileAsync" />
        </div>

        @if (isMenuOpen)
        {
            <button type="button"
                    class="sidebar-backdrop"
                    aria-label="Close menu"
                    @onclick="CloseMenuAsync"></button>
        }

        <main>
            <article class="content">
                @Body
            </article>
        </main>
    </div>
</div>

<NotificationsModal @bind-IsOpen="isNotificationsModalOpen" />

<ToastContainer />

@code {
    private bool isMenuOpen;
    private bool isNotificationsModalOpen;
    private IJSObjectReference? layoutModule;
    
    private string GetSidebarClass()
    {
        var cssClass = isMenuOpen ? "open" : "closed";
        return cssClass;
    }

    private void OpenNotificationsModal()
    {
        isNotificationsModalOpen = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        try
        {
            layoutModule = await JS.InvokeAsync<IJSObjectReference>("import", "./_content/PTDoc.UI/js/layout.js");
            isMenuOpen = !await layoutModule.InvokeAsync<bool>("isMobileLayout");
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Layout JS interop error: {ex.Message}");
        }
    }

    private async Task CloseMenuOnMobileAsync()
    {
        if (layoutModule is null)
        {
            return;
        }

        try
        {
            if (await layoutModule.InvokeAsync<bool>("isMobileLayout"))
            {
                await CloseMenuAsync();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Layout mobile close failed: {ex.Message}");
        }
    }

    private Task CloseMenuAsync()
    {
        isMenuOpen = false;
        return Task.CompletedTask;
    }

    public async ValueTask DisposeAsync()
    {
        if (layoutModule is not null)
        {
            try
            {
                await layoutModule.DisposeAsync();
            }
            catch (Microsoft.JSInterop.JSDisconnectedException)
            {
                // The Blazor Server circuit can disconnect before component disposal completes.
            }
            catch (ObjectDisposedException)
            {
                // Ignore disposal races during circuit teardown.
            }
        }
    }
}

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
