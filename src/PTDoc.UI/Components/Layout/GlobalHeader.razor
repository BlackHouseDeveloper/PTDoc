@using PTDoc.Application.Services
@inherits GlobalHeaderBase

<header class="global-header">
    <div class="header-container">
        <!-- Menu Toggle Button -->
        <button 
            type="button" 
            class="menu-toggle @(IsMenuOpen ? "menu-toggle--open" : "menu-toggle--closed")"
            aria-label="@(IsMenuOpen ? "Close menu" : "Open menu")"
            aria-expanded="@IsMenuOpen.ToString().ToLower()"
            @onclick="ToggleMenu">
            @if (IsMenuOpen)
            {
                <span class="menu-icon menu-icon-close" aria-hidden="true"></span>
            }
            else
            {
                <span class="menu-icon menu-icon-open" aria-hidden="true"></span>
            }
        </button>

        <!-- Right side controls container -->
        <div class="header-controls">
            <!-- Last Sync Indicator -->
            <div class="sync-info">
                <span class="sync-text">Last sync: @LastSyncDisplay</span>
            </div>

            <!-- Sync Now Button -->
            <button 
                type="button" 
                class="sync-button"
                data-sync-now-button
                data-syncing="@IsSyncing.ToString().ToLowerInvariant()"
                data-sync-blocked="@((IsSyncing || !IsOnline).ToString().ToLowerInvariant())"
                aria-label="@(IsSyncing ? "Syncing clinical data" : IsOnline ? "Sync now" : "Sync unavailable while offline")"
                aria-busy="@IsSyncing.ToString().ToLowerInvariant()"
                @onclick="HandleSyncNow">
                <span class="sync-icon @(IsSyncing ? "syncing" : "")" aria-hidden="true"></span>
                <span class="sync-button-text" data-sync-now-text>@(IsSyncing ? "Syncing..." : IsOnline ? "Sync Now" : "Sync Offline")</span>
            </button>

            <!-- Online/Offline Status Badge -->
            <div class="status-badge @(IsOnline ? "online" : "offline")" 
                 data-connectivity-status
                 role="status" 
                 aria-live="polite">
                <span class="status-icon" aria-hidden="true"></span>
                <span class="status-text" data-connectivity-text>@(IsOnline ? "Online" : "Offline")</span>
            </div>
        </div>
    </div>
</header>
