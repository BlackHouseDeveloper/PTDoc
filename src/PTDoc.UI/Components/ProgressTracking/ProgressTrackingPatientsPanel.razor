@using PTDoc.UI.Components.ProgressTracking.Models

<div class="progress-patients-panel">
    @if (Items.Count == 0)
    {
        <p>No patients match the current filters.</p>
    }
    else
    {
        <ul>
            @foreach (var patient in Items)
            {
                <li>
                    <button type="button"
                            aria-current="@IsSelected(patient)"
                            @onclick="() => OnSelectPatient.InvokeAsync(patient.Id)">
                        <span>@patient.DisplayName</span>
                        <StatusBadge Text="@patient.StatusLabel" Variant="@patient.StatusVariant" />
                    </button>
                </li>
            }
        </ul>
    }
</div>

@code {
    [Parameter] public IReadOnlyList<ProgressTrackingPatientVm> Items { get; set; } = Array.Empty<ProgressTrackingPatientVm>();
    [Parameter] public string? SelectedPatientId { get; set; }
    [Parameter] public EventCallback<string> OnSelectPatient { get; set; }

    private string? IsSelected(ProgressTrackingPatientVm patient) =>
        string.Equals(patient.Id, SelectedPatientId, StringComparison.OrdinalIgnoreCase)
            ? "true"
            : null;
}
