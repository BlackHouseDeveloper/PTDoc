@using PTDoc.UI.Components.Notes.Models

<section class="notes-needs-attention" data-testid="notes-needs-attention">
    <div class="notes-needs-attention-header">
        <svg class="notes-needs-attention-header-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M10 1.66666L18.3333 16.6667H1.66666L10 1.66666Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            <path d="M10 7.49997V10.8333" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            <path d="M10 14.1667H10.0083" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        <h3 class="notes-needs-attention-title">Needs Attention (@Items.Count)</h3>
    </div>

    <div class="notes-needs-attention-list">
        @foreach (var item in Items)
        {
            <article class="notes-needs-attention-item">
                <div class="notes-needs-attention-item-header">
                    <div class="notes-needs-attention-patient-row">
                        <svg class="notes-needs-attention-patient-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                            <path d="M9.33333 2H4.66667C4.31305 2 3.97391 2.14048 3.72386 2.39052C3.47381 2.64057 3.33333 2.97971 3.33333 3.33333V12.6667C3.33333 13.0203 3.47381 13.3594 3.72386 13.6095C3.97391 13.8595 4.31305 14 4.66667 14H11.3333C11.687 14 12.0261 13.8595 12.2761 13.6095C12.5262 13.3594 12.6667 13.0203 12.6667 12.6667V5.33333L9.33333 2Z" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" />
                            <path d="M9.33333 2V5.33333H12.6667" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                        <p class="notes-needs-attention-patient">@item.PatientName</p>
                    </div>
                    <StatusBadge Text="@GetStatusText(item)" Variant="@GetStatusVariant(item)" />
                </div>

                <div class="notes-needs-attention-details">
                    <p class="notes-needs-attention-note-type">@item.NoteType</p>
                    @if (!string.IsNullOrWhiteSpace(item.AttentionReason))
                    {
                        <p class="notes-needs-attention-reason">⚠️ @item.AttentionReason</p>
                    }
                    <p class="notes-needs-attention-meta">@GetMetaText(item)</p>
                </div>

                <div class="notes-needs-attention-actions">
                    <button type="button" class="notes-needs-attention-fix" @onclick="() => OnFixNow.InvokeAsync(item)">
                        <svg class="notes-needs-attention-fix-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                            <path d="M7.33333 2H2.66667C2.31305 2 1.97391 2.14048 1.72386 2.39052C1.47381 2.64057 1.33333 2.97971 1.33333 3.33333V13.3333C1.33333 13.687 1.47381 14.0261 1.72386 14.2761C1.97391 14.5262 2.31305 14.6667 2.66667 14.6667H12.6667C13.0203 14.6667 13.3594 14.5262 13.6095 14.2761C13.8595 14.0261 14 13.687 14 13.3333V8.66667" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" />
                            <path d="M13 1.66667C13.2652 1.40146 13.6249 1.25244 14 1.25244C14.3751 1.25244 14.7348 1.40146 15 1.66667C15.2652 1.93189 15.4142 2.29152 15.4142 2.66667C15.4142 3.04181 15.2652 3.40146 15 3.66667L8 10.6667L5.33333 11.3333L6 8.66667L13 1.66667Z" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                        <span>@GetPrimaryActionText(item)</span>
                    </button>

                    <button type="button" class="notes-needs-attention-view" @onclick="() => OnView.InvokeAsync(item)" aria-label="View @item.PatientName note">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                            <path d="M1.33333 8C1.33333 8 3.33333 3.33333 8 3.33333C12.6667 3.33333 14.6667 8 14.6667 8C14.6667 8 12.6667 12.6667 8 12.6667C3.33333 12.6667 1.33333 8 1.33333 8Z" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" />
                            <path d="M8 9.75C8.9665 9.75 9.75 8.9665 9.75 8C9.75 7.0335 8.9665 6.25 8 6.25C7.0335 6.25 6.25 7.0335 6.25 8C6.25 8.9665 7.0335 9.75 8 9.75Z" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                    </button>
                </div>
            </article>
        }
    </div>
</section>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<NoteListItemVm> Items { get; set; } = Array.Empty<NoteListItemVm>();
    [Parameter] public EventCallback<NoteListItemVm> OnFixNow { get; set; }
    [Parameter] public EventCallback<NoteListItemVm> OnView { get; set; }

    private static BadgeVariant GetStatusVariant(NoteListItemVm item) => item.IsPendingCoSign
        ? BadgeVariant.Info
        : BadgeVariant.Destructive;

    private static string GetStatusText(NoteListItemVm item) => item.IsPendingCoSign
        ? "Pending Co-Sign"
        : "Needs Attention";

    private static string GetPrimaryActionText(NoteListItemVm item) => item.IsPendingCoSign
        ? "Finalize"
        : "Fix Now";

    private static string GetMetaText(NoteListItemVm item)
    {
        var createdText = $"Created {item.CreatedDate:MMM d, yyyy}";
        return string.IsNullOrWhiteSpace(item.CreatedBy)
            ? createdText
            : $"{createdText} by {item.CreatedBy}";
    }
}
