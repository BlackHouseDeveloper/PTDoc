@namespace PTDoc.UI.Components.Notes.Workspace
@using PTDoc.UI.Components.Notes.Models
@using PTDoc.UI.Components.Notes.Workspace.DailyTreatment

<section class="objective-tab" data-testid="objective-tab" role="tabpanel" aria-label="Objective section">
    <div class="objective-tab__layout">
        <!-- Main content column -->
        <div class="objective-tab__main">
            <h2 class="objective-tab__title">Objective</h2>

            <!-- Body-part-dependent sections (locked until body part selected in Subjective) -->
            @foreach (var sectionName in _bodyPartSections)
            {
                <div class="objective-tab__locked-section">
                    <h3 class="objective-tab__section-heading">@sectionName</h3>
                    <div class="objective-tab__locked-placeholder">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"
                             xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                            <circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.5"/>
                            <path d="M8 5.5V8M8 10.5H8.01" stroke="currentColor" stroke-width="1.5"
                                  stroke-linecap="round"/>
                        </svg>
                        <span>Select a body part in the Chief Complaint section to see @sectionName measurements.</span>
                    </div>
                </div>
            }

            <!-- Gait Analysis -->
            <div class="objective-tab__section" data-testid="gait-analysis-section">
                <h3 class="objective-tab__section-heading">Gait Analysis</h3>

                <p class="objective-tab__sub-heading">Primary Gait Pattern:</p>
                <div class="objective-tab__radio-list">
                    @foreach (var pattern in _gaitPatterns)
                    {
                        <label class="objective-tab__radio-item">
                            <input type="radio"
                                   name="gait-pattern"
                                   value="@pattern.Value"
                                   checked="@(_vm.PrimaryGaitPattern == pattern.Value)"
                                   disabled="@IsReadOnly"
                                   @onchange="_ => SetAndNotify(v => v.PrimaryGaitPattern = pattern.Value)" />
                            <span class="objective-tab__radio-label">
                                <strong>@pattern.Label</strong>
                                <span class="objective-tab__radio-desc">@pattern.Description</span>
                            </span>
                        </label>
                    }
                </div>

                <p class="objective-tab__sub-heading">Specific Gait Deviations (Optional):</p>
                <div class="objective-tab__deviation-grid">
                    @foreach (var deviation in _gaitDeviations)
                    {
                        <label class="objective-tab__checkbox-chip">
                            <input type="checkbox"
                                   name="gait-deviations"
                                   checked="@_vm.GaitDeviations.Contains(deviation)"
                                   disabled="@IsReadOnly"
                                   @onchange="e => ToggleDeviation(deviation, (bool)e.Value!)" />
                            @deviation
                        </label>
                    }
                </div>

                <p class="objective-tab__sub-heading">Additional Gait Observations:</p>
                <textarea id="additional-gait-observations"
                          name="additional-gait-observations"
                          class="objective-tab__textarea"
                          rows="3"
                          placeholder="Add details about walking distance, endurance, specific deviations..."
                          disabled="@IsReadOnly"
                          value="@_vm.AdditionalGaitObservations"
                          @onchange="e => SetAndNotify(v => v.AdditionalGaitObservations = e.Value?.ToString())"></textarea>
            </div>

            <!-- Therapeutic Exercises -->
            <div class="objective-tab__section" data-testid="therapeutic-exercises-section">
                <InterventionChecklist Title="Therapeutic Exercises"
                                       CountLabel="exercises"
                                       Items="_vm.TherapeuticExercises"
                                       ItemsChanged="UpdateExercises"
                                       IsReadOnly="IsReadOnly"
                                       AddButtonText="+ Add Exercise"
                                       EmptyMessage="No exercises documented yet. Add a manual entry to record the work performed."
                                       TestId="objective-therapeutic-exercises" />
            </div>

            <!-- Manual Work Techniques -->
            <div class="objective-tab__section" data-testid="manual-techniques-section">
                <InterventionChecklist Title="Manual Work Techniques"
                                       CountLabel="techniques"
                                       Items="_vm.ManualTechniques"
                                       ItemsChanged="UpdateManualTechniques"
                                       IsReadOnly="IsReadOnly"
                                       AddButtonText="+ Add Technique"
                                       EmptyMessage="No manual techniques documented yet. Add a manual entry to record the treatment performed."
                                       TestId="objective-manual-techniques" />
            </div>
        </div>

        <!-- Sidebar -->
        <div class="objective-tab__sidebar">
            <PatientGoalsSidebar PatientId="@PatientId"
                                 ActiveGoalCount="@GoalCount"
                                 OverallProgressPercent="@GoalProgressPercent"
                                 ShortTermGoalCount="@ShortTermGoalCount"
                                 LongTermGoalCount="@LongTermGoalCount"
                                 GoalItems="@GoalItems"
                                 HintItems="@GoalHints" />
        </div>
    </div>
</section>

@code {
    private ObjectiveVm _vm = new();

    [Parameter, EditorRequired] public ObjectiveVm Vm { get; set; } = new();
    [Parameter, EditorRequired] public EventCallback<ObjectiveVm> VmChanged { get; set; }
    [Parameter] public bool IsReadOnly { get; set; }
    [Parameter] public string PatientId { get; set; } = string.Empty;

    // Goal sidebar data is provided by the parent container.
    [Parameter] public int GoalCount { get; set; }
    [Parameter] public int GoalProgressPercent { get; set; }
    [Parameter] public int ShortTermGoalCount { get; set; }
    [Parameter] public int LongTermGoalCount { get; set; }
    [Parameter] public IReadOnlyList<PatientGoalItem> GoalItems { get; set; } = Array.Empty<PatientGoalItem>();
    [Parameter] public IReadOnlyList<string> GoalHints { get; set; } = Array.Empty<string>();

    protected override void OnParametersSet() => _vm = Vm;

    private static readonly string[] _bodyPartSections =
    [
        "Range of Motion (ROM)",
        "Manual Muscle Testing (MMT)",
        "Standardized Outcome Measures",
        "Special Tests",
        "Clinical Observations",
        "Measurements",
        "Postural Assessment"
    ];

    private record GaitPatternOption(string Value, string Label, string Description);

    private static readonly GaitPatternOption[] _gaitPatterns =
    [
        new("normal",        "Normal gait",        "No deviations observed"),
        new("antalgic",      "Antalgic gait",      "Pain-avoiding pattern"),
        new("trendelenburg", "Trendelenburg gait",  "Hip abductor weakness"),
        new("steppage",      "Steppage gait",       "Foot drop pattern"),
        new("circumduction", "Circumduction gait",  "Swinging leg outward"),
        new("festinating",   "Festinating gait",    "Short, shuffling steps"),
    ];

    private static readonly string[] _gaitDeviations =
    [
        "Decreased stride length", "Decreased walking speed",
        "Decreased arm swing",     "Trunk lean",
        "Hip hiking",              "Foot drop",
        "Toe walking",             "Absent heel strike",
        "Knee hyperextension",     "Excessive knee flexion",
        "Limping",                 "Patient uses assistive device"
    ];

    private Task ToggleDeviation(string item, bool add)
    {
        if (add) _vm.GaitDeviations.Add(item); else _vm.GaitDeviations.Remove(item);
        return VmChanged.InvokeAsync(_vm);
    }

    private Task SetAndNotify(Action<ObjectiveVm> update)
    {
        update(_vm);
        return VmChanged.InvokeAsync(_vm);
    }

    private Task UpdateExercises(List<string> value) => SetAndNotify(vm => vm.TherapeuticExercises = value);

    private Task UpdateManualTechniques(List<string> value) => SetAndNotify(vm => vm.ManualTechniques = value);
}
