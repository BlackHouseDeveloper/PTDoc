@namespace PTDoc.UI.Components.Notes.Workspace
@using PTDoc.Application.Notes.Workspace
@using PTDoc.Application.Outcomes
@using PTDoc.Core.Models
@using PTDoc.UI.Components.Notes.Models
@using PTDoc.UI.Services

@inject INoteWorkspaceService NoteWorkspaceService
@inject ILogger<ObjectiveTab> Logger

<section class="objective-tab" data-testid="objective-tab" role="tabpanel" aria-label="Objective section">
    <div class="objective-tab__layout">
        <div class="objective-tab__main">
            <h2 class="objective-tab__title">Objective</h2>

            <div class="objective-tab__section">
                <h3 class="objective-tab__section-heading">Body Region</h3>
                <select class="objective-tab__select"
                        value="@(_vm.SelectedBodyPart ?? string.Empty)"
                        disabled="@IsReadOnly"
                        @onchange="HandleSelectedBodyPartChangedAsync"
                        data-testid="objective-body-part-select">
                    <option value="">Select body part ↓</option>
                    @foreach (var option in _bodyPartOptions)
                    {
                        <option value="@option" selected="@string.Equals(_vm.SelectedBodyPart, option, StringComparison.OrdinalIgnoreCase)">@option</option>
                    }
                </select>

                @if (!string.IsNullOrWhiteSpace(_catalogError))
                {
                    <p class="objective-tab__helper objective-tab__helper--error" role="alert">@_catalogError</p>
                }
                else if (_isLoadingCatalog)
                {
                    <p class="objective-tab__helper" role="status">Loading structured objective catalog…</p>
                }
            </div>

            <div class="objective-tab__section" data-testid="objective-rom-section">
                <div class="objective-tab__section-header">
                    <h3 class="objective-tab__section-heading">Range of Motion (ROM)</h3>
                </div>

                @if (RomCatalogOptions.Count == 0)
                {
                    <p class="objective-tab__helper">Select a body part to load source-backed ROM options.</p>
                }
                else
                {
                    <div class="objective-tab__option-grid">
                        @foreach (var option in RomCatalogOptions)
                        {
                            var isSelected = HasMetric(option, MetricType.ROM);
                            <button type="button"
                                    class="objective-tab__chip @(isSelected ? "objective-tab__chip--active" : "")"
                                    disabled="@IsReadOnly"
                                    @onclick="() => AddMetric(option, MetricType.ROM)">
                                @option
                            </button>
                        }
                    </div>
                }

                @if (RomMetrics.Count > 0)
                {
                    <div class="objective-tab__editor-list">
                        @foreach (var metric in RomMetrics)
                        {
                            <div class="objective-tab__editor-row" data-testid="objective-rom-row">
                                <div class="objective-tab__editor-header">
                                    <strong>@metric.Name</strong>
                                    @if (!IsReadOnly)
                                    {
                                        <button type="button" class="objective-tab__remove-btn" @onclick="() => RemoveMetric(metric)">Remove</button>
                                    }
                                </div>
                                <div class="objective-tab__editor-grid">
                                    <label>
                                        <span>Body part</span>
                                        <select class="objective-tab__select"
                                                value="@(metric.BodyPart ?? string.Empty)"
                                                disabled="@IsReadOnly"
                                                @onchange="e => UpdateMetric(metric, row => row.BodyPart = e.Value?.ToString())">
                                            <option value="">Use primary body part</option>
                                            @foreach (var option in _bodyPartOptions)
                                            {
                                                <option value="@option" selected="@string.Equals(metric.BodyPart, option, StringComparison.OrdinalIgnoreCase)">@option</option>
                                            }
                                        </select>
                                    </label>
                                    <label>
                                        <span>Current value</span>
                                        <input class="objective-tab__text-input"
                                               value="@metric.Value"
                                               disabled="@IsReadOnly"
                                               @onchange="e => UpdateMetric(metric, row => row.Value = e.Value?.ToString() ?? string.Empty)" />
                                    </label>
                                    <label>
                                        <span>Normal value</span>
                                        <input class="objective-tab__text-input"
                                               value="@metric.NormValue"
                                               disabled="@IsReadOnly"
                                               @onchange="e => UpdateMetric(metric, row => row.NormValue = e.Value?.ToString())" />
                                    </label>
                                    <label>
                                        <span>Previous value</span>
                                        <input class="objective-tab__text-input"
                                               value="@metric.PreviousValue"
                                               disabled="@IsReadOnly"
                                               @onchange="e => UpdateMetric(metric, row => row.PreviousValue = e.Value?.ToString())" />
                                    </label>
                                    <label class="objective-tab__checkbox-item">
                                        <input type="checkbox"
                                               checked="@metric.IsWithinNormalLimits"
                                               disabled="@IsReadOnly"
                                               @onchange="e => UpdateMetric(metric, row => row.IsWithinNormalLimits = (bool)e.Value!)" />
                                        Within normal limits
                                    </label>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            <div class="objective-tab__section" data-testid="objective-mmt-section">
                <div class="objective-tab__section-header">
                    <h3 class="objective-tab__section-heading">MMT / Joint Mobility</h3>
                    @if (!IsReadOnly)
                    {
                        <button type="button" class="objective-tab__secondary-btn" @onclick="AddBlankMmtMetric">+ Add Row</button>
                    }
                </div>

                @if (MmtMetrics.Count == 0)
                {
                    <p class="objective-tab__helper">No structured MMT or joint-mobility rows documented yet.</p>
                }
                else
                {
                    <div class="objective-tab__editor-list">
                        @foreach (var metric in MmtMetrics)
                        {
                            <div class="objective-tab__editor-row" data-testid="objective-mmt-row">
                                <div class="objective-tab__editor-grid">
                                    <label>
                                        <span>Body part</span>
                                        <select class="objective-tab__select"
                                                value="@(metric.BodyPart ?? string.Empty)"
                                                disabled="@IsReadOnly"
                                                @onchange="e => UpdateMetric(metric, row => row.BodyPart = e.Value?.ToString())">
                                            <option value="">Use primary body part</option>
                                            @foreach (var option in _bodyPartOptions)
                                            {
                                                <option value="@option" selected="@string.Equals(metric.BodyPart, option, StringComparison.OrdinalIgnoreCase)">@option</option>
                                            }
                                        </select>
                                    </label>
                                    <label>
                                        <span>Measurement</span>
                                        <input class="objective-tab__text-input"
                                               value="@metric.Name"
                                               disabled="@IsReadOnly"
                                               @onchange="e => UpdateMetric(metric, row => row.Name = e.Value?.ToString() ?? string.Empty)" />
                                    </label>
                                    <label>
                                        <span>Value</span>
                                        <select class="objective-tab__select"
                                                value="@metric.Value"
                                                disabled="@IsReadOnly"
                                                @onchange="e => UpdateMetric(metric, row => row.Value = e.Value?.ToString() ?? string.Empty)">
                                            <option value="">Select grade ↓</option>
                                            @foreach (var grade in StrengthGradeOptions)
                                            {
                                                <option value="@grade" selected="@string.Equals(metric.Value, grade, StringComparison.OrdinalIgnoreCase)">@grade</option>
                                            }
                                        </select>
                                    </label>
                                    <label>
                                        <span>Normal value</span>
                                        <input class="objective-tab__text-input"
                                               value="@metric.NormValue"
                                               disabled="@IsReadOnly"
                                               @onchange="e => UpdateMetric(metric, row => row.NormValue = e.Value?.ToString())" />
                                    </label>
                                    <label>
                                        <span>Previous value</span>
                                        <input class="objective-tab__text-input"
                                               value="@metric.PreviousValue"
                                               disabled="@IsReadOnly"
                                               @onchange="e => UpdateMetric(metric, row => row.PreviousValue = e.Value?.ToString())" />
                                    </label>
                                    @if (!IsReadOnly)
                                    {
                                        <button type="button" class="objective-tab__remove-btn" @onclick="() => RemoveMetric(metric)">Remove</button>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            <div class="objective-tab__section" data-testid="objective-outcome-measures-section">
                <OutcomeMeasurePanel PatientId="@ParsedPatientId"
                                     FilterBodyPart="@SelectedBodyPartFilter"
                                     SuggestedMeasures="@_vm.RecommendedOutcomeMeasures"
                                     RecordedEntries="@_vm.OutcomeMeasures"
                                     IsReadOnly="@IsReadOnly"
                                     OnScoreRecorded="HandleOutcomeScoreRecorded" />
            </div>

            <div class="objective-tab__section" data-testid="objective-special-tests-section">
                <div class="objective-tab__section-header">
                    <h3 class="objective-tab__section-heading">Special Tests</h3>
                </div>

                @if (SpecialTestOptions.Count == 0)
                {
                    <p class="objective-tab__helper">No source-backed special tests are available for the selected body part.</p>
                }
                else
                {
                    <div class="objective-tab__option-grid">
                        @foreach (var option in SpecialTestOptions)
                        {
                            var isSelected = _vm.SpecialTests.Any(test => string.Equals(test.Name, option, StringComparison.OrdinalIgnoreCase));
                            <button type="button"
                                    class="objective-tab__chip @(isSelected ? "objective-tab__chip--active" : "")"
                                    disabled="@IsReadOnly"
                                    @onclick="() => ToggleSpecialTest(option)">
                                @option
                            </button>
                        }
                    </div>
                }

                @if (_vm.SpecialTests.Count > 0)
                {
                    <div class="objective-tab__editor-list">
                        @foreach (var test in _vm.SpecialTests.OrderBy(test => test.Name, StringComparer.OrdinalIgnoreCase))
                        {
                            <div class="objective-tab__editor-row" data-testid="objective-special-test-row">
                                <div class="objective-tab__editor-header">
                                    <strong>@test.Name</strong>
                                    @if (!IsReadOnly)
                                    {
                                        <button type="button" class="objective-tab__remove-btn" @onclick="() => RemoveSpecialTest(test)">Remove</button>
                                    }
                                </div>
                                <div class="objective-tab__editor-grid">
                                    <label>
                                        <span>Side</span>
                                        <select class="objective-tab__select"
                                                value="@test.Side"
                                                disabled="@IsReadOnly"
                                                @onchange="e => UpdateSpecialTest(test, item => item.Side = e.Value?.ToString())">
                                            <option value="">Not specified</option>
                                            <option value="Left">Left</option>
                                            <option value="Right">Right</option>
                                            <option value="Bilateral">Bilateral</option>
                                        </select>
                                    </label>
                                    <label>
                                        <span>Result</span>
                                        <select class="objective-tab__select"
                                                value="@test.Result"
                                                disabled="@IsReadOnly"
                                                @onchange="e => UpdateSpecialTest(test, item => item.Result = e.Value?.ToString() ?? string.Empty)">
                                            <option value="Positive">Positive</option>
                                            <option value="Negative">Negative</option>
                                            <option value="WNL">WNL</option>
                                            <option value="Not Tested">Not Tested</option>
                                        </select>
                                    </label>
                                    <label>
                                        <span>Notes</span>
                                        <input class="objective-tab__text-input"
                                               value="@test.Notes"
                                               disabled="@IsReadOnly"
                                               @onchange="e => UpdateSpecialTest(test, item => item.Notes = e.Value?.ToString())" />
                                    </label>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            <div class="objective-tab__section" data-testid="objective-tender-muscles-section">
                <h3 class="objective-tab__section-heading">Tender Muscles / Palpation</h3>
                <label class="objective-tab__checkbox-item">
                    <input type="checkbox"
                           checked="@_vm.IsPalpationUnremarkable"
                           disabled="@IsReadOnly"
                           @onchange="e => SetAndNotify(v => v.IsPalpationUnremarkable = (bool)e.Value!)" />
                    Unremarkable
                </label>
                @if (TenderMuscleOptions.Count == 0)
                {
                    <p class="objective-tab__helper">No source-backed tender-muscle catalog is available for the selected body part.</p>
                }
                else
                {
                    <div class="objective-tab__option-grid">
                        @foreach (var muscle in TenderMuscleOptions)
                        {
                            var isSelected = _vm.TenderMuscles.Contains(muscle);
                            <label class="objective-tab__checkbox-chip">
                                <input type="checkbox"
                                       checked="@isSelected"
                                       disabled="@IsReadOnly"
                                       @onchange="e => ToggleTenderMuscle(muscle, (bool)e.Value!)" />
                                @muscle
                            </label>
                        }
                    </div>
                }
                <label class="objective-tab__field">
                    <span class="objective-tab__sub-heading">Palpation comments</span>
                    <textarea class="objective-tab__textarea"
                              rows="2"
                              placeholder="Add palpation details or comments..."
                              disabled="@IsReadOnly"
                              value="@_vm.PalpationComments"
                              @onchange="e => SetAndNotify(v => v.PalpationComments = e.Value?.ToString())"></textarea>
                </label>
            </div>

            <div class="objective-tab__section" data-testid="objective-posture-section">
                <h3 class="objective-tab__section-heading">Posture / Additional Measurements</h3>
                <label class="objective-tab__checkbox-item">
                    <input type="checkbox"
                           checked="@_vm.IsPostureUnremarkable"
                           disabled="@IsReadOnly"
                           @onchange="e => SetAndNotify(v => v.IsPostureUnremarkable = (bool)e.Value!)" />
                    Unremarkable
                </label>
                <div class="objective-tab__option-grid" data-testid="objective-posture-options">
                    @foreach (var posture in PostureFindingOptions)
                    {
                        var isSelected = _vm.PostureFindings.Contains(posture);
                        <label class="objective-tab__checkbox-chip">
                            <input type="checkbox"
                                   checked="@isSelected"
                                   disabled="@IsReadOnly"
                                   @onchange="e => TogglePostureFinding(posture, (bool)e.Value!)" />
                            @posture
                        </label>
                    }
                </div>
                <label class="objective-tab__field">
                    <span class="objective-tab__sub-heading">Posture comments</span>
                    <textarea class="objective-tab__textarea"
                              rows="2"
                              placeholder="Add posture details not covered by the chips..."
                              disabled="@IsReadOnly"
                              value="@_vm.OtherPostureFinding"
                              @onchange="e => SetAndNotify(v => v.OtherPostureFinding = e.Value?.ToString())"></textarea>
                </label>
            </div>

            <div class="objective-tab__section" data-testid="gait-analysis-section">
                <h3 class="objective-tab__section-heading">Gait Analysis</h3>
                <label class="objective-tab__checkbox-item">
                    <input type="checkbox"
                           checked="@_vm.IsGaitUnremarkable"
                           disabled="@IsReadOnly"
                           @onchange="e => SetAndNotify(v => v.IsGaitUnremarkable = (bool)e.Value!)" />
                    Unremarkable
                </label>

                <p class="objective-tab__sub-heading">Primary Gait Pattern:</p>
                <div class="objective-tab__radio-list">
                    @foreach (var pattern in _gaitPatterns)
                    {
                        <label class="objective-tab__radio-item">
                            <input type="radio"
                                   name="gait-pattern"
                                   value="@pattern.Value"
                                   checked="@(_vm.PrimaryGaitPattern == pattern.Value)"
                                   disabled="@IsReadOnly"
                                   @onchange="_ => SetAndNotify(v => v.PrimaryGaitPattern = pattern.Value)" />
                            <span class="objective-tab__radio-label">
                                <strong>@pattern.Label</strong>
                                <span class="objective-tab__radio-desc">@pattern.Description</span>
                            </span>
                        </label>
                    }
                </div>

                <p class="objective-tab__sub-heading">Specific Gait Deviations (Optional):</p>
                <div class="objective-tab__deviation-grid">
                    @foreach (var deviation in _gaitDeviations)
                    {
                        <label class="objective-tab__checkbox-chip">
                            <input type="checkbox"
                                   name="gait-deviations"
                                   checked="@_vm.GaitDeviations.Contains(deviation)"
                                   disabled="@IsReadOnly"
                                   @onchange="e => ToggleDeviation(deviation, (bool)e.Value!)" />
                            @deviation
                        </label>
                    }
                </div>

                <p class="objective-tab__sub-heading">Additional Gait Observations:</p>
                <textarea id="additional-gait-observations"
                          name="additional-gait-observations"
                          class="objective-tab__textarea"
                          rows="3"
                          placeholder="Add details about walking distance, endurance, specific deviations..."
                          disabled="@IsReadOnly"
                          value="@_vm.AdditionalGaitObservations"
                          @onchange="e => SetAndNotify(v => v.AdditionalGaitObservations = e.Value?.ToString())"></textarea>
            </div>

            @if (ShowInterventionAuthoring)
            {
            <div class="objective-tab__section" data-testid="objective-exercises-section">
                <div class="objective-tab__section-header">
                    <h3 class="objective-tab__section-heading">Interventions / Activities Performed</h3>
                    @if (!IsReadOnly)
                    {
                        <button type="button" class="objective-tab__secondary-btn" @onclick="AddManualExerciseRow">+ Add Intervention Row</button>
                    }
                </div>

                @if (ExerciseOptions.Count > 0)
                {
                    <div class="objective-tab__option-grid">
                        @foreach (var exercise in ExerciseOptions)
                        {
                            var isSelected = _vm.ExerciseRows.Any(row =>
                                string.Equals(row.SuggestedExercise, exercise, StringComparison.OrdinalIgnoreCase)
                                || string.Equals(row.ActualExercisePerformed, exercise, StringComparison.OrdinalIgnoreCase));
                            <button type="button"
                                    class="objective-tab__chip @(isSelected ? "objective-tab__chip--active" : "")"
                                    disabled="@IsReadOnly"
                                    @onclick="() => AddSuggestedExercise(exercise)">
                                @exercise
                            </button>
                        }
                    </div>
                }

                @if (_vm.ExerciseRows.Count == 0)
                {
                    <p class="objective-tab__helper">No structured intervention rows documented yet.</p>
                }
                else
                {
                    <div class="objective-tab__editor-list">
                        @foreach (var row in _vm.ExerciseRows)
                        {
                            <div class="objective-tab__editor-row" data-testid="objective-exercise-row">
                                <div class="objective-tab__editor-header">
                                    <strong>@(string.IsNullOrWhiteSpace(row.SuggestedExercise) ? "Exercise Row" : row.SuggestedExercise)</strong>
                                    @if (!IsReadOnly)
                                    {
                                        <button type="button" class="objective-tab__remove-btn" @onclick="() => RemoveExerciseRow(row)">Remove</button>
                                    }
                                </div>
                                <div class="objective-tab__editor-grid">
                                    <label>
                                        <span>Suggested activity</span>
                                        <input class="objective-tab__text-input"
                                               value="@row.SuggestedExercise"
                                               disabled="@IsReadOnly"
                                               @onchange="e => UpdateExerciseRow(row, item => item.SuggestedExercise = e.Value?.ToString() ?? string.Empty)" />
                                    </label>
                                    <label>
                                        <span>Performed</span>
                                        <input class="objective-tab__text-input"
                                               value="@row.ActualExercisePerformed"
                                               disabled="@IsReadOnly"
                                               @onchange="e => UpdateExerciseRow(row, item => item.ActualExercisePerformed = e.Value?.ToString() ?? string.Empty)" />
                                    </label>
                                    <label>
                                        <span>Sets / reps / duration</span>
                                        <input class="objective-tab__text-input"
                                               value="@row.SetsRepsDuration"
                                               disabled="@IsReadOnly"
                                               @onchange="e => UpdateExerciseRow(row, item => item.SetsRepsDuration = e.Value?.ToString())" />
                                    </label>
                                    <label>
                                        <span>Resistance / weight</span>
                                        <input class="objective-tab__text-input"
                                               value="@row.ResistanceOrWeight"
                                               disabled="@IsReadOnly"
                                               @onchange="e => UpdateExerciseRow(row, item => item.ResistanceOrWeight = e.Value?.ToString())" />
                                    </label>
                                    <label>
                                        <span>CPT</span>
                                        <select class="objective-tab__select"
                                                value="@NormalizeCode(row.CptCode)"
                                                disabled="@IsReadOnly"
                                                @onchange="e => UpdateExerciseCpt(row, e.Value?.ToString())">
                                            <option value="">Select CPT ↓</option>
                                            @foreach (var option in InterventionCptOptions)
                                            {
                                                <option value="@option.Code" selected="@CodesMatch(row.CptCode, option.Code)">
                                                    @option.Code - @option.Label
                                                </option>
                                            }
                                        </select>
                                    </label>
                                    <label>
                                        <span>Minutes</span>
                                        <input class="objective-tab__text-input"
                                               type="number"
                                               min="0"
                                               step="1"
                                               value="@(row.TimeMinutes?.ToString() ?? string.Empty)"
                                               disabled="@IsReadOnly"
                                               @onchange="e => UpdateExerciseMinutes(row, e.Value)" />
                                    </label>
                                    <label>
                                        <span>Assistance</span>
                                        <select class="objective-tab__select"
                                                value="@row.AssistanceLevel"
                                                disabled="@IsReadOnly"
                                                @onchange="e => UpdateExerciseRow(row, item => item.AssistanceLevel = e.Value?.ToString())">
                                            <option value="">None documented</option>
                                            @foreach (var option in AssistanceLevelOptions)
                                            {
                                                <option value="@option" selected="@string.Equals(row.AssistanceLevel, option, StringComparison.OrdinalIgnoreCase)">@option</option>
                                            }
                                        </select>
                                    </label>
                                    <label>
                                        <span>Cueing</span>
                                        <select class="objective-tab__select"
                                                value="@row.Cueing"
                                                disabled="@IsReadOnly"
                                                @onchange="e => UpdateExerciseRow(row, item => item.Cueing = e.Value?.ToString())">
                                            <option value="">None documented</option>
                                            @foreach (var option in CueingOptions)
                                            {
                                                <option value="@option" selected="@string.Equals(row.Cueing, option, StringComparison.OrdinalIgnoreCase)">@option</option>
                                            }
                                        </select>
                                    </label>
                                    <label class="objective-tab__checkbox-item">
                                        <input type="checkbox"
                                               checked="@row.IncludeInHomeExerciseProgram"
                                               disabled="@IsReadOnly"
                                               @onchange="e => UpdateExerciseRow(row, item => item.IncludeInHomeExerciseProgram = (bool)e.Value!)" />
                                        Link to HEP
                                    </label>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
            }

            <div class="objective-tab__section">
                <h3 class="objective-tab__section-heading">Clinical Observation Notes</h3>
                <textarea class="objective-tab__textarea"
                          rows="3"
                          placeholder="Additional objective findings, measurements, or clinical observations..."
                          disabled="@IsReadOnly"
                          value="@_vm.ClinicalObservationNotes"
                          @onchange="e => SetAndNotify(v => v.ClinicalObservationNotes = e.Value?.ToString())"></textarea>
            </div>
        </div>

        <div class="objective-tab__sidebar">
            <PatientGoalsSidebar PatientId="@PatientId"
                                 ActiveGoalCount="@GoalCount"
                                 OverallProgressPercent="@GoalProgressPercent"
                                 ShortTermGoalCount="@ShortTermGoalCount"
                                 LongTermGoalCount="@LongTermGoalCount"
                                 GoalItems="@GoalItems"
                                 HintItems="@GoalHints" />
        </div>
    </div>
</section>

@code {
    private ObjectiveVm _vm = new();
    private BodyRegionCatalog? _catalog;
    private bool _isLoadingCatalog;
    private string? _catalogError;
    private string? _loadedCatalogBodyPart;

    [Parameter, EditorRequired] public ObjectiveVm Vm { get; set; } = new();
    [Parameter, EditorRequired] public EventCallback<ObjectiveVm> VmChanged { get; set; }
    [Parameter] public bool IsReadOnly { get; set; }
    [Parameter] public string PatientId { get; set; } = string.Empty;
    [Parameter] public int GoalCount { get; set; }
    [Parameter] public int GoalProgressPercent { get; set; }
    [Parameter] public int ShortTermGoalCount { get; set; }
    [Parameter] public int LongTermGoalCount { get; set; }
    [Parameter] public IReadOnlyList<PatientGoalItem> GoalItems { get; set; } = Array.Empty<PatientGoalItem>();
    [Parameter] public IReadOnlyList<string> GoalHints { get; set; } = Array.Empty<string>();
    [Parameter] public bool ShowInterventionAuthoring { get; set; } = true;

    protected override async Task OnParametersSetAsync()
    {
        _vm = Vm;
        await EnsureCatalogAsync();
    }

    private Guid ParsedPatientId => Guid.TryParse(PatientId, out var parsed) ? parsed : Guid.Empty;
    private BodyPart? SelectedBodyPartFilter => Enum.TryParse<BodyPart>(_vm.SelectedBodyPart, ignoreCase: true, out var parsed)
        ? parsed
        : null;

    private static readonly string[] _bodyPartOptions = Enum.GetValues<BodyPart>()
        .Where(part => part != BodyPart.Other)
        .Select(part => part.ToString())
        .OrderBy(value => value, StringComparer.OrdinalIgnoreCase)
        .ToArray();

    private record GaitPatternOption(string Value, string Label, string Description);
    private record InterventionCptOption(string Code, string Label);

    private static readonly InterventionCptOption[] InterventionCptOptions =
    [
        new("97110", "Exercise"),
        new("97112", "Neuromuscular re-ed"),
        new("97530", "Functional activities"),
        new("97116", "Gait training"),
        new("97535", "Self-care / ADL training"),
        new("97140", "Manual therapy")
    ];

    private static readonly string[] AssistanceLevelOptions =
    [
        "Min Assist",
        "Mod Assist",
        "Max Assist",
        "Contact Guard",
        "Standby Assist",
        "Independent"
    ];

    private static readonly string[] CueingOptions =
    [
