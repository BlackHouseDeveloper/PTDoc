    private static string JoinDelimitedValues(IEnumerable<string> values, string? otherValue)
    {
        var items = values
            .Where(value => !string.IsNullOrWhiteSpace(value))
            .Select(value => value.Trim())
            .ToList();

        if (!string.IsNullOrWhiteSpace(otherValue))
        {
            items.Add(otherValue.Trim());
        }

        return string.Join(", ", items);
    }

    private static List<string> SplitDelimitedValues(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return [];
        }

        return value
            .Split([',', ';', '\n', '\r'], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(token => !string.IsNullOrWhiteSpace(token))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private static BodyPart ParseBodyPart(string? value) =>
        Enum.TryParse<BodyPart>(value, ignoreCase: true, out var parsed) ? parsed : BodyPart.Other;

    private static string? ResolveNormalValue(string name, MetricType metricType)
    {
        if (metricType == MetricType.MMT)
        {
            return "5/5";
        }

        var lastToken = name
            .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .LastOrDefault();

        return lastToken?.Any(char.IsDigit) == true ? lastToken : null;
    }

    private static string NormalizeCode(string? code) => code?.Trim() ?? string.Empty;

    private static bool CodesMatch(string? left, string? right) =>
        string.Equals(NormalizeCode(left), NormalizeCode(right), StringComparison.OrdinalIgnoreCase);
