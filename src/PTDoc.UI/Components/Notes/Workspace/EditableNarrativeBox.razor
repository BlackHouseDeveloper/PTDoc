<section class="editable-narrative-box" data-testid="@TestId">
    @if (!string.IsNullOrEmpty(Label))
    {
        <label class="editable-narrative-box__label" for="@_inputId">@Label</label>
    }

    @if (_reviewState == ReviewState.Pending)
    {
        <div class="editable-narrative-box__review-banner" role="alert" aria-live="polite" data-testid="@($"{TestId}-review-banner")">
            <svg class="editable-narrative-box__review-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M8 1.33334L10.06 5.50667L14.6667 6.18L11.3333 9.42667L12.12 14.0133L8 11.8467L3.88 14.0133L4.66667 9.42667L1.33333 6.18L5.94 5.50667L8 1.33334Z" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            <span class="editable-narrative-box__review-text">AI-generated content — please review before accepting</span>
        </div>

        @if (!string.IsNullOrWhiteSpace(_acceptErrorMessage))
        {
            <p class="editable-narrative-box__error" role="alert" data-testid="@($"{TestId}-error")">
                @_acceptErrorMessage
            </p>
        }
    }

    <div class="editable-narrative-box__editor-row">
        <textarea id="@_inputId"
                  class="editable-narrative-box__textarea @(IsReadOnly ? "editable-narrative-box__textarea--readonly" : "") @(_reviewState == ReviewState.Pending ? "editable-narrative-box__textarea--pending" : "")"
                  rows="@Rows"
                  placeholder="@Placeholder"
                  disabled="@IsReadOnly"
                  aria-label="@(string.IsNullOrEmpty(Label) ? Placeholder : Label)"
                  aria-readonly="@IsReadOnly"
                  data-testid="@($"{TestId}-textarea")"
                  value="@_currentValue"
                  @oninput="OnInputChangedAsync">
        </textarea>
    </div>

    @if (_reviewState == ReviewState.Pending)
    {
        <div class="editable-narrative-box__action-row" data-testid="@($"{TestId}-actions")">
            <button type="button"
                    class="editable-narrative-box__accept-btn"
                    @onclick="AcceptAsync"
                    data-testid="@($"{TestId}-accept-btn")">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M11.6667 3.5L5.25 9.91667L2.33333 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                Accept
            </button>
            <button type="button"
                    class="editable-narrative-box__discard-btn"
                    @onclick="DiscardAsync"
                    data-testid="@($"{TestId}-discard-btn")">
                Discard
            </button>
        </div>
    }

    @if (_reviewState == ReviewState.Accepted)
    {
        <p class="editable-narrative-box__accepted-note" data-testid="@($"{TestId}-accepted-note")">
            ✓ AI suggestion accepted
        </p>
    }
</section>

@code {
    private enum ReviewState { None, Pending, Accepted }

    private string _inputId = $"narrative-{Guid.NewGuid():N}";
    private ReviewState _reviewState = ReviewState.None;
    private string _currentValue = string.Empty;
    private string _preReviewValue = string.Empty;
    private string? _acceptErrorMessage;

    /// <summary>The current text value of the narrative box.</summary>
    [Parameter] public string Value { get; set; } = string.Empty;

    /// <summary>Raised when the text value changes.</summary>
    [Parameter] public EventCallback<string> ValueChanged { get; set; }

    /// <summary>Raised when the clinician explicitly accepts the AI-generated text.</summary>
    [Parameter] public Func<string, Task<EditableNarrativeAcceptResult>>? OnAccepted { get; set; }

    /// <summary>Raised when the clinician discards the AI-generated text.</summary>
    [Parameter] public EventCallback OnDiscarded { get; set; }

    /// <summary>Label displayed above the text area.</summary>
    [Parameter] public string? Label { get; set; }

    /// <summary>Placeholder text shown when the field is empty.</summary>
    [Parameter] public string Placeholder { get; set; } = "Enter clinical narrative…";

    /// <summary>Number of visible rows for the textarea.</summary>
    [Parameter] public int Rows { get; set; } = 6;

    /// <summary>When true, the textarea is disabled (e.g. note is signed).</summary>
    [Parameter] public bool IsReadOnly { get; set; } = false;

    /// <summary>data-testid prefix for automation.</summary>
    [Parameter] public string TestId { get; set; } = "editable-narrative-box";

    protected override void OnParametersSet()
    {
        // Keep backing field in sync when parent pushes a new value.
        // Exception: when an AI suggestion is pending review, the parent's Value
        // is still the pre-AI text. Overwriting _currentValue here would silently
        // discard the pending suggestion, so we only sync from the parameter when
        // there is no active review state.
        if (_reviewState != ReviewState.Pending)
        {
            _currentValue = Value;
        }
    }

    /// <summary>
    /// Called by the parent (e.g. AssessmentTab) to load AI-generated text for review.
    /// Explicit generation always enters local review state, even when the clinician has
    /// already typed content. The pre-review value is preserved for discard.
    /// Does NOT propagate the value to the parent until the clinician explicitly accepts —
    /// this prevents the autosave mechanism from persisting AI content before acceptance.
    /// </summary>
    public Task LoadAiSuggestionAsync(string aiText)
    {
        // Preserve the original pre-review text across repeated generations while the
        // clinician is still in the same review session. Discard should always return
        // to the last accepted/manual value, not a previous AI draft.
        if (_reviewState != ReviewState.Pending)
        {
            _preReviewValue = _currentValue;
        }

        _currentValue = aiText;
        _reviewState = ReviewState.Pending;
        _acceptErrorMessage = null;

        // Intentionally NOT calling ValueChanged here. The pending suggestion is held
        // in the local backing field only. ValueChanged (and therefore the parent's
        // dirty-mark / autosave) fires only for ordinary manual edits outside the
        // review flow. Pending AI text stays local until the clinician explicitly
        // accepts it.
        StateHasChanged();
        return Task.CompletedTask;
    }

    private async Task OnInputChangedAsync(ChangeEventArgs e)
    {
        _currentValue = e.Value?.ToString() ?? string.Empty;
        _acceptErrorMessage = null;

        if (_reviewState == ReviewState.Pending)
        {
            StateHasChanged();
            return;
        }

        _reviewState = ReviewState.None;
        await ValueChanged.InvokeAsync(_currentValue);
    }

    private async Task AcceptAsync()
    {
        EditableNarrativeAcceptResult result;

        try
        {
            result = OnAccepted is null
                ? EditableNarrativeAcceptResult.Ok()
                : await OnAccepted(_currentValue);
        }
        catch
        {
            result = EditableNarrativeAcceptResult.Fail("Unable to accept AI-generated content.");
        }

        if (!result.Success)
        {
            _acceptErrorMessage = result.ErrorMessage ?? "Unable to accept AI-generated content.";
            _reviewState = ReviewState.Pending;
            StateHasChanged();
            return;
        }

        _reviewState = ReviewState.Accepted;
        _preReviewValue = string.Empty;
        _acceptErrorMessage = null;
        StateHasChanged();
    }

    private async Task DiscardAsync()
    {
        _currentValue = _preReviewValue;
        _reviewState = ReviewState.None;
        _preReviewValue = string.Empty;
        _acceptErrorMessage = null;

        await OnDiscarded.InvokeAsync();
        StateHasChanged();
    }
}
