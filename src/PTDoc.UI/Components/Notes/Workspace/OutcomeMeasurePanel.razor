@using System.Globalization
@using PTDoc.Application.Outcomes
@using PTDoc.Core.Models
@using PTDoc.UI.Components.Notes.Models
@inject IOutcomeMeasureRegistry Registry

<div class="outcome-panel" data-testid="outcome-measure-panel">
    <div class="outcome-panel__header">
        <h3 class="outcome-panel__title">Outcome Measures</h3>
    </div>

    @if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <div class="outcome-panel__error" role="alert" data-testid="outcome-panel-error">
            @_errorMessage
        </div>
    }

    @if (SuggestedMeasures.Count > 0)
    {
        <div class="outcome-panel__suggestions" data-testid="outcome-suggested-measures">
            <div class="outcome-panel__suggestions-header">
                <h4 class="outcome-panel__suggestions-title">Suggested from Intake</h4>
                <p class="outcome-panel__suggestions-copy">Suggested measures stay separate from outcome history until you record a score.</p>
            </div>

            <div class="outcome-panel__suggestions-list">
                @foreach (var suggestion in SuggestedMeasures.OrderBy(value => value, StringComparer.OrdinalIgnoreCase))
                {
                    var isSupported = TryResolveDefinition(suggestion, out var definition);
                    var isSelected = isSupported && _selectedDefinition?.MeasureType == definition!.MeasureType;

                    if (isSupported)
                    {
                        <button type="button"
                                class="@(isSelected ? "outcome-panel__suggestion-chip outcome-panel__suggestion-chip--selected" : "outcome-panel__suggestion-chip")"
                                disabled="@IsReadOnly"
                                @onclick="() => SelectSuggestedMeasure(definition!.MeasureType)">
                            @suggestion
                        </button>
                    }
                    else
                    {
                        <span class="outcome-panel__suggestion-chip outcome-panel__suggestion-chip--unsupported"
                              title="This suggested measure is not yet configured for scoring in PTDoc.">
                            @suggestion
                        </span>
                    }
                }
            </div>
        </div>
    }

    <div class="outcome-panel__select-row">
        <label class="outcome-panel__label" for="outcome-measure-select">Measure</label>
        <select id="outcome-measure-select"
                class="outcome-panel__select"
                disabled="@IsReadOnly"
                @bind="_selectedMeasureType"
                data-testid="outcome-measure-select">
            <option value="">— Select an outcome measure —</option>
            @foreach (var measure in _availableMeasures)
            {
                <option value="@((int)measure.MeasureType)">
                    @measure.Abbreviation — @measure.FullName
                </option>
            }
        </select>
    </div>

    @if (_selectedDefinition is not null)
    {
        <div class="outcome-panel__definition" data-testid="outcome-definition">
            <p class="outcome-panel__description">@_selectedDefinition.Description</p>
            <span class="outcome-panel__range">
                Score range: @_selectedDefinition.MinScore – @_selectedDefinition.MaxScore @_selectedDefinition.ScoreUnit
                @if (_selectedDefinition.HigherIsBetter)
                {
                    <span class="outcome-panel__direction outcome-panel__direction--up"> (higher = better)</span>
                }
                else
                {
                    <span class="outcome-panel__direction outcome-panel__direction--down"> (lower = better)</span>
                }
            </span>
        </div>

        <div class="outcome-panel__score-row">
            <label class="outcome-panel__label" for="outcome-score-input">
                Score (@_selectedDefinition.ScoreUnit)
            </label>
            <input id="outcome-score-input"
                   type="number"
                   class="outcome-panel__score-input"
                   min="@_selectedDefinition.MinScore"
                   max="@_selectedDefinition.MaxScore"
                   step="0.1"
                   disabled="@IsReadOnly"
                   @bind="_scoreInput"
                   @bind:event="oninput"
                   data-testid="outcome-score-input" />
        </div>

        @if (_scoreInput.HasValue)
        {
            var interpretation = Registry.InterpretScore(_selectedDefinition.MeasureType, _scoreInput.Value);
            <div class="outcome-panel__interpretation" data-testid="outcome-interpretation">
                Interpretation: <strong>@interpretation</strong>
            </div>
        }

        @if (!IsReadOnly)
        {
            <button class="outcome-panel__record-btn"
                    disabled="@(!CanRecord)"
                    @onclick="RecordScoreAsync"
                    data-testid="outcome-record-btn">
                Record Score
            </button>
        }
    }

    @if (RecordedEntries.Count > 0)
    {
        <div class="outcome-panel__history" data-testid="outcome-history">
            <h4 class="outcome-panel__history-title">Recorded Scores</h4>
            <table class="outcome-panel__history-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Measure</th>
                        <th>Score</th>
                        <th>Interpretation</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var entry in RecordedEntries
                        .Where(record => record.Date.HasValue)
                        .OrderByDescending(record => record.Date))
                    {
                        var isSupported = TryResolveDefinition(entry.Name, out var def);
                        var parsedScore = TryParseScore(entry.Score, out var score);
                        var label = isSupported && parsedScore
                            ? Registry.InterpretScore(def!.MeasureType, score)
                            : "Recorded";
                        <tr data-testid="outcome-history-row">
                            <td>@entry.Date!.Value.ToLocalTime().ToString("MM/dd/yyyy")</td>
                            <td>@(isSupported ? def!.Abbreviation : entry.Name)</td>
                            <td>@FormatRecordedScore(entry, def, parsedScore, score)</td>
                            <td>@label</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    /// <summary>
    /// The patient whose outcomes are being recorded.
    /// </summary>
    [Parameter, EditorRequired]
    public Guid PatientId { get; set; }

    /// <summary>
    /// Optional body part to pre-filter recommended measures.
    /// </summary>
    [Parameter]
    public BodyPart? FilterBodyPart { get; set; }

    /// <summary>
    /// Previously recorded outcome results for trend display.
    /// </summary>
    [Parameter]
    public IReadOnlyList<string> SuggestedMeasures { get; set; } = Array.Empty<string>();

    /// <summary>
    /// Outcome measures already recorded on this note.
    /// </summary>
    [Parameter]
    public IReadOnlyList<OutcomeMeasureEntry> RecordedEntries { get; set; } = Array.Empty<OutcomeMeasureEntry>();

    /// <summary>
    /// When true, disables score entry (note is signed).
    /// </summary>
    [Parameter]
    public bool IsReadOnly { get; set; }

    /// <summary>
    /// Raised when a new score is recorded.
    /// The payload contains measure type, score, and timestamp only.
    /// The caller must supply the authenticated clinician ID when persisting
    /// via <see cref="IOutcomeMeasureService.RecordResultAsync"/>.
    /// </summary>
    [Parameter]
    public EventCallback<OutcomeScoreEntry> OnScoreRecorded { get; set; }

    // ──────────────────────────────────────────────────────────────
    // State
    // ──────────────────────────────────────────────────────────────

    private IReadOnlyList<OutcomeMeasureDefinition> _availableMeasures = Array.Empty<OutcomeMeasureDefinition>();
    private OutcomeMeasureDefinition? _selectedDefinition;
    private string _selectedMeasureTypeRaw = string.Empty;
    private double? _scoreInput;
    private string _errorMessage = string.Empty;
    private bool _hasInitializedSuggestedSelection;

    private string _selectedMeasureType
    {
        get => _selectedMeasureTypeRaw;
        set
        {
            _selectedMeasureTypeRaw = value;
            if (int.TryParse(value, out var intVal) && Enum.IsDefined(typeof(OutcomeMeasureType), intVal))
            {
                _selectedDefinition = Registry.GetDefinition((OutcomeMeasureType)intVal);
            }
            else
            {
                _selectedDefinition = null;
            }
            _scoreInput = null;
            _errorMessage = string.Empty;
        }
    }

    private bool CanRecord =>
        _selectedDefinition is not null &&
        _scoreInput.HasValue &&
        _scoreInput.Value >= _selectedDefinition.MinScore &&
        _scoreInput.Value <= _selectedDefinition.MaxScore;

    protected override void OnParametersSet()
    {
        _availableMeasures = FilterBodyPart.HasValue
            ? Registry.GetMeasuresForBodyPart(FilterBodyPart.Value)
            : Registry.GetAllMeasures();

        if (_hasInitializedSuggestedSelection || _selectedDefinition is not null)
        {
            return;
        }

        var firstSupportedSuggestion = SuggestedMeasures
            .Select(suggestion => TryResolveDefinition(suggestion, out var definition) ? definition : null)
            .FirstOrDefault(definition => definition is not null);

        if (firstSupportedSuggestion is not null)
        {
            _selectedMeasureTypeRaw = ((int)firstSupportedSuggestion.MeasureType).ToString();
            _selectedDefinition = firstSupportedSuggestion;
        }

        _hasInitializedSuggestedSelection = true;
    }

    private async Task RecordScoreAsync()
    {
        if (!CanRecord) return;

        _errorMessage = string.Empty;

        try
        {
            var entry = new OutcomeScoreEntry(
                _selectedDefinition!.MeasureType,
                _scoreInput!.Value,
                DateTime.UtcNow);

            await OnScoreRecorded.InvokeAsync(entry);

            // Reset form after successful record
            _selectedMeasureTypeRaw = string.Empty;
            _selectedDefinition = null;
            _scoreInput = null;
        }
        catch (Exception)
        {
            _errorMessage = "Failed to record score. Please try again.";
        }
    }

    private void SelectSuggestedMeasure(OutcomeMeasureType measureType)
    {
        _selectedMeasureTypeRaw = ((int)measureType).ToString();
        _selectedDefinition = Registry.GetDefinition(measureType);
        _scoreInput = null;
        _errorMessage = string.Empty;
    }

    private bool TryResolveDefinition(string? rawValue, out OutcomeMeasureDefinition? definition)
    {
        definition = null;
        if (string.IsNullOrWhiteSpace(rawValue))
        {
            return false;
        }

        var normalized = rawValue.Trim();
        if (Enum.TryParse<OutcomeMeasureType>(normalized, ignoreCase: true, out var measureType))
        {
            definition = Registry.GetDefinition(measureType);
            return true;
        }

        definition = Registry.GetAllMeasures().FirstOrDefault(candidate =>
            string.Equals(candidate.Abbreviation, normalized, StringComparison.OrdinalIgnoreCase) ||
            string.Equals(candidate.FullName, normalized, StringComparison.OrdinalIgnoreCase) ||
            normalized.Contains(candidate.Abbreviation, StringComparison.OrdinalIgnoreCase) ||
            normalized.Contains(candidate.FullName, StringComparison.OrdinalIgnoreCase));

        return definition is not null;
    }

    private static bool TryParseScore(string? rawValue, out double score)
    {
        return double.TryParse(rawValue, NumberStyles.Float | NumberStyles.AllowThousands, CultureInfo.InvariantCulture, out score)
            || double.TryParse(rawValue, NumberStyles.Float | NumberStyles.AllowThousands, CultureInfo.CurrentCulture, out score);
    }

    private static string FormatRecordedScore(
        OutcomeMeasureEntry entry,
        OutcomeMeasureDefinition? definition,
        bool parsedScore,
        double score)
    {
        if (definition is not null && parsedScore)
        {
            return $"{score:F1} {definition.ScoreUnit}";
        }

        return string.IsNullOrWhiteSpace(entry.Score) ? "Not recorded" : entry.Score;
    }
}
