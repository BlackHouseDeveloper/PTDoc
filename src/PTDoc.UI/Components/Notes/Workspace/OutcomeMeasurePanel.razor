@using PTDoc.Application.Outcomes
@using PTDoc.Core.Models
@inject IOutcomeMeasureRegistry Registry

<div class="outcome-panel" data-testid="outcome-measure-panel">
    <div class="outcome-panel__header">
        <h3 class="outcome-panel__title">Outcome Measures</h3>
    </div>

    @if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <div class="outcome-panel__error" role="alert" data-testid="outcome-panel-error">
            @_errorMessage
        </div>
    }

    <div class="outcome-panel__select-row">
        <label class="outcome-panel__label" for="outcome-measure-select">Measure</label>
        <select id="outcome-measure-select"
                class="outcome-panel__select"
                disabled="@IsReadOnly"
                @bind="_selectedMeasureType"
                data-testid="outcome-measure-select">
            <option value="">— Select an outcome measure —</option>
            @foreach (var measure in _availableMeasures)
            {
                <option value="@((int)measure.MeasureType)">
                    @measure.Abbreviation — @measure.FullName
                </option>
            }
        </select>
    </div>

    @if (_selectedDefinition is not null)
    {
        <div class="outcome-panel__definition" data-testid="outcome-definition">
            <p class="outcome-panel__description">@_selectedDefinition.Description</p>
            <span class="outcome-panel__range">
                Score range: @_selectedDefinition.MinScore – @_selectedDefinition.MaxScore @_selectedDefinition.ScoreUnit
                @if (_selectedDefinition.HigherIsBetter)
                {
                    <span class="outcome-panel__direction outcome-panel__direction--up"> (higher = better)</span>
                }
                else
                {
                    <span class="outcome-panel__direction outcome-panel__direction--down"> (lower = better)</span>
                }
            </span>
        </div>

        <div class="outcome-panel__score-row">
            <label class="outcome-panel__label" for="outcome-score-input">
                Score (@_selectedDefinition.ScoreUnit)
            </label>
            <input id="outcome-score-input"
                   type="number"
                   class="outcome-panel__score-input"
                   min="@_selectedDefinition.MinScore"
                   max="@_selectedDefinition.MaxScore"
                   step="0.1"
                   disabled="@IsReadOnly"
                   @bind="_scoreInput"
                   @bind:event="oninput"
                   data-testid="outcome-score-input" />
        </div>

        @if (_scoreInput.HasValue)
        {
            var interpretation = Registry.InterpretScore(_selectedDefinition.MeasureType, _scoreInput.Value);
            <div class="outcome-panel__interpretation" data-testid="outcome-interpretation">
                Interpretation: <strong>@interpretation</strong>
            </div>
        }

        @if (!IsReadOnly)
        {
            <button class="outcome-panel__record-btn"
                    disabled="@(!CanRecord)"
                    @onclick="RecordScoreAsync"
                    data-testid="outcome-record-btn">
                Record Score
            </button>
        }
    }

    @if (History.Count > 0)
    {
        <div class="outcome-panel__history" data-testid="outcome-history">
            <h4 class="outcome-panel__history-title">Recorded Scores</h4>
            <table class="outcome-panel__history-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Measure</th>
                        <th>Score</th>
                        <th>Interpretation</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var entry in History.OrderByDescending(h => h.DateRecorded))
                    {
                        var def = Registry.GetDefinition(entry.MeasureType);
                        var label = Registry.InterpretScore(entry.MeasureType, entry.Score);
                        <tr data-testid="outcome-history-row">
                            <td>@entry.DateRecorded.ToLocalTime().ToString("MM/dd/yyyy")</td>
                            <td>@def.Abbreviation</td>
                            <td>@entry.Score.ToString("F1") @def.ScoreUnit</td>
                            <td>@label</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    /// <summary>
    /// The patient whose outcomes are being recorded.
    /// </summary>
    [Parameter, EditorRequired]
    public Guid PatientId { get; set; }

    /// <summary>
    /// Optional body part to pre-filter recommended measures.
    /// </summary>
    [Parameter]
    public BodyPart? FilterBodyPart { get; set; }

    /// <summary>
    /// Previously recorded outcome results for trend display.
    /// </summary>
    [Parameter]
    public IReadOnlyList<OutcomeMeasureResult> History { get; set; } = Array.Empty<OutcomeMeasureResult>();

    /// <summary>
    /// When true, disables score entry (note is signed).
    /// </summary>
    [Parameter]
    public bool IsReadOnly { get; set; }

    /// <summary>
    /// Raised when a new score is recorded. Passes the recorded result.
    /// </summary>
    [Parameter]
    public EventCallback<OutcomeMeasureResult> OnScoreRecorded { get; set; }

    // ──────────────────────────────────────────────────────────────
    // State
    // ──────────────────────────────────────────────────────────────

    private IReadOnlyList<OutcomeMeasureDefinition> _availableMeasures = Array.Empty<OutcomeMeasureDefinition>();
    private OutcomeMeasureDefinition? _selectedDefinition;
    private string _selectedMeasureTypeRaw = string.Empty;
    private double? _scoreInput;
    private string _errorMessage = string.Empty;

    private string _selectedMeasureType
    {
        get => _selectedMeasureTypeRaw;
        set
        {
            _selectedMeasureTypeRaw = value;
            if (int.TryParse(value, out var intVal) && Enum.IsDefined(typeof(OutcomeMeasureType), intVal))
            {
                _selectedDefinition = Registry.GetDefinition((OutcomeMeasureType)intVal);
            }
            else
            {
                _selectedDefinition = null;
            }
            _scoreInput = null;
            _errorMessage = string.Empty;
        }
    }

    private bool CanRecord =>
        _selectedDefinition is not null &&
        _scoreInput.HasValue &&
        _scoreInput.Value >= _selectedDefinition.MinScore &&
        _scoreInput.Value <= _selectedDefinition.MaxScore;

    protected override void OnParametersSet()
    {
        _availableMeasures = FilterBodyPart.HasValue
            ? Registry.GetMeasuresForBodyPart(FilterBodyPart.Value)
            : Registry.GetAllMeasures();
    }

    private async Task RecordScoreAsync()
    {
        if (!CanRecord) return;

        _errorMessage = string.Empty;

        try
        {
            var result = new OutcomeMeasureResult
            {
                PatientId = PatientId,
                MeasureType = _selectedDefinition!.MeasureType,
                Score = _scoreInput!.Value,
                DateRecorded = DateTime.UtcNow,
                ClinicianId = Guid.Empty // populated by the service/API layer
            };

            await OnScoreRecorded.InvokeAsync(result);

            // Reset form after successful record
            _selectedMeasureTypeRaw = string.Empty;
            _selectedDefinition = null;
            _scoreInput = null;
        }
        catch (Exception)
        {
            _errorMessage = "Failed to record score. Please try again.";
        }
    }
}
