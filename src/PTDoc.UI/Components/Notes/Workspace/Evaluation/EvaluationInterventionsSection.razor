    private Task ToggleModifier(UiCptCodeEntry entry, string modifier)
    {
        if (entry.Modifiers.Contains(modifier, StringComparer.OrdinalIgnoreCase))
        {
            entry.Modifiers.RemoveAll(value => string.Equals(value, modifier, StringComparison.OrdinalIgnoreCase));
        }
        else
        {
            entry.Modifiers.Add(modifier);
        }

        return PlanChanged.InvokeAsync(Plan);
    }

