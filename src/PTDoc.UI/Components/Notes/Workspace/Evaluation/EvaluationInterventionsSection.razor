@namespace PTDoc.UI.Components.Notes.Workspace.Evaluation
@using PTDoc.Application.Compliance
@using PTDoc.Application.Notes.Workspace
@using PTDoc.Core.Models
@using PTDoc.UI.Components.Notes.Models
@using UiCptCodeEntry = PTDoc.UI.Components.Notes.Models.CptCodeEntry
@implements IDisposable

@inject PTDoc.UI.Services.INoteWorkspaceService NoteWorkspaceService
@inject ILogger<EvaluationInterventionsSection> Logger

<section class="plan-tab" data-testid="evaluation-interventions-section" role="tabpanel" aria-label="Interventions section">
    @if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <p class="pt-card__poc-placeholder" role="alert">@_errorMessage</p>
    }

    <div class="pt-card" data-testid="evaluation-cpt-card">
        <div class="pt-card__header">
            <div>
                <h3 class="pt-card__title">CPT Procedure Codes</h3>
                <p class="pt-card__subtitle">Source-backed CPT lookup with modifier guidance</p>
            </div>
        </div>

        @if (!IsReadOnly)
        {
            <div class="pt-card__field">
                <label class="pt-card__field-label" for="evaluation-cpt-search">Search CPT Codes</label>
                <input id="evaluation-cpt-search"
                       type="search"
                       class="pt-card__search-input"
                       placeholder="Search by CPT code or description"
                       value="@_cptSearchQuery"
                       @oninput="HandleCptSearchChangedAsync"
                       data-testid="evaluation-cpt-search" />
            </div>

            @if (_isSearchingCpt)
            {
                <p class="pt-card__search-status" role="status">Searching CPT codes...</p>
            }
            else if (!string.IsNullOrWhiteSpace(_cptLookupError))
            {
                <p class="pt-card__search-status pt-card__search-status--error" role="alert">@_cptLookupError</p>
            }
            else if (_cptResults.Count > 0)
            {
                <div class="pt-card__search-results" data-testid="evaluation-cpt-search-results">
                    @foreach (var result in _cptResults)
                    {
                        <button type="button"
                                class="pt-card__search-result"
                                @onclick="() => AddCptCodeAsync(result)"
                                data-testid="evaluation-cpt-search-result">
                            <span class="pt-card__search-result-code">@result.Code</span>
                            <span class="pt-card__search-result-desc">@result.Description</span>
                            @if (BillingSettings.ModifierWorkflowEnabled && result.SuggestedModifiers.Count > 0)
                            {
                                <span class="pt-card__search-result-hint">Suggested: @string.Join(", ", result.SuggestedModifiers)</span>
                            }
                        </button>
                    }
                </div>
            }
        }

        <p class="pt-card__field-label">Quick-pick CPT shortcuts</p>
        <div class="pt-card__cpt-grid">
            @foreach (var quickPick in QuickPickCptCodes)
            {
                var alreadySelected = Plan.SelectedCptCodes.Any(c => CodesMatch(c.Code, quickPick.Code));
                <button type="button"
                        class="pt-card__cpt-tile @(alreadySelected ? "pt-card__cpt-tile--active" : "")"
                        disabled="@IsReadOnly"
                        aria-pressed="@(alreadySelected ? "true" : "false")"
                        @onclick="() => ToggleCptQuickPickAsync(quickPick)"
                        data-testid="evaluation-cpt-quick-pick">
                    <span class="pt-card__cpt-code">@quickPick.Code</span>
                    <span class="pt-card__cpt-name">@quickPick.ShortName</span>
                    <span class="pt-card__cpt-unit">@quickPick.DefaultUnits units</span>
                </button>
            }
        </div>

        @if (Plan.SelectedCptCodes.Count == 0)
        {
            <div class="pt-card__cpt-empty">
                <p>No CPT codes selected.</p>
            </div>
        }
        else
        {
            @if (GetBillingAdvisories().Count > 0)
            {
                <div class="pt-card__advisory-list" role="status" aria-live="polite">
                    @foreach (var advisory in GetBillingAdvisories())
                    {
                        <p class="pt-card__advisory-item">@advisory</p>
                    }
                </div>
            }

            <ul class="pt-card__cpt-list">
                @foreach (var entry in Plan.SelectedCptCodes)
                {
                    <li class="pt-card__cpt-row">
                        <div class="pt-card__cpt-main">
                            <div class="pt-card__cpt-row-header">
                                <div class="pt-card__cpt-summary">
                                    <span class="pt-card__cpt-code">@entry.Code</span>
                                    <span class="pt-card__cpt-desc">@entry.Description</span>
                                </div>
                                @if (!IsReadOnly)
                                {
                                    <button type="button" class="pt-card__remove-btn" @onclick="() => RemoveCptCode(entry)">x</button>
                                }
                            </div>

                            <div class="pt-card__cpt-detail-grid">
                                <div class="pt-card__cpt-units-row">
                                    <button type="button" class="pt-card__stepper" disabled="@(IsReadOnly || entry.Units <= 1)" @onclick="() => ChangeUnits(entry, -1)">-</button>
                                    <span class="pt-card__unit-value">@entry.Units</span>
                                    <button type="button" class="pt-card__stepper" disabled="@IsReadOnly" @onclick="() => ChangeUnits(entry, 1)">+</button>
                                    <span class="pt-card__unit-label">units</span>
                                </div>
                                @if (IsTimedCode(entry.Code))
                                {
                                    <label class="pt-card__minutes-field">
                                        <span class="pt-card__unit-label">Minutes</span>
                                        <input type="number"
                                               min="0"
                                               step="1"
                                               class="pt-card__minutes-input"
                                               value="@(entry.Minutes?.ToString() ?? string.Empty)"
                                               disabled="@IsReadOnly"
                                               @onchange="e => UpdateCptMinutes(entry, e.Value)"
                                               data-testid="evaluation-cpt-minutes-input" />
                                    </label>
                                }
                            </div>

                            @if (BillingSettings.ModifierWorkflowEnabled && entry.ModifierOptions.Count > 0)
                            {
                                <div class="pt-card__modifier-section">
                                    <p class="pt-card__modifier-label">Modifiers</p>
                                    <div class="pt-card__modifier-chip-row">
                                        @foreach (var modifier in entry.ModifierOptions)
                                        {
                                            var isSelected = entry.Modifiers.Contains(modifier, StringComparer.OrdinalIgnoreCase);
                                            var isSuggested = entry.SuggestedModifiers.Contains(modifier, StringComparer.OrdinalIgnoreCase);
                                            <button type="button"
                                                    class="pt-card__modifier-chip @(isSelected ? "pt-card__modifier-chip--active" : "") @(isSuggested ? "pt-card__modifier-chip--suggested" : "")"
                                                    disabled="@IsReadOnly"
                                                    @onclick="() => ToggleModifier(entry, modifier)"
                                                    data-testid="evaluation-modifier-chip">
                                                @modifier
                                            </button>
                                        }
                                    </div>
                                    @if (entry.SuggestedModifiers.Count > 0)
                                    {
                                        <p class="pt-card__modifier-hint">
                                            Suggested: @string.Join(", ", entry.SuggestedModifiers)
                                            @if (!string.IsNullOrWhiteSpace(entry.ModifierSource))
                                            {
                                                <span> - Source: @entry.ModifierSource</span>
                                            }
                                        </p>
                                    }
                                </div>
                            }
                        </div>
                    </li>
                }
            </ul>
        }
    </div>

    <div class="pt-card" data-testid="evaluation-activity-rows-card">
        <div class="pt-card__header">
            <div>
                <h3 class="pt-card__title">Intervention / Activity Rows</h3>
                <p class="pt-card__subtitle">Evaluation intervention authoring, assistance, cueing, response, and HEP linkage</p>
            </div>
            @if (!IsReadOnly)
            {
                <button type="button" class="pt-card__secondary-btn" @onclick="AddManualExerciseRow">+ Add Row</button>
            }
        </div>

        @if (ExerciseOptions.Count > 0)
        {
            <div class="pt-card__modifier-chip-row" data-testid="evaluation-exercise-options">
                @foreach (var exercise in ExerciseOptions)
                {
                    var isSelected = Objective.ExerciseRows.Any(row =>
                        string.Equals(row.SuggestedExercise, exercise, StringComparison.OrdinalIgnoreCase)
                        || string.Equals(row.ActualExercisePerformed, exercise, StringComparison.OrdinalIgnoreCase));
                    <button type="button"
                            class="pt-card__modifier-chip @(isSelected ? "pt-card__modifier-chip--active" : "")"
                            disabled="@IsReadOnly"
                            @onclick="() => AddSuggestedExercise(exercise)">
                        @exercise
                    </button>
                }
            </div>
        }

        @if (Objective.ExerciseRows.Count == 0)
        {
            <p class="pt-card__poc-placeholder">No evaluation intervention rows documented yet.</p>
        }
        else
        {
            <div class="pt-card__editor-list">
                @foreach (var row in Objective.ExerciseRows)
                {
                    <div class="pt-card__editor-row" data-testid="evaluation-exercise-row">
                        <div class="pt-card__editor-row-header">
                            <strong>@(string.IsNullOrWhiteSpace(row.SuggestedExercise) ? "Intervention row" : row.SuggestedExercise)</strong>
                            @if (!IsReadOnly)
                            {
                                <button type="button" class="pt-card__remove-btn" @onclick="() => RemoveExerciseRow(row)">x</button>
                            }
                        </div>
                        <div class="pt-card__row-2col">
                            <label class="pt-card__field">
                                <span class="pt-card__field-label">Suggested activity</span>
                                <input class="pt-card__search-input" value="@row.SuggestedExercise" disabled="@IsReadOnly" @onchange="e => UpdateExerciseRow(row, item => item.SuggestedExercise = e.Value?.ToString() ?? string.Empty)" />
                            </label>
                            <label class="pt-card__field">
                                <span class="pt-card__field-label">Performed</span>
                                <input class="pt-card__search-input" value="@row.ActualExercisePerformed" disabled="@IsReadOnly" @onchange="e => UpdateExerciseRow(row, item => item.ActualExercisePerformed = e.Value?.ToString() ?? string.Empty)" />
                            </label>
                            <label class="pt-card__field">
                                <span class="pt-card__field-label">Sets / reps / duration</span>
                                <input class="pt-card__search-input" value="@row.SetsRepsDuration" disabled="@IsReadOnly" @onchange="e => UpdateExerciseRow(row, item => item.SetsRepsDuration = e.Value?.ToString())" />
                            </label>
                            <label class="pt-card__field">
                                <span class="pt-card__field-label">CPT for this intervention</span>
                                <select class="pt-card__select" value="@NormalizeCode(row.CptCode)" disabled="@IsReadOnly" @onchange="e => UpdateExerciseCptAsync(row, e.Value?.ToString())" data-testid="evaluation-exercise-cpt">
                                    <option value="">Select CPT</option>
                                    @foreach (var option in QuickPickCptCodes)
                                    {
                                        <option value="@option.Code" selected="@CodesMatch(row.CptCode, option.Code)">@option.Code - @option.ShortName</option>
                                    }
                                </select>
                            </label>
                            <label class="pt-card__field">
                                <span class="pt-card__field-label">Minutes</span>
                                <input class="pt-card__search-input" type="number" min="0" step="1" value="@(row.TimeMinutes?.ToString() ?? string.Empty)" disabled="@IsReadOnly" @onchange="e => UpdateExerciseMinutes(row, e.Value)" />
                            </label>
                            <label class="pt-card__field">
                                <span class="pt-card__field-label">Assistance</span>
                                <select class="pt-card__select" value="@row.AssistanceLevel" disabled="@IsReadOnly" @onchange="e => UpdateExerciseRow(row, item => item.AssistanceLevel = e.Value?.ToString())">
                                    <option value="">None documented</option>
                                    @foreach (var option in AssistanceLevelOptions)
                                    {
                                        <option value="@option" selected="@string.Equals(row.AssistanceLevel, option, StringComparison.OrdinalIgnoreCase)">@option</option>
                                    }
                                </select>
                            </label>
                            <label class="pt-card__field">
                                <span class="pt-card__field-label">Cueing</span>
                                <select class="pt-card__select" value="@row.Cueing" disabled="@IsReadOnly" @onchange="e => UpdateExerciseRow(row, item => item.Cueing = e.Value?.ToString())">
                                    <option value="">None documented</option>
                                    @foreach (var option in CueingOptions)
                                    {
                                        <option value="@option" selected="@string.Equals(row.Cueing, option, StringComparison.OrdinalIgnoreCase)">@option</option>
                                    }
                                </select>
                            </label>
                        </div>
                        <label class="pt-card__checkbox-row">
                            <input type="checkbox" checked="@row.IncludeInHomeExerciseProgram" disabled="@IsReadOnly" @onchange="e => UpdateExerciseRow(row, item => item.IncludeInHomeExerciseProgram = (bool)e.Value!)" />
                            Link this intervention to HEP
                        </label>
                    </div>
                }
            </div>
        }
    </div>

    <div class="pt-card" data-testid="evaluation-general-interventions-card">
        <div class="pt-card__header">
            <div>
                <h3 class="pt-card__title">General Interventions</h3>
                <p class="pt-card__subtitle">Additional treatment rows when catalog activity rows are not specific enough</p>
            </div>
            @if (!IsReadOnly)
            {
                <button type="button" class="pt-card__secondary-btn" @onclick="AddManualIntervention">+ Add Manual Intervention</button>
            }
        </div>

        @if (InterventionOptions.Count > 0)
        {
            <div class="pt-card__modifier-chip-row" data-testid="evaluation-general-intervention-options">
                @foreach (var intervention in InterventionOptions)
                {
                    var isSelected = Plan.GeneralInterventions.Any(entry => string.Equals(entry.Name, intervention, StringComparison.OrdinalIgnoreCase));
                    <button type="button" class="pt-card__modifier-chip @(isSelected ? "pt-card__modifier-chip--active" : "")" disabled="@IsReadOnly" @onclick="() => ToggleGeneralIntervention(intervention)">
                        @intervention
                    </button>
                }
            </div>
        }

        @if (Plan.GeneralInterventions.Count == 0)
        {
            <p class="pt-card__poc-placeholder">No general interventions documented yet.</p>
        }
        else
        {
            <div class="pt-card__editor-list">
                @foreach (var intervention in Plan.GeneralInterventions)
                {
                    <div class="pt-card__editor-row" data-testid="evaluation-general-intervention-row">
                        <div class="pt-card__editor-row-header">
                            <strong>@(string.IsNullOrWhiteSpace(intervention.Name) ? "Intervention" : intervention.Name)</strong>
                            @if (!IsReadOnly)
                            {
                                <button type="button" class="pt-card__remove-btn" @onclick="() => RemoveGeneralIntervention(intervention)">x</button>
                            }
                        </div>
                        <div class="pt-card__row-2col">
                            <label class="pt-card__field">
                                <span class="pt-card__field-label">Intervention</span>
                                <input class="pt-card__search-input" value="@intervention.Name" disabled="@IsReadOnly" @onchange="e => UpdateGeneralIntervention(intervention, entry => entry.Name = e.Value?.ToString() ?? string.Empty)" />
                            </label>
                            <label class="pt-card__field">
                                <span class="pt-card__field-label">CPT for this intervention</span>
                                <select class="pt-card__select" value="@NormalizeCode(intervention.CptCode)" disabled="@IsReadOnly" @onchange="e => UpdateInterventionCptAsync(intervention, e.Value?.ToString())" data-testid="evaluation-intervention-cpt">
                                    <option value="">Select CPT</option>
                                    @foreach (var option in QuickPickCptCodes)
                                    {
                                        <option value="@option.Code" selected="@CodesMatch(intervention.CptCode, option.Code)">@option.Code - @option.ShortName</option>
                                    }
                                </select>
                            </label>
                            <label class="pt-card__field">
                                <span class="pt-card__field-label">Minutes</span>
                                <input class="pt-card__search-input" type="number" min="0" step="1" value="@(intervention.TimeMinutes?.ToString() ?? string.Empty)" disabled="@IsReadOnly" @onchange="e => UpdateInterventionMinutes(intervention, e.Value)" />
                            </label>
                            <label class="pt-card__field">
                                <span class="pt-card__field-label">Assistance</span>
                                <select class="pt-card__select" value="@intervention.AssistanceLevel" disabled="@IsReadOnly" @onchange="e => UpdateGeneralIntervention(intervention, entry => entry.AssistanceLevel = e.Value?.ToString())">
                                    <option value="">None documented</option>
                                    @foreach (var option in AssistanceLevelOptions)
                                    {
                                        <option value="@option" selected="@string.Equals(intervention.AssistanceLevel, option, StringComparison.OrdinalIgnoreCase)">@option</option>
                                    }
                                </select>
                            </label>
                            <label class="pt-card__field">
                                <span class="pt-card__field-label">Cueing</span>
                                <select class="pt-card__select" value="@intervention.Cueing" disabled="@IsReadOnly" @onchange="e => UpdateGeneralIntervention(intervention, entry => entry.Cueing = e.Value?.ToString())">
                                    <option value="">None documented</option>
                                    @foreach (var option in CueingOptions)
                                    {
                                        <option value="@option" selected="@string.Equals(intervention.Cueing, option, StringComparison.OrdinalIgnoreCase)">@option</option>
                                    }
                                </select>
                            </label>
                            <label class="pt-card__field">
                                <span class="pt-card__field-label">Response</span>
                                <input class="pt-card__search-input" value="@intervention.Response" disabled="@IsReadOnly" @onchange="e => UpdateGeneralIntervention(intervention, entry => entry.Response = e.Value?.ToString())" />
                            </label>
                        </div>
                        <label class="pt-card__checkbox-row">
                            <input type="checkbox" checked="@intervention.IncludeInHomeExerciseProgram" disabled="@IsReadOnly" @onchange="e => UpdateGeneralIntervention(intervention, entry => entry.IncludeInHomeExerciseProgram = (bool)e.Value!)" />
                            Link this intervention to HEP
                        </label>
                    </div>
                }
            </div>
        }
    </div>

    <div class="pt-card" data-testid="evaluation-hep-card">
        <div class="pt-card__header">
            <h3 class="pt-card__title">Home Exercise Program (HEP)</h3>
        </div>

        @if (LinkedHepInterventions.Count > 0)
        {
            <div class="pt-card__advisory-list" role="status" aria-live="polite" data-testid="evaluation-hep-linked-interventions">
                <p class="pt-card__advisory-item">Linked HEP activities: @string.Join("; ", LinkedHepInterventions)</p>
            </div>
        }

        <textarea id="evaluation-hep-notes"
                  class="pt-card__textarea"
                  rows="3"
                  placeholder="Supplement linked activities with frequency, precautions, and patient education..."
                  disabled="@IsReadOnly"
                  value="@Plan.HomeExerciseProgramNotes"
                  @onchange="e => SetPlanAndNotify(vm => vm.HomeExerciseProgramNotes = e.Value?.ToString())"></textarea>
    </div>
</section>

@code {
    [Parameter, EditorRequired] public ObjectiveVm Objective { get; set; } = new();
    [Parameter, EditorRequired] public EventCallback<ObjectiveVm> ObjectiveChanged { get; set; }
    [Parameter, EditorRequired] public PlanVm Plan { get; set; } = new();
    [Parameter, EditorRequired] public EventCallback<PlanVm> PlanChanged { get; set; }
    [Parameter] public BillingModifierSettingsVm BillingSettings { get; set; } = new();
    [Parameter] public bool IsReadOnly { get; set; }
    [Parameter] public string? SelectedBodyPart { get; set; }

    private bool _isSearchingCpt;
    private string _cptSearchQuery = string.Empty;
    private string? _cptLookupError;
    private string? _errorMessage;
    private string? _loadedCatalogBodyPart;
    private List<CodeLookupEntry> _cptResults = [];
    private BodyRegionCatalog? _catalog;
    private CancellationTokenSource? _cptSearchCts;

    private record QuickPickCptCode(string Code, string ShortName, int DefaultUnits);

    private static readonly QuickPickCptCode[] QuickPickCptCodes =
    [
        new("97140", "Manual Therapy", 2),
        new("97110", "Exercise", 2),
        new("97112", "Neuromuscular Re-ed", 2),
        new("97530", "Functional Activities", 2),
        new("97116", "Gait Training", 2),
        new("97535", "Self-care/ADL Training", 2),
    ];

    private static readonly string[] AssistanceLevelOptions =
    [
        "Min Assist", "Mod Assist", "Max Assist", "Contact Guard", "Standby Assist", "Independent"
    ];

    private static readonly string[] CueingOptions =
    [
        "Verbal cueing", "Tactile cueing", "Visual cueing", "Verbal + tactile cueing", "Verbal + visual cueing", "Tactile + visual cueing"
    ];

    protected override async Task OnParametersSetAsync()
    {
        await EnsureCatalogAsync();
    }

    private List<string> ExerciseOptions => _catalog?.ExerciseOptions
        .OrderBy(value => value, StringComparer.OrdinalIgnoreCase)
        .ToList() ?? [];

    private List<string> InterventionOptions => _catalog?.TreatmentInterventionOptions
        .OrderBy(value => value, StringComparer.OrdinalIgnoreCase)
        .ToList() ?? [];

    private List<string> LinkedHepInterventions
    {
        get
        {
            var rows = Objective.ExerciseRows
                .Where(row => row.IncludeInHomeExerciseProgram)
                .Select(FormatExerciseForHep);

            var interventions = Plan.GeneralInterventions
                .Where(entry => entry.IncludeInHomeExerciseProgram && !string.IsNullOrWhiteSpace(entry.Name))
                .Select(FormatInterventionForHep);

            return rows.Concat(interventions)
                .Where(value => !string.IsNullOrWhiteSpace(value))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(value => value, StringComparer.OrdinalIgnoreCase)
                .ToList();
        }
    }

    private async Task EnsureCatalogAsync()
    {
        if (string.IsNullOrWhiteSpace(SelectedBodyPart))
        {
            _catalog = null;
            _errorMessage = null;
            _loadedCatalogBodyPart = null;
            return;
        }

        if (string.Equals(_loadedCatalogBodyPart, SelectedBodyPart, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        try
        {
            _catalog = await NoteWorkspaceService.GetBodyRegionCatalogAsync(ParseBodyPart(SelectedBodyPart));
            _errorMessage = null;
            _loadedCatalogBodyPart = SelectedBodyPart;
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Unable to load evaluation interventions catalog for {BodyPart}", SelectedBodyPart);
            _catalog = null;
            _errorMessage = "Unable to load the structured intervention catalog right now.";
        }
    }

    private async Task ToggleCptQuickPickAsync(QuickPickCptCode quickPick)
    {
        var existing = Plan.SelectedCptCodes.FirstOrDefault(c => CodesMatch(c.Code, quickPick.Code));
        if (existing is not null)
        {
            Plan.SelectedCptCodes.Remove(existing);
            await PlanChanged.InvokeAsync(Plan);
            return;
        }

        Plan.SelectedCptCodes.Add(await BuildCptEntryAsync(quickPick.Code, quickPick.ShortName, quickPick.DefaultUnits));
        await PlanChanged.InvokeAsync(Plan);
    }

    private async Task AddCptCodeAsync(CodeLookupEntry result)
    {
        var normalizedCode = NormalizeCode(result.Code);
        var existing = Plan.SelectedCptCodes.FirstOrDefault(code => CodesMatch(code.Code, normalizedCode));
        if (existing is not null)
        {
            existing.Description = result.Description;
            existing.ModifierOptions = BillingSettings.ModifierWorkflowEnabled ? [.. result.ModifierOptions] : [];
            existing.SuggestedModifiers = BillingSettings.ModifierWorkflowEnabled ? [.. result.SuggestedModifiers] : [];
            existing.ModifierSource = result.ModifierSource;
            if (BillingSettings.ModifierWorkflowEnabled && BillingSettings.AutoApplySuggestedModifiers)
            {
                existing.Modifiers = [.. result.SuggestedModifiers];
            }
        }
        else
        {
            Plan.SelectedCptCodes.Add(new UiCptCodeEntry
            {
                Code = normalizedCode,
                Description = result.Description,
                Units = ResolveDefaultUnits(normalizedCode),
                Modifiers = BillingSettings.ModifierWorkflowEnabled && BillingSettings.AutoApplySuggestedModifiers ? [.. result.SuggestedModifiers] : [],
                ModifierOptions = BillingSettings.ModifierWorkflowEnabled ? [.. result.ModifierOptions] : [],
                SuggestedModifiers = BillingSettings.ModifierWorkflowEnabled ? [.. result.SuggestedModifiers] : [],
                ModifierSource = result.ModifierSource
            });
        }

        _cptResults = [];
        _cptSearchQuery = string.Empty;
        await PlanChanged.InvokeAsync(Plan);
    }

    private async Task<UiCptCodeEntry> BuildCptEntryAsync(string code, string description, int defaultUnits)
    {
        var normalizedCode = NormalizeCode(code);
        if (BillingSettings.ModifierWorkflowEnabled)
        {
            try
            {
                var matches = await NoteWorkspaceService.SearchCptAsync(normalizedCode, take: 5);
                var exactMatch = matches.FirstOrDefault(match => CodesMatch(match.Code, normalizedCode));
                if (exactMatch is not null)
                {
                    return new UiCptCodeEntry
                    {
                        Code = NormalizeCode(exactMatch.Code),
                        Description = exactMatch.Description,
                        Units = defaultUnits,
                        Modifiers = BillingSettings.AutoApplySuggestedModifiers ? [.. exactMatch.SuggestedModifiers] : [],
                        ModifierOptions = [.. exactMatch.ModifierOptions],
                        SuggestedModifiers = [.. exactMatch.SuggestedModifiers],
                        ModifierSource = exactMatch.ModifierSource
                    };
                }
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Unable to enrich CPT code {Code} with modifier metadata", code);
            }
        }

        return new UiCptCodeEntry
        {
            Code = normalizedCode,
            Description = description,
            Units = defaultUnits
        };
    }

    private async Task HandleCptSearchChangedAsync(ChangeEventArgs args)
    {
        _cptSearchQuery = args.Value?.ToString() ?? string.Empty;
        _cptSearchCts?.Cancel();
        _cptSearchCts?.Dispose();
        _cptSearchCts = new CancellationTokenSource();
        var cancellationToken = _cptSearchCts.Token;

        if (string.IsNullOrWhiteSpace(_cptSearchQuery))
        {
            _cptResults = [];
            _cptLookupError = null;
            _isSearchingCpt = false;
            return;
        }

        _isSearchingCpt = true;
        _cptLookupError = null;
        try
        {
            await Task.Delay(250, cancellationToken);
            var results = await NoteWorkspaceService.SearchCptAsync(_cptSearchQuery, take: 8, cancellationToken);
            if (!cancellationToken.IsCancellationRequested)
            {
                _cptResults = [.. results];
            }
        }
        catch (OperationCanceledException)
        {
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "CPT lookup failed for evaluation interventions query {Query}", _cptSearchQuery);
            _cptLookupError = "Unable to search CPT codes.";
            _cptResults = [];
        }
        finally
        {
            if (!cancellationToken.IsCancellationRequested)
            {
                _isSearchingCpt = false;
            }
        }
    }

    private List<string> GetBillingAdvisories()
    {
        var advisories = new List<string>();
        var timedCodesMissingMinutes = Plan.SelectedCptCodes
            .Where(entry => IsTimedCode(entry.Code) && entry.Units > 0 && entry.Minutes is null or <= 0)
            .Select(entry => entry.Code)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        if (timedCodesMissingMinutes.Count > 0)
        {
            advisories.Add($"Timed CPT minutes are still needed for: {string.Join(", ", timedCodesMissingMinutes)}.");
        }

        if (BillingSettings.ModifierWorkflowEnabled && BillingSettings.RequireSuggestedModifierReview)
        {
            var missingSuggestedModifiers = Plan.SelectedCptCodes
                .Where(entry => entry.SuggestedModifiers.Any(suggested => !entry.Modifiers.Contains(suggested, StringComparer.OrdinalIgnoreCase)))
                .Select(entry => entry.Code)
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .ToList();

            if (missingSuggestedModifiers.Count > 0)
            {
                advisories.Add($"Review suggested modifiers before billing: {string.Join(", ", missingSuggestedModifiers)}.");
            }
        }

        return advisories;
    }

    private async Task UpdateExerciseCptAsync(ExerciseRowEntry row, string? code)
    {
        var option = QuickPickCptCodes.FirstOrDefault(item => CodesMatch(item.Code, code));
        row.CptCode = option?.Code;
        row.CptDescription = option?.ShortName;
        if (option is not null && !Plan.SelectedCptCodes.Any(entry => CodesMatch(entry.Code, option.Code)))
        {
            Plan.SelectedCptCodes.Add(await BuildCptEntryAsync(option.Code, option.ShortName, option.DefaultUnits));
            await PlanChanged.InvokeAsync(Plan);
        }

        await ObjectiveChanged.InvokeAsync(Objective);
    }

    private async Task UpdateInterventionCptAsync(GeneralInterventionEntry intervention, string? code)
    {
        var option = QuickPickCptCodes.FirstOrDefault(item => CodesMatch(item.Code, code));
        intervention.CptCode = option?.Code;
        intervention.CptDescription = option?.ShortName;
        if (option is not null && !Plan.SelectedCptCodes.Any(entry => CodesMatch(entry.Code, option.Code)))
        {
            Plan.SelectedCptCodes.Add(await BuildCptEntryAsync(option.Code, option.ShortName, option.DefaultUnits));
        }

        await PlanChanged.InvokeAsync(Plan);
    }

