    {
        entry.Minutes = int.TryParse(value?.ToString(), out var minutes) ? Math.Max(0, minutes) : null;
        return PlanChanged.InvokeAsync(Plan);
    }

    private static string FormatExerciseForHep(ExerciseRowEntry row)
    {
        var title = string.IsNullOrWhiteSpace(row.ActualExercisePerformed) ? row.SuggestedExercise : row.ActualExercisePerformed;
        var parts = new List<string> { title.Trim() };
        if (!string.IsNullOrWhiteSpace(row.SetsRepsDuration))
        {
            parts.Add(row.SetsRepsDuration.Trim());
        }
        if (!string.IsNullOrWhiteSpace(row.CptCode))
        {
            parts.Add($"CPT {row.CptCode.Trim()}");
        }
        return string.Join(" - ", parts);
    }

    private static string FormatInterventionForHep(GeneralInterventionEntry entry)
    {
        var parts = new List<string> { entry.Name.Trim() };
        if (!string.IsNullOrWhiteSpace(entry.CptCode))
        {
            parts.Add($"CPT {entry.CptCode.Trim()}");
        }
        if (!string.IsNullOrWhiteSpace(entry.AssistanceLevel))
        {
            parts.Add(entry.AssistanceLevel.Trim());
        }
        if (!string.IsNullOrWhiteSpace(entry.Cueing))
        {
            parts.Add(entry.Cueing.Trim());
        }
        return string.Join(" - ", parts);
    }

    private static string NormalizeCode(string? code) => code?.Trim() ?? string.Empty;
    private static bool CodesMatch(string? left, string? right) => string.Equals(NormalizeCode(left), NormalizeCode(right), StringComparison.OrdinalIgnoreCase);
    private static bool IsTimedCode(string? code) => KnownTimedCptCodes.Codes.Contains(NormalizeCode(code));
    private static int ResolveDefaultUnits(string code) => IsTimedCode(code) ? 2 : 1;
    private static BodyPart ParseBodyPart(string? value) => Enum.TryParse<BodyPart>(value, ignoreCase: true, out var parsed) ? parsed : BodyPart.Other;

    public void Dispose()
    {
        _cptSearchCts?.Cancel();
        _cptSearchCts?.Dispose();
    }
