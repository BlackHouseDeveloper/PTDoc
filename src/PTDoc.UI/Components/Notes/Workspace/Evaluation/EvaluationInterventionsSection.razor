    private Task ToggleGeneralIntervention(string interventionName)
    {
        var existing = Plan.GeneralInterventions.FirstOrDefault(entry => string.Equals(entry.Name, interventionName, StringComparison.OrdinalIgnoreCase));
        if (existing is null)
        {
            Plan.GeneralInterventions.Add(new GeneralInterventionEntry
            {
                Name = interventionName,
                IsSourceBacked = true
            });
        }
        else
        {
            Plan.GeneralInterventions.Remove(existing);
        }

        return PlanChanged.InvokeAsync(Plan);
    }

