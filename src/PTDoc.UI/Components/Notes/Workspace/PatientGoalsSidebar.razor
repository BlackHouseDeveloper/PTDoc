@namespace PTDoc.UI.Components.Notes.Workspace
@using PTDoc.UI.Components.Notes.Models

<aside class="patient-goals-sidebar" data-testid="patient-goals-sidebar">
    <!-- Goals Card -->
    <div class="pgs-card @(_goalsExpanded ? "" : "pgs-card--collapsed")">
        <div class="pgs-card__header">
            <button type="button"
                    class="pgs-card__collapse-btn"
                    @onclick="ToggleGoals"
                    aria-expanded="@_goalsExpanded"
                    aria-label="@(_goalsExpanded ? "Collapse goals" : "Expand goals")">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"
                     xmlns="http://www.w3.org/2000/svg" aria-hidden="true"
                     class="pgs-card__chevron @(_goalsExpanded ? "pgs-card__chevron--open" : "")">
                    <path d="M4 6L8 10L12 6" stroke="currentColor" stroke-width="1.5"
                          stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </button>
            <svg class="pgs-card__title-icon" width="18" height="18" viewBox="0 0 18 18"
                 fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <circle cx="9" cy="9" r="7.5" stroke="currentColor" stroke-width="1.5"/>
                <circle cx="9" cy="9" r="4.5" stroke="currentColor" stroke-width="1.5"/>
                <circle cx="9" cy="9" r="1.5" fill="currentColor"/>
            </svg>
            <h3 class="pgs-card__title">Patient Goals</h3>
            <span class="pgs-card__badge">@ActiveGoalCount Active</span>
        </div>

        @if (_goalsExpanded)
        {
            <div class="pgs-card__body">
                <div class="pgs-card__progress-row">
                    <span class="pgs-card__progress-label">Overall Progress</span>
                    <span class="pgs-card__progress-pct" style="color: var(--primary)">@OverallProgressPercent%</span>
                </div>
                <div class="pgs-card__progress-bar">
                    <div class="pgs-card__progress-fill"
                         style="width: @OverallProgressPercent%"
                         role="progressbar"
                         aria-valuenow="@OverallProgressPercent"
                         aria-valuemin="0"
                         aria-valuemax="100"></div>
                </div>

                <div class="pgs-card__counts-row">
                    <div class="pgs-card__count-chip">
                        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                            <path d="M6 1.5L7.5 4.5H10.5L8 6.5L8.5 9.5L6 7.5L3.5 9.5L4 6.5L1.5 4.5H4.5L6 1.5Z"
                                  stroke="currentColor" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                        <span>Short-Term</span>
                        <strong>@ShortTermGoalCount</strong>
                    </div>
                    <div class="pgs-card__count-chip">
                        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                            <rect x="1.5" y="2" width="9" height="8" rx="0.75"
                                  stroke="currentColor" stroke-width="1.1"/>
                            <path d="M4 1.5V2.5M8 1.5V2.5M1.5 5H10.5"
                                  stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/>
                        </svg>
                        <span>Long-Term</span>
                        <strong>@LongTermGoalCount</strong>
                    </div>
                </div>

                @if (GoalItems.Count > 0)
                {
                    <div class="pgs-card__goals-section-label">
                        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                            <path d="M1 6L11 6M6 2L11 6L6 10"
                                  stroke="currentColor" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                        Short-Term Goals
                    </div>

                    @foreach (var goal in GoalItems)
                    {
                        <div class="pgs-card__goal-item">
                            <div class="pgs-card__goal-header">
                                <span class="pgs-card__goal-name">@goal.Name</span>
                                <span class="pgs-card__goal-type-badge">@goal.Type</span>
                            </div>
                            <div class="pgs-card__goal-sub">
                                <span class="pgs-card__goal-category">@goal.Category</span>
                                <span class="pgs-card__goal-timeline">⏱ @goal.Timeline</span>
                            </div>
                            <div class="pgs-card__goal-progress-row">
                                <span class="pgs-card__goal-progress-label">Progress</span>
                                <span class="pgs-card__goal-progress-pct" style="color: var(--primary)">@goal.ProgressPercent%</span>
                            </div>
                            <div class="pgs-card__progress-bar">
                                <div class="pgs-card__progress-fill"
                                     style="width: @goal.ProgressPercent%"></div>
                            </div>
                            <p class="pgs-card__goal-target">📊 @goal.TargetDescription</p>
                        </div>
                    }
                }
            </div>
        }
    </div>

    <!-- AI Hints Panel -->
    <div class="pgs-hints" data-testid="patient-goals-hints">
        <svg class="pgs-hints__icon" width="16" height="16" viewBox="0 0 16 16" fill="none"
             xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.5"/>
            <path d="M8 5.5V8M8 10.5H8.01" stroke="currentColor" stroke-width="1.5"
                  stroke-linecap="round"/>
        </svg>
        <div class="pgs-hints__body">
            @if (HintItems.Count > 0)
            {
                <ul class="pgs-hints__list">
                    @foreach (var hint in HintItems)
                    {
                        <li>@hint</li>
                    }
                </ul>
            }
            else
            {
                <p class="pgs-hints__placeholder">Reference goals while documenting objective findings</p>
                <ul class="pgs-hints__list">
                    <li>Compare ROM to goal targets</li>
                    <li>Note progress toward strength goals</li>
                    <li>Update functional status</li>
                </ul>
            }
        </div>
    </div>
</aside>

@code {
    private bool _goalsExpanded = true;

    [Parameter] public string PatientId { get; set; } = string.Empty;
    [Parameter] public int ActiveGoalCount { get; set; } = 0;
    [Parameter] public int OverallProgressPercent { get; set; } = 0;
    [Parameter] public int ShortTermGoalCount { get; set; } = 0;
    [Parameter] public int LongTermGoalCount { get; set; } = 0;
    [Parameter] public IReadOnlyList<PatientGoalItem> GoalItems { get; set; } = Array.Empty<PatientGoalItem>();
    [Parameter] public IReadOnlyList<string> HintItems { get; set; } = Array.Empty<string>();

    private void ToggleGoals() => _goalsExpanded = !_goalsExpanded;
}
