@namespace PTDoc.UI.Components.Notes.Workspace.DailyTreatment
@using PTDoc.UI.Components.Notes.Models

<section class="daily-assessment @(IsDarkMode ? "daily-assessment--dark" : string.Empty)" data-testid="daily-assessment-section">
    <div class="daily-grid">
        <div class="daily-col-12">
            <FormSection Title="Clinical Assessment Summary" Subtitle="Clinical assessment narrative based on subjective and objective findings"
                         TestId="daily-assessment-summary">
                <div class="daily-assessment__actions">
                    <button type="button" disabled="@IsReadOnly" @onclick="GenerateAssessment">Generate Assessment</button>
                </div>

                <EditableTextArea Value="@_vm.AssessmentNarrative"
                                  ValueChanged="UpdateNarrative"
                                  IsReadOnly="IsReadOnly"
                                  Placeholder="Click 'Generate Assessment' to create AI-assisted draft."
                                  Rows="5" />
            </FormSection>
        </div>

        <div class="daily-col-12">
            <FormSection Title="Deficits &amp; Impairments" Subtitle="Auto-populated from objective findings">
                <div class="daily-assessment__actions">
                    <button type="button" disabled="@IsReadOnly" @onclick="AutoGenerateDeficits">Auto-Generate</button>
                </div>

                <EditableTextArea Label="Deficits Summary"
                                  Value="@_vm.DeficitsSummary"
                                  ValueChanged="UpdateDeficitsSummary"
                                  IsReadOnly="IsReadOnly"
                                  Placeholder="Click 'Auto-Generate' to populate from objective findings, or enter manually."
                                  Rows="4" />

                <div class="daily-assessment__chips">
                    @foreach (var category in _vm.DeficitCategories)
                    {
                        <span>@category</span>
                    }
                </div>
            </FormSection>
        </div>

        <div class="daily-col-12">
            <FormSection Title="Goal Status Review" Subtitle="Update the status of each goal from initial evaluation">
                <div class="daily-assessment__goal-status-legend">
                    <span>Met: @_metCount</span>
                    <span>Ongoing: @_ongoingCount</span>
                    <span>Modified: @_modifiedCount</span>
                </div>

                @for (var i = 0; i < _goalStatusCards.Count; i++)
                {
                    var card = _goalStatusCards[i];
                    <div class="daily-assessment__goal-status-card">
                        <GoalCard Type="@card.Type"
                                  Status="@card.Status"
                                  Title="@card.Title"
                                  Measure="@card.Measure"
                                  Timeline="@card.Timeline"
                                  ProgressPercent="@card.ProgressPercent" />

                        <div class="daily-assessment__status-options">
                            <label><input type="radio" name="status-@i" disabled="@IsReadOnly" checked='@(card.Status == "Met")' @onchange='() => SetGoalStatus(i, "Met")' /> Met</label>
                            <label><input type="radio" name="status-@i" disabled="@IsReadOnly" checked='@(card.Status == "Ongoing")' @onchange='() => SetGoalStatus(i, "Ongoing")' /> Ongoing</label>
                            <label><input type="radio" name="status-@i" disabled="@IsReadOnly" checked='@(card.Status == "Modified")' @onchange='() => SetGoalStatus(i, "Modified")' /> Modified</label>
                        </div>
                    </div>
                }
            </FormSection>
        </div>

        <div class="daily-col-12">
            <FormSection Title="ICD-10 Diagnosis Codes *" Subtitle="Search and select diagnosis codes (max 4)">
                <div class="daily-assessment__field">
                    <input type="text" disabled="@IsReadOnly" @bind="_icdQuery" @bind:event="oninput" placeholder="Search by code or description" />
                    <button type="button" disabled="@(IsReadOnly || string.IsNullOrWhiteSpace(_icdQuery) || _vm.DiagnosisCodes.Count >= 4)" @onclick="AddIcdCode">Add</button>
                </div>

                @if (_vm.DiagnosisCodes.Count == 0)
                {
                    <p class="daily-assessment__placeholder">No diagnosis codes selected.</p>
                }
                else
                {
                    <ul class="daily-assessment__code-list">
                        @for (var i = 0; i < _vm.DiagnosisCodes.Count; i++)
                        {
                            var idx = i;
                            <li>
                                <span>@_vm.DiagnosisCodes[idx].Code - @_vm.DiagnosisCodes[idx].Description</span>
                                @if (!IsReadOnly)
                                {
                                    <button type="button" @onclick="() => RemoveIcdCode(idx)">Remove</button>
                                }
                            </li>
                        }
                    </ul>
                }
            </FormSection>
        </div>

        <div class="daily-col-12">
            <FormSection Title="Patient Motivation &amp; Goals" Subtitle="Assess patient readiness and motivation for therapy">
                <div class="daily-assessment__field">
                    <label for="motivation-level">Motivation Level *</label>
                    <select id="motivation-level" disabled="@IsReadOnly" @bind="_vm.MotivationLevel">
                        <option value="">Select motivation level</option>
                        <option>Low</option>
                        <option>Moderate</option>
                        <option>High</option>
                    </select>
                </div>

                <CheckboxGrid Options="_motivationFactors"
                              Selected="_vm.MotivatingFactors"
                              SelectedChanged="v => _vm.MotivatingFactors = v"
                              IsReadOnly="IsReadOnly"
                              Columns="2" />

                <EditableTextArea Label="Patient's Personal Goals"
                                  Value="@(_vm.PatientPersonalGoals ?? string.Empty)"
                                  ValueChanged="v => _vm.PatientPersonalGoals = v"
                                  IsReadOnly="IsReadOnly"
                                  Placeholder="What does the patient want to accomplish?"
                                  Rows="3" />

                <EditableTextArea Label="Additional Motivation Notes"
                                  Value="@(_vm.AdditionalMotivationNotes ?? string.Empty)"
                                  ValueChanged="v => _vm.AdditionalMotivationNotes = v"
                                  IsReadOnly="IsReadOnly"
                                  Placeholder="Observed behaviors, readiness for change..."
                                  Rows="3" />
            </FormSection>
        </div>

        <div class="daily-col-12">
            <FormSection Title="Support System &amp; Barriers" Subtitle="Identify resources and barriers to recovery">
                <div class="daily-assessment__field">
                    <label for="support-level">Support System Level *</label>
                    <select id="support-level" disabled="@IsReadOnly" @bind="_vm.SupportSystemLevel">
                        <option value="">Select support level</option>
                        <option>Limited</option>
                        <option>Adequate</option>
                        <option>Strong</option>
                    </select>
                </div>

                <p class="daily-assessment__subheading">Available Resources &amp; Supports</p>
                <CheckboxGrid Options="_supportResources"
                              Selected="_vm.AvailableResources"
                              SelectedChanged="v => _vm.AvailableResources = v"
                              IsReadOnly="IsReadOnly"
                              Columns="2" />

                <p class="daily-assessment__subheading">Barriers To Recovery</p>
                <CheckboxGrid Options="_barrierOptions"
                              Selected="_vm.BarriersToRecovery"
                              SelectedChanged="v => _vm.BarriersToRecovery = v"
                              IsReadOnly="IsReadOnly"
                              Columns="2" />

                <EditableTextArea Label="Support System Details"
                                  Value="@(_vm.SupportSystemDetails ?? string.Empty)"
                                  ValueChanged="v => _vm.SupportSystemDetails = v"
                                  IsReadOnly="IsReadOnly"
                                  Placeholder="Who will assist? Work, transport, home situation details..."
                                  Rows="3" />

                <EditableTextArea Label="Additional Notes"
                                  Value="@(_vm.SupportAdditionalNotes ?? string.Empty)"
                                  ValueChanged="v => _vm.SupportAdditionalNotes = v"
                                  IsReadOnly="IsReadOnly"
                                  Placeholder="Strategies to address barriers, resources to provide..."
                                  Rows="3" />
            </FormSection>
        </div>

        <div class="daily-col-12">
            <FormSection Title="Prognosis" Subtitle="Expected outcomes based on findings, motivation, and support">
                <div class="daily-assessment__field">
                    <label for="overall-prognosis">Overall Prognosis *</label>
                    <select id="overall-prognosis" disabled="@IsReadOnly" @bind="_vm.OverallPrognosis">
                        <option value="">Select prognosis</option>
                        <option>Excellent</option>
                        <option>Good</option>
                        <option>Fair</option>
                        <option>Guarded</option>
                    </select>
                </div>

                <ul class="daily-assessment__considerations">
                    <li>Patient age and comorbidities</li>
                    <li>Severity and chronicity of condition</li>
                    <li>Patient motivation and compliance</li>
                    <li>Available support system</li>
                    <li>Barriers to treatment</li>
                    <li>Response to initial treatment</li>
                </ul>
            </FormSection>
        </div>
    </div>
</section>

@code {
    private AssessmentWorkspaceVm _vm = new();
    private string _icdQuery = string.Empty;

    private readonly List<GoalStatusVm> _goalStatusCards =
    [
        new() { Type = "Goal 1", Title = "Increase knee flexion ROM to 120°", Measure = "Current: 100°", Timeline = "4 weeks", Status = "Ongoing", ProgressPercent = 65 },
        new() { Type = "Goal 2", Title = "Improve quadriceps strength to 5/5", Measure = "Current: 4/5", Timeline = "3 weeks", Status = "Ongoing", ProgressPercent = 40 },
        new() { Type = "Goal 3", Title = "Reduce pain to ≤3/10 during ADLs", Measure = "Current: 5/10", Timeline = "3 weeks", Status = "Ongoing", ProgressPercent = 50 }
    ];

    private int _metCount => _goalStatusCards.Count(v => v.Status == "Met");
    private int _ongoingCount => _goalStatusCards.Count(v => v.Status == "Ongoing");
    private int _modifiedCount => _goalStatusCards.Count(v => v.Status == "Modified");

    private static readonly string[] _motivationFactors =
    [
        "Return to work", "Return to sports/recreation", "Reduce pain", "Improve daily activities",
        "Avoid surgery", "Care for family members", "Maintain independence", "Weight loss/Fitness goals"
    ];

    private static readonly string[] _supportResources =
    [
        "Family assistance available", "Reliable transportation", "Flexible work schedule", "Home exercise equipment",
        "Gym/local access", "Caregiver support", "Community resources", "Technology savvy", "Strong social network"
    ];

    private static readonly string[] _barrierOptions =
    [
        "Limited family support", "Transportation difficulties", "Financial constraints", "Work schedule conflicts",
        "Childcare responsibilities", "Language barrier", "Health literacy concerns", "Cognitive impairment", "Depression/anxiety", "Poor social support network"
    ];

    [Parameter, EditorRequired] public AssessmentWorkspaceVm Vm { get; set; } = new();
    [Parameter, EditorRequired] public EventCallback<AssessmentWorkspaceVm> VmChanged { get; set; }
    [Parameter] public bool IsReadOnly { get; set; }
    [Parameter] public bool IsDarkMode { get; set; }

    protected override void OnParametersSet() => _vm = Vm;

    private Task UpdateNarrative(string value)
    {
        _vm.AssessmentNarrative = value;
        return VmChanged.InvokeAsync(_vm);
    }

    private Task UpdateDeficitsSummary(string value)
    {
        _vm.DeficitsSummary = value;
        return VmChanged.InvokeAsync(_vm);
    }

    private Task GenerateAssessment()
    {
        // Placeholder assessment generation until AI-backed synthesis is integrated.
        if (string.IsNullOrWhiteSpace(_vm.AssessmentNarrative))
        {
            _vm.AssessmentNarrative = "AI-generated assessment draft placeholder.";
        }

        return VmChanged.InvokeAsync(_vm);
    }

    private Task AutoGenerateDeficits()
    {
        // Placeholder deficit generation until objective-to-deficit extraction is integrated.
        _vm.DeficitsSummary = string.IsNullOrWhiteSpace(_vm.DeficitsSummary) ? "Auto-generated deficits summary placeholder." : _vm.DeficitsSummary;
        _vm.DeficitCategories = ["Pain", "ROM Deficit", "Strength Deficit"];
        return VmChanged.InvokeAsync(_vm);
    }

    private void SetGoalStatus(int index, string status)
    {
        if (index < 0 || index >= _goalStatusCards.Count)
        {
            return;
        }

        _goalStatusCards[index].Status = status;
    }

    private Task AddIcdCode()
    {
        if (string.IsNullOrWhiteSpace(_icdQuery) || _vm.DiagnosisCodes.Count >= 4)
        {
            return Task.CompletedTask;
        }

        _vm.DiagnosisCodes.Add(new Icd10Entry
        {
            Code = _icdQuery.Split(' ', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault() ?? "M25.519",
            Description = _icdQuery
        });
        _icdQuery = string.Empty;
        return VmChanged.InvokeAsync(_vm);
    }

    private Task RemoveIcdCode(int index)
    {
        if (index < 0 || index >= _vm.DiagnosisCodes.Count)
        {
            return Task.CompletedTask;
        }

        _vm.DiagnosisCodes.RemoveAt(index);
        return VmChanged.InvokeAsync(_vm);
    }

    private sealed class GoalStatusVm
    {
        public string Type { get; set; } = string.Empty;
        public string Title { get; set; } = string.Empty;
        public string Measure { get; set; } = string.Empty;
        public string Timeline { get; set; } = string.Empty;
        public string Status { get; set; } = "Ongoing";
        public int ProgressPercent { get; set; }
    }
}
