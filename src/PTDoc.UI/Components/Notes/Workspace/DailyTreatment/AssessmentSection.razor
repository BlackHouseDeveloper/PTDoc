@namespace PTDoc.UI.Components.Notes.Workspace.DailyTreatment
@using PTDoc.Application.AI
@using PTDoc.Application.Notes.Workspace
@using PTDoc.Core.Models
@using PTDoc.UI.Components.Notes.Models
@implements IDisposable

@inject IAiClinicalGenerationService AiService
@inject PTDoc.UI.Services.INoteWorkspaceService NoteWorkspaceService
@inject ILogger<AssessmentSection> Logger

<section class="daily-assessment @(IsDarkMode ? "daily-assessment--dark" : string.Empty)" data-testid="daily-assessment-section">
    <div class="daily-grid">
        <div class="daily-col-12">
            <FormSection Title="Clinical Assessment Summary" Subtitle="Clinical assessment narrative based on subjective and objective findings"
                         TestId="daily-assessment-summary">
                <div class="daily-assessment__actions">
                    <button type="button" disabled="@(IsReadOnly || NoteId == Guid.Empty || _isGeneratingAssessment)" @onclick="GenerateAssessmentAsync">
                        @(_isGeneratingAssessment ? "Generating..." : "Generate Assessment")
                    </button>
                </div>

                <EditableNarrativeBox @ref="_assessmentNarrativeBox"
                                      Value="@_vm.AssessmentNarrative"
                                      ValueChanged="UpdateNarrative"
                                      OnAccepted="HandleAssessmentAcceptedAsync"
                                      OnDiscarded="HandleAssessmentDiscardedAsync"
                                      IsReadOnly="IsReadOnly"
                                      Placeholder="Click 'Generate Assessment' to create an AI-assisted draft."
                                      Rows="5"
                                      TestId="daily-assessment-narrative-box" />

                @if (!IsReadOnly && NoteId == Guid.Empty)
                {
                    <p class="daily-assessment__message" role="note">Save the note before generating an AI assessment.</p>
                }

                @if (!string.IsNullOrWhiteSpace(_assessmentErrorMessage))
                {
                    <p class="daily-assessment__message daily-assessment__message--error" role="alert">@_assessmentErrorMessage</p>
                }

                @if (_assessmentWarnings.Count > 0)
                {
                    <ul class="daily-assessment__message-list">
                        @foreach (var warning in _assessmentWarnings)
                        {
                            <li>@warning</li>
                        }
                    </ul>
                }
            </FormSection>
        </div>

        <div class="daily-col-12">
            <FormSection Title="Deficits &amp; Impairments" Subtitle="Document deficits manually from today's objective findings">
                <EditableTextArea Label="Deficits Summary"
                                  Value="@_vm.DeficitsSummary"
                                  ValueChanged="UpdateDeficitsSummary"
                                  IsReadOnly="IsReadOnly"
                                  Placeholder="Document observed pain, ROM, strength, gait, balance, or functional deficits."
                                  Rows="4" />

                <div class="daily-assessment__chips">
                    @foreach (var category in _vm.DeficitCategories)
                    {
                        <span>@category</span>
                    }
                </div>
            </FormSection>
        </div>

        <div class="daily-col-12">
            <FormSection Title="Goal Status Review" Subtitle="Update the status of the patient's persisted goals">
                <div class="daily-assessment__goal-status-legend">
                    <span>Met: @_metCount</span>
                    <span>Active: @_activeCount</span>
                    <span>Archived: @_archivedCount</span>
                </div>

                @if (TrackedGoals.Count == 0)
                {
                    <p class="daily-assessment__placeholder">No patient goals are available for this note yet.</p>
                }
                else
                {
                    @for (var i = 0; i < TrackedGoals.Count; i++)
                    {
                        var goal = TrackedGoals[i];
                        <div class="daily-assessment__goal-status-card">
                            <div class="daily-assessment__goal-status-header">
                                <strong>@goal.Description</strong>
                                <span>@GetGoalTimeframeLabel(goal)</span>
                            </div>

                            <div class="daily-assessment__goal-status-meta">
                                @if (!string.IsNullOrWhiteSpace(goal.Category))
                                {
                                    <span>@goal.Category</span>
                                }
                                <span>Status: @GetGoalStatusLabel(goal.Status)</span>
                            </div>

                            <div class="daily-assessment__status-options">
                                <label><input type="radio" name="status-@i" disabled="@IsReadOnly" checked="@(goal.Status == GoalStatus.Met)" @onchange='() => SetGoalStatusAsync(goal, GoalStatus.Met)' /> Met</label>
                                <label><input type="radio" name="status-@i" disabled="@IsReadOnly" checked="@(goal.Status == GoalStatus.Active)" @onchange='() => SetGoalStatusAsync(goal, GoalStatus.Active)' /> Active</label>
                                <label><input type="radio" name="status-@i" disabled="@IsReadOnly" checked="@(goal.Status == GoalStatus.Archived)" @onchange='() => SetGoalStatusAsync(goal, GoalStatus.Archived)' /> Archived</label>
                            </div>
                        </div>
                    }
                }
            </FormSection>
        </div>

        <div class="daily-col-12">
            <FormSection Title="ICD-10 Diagnosis Codes *" Subtitle="Search and select diagnosis codes (max 4)">
                <div class="daily-assessment__field">
                    <input type="text"
                           disabled="@IsReadOnly"
                           value="@_icdQuery"
                           @oninput="HandleIcdQueryChangedAsync"
                           placeholder="Search by code or description" />
                    <button type="button"
                            disabled="@(IsReadOnly || _vm.DiagnosisCodes.Count >= 4 || _icdResults.Count == 0)"
                            @onclick="AddFirstIcdCodeAsync">Add</button>
                </div>

                @if (_isSearchingIcd)
                {
                    <p class="daily-assessment__placeholder">Searching ICD-10 codes…</p>
                }
                else if (!string.IsNullOrWhiteSpace(_icdLookupError))
                {
                    <p class="daily-assessment__message daily-assessment__message--error" role="alert">@_icdLookupError</p>
                }
                else if (_icdResults.Count > 0 && !IsReadOnly)
                {
                    <ul class="daily-assessment__lookup-list">
                        @foreach (var result in _icdResults)
                        {
                            <li>
                                <button type="button" @onclick="() => AddIcdCodeAsync(result)">
                                    <strong>@result.Code</strong>
                                    <span>@result.Description</span>
                                </button>
                            </li>
                        }
                    </ul>
                }

                @if (_vm.DiagnosisCodes.Count == 0)
                {
                    <p class="daily-assessment__placeholder">No diagnosis codes selected.</p>
                }
                else
                {
                    <ul class="daily-assessment__code-list">
                        @for (var i = 0; i < _vm.DiagnosisCodes.Count; i++)
                        {
                            var idx = i;
                            <li>
                                <span>@_vm.DiagnosisCodes[idx].Code - @_vm.DiagnosisCodes[idx].Description</span>
                                @if (!IsReadOnly)
                                {
                                    <button type="button" @onclick="() => RemoveIcdCodeAsync(idx)">Remove</button>
                                }
                            </li>
                        }
                    </ul>
                }
            </FormSection>
        </div>

        <div class="daily-col-12">
            <FormSection Title="Patient Motivation &amp; Goals" Subtitle="Assess patient readiness and motivation for therapy">
                <div class="daily-assessment__field">
                    <label for="motivation-level">Motivation Level *</label>
                    <select id="motivation-level" disabled="@IsReadOnly" @bind="_vm.MotivationLevel" @bind:after="NotifyChangedAsync">
                        <option value="">Select motivation level</option>
                        <option>Low</option>
                        <option>Moderate</option>
                        <option>High</option>
                    </select>
                </div>

                <CheckboxGrid Options="_motivationFactors"
                              Selected="_vm.MotivatingFactors"
                              SelectedChanged="UpdateMotivatingFactors"
                              IsReadOnly="IsReadOnly"
                              Columns="2" />

                <EditableTextArea Label="Patient's Personal Goals"
                                  Value="@(_vm.PatientPersonalGoals ?? string.Empty)"
                                  ValueChanged="UpdatePatientPersonalGoals"
                                  IsReadOnly="IsReadOnly"
                                  Placeholder="What does the patient want to accomplish?"
                                  Rows="3" />

                <EditableTextArea Label="Additional Motivation Notes"
                                  Value="@(_vm.AdditionalMotivationNotes ?? string.Empty)"
                                  ValueChanged="UpdateAdditionalMotivationNotes"
                                  IsReadOnly="IsReadOnly"
                                  Placeholder="Observed behaviors, readiness for change..."
                                  Rows="3" />
            </FormSection>
        </div>

        <div class="daily-col-12">
            <FormSection Title="Support System &amp; Barriers" Subtitle="Identify resources and barriers to recovery">
                <div class="daily-assessment__field">
                    <label for="support-level">Support System Level *</label>
                    <select id="support-level" disabled="@IsReadOnly" @bind="_vm.SupportSystemLevel" @bind:after="NotifyChangedAsync">
                        <option value="">Select support level</option>
                        <option>Limited</option>
                        <option>Adequate</option>
                        <option>Strong</option>
                    </select>
                </div>

                <p class="daily-assessment__subheading">Available Resources &amp; Supports</p>
                <CheckboxGrid Options="_supportResources"
                              Selected="_vm.AvailableResources"
                              SelectedChanged="UpdateAvailableResources"
                              IsReadOnly="IsReadOnly"
                              Columns="2" />

                <p class="daily-assessment__subheading">Barriers To Recovery</p>
                <CheckboxGrid Options="_barrierOptions"
                              Selected="_vm.BarriersToRecovery"
                              SelectedChanged="UpdateBarriersToRecovery"
                              IsReadOnly="IsReadOnly"
                              Columns="2" />

                <EditableTextArea Label="Support System Details"
                                  Value="@(_vm.SupportSystemDetails ?? string.Empty)"
                                  ValueChanged="UpdateSupportSystemDetails"
                                  IsReadOnly="IsReadOnly"
                                  Placeholder="Who will assist? Work, transport, home situation details..."
                                  Rows="3" />

                <EditableTextArea Label="Additional Notes"
                                  Value="@(_vm.SupportAdditionalNotes ?? string.Empty)"
                                  ValueChanged="UpdateSupportAdditionalNotes"
                                  IsReadOnly="IsReadOnly"
                                  Placeholder="Strategies to address barriers, resources to provide..."
                                  Rows="3" />
            </FormSection>
        </div>

        <div class="daily-col-12">
            <FormSection Title="Prognosis" Subtitle="Expected outcomes based on findings, motivation, and support">
                <div class="daily-assessment__field">
                    <label for="overall-prognosis">Overall Prognosis *</label>
                    <select id="overall-prognosis" disabled="@IsReadOnly" @bind="_vm.OverallPrognosis" @bind:after="NotifyChangedAsync">
                        <option value="">Select prognosis</option>
                        <option>Excellent</option>
                        <option>Good</option>
                        <option>Fair</option>
                        <option>Guarded</option>
                    </select>
                </div>

                <ul class="daily-assessment__considerations">
                    <li>Patient age and comorbidities</li>
                    <li>Severity and chronicity of condition</li>
                    <li>Patient motivation and compliance</li>
                    <li>Available support system</li>
                    <li>Barriers to treatment</li>
                    <li>Response to initial treatment</li>
                </ul>
            </FormSection>
        </div>
    </div>
</section>

@code {
    private AssessmentWorkspaceVm _vm = new();
    private string _icdQuery = string.Empty;
    private bool _isGeneratingAssessment;
    private bool _isSearchingIcd;
    private string? _assessmentErrorMessage;
    private string? _icdLookupError;
    private IReadOnlyList<string> _assessmentWarnings = Array.Empty<string>();
    private List<CodeLookupEntry> _icdResults = [];
    private CancellationTokenSource? _icdSearchCts;
    private bool _disposed;
    private EditableNarrativeBox? _assessmentNarrativeBox;

    private IReadOnlyList<SmartGoalEntry> TrackedGoals => _vm.Goals
        .Where(goal => !string.IsNullOrWhiteSpace(goal.Description) && (!goal.IsAiSuggested || goal.IsAccepted))
        .OrderBy(goal => goal.Timeframe)
        .ThenBy(goal => goal.Description, StringComparer.OrdinalIgnoreCase)
        .ToList();

    private int _metCount => TrackedGoals.Count(goal => goal.Status == GoalStatus.Met);
    private int _activeCount => TrackedGoals.Count(goal => goal.Status == GoalStatus.Active);
    private int _archivedCount => TrackedGoals.Count(goal => goal.Status == GoalStatus.Archived);

    private static readonly string[] _motivationFactors =
    [
        "Return to work", "Return to sports/recreation", "Reduce pain", "Improve daily activities",
        "Avoid surgery", "Care for family members", "Maintain independence", "Weight loss/Fitness goals"
    ];

    private static readonly string[] _supportResources =
    [
        "Family assistance available", "Reliable transportation", "Flexible work schedule", "Home exercise equipment",
        "Gym/local access", "Caregiver support", "Community resources", "Technology savvy", "Strong social network"
    ];

    private static readonly string[] _barrierOptions =
    [
        "Limited family support", "Transportation difficulties", "Financial constraints", "Work schedule conflicts",
        "Childcare responsibilities", "Language barrier", "Health literacy concerns", "Cognitive impairment", "Depression/anxiety", "Poor social support network"
    ];

    [Parameter, EditorRequired] public AssessmentWorkspaceVm Vm { get; set; } = new();
    [Parameter, EditorRequired] public EventCallback<AssessmentWorkspaceVm> VmChanged { get; set; }
    [Parameter] public bool IsReadOnly { get; set; }
    [Parameter] public bool IsDarkMode { get; set; }
    [Parameter] public Guid NoteId { get; set; }
    [Parameter] public string? ChiefComplaint { get; set; }
    [Parameter] public string? ExaminationFindings { get; set; }

    protected override void OnParametersSet() => _vm = Vm;

    private Task NotifyChangedAsync() => VmChanged.InvokeAsync(_vm);

    private Task UpdateNarrative(string value)
    {
        _vm.AssessmentNarrative = value;
        return NotifyChangedAsync();
    }

    private Task UpdateDeficitsSummary(string value)
    {
        _vm.DeficitsSummary = value;
        return NotifyChangedAsync();
    }

    private Task UpdateMotivatingFactors(HashSet<string> value)
    {
        _vm.MotivatingFactors = value;
        return NotifyChangedAsync();
    }

    private Task UpdatePatientPersonalGoals(string value)
    {
        _vm.PatientPersonalGoals = value;
        return NotifyChangedAsync();
    }

    private Task UpdateAdditionalMotivationNotes(string value)
    {
        _vm.AdditionalMotivationNotes = value;
        return NotifyChangedAsync();
    }

    private Task UpdateAvailableResources(HashSet<string> value)
    {
        _vm.AvailableResources = value;
        return NotifyChangedAsync();
    }

    private Task UpdateBarriersToRecovery(HashSet<string> value)
    {
        _vm.BarriersToRecovery = value;
        return NotifyChangedAsync();
    }

    private Task UpdateSupportSystemDetails(string value)
    {
        _vm.SupportSystemDetails = value;
        return NotifyChangedAsync();
    }

    private Task UpdateSupportAdditionalNotes(string value)
    {
        _vm.SupportAdditionalNotes = value;
        return NotifyChangedAsync();
    }

    private async Task GenerateAssessmentAsync()
    {
        if (IsReadOnly)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(ChiefComplaint))
        {
            _assessmentErrorMessage = "A chief complaint is required before generating an assessment.";
            _assessmentWarnings = Array.Empty<string>();
            return;
        }

        if (NoteId == Guid.Empty)
        {
            _assessmentErrorMessage = "Save the note before generating an AI assessment.";
            _assessmentWarnings = Array.Empty<string>();
            return;
        }

        _isGeneratingAssessment = true;
        _assessmentErrorMessage = null;
        _assessmentWarnings = Array.Empty<string>();
        StateHasChanged();

        try
        {
            var result = await AiService.GenerateAssessmentAsync(new AssessmentGenerationRequest
            {
                NoteId = NoteId,
                ChiefComplaint = ChiefComplaint!,
                ExaminationFindings = ExaminationFindings,
                FunctionalLimitations = _vm.FunctionalLimitations,
                IsNoteSigned = IsReadOnly
            });

            if (!result.Success)
            {
                _assessmentErrorMessage = result.ErrorMessage ?? "Unable to generate an assessment narrative.";
                return;
            }

            _assessmentWarnings = result.Warnings;

            if (_assessmentNarrativeBox is not null)
            {
                await _assessmentNarrativeBox.LoadAiSuggestionAsync(result.GeneratedText);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Daily assessment generation failed for note {NoteId}", NoteId);
            _assessmentErrorMessage = "Unable to generate an assessment narrative.";
        }
        finally
        {
            _isGeneratingAssessment = false;
        }
    }

    private Task HandleAssessmentDiscardedAsync()
    {
        _assessmentWarnings = Array.Empty<string>();
        _assessmentErrorMessage = null;
        return Task.CompletedTask;
    }

    private async Task<EditableNarrativeAcceptResult> HandleAssessmentAcceptedAsync(string acceptedText)
    {
        try
        {
            if (NoteId != Guid.Empty)
            {
                var acceptance = await NoteWorkspaceService.AcceptAiSuggestionAsync(
                    NoteId,
                    section: "assessment",
                    generatedText: acceptedText,
                    generationType: "Assessment");

                if (!acceptance.Success)
                {
                    _assessmentErrorMessage = acceptance.ErrorMessage ?? "Unable to accept the AI-generated assessment.";
                    await InvokeAsync(StateHasChanged);
                    return EditableNarrativeAcceptResult.Fail(_assessmentErrorMessage);
                }
            }

            _vm.AssessmentNarrative = acceptedText;
            _assessmentWarnings = Array.Empty<string>();
            _assessmentErrorMessage = null;
            await NotifyChangedAsync();
            await InvokeAsync(StateHasChanged);
            return EditableNarrativeAcceptResult.Ok();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Daily assessment acceptance failed for note {NoteId}", NoteId);
            _assessmentErrorMessage = "Unable to accept the AI-generated assessment.";
            await InvokeAsync(StateHasChanged);
            return EditableNarrativeAcceptResult.Fail(_assessmentErrorMessage);
        }
    }

    private Task SetGoalStatusAsync(SmartGoalEntry goal, GoalStatus status)
    {
        goal.Status = status;
        return NotifyChangedAsync();
    }

    private async Task HandleIcdQueryChangedAsync(ChangeEventArgs args)
    {
        _icdQuery = args.Value?.ToString() ?? string.Empty;
        _icdLookupError = null;

        _icdSearchCts?.Cancel();
        _icdSearchCts?.Dispose();
        _icdSearchCts = new CancellationTokenSource();
        var cts = _icdSearchCts;

        if (string.IsNullOrWhiteSpace(_icdQuery) || _icdQuery.Trim().Length < 2)
        {
            _icdResults = [];
            _isSearchingIcd = false;
            return;
        }

        try
        {
            await Task.Delay(300, cts.Token);
        }
        catch (OperationCanceledException)
        {
            return;
        }

        _isSearchingIcd = true;
        StateHasChanged();

        try
        {
            var results = await NoteWorkspaceService.SearchIcd10Async(_icdQuery, take: 8, cts.Token);
            if (!cts.IsCancellationRequested)
            {
                _icdResults = results
                    .Where(result => _vm.DiagnosisCodes.All(code => !string.Equals(code.Code, result.Code, StringComparison.OrdinalIgnoreCase)))
                    .ToList();
            }
        }
        catch (OperationCanceledException)
        {
            // Superseded by a newer keystroke; leave state for the newer request.
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "ICD-10 lookup failed for query {Query}", _icdQuery);
            _icdLookupError = ex.Message;
            _icdResults = [];
        }
        finally
        {
            if (!cts.IsCancellationRequested)
            {
                _isSearchingIcd = false;
            }
        }
    }

    private Task AddFirstIcdCodeAsync()
    {
        return _icdResults.Count == 0 ? Task.CompletedTask : AddIcdCodeAsync(_icdResults[0]);
    }

    private Task AddIcdCodeAsync(CodeLookupEntry code)
    {
        if (!_vm.TryAddDiagnosisCode(new Icd10Entry
            {
                Code = code.Code,
                Description = code.Description
            }))
        {
            return Task.CompletedTask;
        }

        _icdQuery = string.Empty;
        _icdResults = [];
        _icdLookupError = null;
        return NotifyChangedAsync();
    }

    private Task RemoveIcdCodeAsync(int index)
    {
        if (index < 0 || index >= _vm.DiagnosisCodes.Count)
        {
            return Task.CompletedTask;
        }

        _vm.DiagnosisCodes.RemoveAt(index);
        return NotifyChangedAsync();
    }

    private static string GetGoalTimeframeLabel(SmartGoalEntry goal) =>
        goal.Timeframe == GoalTimeframe.LongTerm ? "Long-term" : "Short-term";

    private static string GetGoalStatusLabel(GoalStatus status) => status switch
    {
        GoalStatus.Met => "Met",
        GoalStatus.Archived => "Archived",
        _ => "Active"
    };

    public void Dispose()
    {
        if (_disposed) return;
        _disposed = true;
        _icdSearchCts?.Cancel();
        _icdSearchCts?.Dispose();
    }
}
