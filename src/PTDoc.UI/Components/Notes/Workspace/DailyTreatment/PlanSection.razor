@namespace PTDoc.UI.Components.Notes.Workspace.DailyTreatment
@using PTDoc.Application.AI
@using PTDoc.UI.Components.Notes.Models

@inject IAiClinicalGenerationService AiService
@inject PTDoc.UI.Services.INoteWorkspaceService NoteWorkspaceService
@inject ILogger<PlanSection> Logger
@inject IToastService ToastService

<section class="daily-plan @(IsDarkMode ? "daily-plan--dark" : string.Empty)" data-testid="daily-plan-section">
    <div class="daily-grid">
        <div class="daily-col-12">
            <FormSection Title="Plan for Today's Session">
                <EditableTextArea Label="Treatment Plan *"
                                  Value="@(_vm.HomeExerciseProgramNotes ?? string.Empty)"
                                  ValueChanged="UpdateTreatmentPlan"
                                  IsReadOnly="IsReadOnly"
                                  Placeholder="Document today's treatment plan (modalities, therapeutic exercises, manual therapy, patient education, etc.)..."
                                  Rows="6"
                                  IsRequired="true"
                                  ShowValidation="@string.IsNullOrWhiteSpace(_vm.HomeExerciseProgramNotes)" />
            </FormSection>
        </div>

        <div class="daily-col-12">
            <FormSection Title="Treatment / Intervention Entries" Subtitle="Document skilled interventions performed today">
                <div class="daily-plan__summary-header">
                    @if (!IsReadOnly)
                    {
                        <button type="button" @onclick="AddIntervention">Add Intervention</button>
                    }
                </div>

                @if (_vm.GeneralInterventions.Count == 0)
                {
                    <p class="daily-plan__message" role="note">No interventions documented yet.</p>
                }
                else
                {
                    <div class="daily-plan__intervention-list" data-testid="daily-plan-interventions">
                        @for (var i = 0; i < _vm.GeneralInterventions.Count; i++)
                        {
                            var index = i;
                            var intervention = _vm.GeneralInterventions[index];
                            <div class="daily-plan__intervention-row">
                                <label>
                                    <span>Intervention</span>
                                    <input type="text"
                                           value="@intervention.Name"
                                           disabled="@IsReadOnly"
                                           @oninput="e => UpdateInterventionName(index, e.Value?.ToString())" />
                                </label>
                                <label>
                                    <span>Notes</span>
                                    <textarea rows="2"
                                              value="@intervention.Notes"
                                              disabled="@IsReadOnly"
                                              @oninput="e => UpdateInterventionNotes(index, e.Value?.ToString())"></textarea>
                                </label>
                                @if (!IsReadOnly)
                                {
                                    <button type="button" @onclick="() => RemoveIntervention(index)">Remove</button>
                                }
                            </div>
                        }
                    </div>
                }
            </FormSection>
        </div>

        <div class="daily-col-12">
            <FormSection Title="Response to Treatment">
                <EditableTextArea Label="Response to Treatment"
                                  Id="daily-response-to-treatment"
                                  Value="@_dailyTreatment.ResponseToTreatment"
                                  ValueChanged="UpdateResponseToTreatment"
                                  IsReadOnly="IsReadOnly"
                                  Placeholder="Document tolerance, symptom response, performance quality, and safety response."
                                  Rows="4" />
            </FormSection>
        </div>

        <div class="daily-col-12">
            <FormSection Title="Follow-Up &amp; Next Appointments">
                <EditableTextArea Label="Next Visit Schedule"
                                  Value="@(_vm.FollowUpInstructions ?? string.Empty)"
                                  ValueChanged="UpdateFollowUpInstructions"
                                  IsReadOnly="IsReadOnly"
                                  Placeholder="Next PT visit scheduled for [date], next Progress Note due [date], next MD follow-up [date]..."
                                  Rows="4" />
            </FormSection>
        </div>

        <div class="daily-col-12">
            <FormSection Title="Clinical Summary (S.O.A.P)" Subtitle="AI-generated comprehensive summary of all SOAP sections">
                <div class="daily-plan__summary-header">
                    <button type="button" disabled="@(IsReadOnly || NoteId == Guid.Empty || _isGeneratingSummary)" @onclick="GenerateSummaryAsync">
                        @(_isGeneratingSummary ? "Generating..." : "Generate Summary")
                    </button>
                </div>

                <EditableNarrativeBox @ref="_clinicalSummaryBox"
                                      Value="@(_vm.ClinicalSummary ?? string.Empty)"
                                      ValueChanged="UpdateClinicalSummary"
                                      OnAccepted="HandleClinicalSummaryAcceptedAsync"
                                      OnDiscarded="HandleClinicalSummaryDiscardedAsync"
                                      IsReadOnly="IsReadOnly"
                                      Placeholder="Click 'Generate Summary' to create an AI-powered comprehensive clinical summary..."
                                      Rows="5"
                                      TestId="daily-plan-clinical-summary-box" />

                @if (!IsReadOnly && NoteId == Guid.Empty)
                {
                    <p class="daily-plan__message" role="note">Save the note before generating an AI plan summary.</p>
                }

                @if (!string.IsNullOrWhiteSpace(_summaryErrorMessage))
                {
                    <p class="daily-plan__message daily-plan__message--error" role="alert">@_summaryErrorMessage</p>
                }
            </FormSection>
        </div>
    </div>
</section>

@code {
    private PlanVm _vm = new();
    private DailyTreatmentVm _dailyTreatment = new();
    private bool _isGeneratingSummary;
    private string? _summaryErrorMessage;
    private EditableNarrativeBox? _clinicalSummaryBox;

    [Parameter, EditorRequired] public PlanVm Vm { get; set; } = new();
    [Parameter] public DailyTreatmentVm DailyTreatment { get; set; } = new();
    [Parameter, EditorRequired] public EventCallback<PlanVm> VmChanged { get; set; }
    [Parameter] public EventCallback<DailyTreatmentVm> DailyTreatmentChanged { get; set; }
    [Parameter] public bool IsReadOnly { get; set; }
    [Parameter] public bool IsDarkMode { get; set; }
    [Parameter] public Guid NoteId { get; set; }
    [Parameter] public string? DiagnosisSummary { get; set; }
    [Parameter] public string? AssessmentSummary { get; set; }
    [Parameter] public string? GoalsSummary { get; set; }
    [Parameter] public string? PrecautionsSummary { get; set; }
    [Parameter] public bool ForceAiReviewUnavailable { get; set; }

    protected override void OnParametersSet()
    {
        _vm = Vm;
        _dailyTreatment = DailyTreatment;
    }

    private Task NotifyChangedAsync() => VmChanged.InvokeAsync(_vm);
    private Task NotifyDailyChangedAsync() => DailyTreatmentChanged.InvokeAsync(_dailyTreatment);

    private Task UpdateTreatmentPlan(string value)
    {
        _vm.HomeExerciseProgramNotes = value;
        return NotifyChangedAsync();
    }

    private Task UpdateFollowUpInstructions(string value)
    {
        _vm.FollowUpInstructions = value;
        return NotifyChangedAsync();
    }

    private Task UpdateClinicalSummary(string value)
    {
        _vm.ClinicalSummary = value;
        return NotifyChangedAsync();
    }

    private Task AddIntervention()
    {
        _vm.GeneralInterventions.Add(new GeneralInterventionEntry
        {
            Name = "Skilled intervention"
        });
        return NotifyChangedAsync();
    }

    private Task UpdateInterventionName(int index, string? value)
    {
        if (index < 0 || index >= _vm.GeneralInterventions.Count)
        {
            return Task.CompletedTask;
        }

        _vm.GeneralInterventions[index].Name = value ?? string.Empty;
        return NotifyChangedAsync();
    }

    private Task UpdateInterventionNotes(int index, string? value)
    {
        if (index < 0 || index >= _vm.GeneralInterventions.Count)
        {
            return Task.CompletedTask;
        }

        _vm.GeneralInterventions[index].Notes = value;
        return NotifyChangedAsync();
    }

    private Task RemoveIntervention(int index)
    {
        if (index < 0 || index >= _vm.GeneralInterventions.Count)
        {
            return Task.CompletedTask;
        }

        _vm.GeneralInterventions.RemoveAt(index);
        return NotifyChangedAsync();
    }

    private Task UpdateResponseToTreatment(string value)
    {
        _dailyTreatment.ResponseToTreatment = value;
        return NotifyDailyChangedAsync();
    }

    private async Task GenerateSummaryAsync()
    {
        if (IsReadOnly)
        {
            return;
        }

        if (NoteId == Guid.Empty)
        {
            _summaryErrorMessage = "Save the note before generating an AI plan summary.";
            ToastService.ShowError(_summaryErrorMessage, "AI generation unavailable");
            return;
        }

        _isGeneratingSummary = true;
        _summaryErrorMessage = null;
        StateHasChanged();

        try
        {
            var result = await AiService.GeneratePlanOfCareAsync(new PlanOfCareGenerationRequest
            {
                NoteId = NoteId,
                Diagnosis = string.IsNullOrWhiteSpace(DiagnosisSummary) ? "Physical therapy plan of care" : DiagnosisSummary!,
                AssessmentSummary = AssessmentSummary,
                Goals = GoalsSummary,
                Precautions = PrecautionsSummary,
                IsNoteSigned = IsReadOnly
            });

            if (!result.Success)
            {
                _summaryErrorMessage = result.ErrorMessage ?? "Unable to generate a clinical summary.";
                ToastService.ShowError(_summaryErrorMessage, "AI generation failed");
                return;
            }

            if (ForceAiReviewUnavailable || _clinicalSummaryBox is null)
            {
                _summaryErrorMessage = "Unable to open AI review for the clinical summary. Please try again.";
                ToastService.ShowError(_summaryErrorMessage, "AI generation failed");
                return;
            }

            await _clinicalSummaryBox.LoadAiSuggestionAsync(result.GeneratedText);
            ToastService.ShowSuccess("AI clinical summary generated. Review it before accepting.", "AI generation complete");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Daily plan summary generation failed for note {NoteId}", NoteId);
            _summaryErrorMessage = "Unable to generate a clinical summary.";
            ToastService.ShowError(_summaryErrorMessage, "AI generation failed");
        }
        finally
        {
            _isGeneratingSummary = false;
        }
    }

    private Task HandleClinicalSummaryDiscardedAsync()
    {
        _summaryErrorMessage = null;
        return Task.CompletedTask;
    }

    private async Task<EditableNarrativeAcceptResult> HandleClinicalSummaryAcceptedAsync(string acceptedText)
    {
        try
        {
            if (NoteId != Guid.Empty)
            {
                var acceptance = await NoteWorkspaceService.AcceptAiSuggestionAsync(
                    NoteId,
                    section: "plan",
                    generatedText: acceptedText,
                    generationType: "ClinicalSummary");

                if (!acceptance.Success)
                {
                    _summaryErrorMessage = acceptance.ErrorMessage ?? "Unable to accept the AI-generated summary.";
                    ToastService.ShowError(_summaryErrorMessage, "AI acceptance failed");
                    await InvokeAsync(StateHasChanged);
                    return EditableNarrativeAcceptResult.Fail(_summaryErrorMessage);
                }
            }

            _vm.ClinicalSummary = acceptedText;
            _summaryErrorMessage = null;
            await NotifyChangedAsync();
            ToastService.ShowSuccess("AI clinical summary accepted. Save the note to keep it.", "AI content accepted");
            await InvokeAsync(StateHasChanged);
            return EditableNarrativeAcceptResult.Ok();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Daily plan summary acceptance failed for note {NoteId}", NoteId);
            _summaryErrorMessage = "Unable to accept the AI-generated summary.";
            ToastService.ShowError(_summaryErrorMessage, "AI acceptance failed");
            await InvokeAsync(StateHasChanged);
            return EditableNarrativeAcceptResult.Fail(_summaryErrorMessage);
        }
    }
}
