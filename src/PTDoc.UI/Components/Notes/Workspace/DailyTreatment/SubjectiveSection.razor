@namespace PTDoc.UI.Components.Notes.Workspace.DailyTreatment
@using PTDoc.UI.Components.Notes.Models

<section class="daily-subjective @(IsDarkMode ? "daily-subjective--dark" : string.Empty)" data-testid="daily-subjective-section">
    <div class="daily-grid">
        <div class="daily-col-12">
            <FormSection Title="Chief Complaint / Carry-Forward Context" Subtitle="Confirm carried-forward complaint and add today's update">
                @if (!string.IsNullOrWhiteSpace(GetCarriedForwardComplaint()))
                {
                    <div class="daily-subjective__progress-note" data-testid="daily-carried-forward-chief-complaint">
                        <strong>Carried-forward chief complaint</strong>
                        <p>@GetCarriedForwardComplaint()</p>
                    </div>
                }

                <CheckboxGrid Options="_bodyParts"
                              Selected="_vm.Locations"
                              SelectedChanged="UpdateLocations"
                              IsReadOnly="IsReadOnly"
                              Columns="2" />

                <EditableTextArea Label="Today's update/additions"
                                  Value="@(_vm.OtherProblem ?? string.Empty)"
                                  ValueChanged="UpdateOtherProblem"
                                  IsReadOnly="IsReadOnly"
                                  Placeholder="Add today's patient-reported update or additions to the carried-forward complaint."
                                  Rows="3" />
            </FormSection>
        </div>

        <div class="daily-col-12">
            <div class="daily-subjective__progress-note">
                <strong>Daily Visit Update</strong>
                <p>Document patient-reported changes since the last visit.</p>
            </div>
        </div>

        <div class="daily-col-12">
            <FormSection Title="Pain Level Comparison">
                <div class="daily-subjective__comparison">
                    <div class="daily-subjective__comparison-card">
                        <span>Baseline (Initial Eval)</span>
                        <strong>@(_baselinePainLevel == 0 ? "--/10" : $"{_baselinePainLevel}/10")</strong>
                    </div>
                    <div class="daily-subjective__comparison-card daily-subjective__comparison-card--current">
                        <span>Current (Today)</span>
                        <strong>@_vm.CurrentPainScore/10</strong>
                    </div>
                </div>

                <label class="daily-subjective__label" for="current-pain">Current Pain Level (0-10)</label>
                <input id="current-pain"
                       class="daily-subjective__range"
                       type="range"
                       min="0"
                       max="10"
                       disabled="@IsReadOnly"
                       @bind="_vm.CurrentPainScore"
                       @bind:event="oninput" />

                <div class="daily-subjective__range-legend">
                    <span>No Pain (0)</span>
                    <span>@_vm.CurrentPainScore</span>
                    <span>Severe (10)</span>
                </div>
            </FormSection>
        </div>

        <div class="daily-col-12">
            <FormSection Title="Pain Details">
                <div class="daily-subjective__field">
                    <label for="pain-location">Pain Location *</label>
                    <input id="pain-location"
                           type="text"
                           placeholder="e.g., Lower back, Right shoulder..."
                           disabled="@IsReadOnly"
                           @bind="_painLocation"
                           @bind:event="oninput" />
                    @if (!IsReadOnly && string.IsNullOrWhiteSpace(_painLocation))
                    {
                        <p class="daily-subjective__validation">Pain location is required.</p>
                    }
                </div>

                <EditableTextArea Label="Pain Description"
                                  Value="@(_vm.KnownCause ?? string.Empty)"
                                  ValueChanged="UpdateKnownCause"
                                  IsReadOnly="IsReadOnly"
                                  Placeholder="Describe the quality, onset, duration, aggravating/relieving factors..."
                                  Rows="3" />
            </FormSection>
        </div>

        <div class="daily-col-12">
            <FormSection Title="Associated Symptoms">
                <CheckboxGrid Options="_associatedSymptomOptions"
                              Selected="_dailyTreatment.AssociatedSymptoms"
                              SelectedChanged="UpdateAssociatedSymptoms"
                              IsReadOnly="IsReadOnly"
                              Columns="2" />
            </FormSection>
        </div>

        <div class="daily-col-12">
            <FormSection Title="Functional Limitations">
                <EditableTextArea Value="@(_vm.AdditionalFunctionalLimitations ?? string.Empty)"
                                  ValueChanged="UpdateAdditionalFunctionalLimitations"
                                  IsReadOnly="IsReadOnly"
                                  Placeholder="Activities the patient has difficulty with or can perform with changed tolerance..."
                                  Rows="3" />
            </FormSection>
        </div>

        <div class="daily-col-12">
            <FormSection Title="Progress Since Last Visit">
                <EditableTextArea Label="Visit changes since last visit *"
                                  Value="@_dailyTreatment.ChangesSinceLastVisit"
                                  ValueChanged="UpdateChangesSinceLastVisit"
                                  IsReadOnly="IsReadOnly"
                                  Placeholder="What has changed? Better, worse, or same?"
                                  Rows="3"
                                  IsRequired="true"
                                  ShowValidation="@string.IsNullOrWhiteSpace(_dailyTreatment.ChangesSinceLastVisit)" />

                <EditableTextArea Label="Subjective Update"
                                  Value="@_dailyTreatment.SubjectiveUpdate"
                                  ValueChanged="UpdateSubjectiveUpdate"
                                  IsReadOnly="IsReadOnly"
                                  Placeholder="Patient-reported status, tolerance, soreness, or concerns since the last visit."
                                  Rows="3" />

                <div class="daily-subjective__field">
                    <label for="hep-adherence">Home Exercise Program Adherence *</label>
                    <select id="hep-adherence" disabled="@IsReadOnly" value="@_dailyTreatment.HepAdherence" @onchange="HandleHepAdherenceChanged">
                        <option value="">Select adherence level</option>
                        <option>Excellent (&gt;90%)</option>
                        <option>Good (70-90%)</option>
                        <option>Fair (50-69%)</option>
                        <option>Poor (&lt;50%)</option>
                    </select>
                    @if (!IsReadOnly && string.IsNullOrWhiteSpace(_dailyTreatment.HepAdherence))
                    {
                        <p class="daily-subjective__validation">Adherence level is required.</p>
                    }
                </div>

                <EditableTextArea Label="HEP Update"
                                  Value="@_dailyTreatment.HepUpdateNotes"
                                  ValueChanged="UpdateHepUpdateNotes"
                                  IsReadOnly="IsReadOnly"
                                  Placeholder="Document HEP changes, patient questions, or adherence context."
                                  Rows="3" />

                <EditableTextArea Label="Functional Improvements"
                                  Value="@_dailyTreatment.FunctionalImprovements"
                                  ValueChanged="UpdateFunctionalImprovements"
                                  IsReadOnly="IsReadOnly"
                                  Placeholder="What activities can the patient now do that they had difficulty with before?"
                                  Rows="3" />

                <EditableTextArea Label="New or Changed Symptoms"
                                  Value="@_dailyTreatment.NewOrChangedSymptoms"
                                  ValueChanged="UpdateNewOrChangedSymptoms"
                                  IsReadOnly="IsReadOnly"
                                  Placeholder="Any new pain areas, increased/decreased symptoms..."
                                  Rows="3" />

                <EditableTextArea Label="Barriers to Progress"
                                  Value="@_dailyTreatment.BarriersToProgress"
                                  ValueChanged="UpdateBarriersToProgress"
                                  IsReadOnly="IsReadOnly"
                                  Placeholder="Work schedule conflicts, equipment access, pain flare-ups..."
                                  Rows="3" />
            </FormSection>
        </div>
    </div>
</section>

@code {
    private SubjectiveVm _vm = new();
    private DailyTreatmentVm _dailyTreatment = new();
    private int _baselinePainLevel = 0;
    private string _painLocation = string.Empty;

    private static readonly string[] _bodyParts =
    [
        "Shoulder Pain", "Elbow Pain", "Wrist/Hand Pain", "Neck Pain",
        "Back Pain", "Hip Pain", "Knee Pain", "Ankle/Foot Pain"
    ];

    private static readonly string[] _associatedSymptomOptions =
    [
        "Sharp Pain", "Dull Ache", "Stiffness", "Weakness", "Numbness", "Tingling", "Swelling", "Instability"
    ];

    [Parameter, EditorRequired] public SubjectiveVm Vm { get; set; } = new();
    [Parameter] public DailyTreatmentVm DailyTreatment { get; set; } = new();
    [Parameter, EditorRequired] public EventCallback<SubjectiveVm> VmChanged { get; set; }
    [Parameter] public EventCallback<DailyTreatmentVm> DailyTreatmentChanged { get; set; }
    [Parameter] public bool IsReadOnly { get; set; }
    [Parameter] public bool IsDarkMode { get; set; }

    protected override void OnParametersSet()
    {
        _vm = Vm;
        _dailyTreatment = DailyTreatment;
        if (_vm.BestPainScore > 0)
        {
            _baselinePainLevel = _vm.BestPainScore;
        }
    }

    private string GetCarriedForwardComplaint()
    {
        var values = _vm.Problems
            .Concat(_vm.Locations)
            .Append(_vm.OtherLocation)
            .Where(value => !string.IsNullOrWhiteSpace(value))
            .Select(value => value!.Trim())
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(value => value, StringComparer.OrdinalIgnoreCase)
            .ToList();

        return values.Count == 0 ? string.Empty : string.Join("; ", values);
    }

    private Task UpdateLocations(HashSet<string> value)
    {
        _vm.Locations = value;
        return VmChanged.InvokeAsync(_vm);
    }

    private Task UpdateAssociatedSymptoms(HashSet<string> value)
    {
        _dailyTreatment.AssociatedSymptoms = value;
        return NotifyDailyChangedAsync();
    }

    private Task UpdateOtherProblem(string value)
    {
        _vm.OtherProblem = value;
        return VmChanged.InvokeAsync(_vm);
    }

    private Task UpdateKnownCause(string value)
    {
        _vm.KnownCause = value;
        return VmChanged.InvokeAsync(_vm);
    }

    private Task UpdateAdditionalFunctionalLimitations(string value)
    {
        _vm.AdditionalFunctionalLimitations = value;
        return VmChanged.InvokeAsync(_vm);
    }

    private Task UpdatePreviousTreatment(string value)
    {
        _dailyTreatment.PreviousTreatment = value;
        return NotifyDailyChangedAsync();
    }

    private Task UpdateChangesSinceLastVisit(string value)
    {
        _dailyTreatment.ChangesSinceLastVisit = value;
        return NotifyDailyChangedAsync();
    }

    private Task UpdatePainLevelChanges(string value)
    {
        _dailyTreatment.PainLevelChanges = value;
        return NotifyDailyChangedAsync();
    }

    private Task UpdateSubjectiveUpdate(string value)
    {
        _dailyTreatment.SubjectiveUpdate = value;
        return NotifyDailyChangedAsync();
    }

    private Task HandleHepAdherenceChanged(ChangeEventArgs args)
    {
        _dailyTreatment.HepAdherence = args.Value?.ToString() ?? string.Empty;
        return NotifyDailyChangedAsync();
    }

    private Task UpdateHepUpdateNotes(string value)
    {
        _dailyTreatment.HepUpdateNotes = value;
        return NotifyDailyChangedAsync();
    }

    private Task UpdateFunctionalImprovements(string value)
    {
        _dailyTreatment.FunctionalImprovements = value;
        return NotifyDailyChangedAsync();
    }

    private Task UpdateNewOrChangedSymptoms(string value)
    {
        _dailyTreatment.NewOrChangedSymptoms = value;
        return NotifyDailyChangedAsync();
    }

    private Task UpdateBarriersToProgress(string value)
    {
        _dailyTreatment.BarriersToProgress = value;
        return NotifyDailyChangedAsync();
    }

    private Task NotifyDailyChangedAsync() => DailyTreatmentChanged.InvokeAsync(_dailyTreatment);
}
