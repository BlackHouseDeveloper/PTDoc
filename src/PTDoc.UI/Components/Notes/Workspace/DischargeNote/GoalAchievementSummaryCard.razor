@namespace PTDoc.UI.Components.Notes.Workspace.DischargeNote
@using PTDoc.Core.Models
@using PTDoc.UI.Components.Notes.Models

<section class="goal-achievement-card" data-testid="goal-achievement-summary-card" aria-label="Goal achievement summary">
    <header class="goal-achievement-card__header">
        <div>
            <h3 class="goal-achievement-card__title">Goal Achievement Summary</h3>
            <p class="goal-achievement-card__subtitle">Final status of documented treatment goals</p>
        </div>
        <div class="goal-achievement-card__metrics">
            <span class="goal-achievement-card__achievement">@AchievementPercent% Achieved</span>
            <div class="goal-achievement-card__counts">
                <span>Met: @MetCount</span>
                <span>Active/Not Met: @NotMetCount</span>
            </div>
        </div>
    </header>

    @if (VisibleGoals.Count == 0)
    {
        <div class="goal-achievement-card__empty-state" role="status">
            <strong>No goals documented yet.</strong>
            <p>Add or carry forward goals before completing the discharge note, then update each final status.</p>
        </div>
    }
    else
    {
        <div class="goal-achievement-card__list">
            @foreach (var goal in VisibleGoals)
            {
                <article class="goal-achievement-card__item">
                    <div class="goal-achievement-card__item-head">
                        <div>
                            <h4 class="goal-achievement-card__item-title">@GetGoalTitle(goal)</h4>
                            <div class="goal-achievement-card__chips">
                                @if (!string.IsNullOrWhiteSpace(goal.Category))
                                {
                                    <span class="goal-achievement-card__chip">@goal.Category</span>
                                }
                                <span class="goal-achievement-card__chip">@GetTimeline(goal.Timeframe)</span>
                            </div>
                        </div>
                        <span class="goal-achievement-card__status">@GetStatusLabel(goal.Status)</span>
                    </div>

                    <p class="goal-achievement-card__goal-text">@goal.Description</p>
                </article>
            }
        </div>
    }
</section>

@code {
    [Parameter] public IReadOnlyList<SmartGoalEntry> Goals { get; set; } = Array.Empty<SmartGoalEntry>();

    private IReadOnlyList<SmartGoalEntry> VisibleGoals => Goals
        .Where(goal => !string.IsNullOrWhiteSpace(goal.Description) && (!goal.IsAiSuggested || goal.IsAccepted))
        .ToList();

    private int MetCount => VisibleGoals.Count(goal => goal.Status == GoalStatus.Met);
    private int NotMetCount => VisibleGoals.Count - MetCount;
    private int AchievementPercent => VisibleGoals.Count == 0
        ? 0
        : (int)Math.Round((double)MetCount / VisibleGoals.Count * 100);

    private static string GetGoalTitle(SmartGoalEntry goal) =>
        string.IsNullOrWhiteSpace(goal.Category)
            ? "Treatment goal"
            : $"{goal.Category} goal";

    private static string GetTimeline(GoalTimeframe timeframe) =>
        timeframe == GoalTimeframe.LongTerm ? "Long-term" : "Short-term";

    private static string GetStatusLabel(GoalStatus status) => status switch
    {
        GoalStatus.Met => "Met",
        GoalStatus.Archived => "Archived",
        _ => "Active / Not Met"
    };
}
