@namespace PTDoc.UI.Components.Notes.Workspace.DischargeNote
@using PTDoc.UI.Components.Notes.Models

<section class="discharge-plan" data-testid="discharge-plan-section" role="tabpanel" aria-label="Discharge plan section">
    <article class="discharge-plan__card" data-testid="discharge-recommendations-card">
        <header class="discharge-plan__card-header">
            <h3 class="discharge-plan__card-title">Discharge Reason and Recommendations</h3>
        </header>

        <label class="discharge-plan__label" for="discharge-documentation-mode">Documentation Mode *</label>
        <select id="discharge-documentation-mode" class="discharge-plan__select" disabled="@IsReadOnly" @bind="Vm.DischargeDocumentationMode" @bind:after="HandleDocumentationModeChangedAsync">
            @foreach (var option in DischargeDocumentationOptions.DocumentationModeOptions)
            {
                <option value="@option">@option</option>
            }
        </select>

        @if (IsNonBillableDischarge)
        {
            <div class="discharge-plan__billing-note" data-testid="non-billable-discharge-callout">
                <strong>Non-billable discharge</strong>
                <p>This discharge will be documented as non-billable. Clinical subjective, objective, assessment, and plan documentation remains available.</p>
            </div>
        }

        <label class="discharge-plan__label" for="discharge-reason">Primary Discharge Reason *</label>
        <select id="discharge-reason" class="discharge-plan__select" disabled="@IsReadOnly" @bind="Vm.PrimaryDischargeReason" @bind:after="HandleChangedAsync" aria-required="true" data-note-field-key="discharge-primary-reason">
            <option value="">Select discharge reason...</option>
            @foreach (var option in DischargeDocumentationOptions.DischargeReasonOptions)
            {
                <option value="@option">@option</option>
            }
        </select>

        @if (IsOtherReason)
        {
            <label class="discharge-plan__label" for="discharge-other-reason">Other Discharge Reason Explanation</label>
            <textarea id="discharge-other-reason"
                      class="discharge-plan__textarea"
                      rows="2"
                      disabled="@IsReadOnly"
                      @bind="Vm.OtherDischargeReasonExplanation"
                      @bind:event="oninput"
                      @bind:after="HandleChangedAsync"
                      placeholder="Explain the discharge reason when Other is selected..."></textarea>
        }

        <label class="discharge-plan__label" for="discharge-recommendations">Discharge Recommendations &amp; Follow-up Plan *</label>
        <textarea id="discharge-recommendations"
                  class="discharge-plan__textarea"
                  rows="6"
                  disabled="@IsReadOnly"
                  aria-required="true"
                  data-note-field-key="discharge-recommendations"
                  @bind="Vm.DischargeRecommendations"
                  @bind:event="oninput"
                  @bind:after="HandleChangedAsync"
                  placeholder="Document final functional status, home exercise program provided, follow-up recommendations, return-to-PT criteria, precautions, red flags, or activity modifications..."></textarea>

        <label class="discharge-plan__label" for="post-discharge">Post-Discharge Instructions</label>
        <textarea id="post-discharge"
                  class="discharge-plan__textarea"
                  rows="4"
                  disabled="@IsReadOnly"
                  @bind="Vm.PostDischargeInstructions"
                  @bind:event="oninput"
                  @bind:after="HandleChangedAsync"
                  placeholder="Follow-up recommendations, home program maintenance, warning signs, when to seek medical attention..."></textarea>

        <div class="discharge-plan__tips">
            <p>Documentation Tips:</p>
            <ul>
                <li>Summarize the patient's functional progress and status at discharge</li>
                <li>Note HEP education, understanding, and expected maintenance frequency</li>
                <li>Specify follow-up care and return-to-PT criteria</li>
                <li>Document ongoing precautions, red flags, or activity modifications</li>
            </ul>
        </div>
    </article>

    <article class="discharge-plan__card" data-testid="discharge-plan-card">
        <header class="discharge-plan__card-header">
            <h3 class="discharge-plan__card-title">Discharge Summary</h3>
            <button type="button" class="discharge-plan__action-btn" disabled="@IsReadOnly" @onclick="GenerateFullNote">Generate Full Note</button>
        </header>

        <label class="discharge-plan__label" for="full-discharge-note">Discharge Summary Narrative</label>
        <textarea class="discharge-plan__textarea"
                  id="full-discharge-note"
                  rows="5"
                  disabled="@IsReadOnly"
                  @bind="Vm.FullDischargeSummary"
                  @bind:event="oninput"
                  @bind:after="HandleChangedAsync"
                  placeholder="Summarize all clinically relevant discharge documentation. Review and edit before signing."></textarea>
    </article>

    <article class="discharge-plan__card" data-testid="home-exercise-program-card">
        <header class="discharge-plan__card-header">
            <div>
                <h3 class="discharge-plan__card-title">Home Exercise Program (HEP)</h3>
                <p class="discharge-plan__card-subtitle">Export patient's home exercise program for continued self-management</p>
            </div>
            <button type="button" class="discharge-plan__secondary-btn" disabled="@(IsReadOnly || LinkedHepItems.Count == 0)">Export HEP</button>
        </header>

        @if (LinkedHepItems.Count == 0)
        {
            <div class="discharge-plan__empty-state">
                <strong>0 Exercises</strong>
                <p>No exercises have been linked to this patient's HEP. Link exercises or interventions from Objective or Plan before export.</p>
            </div>
        }
        else
        {
            <div class="discharge-plan__hep-list" data-testid="discharge-linked-hep-list">
                <strong>@LinkedHepItems.Count @Pluralize("Exercise", LinkedHepItems.Count)</strong>
                <ul>
                    @foreach (var item in LinkedHepItems)
                    {
                        <li>@item</li>
                    }
                </ul>
            </div>
        }

        <div class="discharge-plan__note">
            <strong>Documentation Note:</strong>
            Ensure patient has been educated on HEP compliance, proper exercise form, and progression criteria.
        </div>
    </article>

    <article class="discharge-plan__card" data-testid="end-of-care-checklist-card" data-note-field-key="discharge-end-of-care-checklist">
        <header class="discharge-plan__card-header">
            <div>
                <h3 class="discharge-plan__card-title">End-of-Care Checklist</h3>
                <p class="discharge-plan__card-subtitle">Ensure all discharge requirements are completed before finalizing</p>
            </div>
            <span class="discharge-plan__status">@CompletedChecklistCount/@_checklistItems.Count Complete</span>
        </header>

        <div class="discharge-plan__progress-wrap">
            <div class="discharge-plan__progress-track" role="progressbar" aria-valuenow="@ChecklistProgressPercent" aria-valuemin="0" aria-valuemax="100">
                <div class="discharge-plan__progress-fill" style="@($"width: {ChecklistProgressPercent}%")"></div>
            </div>
            <p>All required items must be completed before note can be signed and submitted</p>
        </div>

        <ul class="discharge-plan__checklist">
            @foreach (var item in _checklistItems)
            {
                <li>
                    <label>
                        <input type="checkbox"
                               disabled="@IsReadOnly"
                               checked="@item.IsComplete"
                               @onchange="args => HandleChecklistChanged(item, args)" />
                        <span>@item.Title</span>
                    </label>
                    <p>@item.Description</p>
                </li>
            }
        </ul>
    </article>

    <article class="discharge-plan__card" data-testid="clinical-summary-card">
        <header class="discharge-plan__card-header">
            <div>
                <h3 class="discharge-plan__card-title">Clinical Summary (S.O.A.P)</h3>
                <p class="discharge-plan__card-subtitle">Comprehensive summary of the finalized discharge SOAP sections</p>
            </div>
            <button type="button" class="discharge-plan__action-btn" disabled="@IsReadOnly" @onclick="GenerateClinicalSummary">Generate Summary</button>
        </header>

        <textarea class="discharge-plan__textarea"
                  rows="4"
                  disabled="@IsReadOnly"
                  @bind="Vm.ClinicalSummary"
                  @bind:event="oninput"
                  @bind:after="HandleChangedAsync"
                  placeholder="Click 'Generate Summary' to create a comprehensive clinical summary, or type manually..."></textarea>
    </article>
</section>

@code {
    [Parameter, EditorRequired] public PlanVm Vm { get; set; } = new();
    [Parameter, EditorRequired] public EventCallback<PlanVm> VmChanged { get; set; }
    [Parameter] public IReadOnlyList<string> LinkedHepItems { get; set; } = Array.Empty<string>();
    [Parameter] public bool IsReadOnly { get; set; }

    private readonly List<ChecklistItem> _checklistItems =
    [
        new("All goals reviewed and final status documented", "Each treatment goal marked as Met, Partially Met, or Not Met"),
        new("Final outcome measures documented and compared to baseline", "ROM, strength, functional tests, and outcome scores recorded"),
        new("Home Exercise Program provided to patient", "HEP exported and reviewed with patient"),
        new("Patient education completed and documented", "Self-management strategies and red flags discussed"),
        new("Discharge reason and recommendations documented", "Reason and follow-up plan clearly documented")
    ];

    private bool IsOtherReason => string.Equals(Vm.PrimaryDischargeReason, "Other", StringComparison.OrdinalIgnoreCase);
    private bool IsNonBillableMode => DischargeDocumentationOptions.IsNonBillableMode(Vm.DischargeDocumentationMode);
    private bool IsNonBillableDischarge => Vm.IsNonBillableDischarge || IsNonBillableMode;
    private int CompletedChecklistCount => _checklistItems.Count(item => item.IsComplete);
    private int ChecklistProgressPercent => _checklistItems.Count == 0
        ? 0
        : (int)Math.Round((double)CompletedChecklistCount / _checklistItems.Count * 100);

    protected override void OnParametersSet()
    {
        EnsureDischargeDocumentationMode();

        Vm.IsNonBillableDischarge = ResolveIsNonBillableDischarge(preserveExplicitFlag: true);
        Vm.CompletedDischargeChecklistItems ??= new();

        var completed = new HashSet<string>(Vm.CompletedDischargeChecklistItems, StringComparer.OrdinalIgnoreCase);
        foreach (var item in _checklistItems)
        {
            item.IsComplete = completed.Contains(item.Title);
        }
    }

    private async Task GenerateFullNote()
    {
        await HandleChangedAsync();
    }

    private async Task GenerateClinicalSummary()
    {
        await HandleChangedAsync();
    }

    private Task HandleDocumentationModeChangedAsync() => ApplyChangedAsync(preserveExplicitFlag: false);

    private Task HandleChangedAsync() => ApplyChangedAsync(preserveExplicitFlag: true);

    private async Task ApplyChangedAsync(bool preserveExplicitFlag)
    {
        EnsureDischargeDocumentationMode();

        Vm.IsNonBillableDischarge = ResolveIsNonBillableDischarge(preserveExplicitFlag);

        if (!IsOtherReason)
        {
            Vm.OtherDischargeReasonExplanation = null;
        }

        Vm.CompletedDischargeChecklistItems = _checklistItems
            .Where(item => item.IsComplete)
            .Select(item => item.Title)
            .ToList();

        await VmChanged.InvokeAsync(Vm);
    }

    private void EnsureDischargeDocumentationMode()
    {
        if (string.IsNullOrWhiteSpace(Vm.DischargeDocumentationMode))
        {
            Vm.DischargeDocumentationMode = DischargeDocumentationOptions.StandardBillableMode;
        }
    }

    private bool ResolveIsNonBillableDischarge(bool preserveExplicitFlag) =>
        (preserveExplicitFlag && Vm.IsNonBillableDischarge) || IsNonBillableMode;

    private async Task HandleChecklistChanged(ChecklistItem item, ChangeEventArgs args)
    {
        item.IsComplete = args.Value switch
        {
            bool flag => flag,
            string text when bool.TryParse(text, out var parsed) => parsed,
            _ => false
        };

        await HandleChangedAsync();
    }

    private static string Pluralize(string singular, int count) => count == 1 ? singular : $"{singular}s";

    private sealed class ChecklistItem
    {
        public ChecklistItem(string title, string description)
        {
            Title = title;
            Description = description;
        }

        public string Title { get; }
        public string Description { get; }
        public bool IsComplete { get; set; }
    }
}
