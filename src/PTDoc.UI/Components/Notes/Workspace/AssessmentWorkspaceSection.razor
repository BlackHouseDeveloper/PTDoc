@namespace PTDoc.UI.Components.Notes.Workspace
@using PTDoc.UI.Components.Notes.Models
@using PTDoc.Application.AI

@* AssessmentWorkspaceSection: orchestrates all assessment cards per Blueprint.
   Embeds existing AssessmentTab for narrative/functional limitations (AI generation)
   and adds: Deficits, ICD-10, SMART Goals, Motivation, Support, Prognosis.
*@

<section class="assessment-workspace" data-testid="assessment-workspace-section" role="tabpanel" aria-label="Assessment section">

    <!-- 1. Clinical Assessment Summary (handled by existing AssessmentTab) -->
    <AssessmentTab NoteId="@NoteId"
                   IsNoteSigned="@IsReadOnly"
                   AssessmentText="@Vm.AssessmentNarrative"
                   AssessmentTextChanged="@(v => SetAndNotify(vm => vm.AssessmentNarrative = v))"
                   FunctionalLimitations="@Vm.FunctionalLimitations"
                   FunctionalLimitationsChanged="@(v => SetAndNotify(vm => vm.FunctionalLimitations = v))"
                   ChiefComplaint="@ChiefComplaint"
                   ExaminationFindings="@ExaminationFindings"
                   OnAiAccepted="@(v => SetAndNotify(vm => vm.AssessmentNarrative = v))" />

    <!-- 2. Deficits & Impairments -->
    <div class="aws-card" data-testid="deficits-card">
        <div class="aws-card__header">
            <div>
                <h3 class="aws-card__title">Deficits &amp; Impairments</h3>
                <p class="aws-card__subtitle">Auto-populated from objective findings</p>
            </div>
            @if (!IsReadOnly)
            {
                <button type="button" class="aws-card__secondary-btn"
                        data-testid="auto-generate-deficits"
                        @onclick="HandleAutoGenerateDeficitsAsync">
                    <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                        <path d="M6 1L7.545 3.909L10.8 4.364L8.4 6.709L8.945 9.977L6 8.364L3.055 9.977L3.6 6.709L1.2 4.364L4.455 3.909L6 1Z"
                              stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    Auto-Generate
                </button>
            }
        </div>

        @if (_deficitItems.Count > 0)
        {
            <div class="aws-card__deficits-list">
                @foreach (var d in _deficitItems)
                {
                    <span class="aws-card__deficit-chip aws-card__deficit-chip--@d.Severity.ToLower()">
                        @d.Severity — @d.Name
                    </span>
                }
            </div>
        }

        <textarea id="deficits-summary"
                  name="deficits-summary"
                  class="aws-card__textarea"
                  rows="4"
                  placeholder="Click 'Auto-Generate' to populate from objective findings, or enter manually..."
                  disabled="@IsReadOnly"
                  value="@Vm.DeficitsSummary"
                  @onchange="e => SetAndNotify(vm => vm.DeficitsSummary = e.Value?.ToString() ?? string.Empty)"></textarea>

        @if (Vm.DeficitCategories.Count > 0)
        {
            <div class="aws-card__category-row">
                <span class="aws-card__category-label">Deficit Categories:</span>
                @foreach (var cat in Vm.DeficitCategories)
                {
                    <span class="aws-card__tag aws-card__tag--deficit">@cat</span>
                }
            </div>
        }
    </div>

    @if (ShowSmartGoals)
    {
    <!-- 3. SMART Goals -->
    <div class="aws-card" data-testid="smart-goals-card">
        <div class="aws-card__header">
            <div>
                <h3 class="aws-card__title">SMART Goals</h3>
                <p class="aws-card__subtitle">Specific, Measurable, Achievable, Relevant, Time-bound</p>
            </div>
            @if (!IsReadOnly)
            {
                <div class="aws-card__action-group">
                    <AiGenerateButton ButtonLabel="AI Suggest"
                                      IsGenerating="@_isGeneratingGoals"
                                      OnGenerate="HandleAiSuggestGoalsAsync"
                                      TestId="ai-suggest-goals-btn" />
                    <button type="button" class="aws-card__secondary-btn"
                            @onclick="HandleAddGoal"
                            data-testid="add-goal-btn">
                        + Add Goal
                    </button>
                </div>
            }
        </div>

        @if (Vm.Goals.Count == 0)
        {
            <div class="aws-card__empty-state">
                <svg class="aws-card__empty-icon" width="36" height="36" viewBox="0 0 36 36"
                     fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <circle cx="18" cy="18" r="15" stroke="currentColor" stroke-width="1.5"/>
                    <circle cx="18" cy="18" r="9"  stroke="currentColor" stroke-width="1.5"/>
                    <circle cx="18" cy="18" r="3"  fill="currentColor"/>
                </svg>
                <p class="aws-card__empty-title">No treatment goals added yet.</p>
                <p class="aws-card__empty-hint">Click "AI Suggest" for smart recommendations or "Add Goal" to create manually.</p>
            </div>
        }
        else
        {
            <ul class="aws-card__goal-list">
                @foreach (var goal in Vm.Goals)
                {
                    <li class="aws-card__goal-item @(goal.IsAiSuggested && !goal.IsAccepted ? "aws-card__goal-item--pending" : "")">
                        <span class="aws-card__goal-text">@goal.Description</span>
                        @if (!string.IsNullOrWhiteSpace(goal.Category))
                        {
                            <span class="aws-card__tag">@goal.Category</span>
                        }
                        @if (goal.IsAiSuggested && !goal.IsAccepted && !IsReadOnly)
                        {
                            <button type="button" class="aws-card__accept-btn"
                                    @onclick="() => AcceptGoal(goal)">Accept</button>
                            <button type="button" class="aws-card__discard-btn"
                                    @onclick="() => DiscardGoal(goal)">Discard</button>
                        }
                    </li>
                }
            </ul>
        }
    </div>
    }

    <!-- 4. ICD-10 Diagnosis Codes (max 4) -->
    <div class="aws-card" data-testid="icd10-card">
        <div class="aws-card__header">
            <h3 class="aws-card__title">ICD-10 Diagnosis Codes *</h3>
            <span class="aws-card__badge @(Vm.DiagnosisCodes.Count >= 4 ? "aws-card__badge--warning" : "")">
                @Vm.DiagnosisCodes.Count / 4
            </span>
        </div>
        <p class="aws-card__subtitle">Search and select diagnosis codes (max 4)</p>

        @if (!IsReadOnly && Vm.DiagnosisCodes.Count < 4)
        {
            <div class="aws-card__search-row">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                    <path d="M6.5 11C8.98528 11 11 8.98528 11 6.5C11 4.01472 8.98528 2 6.5 2C4.01472 2 2 4.01472 2 6.5C2 8.98528 4.01472 11 6.5 11Z"
                          stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
                    <path d="M12 12L9.7 9.7" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
                </svg>
                <input type="text"
                       id="icd-search-input"
                       name="icd-search"
                       class="aws-card__search-input"
                       placeholder="Search by code or description (e.g., M25.511, shoulder pain)..."
                       value="@_icdSearchQuery"
                       @oninput="e => _icdSearchQuery = e.Value?.ToString() ?? string.Empty"
                       data-testid="icd-search-input" />
            </div>
            @* ICD-10 lookup dropdown integration is pending; selected codes are managed manually below. *@
        }

        @if (Vm.DiagnosisCodes.Count == 0)
        {
            <p class="aws-card__empty-hint" style="padding: var(--spacing-4) 0; text-align: center;">
                No diagnosis codes selected — search above to add codes.
            </p>
        }
        else
        {
            <ul class="aws-card__icd-list">
                @foreach (var dx in Vm.DiagnosisCodes)
                {
                    <li class="aws-card__icd-item">
                        <span class="aws-card__icd-code">@dx.Code</span>
                        <span class="aws-card__icd-desc">@dx.Description</span>
                        @if (!IsReadOnly)
                        {
                            <button type="button" class="aws-card__remove-btn"
                                    aria-label="@($"Remove {dx.Code}")"
                                    @onclick="() => RemoveDiagnosisCode(dx)">✕</button>
                        }
                    </li>
                }
            </ul>
        }

        @if (Vm.DiagnosisCodes.Count >= 4)
        {
            <p class="aws-card__limit-notice" role="alert">Maximum of 4 ICD-10 codes allowed per Medicare documentation requirements.</p>
        }
    </div>

    <!-- 5. Patient Motivation & Goals -->
    <div class="aws-card" data-testid="motivation-card">
        <div class="aws-card__header">
            <div class="aws-card__title-row">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <path d="M8 2.5C8 2.5 4 6 4 9.5C4 11.7091 5.79086 13.5 8 13.5C10.2091 13.5 12 11.7091 12 9.5C12 6 8 2.5 8 2.5Z"
                          stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <h3 class="aws-card__title">Patient Motivation &amp; Goals</h3>
            </div>
        </div>
        <p class="aws-card__subtitle">Assess patient's readiness and motivation for therapy</p>

        <div class="aws-card__field">
            <label class="aws-card__field-label" for="motivation-level">Motivation Level *</label>
            <select id="motivation-level" name="motivation-level" class="aws-card__select"
                    disabled="@IsReadOnly"
                    value="@Vm.MotivationLevel"
                    @onchange="e => SetAndNotify(vm => vm.MotivationLevel = e.Value?.ToString())">
                <option value="">Select motivation level ↓</option>
                @foreach (var level in _motivationLevels)
                {
                    <option value="@level" selected="@(Vm.MotivationLevel == level)">@level</option>
                }
            </select>
        </div>

        <div class="aws-card__field">
            <p class="aws-card__field-label">Primary Motivating Factors</p>
            <div class="aws-card__checkbox-grid">
                @foreach (var factor in _motivatingFactors)
                {
                    <label class="aws-card__checkbox-item">
                        <input type="checkbox"
                               name="motivating-factors"
                               checked="@Vm.MotivatingFactors.Contains(factor)"
                               disabled="@IsReadOnly"
                               @onchange="e => ToggleMotivation(factor, (bool)e.Value!)" />
                        @factor
                    </label>
                }
            </div>
        </div>

        <div class="aws-card__field">
            <label class="aws-card__field-label" for="patient-goals-text">Patient's Personal Goals (in their own words)</label>
            <textarea id="patient-goals-text" name="patient-goals-text" class="aws-card__textarea" rows="3"
                      placeholder="What does the patient want to accomplish? What is most important to them?"
                      disabled="@IsReadOnly"
                      value="@Vm.PatientPersonalGoals"
                      @onchange="e => SetAndNotify(vm => vm.PatientPersonalGoals = e.Value?.ToString())"></textarea>
        </div>

        <div class="aws-card__field">
            <label class="aws-card__field-label" for="motivation-notes">Additional Motivation Notes</label>
            <textarea id="motivation-notes" name="motivation-notes" class="aws-card__textarea" rows="2"
                      placeholder="Observed behaviors, readiness for change, concerns, expectations..."
                      disabled="@IsReadOnly"
                      value="@Vm.AdditionalMotivationNotes"
                      @onchange="e => SetAndNotify(vm => vm.AdditionalMotivationNotes = e.Value?.ToString())"></textarea>
        </div>
    </div>

    <!-- 6. Support System & Barriers -->
    <div class="aws-card" data-testid="support-system-card">
        <div class="aws-card__header">
            <div class="aws-card__title-row">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <path d="M6 8C7.65685 8 9 6.65685 9 5C9 3.34315 7.65685 2 6 2C4.34315 2 3 3.34315 3 5C3 6.65685 4.34315 8 6 8Z"
                          stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                    <path d="M1 14C1 11.7909 3.23858 10 6 10" stroke="currentColor" stroke-width="1.5"
                          stroke-linecap="round"/>
                    <path d="M11 8C12.1046 8 13 7.10457 13 6C13 4.89543 12.1046 4 11 4C9.89543 4 9 4.89543 9 6C9 7.10457 9.89543 8 11 8Z"
                          stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                    <path d="M9 14C9 12.3431 9.89543 11 11 11C12.1046 11 13 12.3431 13 14"
                          stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
                <h3 class="aws-card__title">Support System &amp; Barriers</h3>
            </div>
        </div>
        <p class="aws-card__subtitle">Identify resources and potential obstacles to recovery</p>

        <div class="aws-card__field">
            <label class="aws-card__field-label" for="support-level">Support System Level *</label>
            <select id="support-level" name="support-level" class="aws-card__select"
                    disabled="@IsReadOnly"
                    value="@Vm.SupportSystemLevel"
                    @onchange="e => SetAndNotify(vm => vm.SupportSystemLevel = e.Value?.ToString())">
                <option value="">Select support level ↓</option>
                @foreach (var level in _supportLevels)
                {
                    <option value="@level" selected="@(Vm.SupportSystemLevel == level)">@level</option>
                }
            </select>
        </div>

        <div class="aws-card__field">
            <p class="aws-card__field-label">Available Resources &amp; Supports</p>
            <div class="aws-card__checkbox-grid">
                @foreach (var resource in _availableResources)
                {
                    <label class="aws-card__checkbox-item">
                        <input type="checkbox"
                               name="available-resources"
                               checked="@Vm.AvailableResources.Contains(resource)"
                               disabled="@IsReadOnly"
                               @onchange="e => ToggleResource(resource, (bool)e.Value!)" />
                        @resource
                    </label>
                }
            </div>
        </div>

        <div class="aws-card__field">
            <p class="aws-card__field-label">Barriers to Recovery</p>
            <div class="aws-card__checkbox-grid">
                @foreach (var barrier in _barriers)
                {
                    <label class="aws-card__checkbox-item">
                        <input type="checkbox"
                               name="recovery-barriers"
                               checked="@Vm.BarriersToRecovery.Contains(barrier)"
                               disabled="@IsReadOnly"
                               @onchange="e => ToggleBarrier(barrier, (bool)e.Value!)" />
                        @barrier
                    </label>
                }
            </div>
        </div>

        <div class="aws-card__field">
            <label class="aws-card__field-label" for="support-details">Support System Details</label>
            <textarea id="support-details" name="support-details" class="aws-card__textarea" rows="2"
                      placeholder="Who will assist? What support is available? Living situation details..."
                      disabled="@IsReadOnly"
                      value="@Vm.SupportSystemDetails"
                      @onchange="e => SetAndNotify(vm => vm.SupportSystemDetails = e.Value?.ToString())"></textarea>
        </div>

        <div class="aws-card__field">
            <label class="aws-card__field-label" for="support-additional">Additional Notes</label>
            <textarea id="support-additional" name="support-additional" class="aws-card__textarea" rows="2"
                      placeholder="Strategies to address barriers, resources to provide..."
                      disabled="@IsReadOnly"
                      value="@Vm.SupportAdditionalNotes"
                      @onchange="e => SetAndNotify(vm => vm.SupportAdditionalNotes = e.Value?.ToString())"></textarea>
        </div>
    </div>

    <!-- 7. Prognosis -->
    <div class="aws-card" data-testid="prognosis-card">
        <div class="aws-card__header">
            <div class="aws-card__title-row">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <path d="M2 12L6 8L9 11L14 5" stroke="currentColor" stroke-width="1.5"
                          stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <h3 class="aws-card__title">Prognosis</h3>
            </div>
        </div>
        <p class="aws-card__subtitle">Expected outcome based on clinical findings, motivation, and support</p>

        <div class="aws-card__field">
            <label class="aws-card__field-label" for="overall-prognosis">Overall Prognosis *</label>
            <select id="overall-prognosis" name="overall-prognosis" class="aws-card__select"
                    disabled="@IsReadOnly"
                    value="@Vm.OverallPrognosis"
                    @onchange="e => SetAndNotify(vm => vm.OverallPrognosis = e.Value?.ToString())">
                <option value="">Select prognosis ↓</option>
                @foreach (var prognosis in _prognosisOptions)
                {
                    <option value="@prognosis" selected="@(Vm.OverallPrognosis == prognosis)">@prognosis</option>
                }
            </select>
        </div>

        <div class="aws-card__prognosis-considerations">
            <p class="aws-card__field-label">Prognosis Considerations:</p>
            <ul class="aws-card__considerations-list">
                <li>✓ Patient age and comorbidities</li>
                <li>✓ Severity and chronicity of condition</li>
                <li>✓ Patient motivation and compliance</li>
                <li>✓ Available support system</li>
                <li>✓ Barriers to treatment</li>
                <li>✓ Response to initial treatment</li>
            </ul>
        </div>
    </div>

</section>

@code {
    private bool _isGeneratingGoals;
    private string _icdSearchQuery = string.Empty;

    // Placeholder deficit items populated by Auto-Generate.
    private List<(string Name, string Severity)> _deficitItems = new();

    [Parameter, EditorRequired] public AssessmentWorkspaceVm Vm { get; set; } = new();
    [Parameter, EditorRequired] public EventCallback<AssessmentWorkspaceVm> VmChanged { get; set; }
    [Parameter, EditorRequired] public Guid NoteId { get; set; }
    [Parameter] public bool IsReadOnly { get; set; }
    [Parameter] public bool ShowSmartGoals { get; set; } = true;
    [Parameter] public string? ChiefComplaint { get; set; }
    [Parameter] public string? ExaminationFindings { get; set; }

    // ── Static option lists ──────────────────────────────────────────

    private static readonly string[] _motivationLevels =
    [
        "Highly motivated — eager to participate and comply",
        "Motivated — willing to participate with occasional prompting",
        "Moderately motivated — participates with consistent encouragement",
        "Low motivation — significant barriers to engagement",
        "Unmotivated — resistant or disengaged"
    ];

    private static readonly string[] _motivatingFactors =
    [
        "Return to work",        "Return to sports/recreation",
        "Reduce pain",           "Improve daily activities",
        "Avoid surgery",         "Care for family members",
        "Maintain independence", "Weight loss/fitness goals"
    ];

    private static readonly string[] _supportLevels =
    [
        "Strong — reliable network available",
        "Moderate — some support available",
        "Limited — minimal support available",
        "None — no support system identified"
    ];

    private static readonly string[] _availableResources =
    [
        "Family assistance available",  "Reliable transportation",
        "Flexible work schedule",       "Home exercise equipment",
        "Gym/pool access",              "Caregiver support",
        "Community resources",          "Technology savvy",
        "Strong social network"
    ];

    private static readonly string[] _barriers =
    [
        "Limited family support",       "Transportation difficulties",
        "Financial constraints",         "Work schedule conflicts",
        "Childcare responsibilities",    "Language barrier",
        "Health literacy concerns",      "Cognitive impairment",
        "Depression/Anxiety",            "Poor social support network"
    ];

    private static readonly string[] _prognosisOptions =
    [
        "Excellent — full recovery expected within treatment period",
        "Good — significant improvement expected",
        "Fair — moderate improvement expected with sustained effort",
        "Guarded — limited improvement; multiple barriers present",
        "Poor — minimal expected improvement"
    ];

    // ── Helpers ──────────────────────────────────────────────────────

    private Task SetAndNotify(Action<AssessmentWorkspaceVm> update)
    {
        update(Vm);
        return VmChanged.InvokeAsync(Vm);
    }

    private Task ToggleMotivation(string item, bool add)
    {
        if (add) Vm.MotivatingFactors.Add(item); else Vm.MotivatingFactors.Remove(item);
        return VmChanged.InvokeAsync(Vm);
    }

    private Task ToggleResource(string item, bool add)
    {
        if (add) Vm.AvailableResources.Add(item); else Vm.AvailableResources.Remove(item);
        return VmChanged.InvokeAsync(Vm);
    }

    private Task ToggleBarrier(string item, bool add)
    {
        if (add) Vm.BarriersToRecovery.Add(item); else Vm.BarriersToRecovery.Remove(item);
        return VmChanged.InvokeAsync(Vm);
    }

    private Task AcceptGoal(SmartGoalEntry goal)
    {
        goal.IsAccepted = true;
        return VmChanged.InvokeAsync(Vm);
    }

    private Task DiscardGoal(SmartGoalEntry goal)
    {
        Vm.Goals.Remove(goal);
        return VmChanged.InvokeAsync(Vm);
    }

    private void HandleAddGoal()
    {
        Vm.Goals.Add(new SmartGoalEntry { Description = string.Empty });
        VmChanged.InvokeAsync(Vm);
    }

    private void RemoveDiagnosisCode(Icd10Entry code)
    {
        Vm.DiagnosisCodes.Remove(code);
        VmChanged.InvokeAsync(Vm);
    }

    private async Task HandleAutoGenerateDeficitsAsync()
    {
        // Placeholder hook for objective-to-deficit extraction integration.
        await Task.CompletedTask;
    }

    private async Task HandleAiSuggestGoalsAsync()
    {
        // Safety: never auto-persist; adds goals as IsAiSuggested=true, IsAccepted=false
        // Clinician must Accept each suggestion (Blueprint rule)
        if (IsReadOnly) return;

        _isGeneratingGoals = true;
        StateHasChanged();

        try
        {
            // Placeholder generation path until IAiClinicalGenerationService integration is added.
            await Task.Delay(100); // stub
        }
        finally
        {
            _isGeneratingGoals = false;
        }
    }
}
