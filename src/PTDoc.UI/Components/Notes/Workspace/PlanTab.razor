@namespace PTDoc.UI.Components.Notes.Workspace
@using PTDoc.Application.AI
@using PTDoc.Application.Compliance
@using PTDoc.Application.Notes.Workspace
@using PTDoc.UI.Components.Notes.Models
@using UiCptCodeEntry = PTDoc.UI.Components.Notes.Models.CptCodeEntry
@implements IDisposable

@inject IAiClinicalGenerationService AiService
@inject PTDoc.UI.Services.INoteWorkspaceService NoteWorkspaceService
@inject ILogger<PlanTab> Logger

@* PlanTab: CPT codes, treatment plan, additional planning, clinical summary.
   Per Blueprint: CPT favorites grid, frequency/duration required fields, AI-assisted
   discharge planning, follow-up instructions, and final clinical summary.
*@

<div class="plan-tab" data-testid="plan-tab">
    @if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <p class="pt-card__poc-placeholder" role="alert">@_errorMessage</p>
    }

    <!-- 1. CPT Codes -->
    <div class="pt-card" data-testid="cpt-codes-card">
        <div class="pt-card__header">
            <div>
                <h3 class="pt-card__title">CPT Procedure Codes</h3>
                <p class="pt-card__subtitle">Select billable procedure codes for this session</p>
            </div>
            @if (!IsReadOnly)
            {
                <button type="button" class="pt-card__secondary-btn"
                        data-testid="customize-cpt-btn"
                        @onclick="HandleCustomizeCptAsync">
                    Customize
                </button>
            }
        </div>

        @if (!IsReadOnly)
        {
            <div class="pt-card__field">
                <label class="pt-card__field-label" for="cpt-search-input">Search CPT Codes</label>
                <input id="cpt-search-input"
                       type="search"
                       class="pt-card__search-input"
                       placeholder="Search by CPT code or description"
                       value="@_cptSearchQuery"
                       @oninput="HandleCptSearchChangedAsync"
                       data-testid="cpt-search-input" />
            </div>

            @if (_isSearchingCpt)
            {
                <p class="pt-card__search-status" role="status">Searching CPT codes…</p>
            }
            else if (!string.IsNullOrWhiteSpace(_cptLookupError))
            {
                <p class="pt-card__search-status pt-card__search-status--error" role="alert">@_cptLookupError</p>
            }
            else if (_cptResults.Count > 0)
            {
                <div class="pt-card__search-results" data-testid="cpt-search-results">
                    @foreach (var result in _cptResults)
                    {
                        var isSelected = Vm.SelectedCptCodes.Any(code => string.Equals(code.Code, result.Code, StringComparison.OrdinalIgnoreCase));
                        <button type="button"
                                class="pt-card__search-result @(isSelected ? "pt-card__search-result--selected" : "")"
                                disabled="@IsReadOnly"
                                @onclick="() => AddCptCodeAsync(result)"
                                data-testid="cpt-search-result">
                            <span class="pt-card__search-result-code">@result.Code</span>
                            <span class="pt-card__search-result-desc">@result.Description</span>
                            @if (result.SuggestedModifiers.Count > 0)
                            {
                                <span class="pt-card__search-result-hint">Suggested: @string.Join(", ", result.SuggestedModifiers)</span>
                            }
                        </button>
                    }
                </div>
            }
        }

        <!-- Favorites grid (6 pre-loaded) -->
        <p class="pt-card__field-label">Favorite CPT Codes</p>
        <div class="pt-card__cpt-grid">
            @foreach (var fav in _favoriteCptCodes)
            {
                var alreadySelected = Vm.SelectedCptCodes.Any(c => c.Code == fav.Code);
                <button type="button"
                        class="pt-card__cpt-tile @(alreadySelected ? "pt-card__cpt-tile--active" : "")"
                        disabled="@(IsReadOnly || (alreadySelected ? false : false))"
                        aria-pressed="@alreadySelected.ToString().ToLower()"
                        @onclick="() => ToggleCptFavoriteAsync(fav)">
                    <span class="pt-card__cpt-code">@fav.Code</span>
                    <span class="pt-card__cpt-name">@fav.ShortName</span>
                    <span class="pt-card__cpt-unit">@fav.DefaultUnits min</span>
                </button>
            }
        </div>

        <!-- Selected codes list -->
        @if (Vm.SelectedCptCodes.Count == 0)
        {
            <div class="pt-card__cpt-empty">
                <svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
                    <rect x="4" y="4" width="20" height="24" rx="2" stroke="currentColor" stroke-width="1.5"/>
                    <path d="M9 10h10M9 14h10M9 18h6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
                <p>No CPT codes selected — click a favorite above to add.</p>
            </div>
        }
        else
        {
            <div class="pt-card__cpt-selected-header">
                <span class="pt-card__field-label">Selected Codes</span>
                <span class="pt-card__badge">@Vm.SelectedCptCodes.Count selected</span>
            </div>
            @if (GetBillingAdvisories().Count > 0)
            {
                <div class="pt-card__advisory-list" role="status" aria-live="polite">
                    @foreach (var advisory in GetBillingAdvisories())
                    {
                        <p class="pt-card__advisory-item">@advisory</p>
                    }
                </div>
            }
            <ul class="pt-card__cpt-list">
                @foreach (var entry in Vm.SelectedCptCodes)
                {
                    <li class="pt-card__cpt-row">
                        <div class="pt-card__cpt-main">
                            <div class="pt-card__cpt-row-header">
                                <div class="pt-card__cpt-summary">
                                    <span class="pt-card__cpt-code">@entry.Code</span>
                                    <span class="pt-card__cpt-desc">@entry.Description</span>
                                </div>
                                @if (!IsReadOnly)
                                {
                                    <button type="button" class="pt-card__remove-btn"
                                            aria-label="Remove @entry.Code"
                                            @onclick="() => RemoveCptCode(entry)">✕</button>
                                }
                            </div>

                            <div class="pt-card__cpt-detail-grid">
                                <div class="pt-card__cpt-units-row">
                                    <button type="button" class="pt-card__stepper"
                                            aria-label="Decrease units for @entry.Code"
                                            disabled="@(IsReadOnly || entry.Units <= 1)"
                                            @onclick="() => ChangeUnits(entry, -1)">−</button>
                                    <span class="pt-card__unit-value">@entry.Units</span>
                                    <button type="button" class="pt-card__stepper"
                                            aria-label="Increase units for @entry.Code"
                                            disabled="@IsReadOnly"
                                            @onclick="() => ChangeUnits(entry, 1)">+</button>
                                    <span class="pt-card__unit-label">units</span>
                                </div>

                                @if (KnownTimedCptCodes.Codes.Contains(entry.Code))
                                {
                                    <label class="pt-card__minutes-field">
                                        <span class="pt-card__unit-label">Minutes</span>
                                        <input type="number"
                                               min="0"
                                               step="1"
                                               class="pt-card__minutes-input"
                                               value="@(entry.Minutes?.ToString() ?? string.Empty)"
                                               disabled="@IsReadOnly"
                                               @onchange="e => UpdateMinutes(entry, e.Value)"
                                               data-testid="cpt-minutes-input" />
                                    </label>
                                }
                            </div>

                            @if (entry.ModifierOptions.Count > 0)
                            {
                                <div class="pt-card__modifier-section">
                                    <p class="pt-card__modifier-label">Modifiers</p>
                                    <div class="pt-card__modifier-chip-row">
                                        @foreach (var modifier in entry.ModifierOptions)
                                        {
                                            var isSelected = entry.Modifiers.Contains(modifier, StringComparer.OrdinalIgnoreCase);
                                            var isSuggested = entry.SuggestedModifiers.Contains(modifier, StringComparer.OrdinalIgnoreCase);
                                            <button type="button"
                                                    class="pt-card__modifier-chip @(isSelected ? "pt-card__modifier-chip--active" : "") @(isSuggested ? "pt-card__modifier-chip--suggested" : "")"
                                                    disabled="@IsReadOnly"
                                                    @onclick="() => ToggleModifier(entry, modifier)"
                                                    data-testid="modifier-chip">
                                                @modifier
                                            </button>
                                        }
                                    </div>
                                    @if (entry.SuggestedModifiers.Count > 0)
                                    {
                                        <p class="pt-card__modifier-hint">
                                            Suggested: @string.Join(", ", entry.SuggestedModifiers)
                                            @if (!string.IsNullOrWhiteSpace(entry.ModifierSource))
                                            {
                                                <span> · Source: @entry.ModifierSource</span>
                                            }
                                        </p>
                                    }
                                </div>
                            }
                        </div>
                    </li>
                }
            </ul>
        }
    </div>

    <!-- 2. Treatment Plan -->
    <div class="pt-card" data-testid="treatment-plan-card">
        <div class="pt-card__header">
            <div class="pt-card__title-row">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <rect x="2" y="2" width="12" height="12" rx="1.5" stroke="currentColor" stroke-width="1.5"/>
                    <path d="M5 8h6M8 5v6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
                <h3 class="pt-card__title">Treatment Plan</h3>
            </div>
        </div>

        <div class="pt-card__row-2col">
            <div class="pt-card__field">
                <label class="pt-card__field-label" for="treatment-frequency">
                    Treatment Frequency *
                </label>
                <select id="treatment-frequency" class="pt-card__select"
                        disabled="@IsReadOnly"
                        value="@Vm.TreatmentFrequency"
                        @onchange="e => SetAndNotify(vm => vm.TreatmentFrequency = e.Value?.ToString())">
                    <option value="">Select frequency ↓</option>
                    @foreach (var f in _frequencyOptions)
                    {
                        <option value="@f" selected="@(Vm.TreatmentFrequency == f)">@f</option>
                    }
                </select>
            </div>

            <div class="pt-card__field">
                <label class="pt-card__field-label" for="treatment-duration">
                    Treatment Duration *
                </label>
                <select id="treatment-duration" class="pt-card__select"
                        disabled="@IsReadOnly"
                        value="@Vm.TreatmentDuration"
                        @onchange="e => SetAndNotify(vm => vm.TreatmentDuration = e.Value?.ToString())">
                    <option value="">Select duration ↓</option>
                    @foreach (var d in _durationOptions)
                    {
                        <option value="@d" selected="@(Vm.TreatmentDuration == d)">@d</option>
                    }
                </select>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Vm.TreatmentFrequency) && !string.IsNullOrWhiteSpace(Vm.TreatmentDuration))
        {
            <div class="pt-card__poc-hint" role="status" aria-live="polite">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                    <circle cx="7" cy="7" r="5.5" stroke="currentColor" stroke-width="1.3"/>
                    <path d="M7 4.5v3.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
                    <circle cx="7" cy="10" r="0.65" fill="currentColor"/>
                </svg>
                Plan of Care: <strong>@Vm.TreatmentFrequency</strong> for <strong>@Vm.TreatmentDuration</strong>
            </div>
        }
        else
        {
            <p class="pt-card__poc-placeholder">
                Select treatment frequency and duration to calculate Plan of Care dates.
            </p>
        }
    </div>

    <!-- 3. Additional Planning -->
    <div class="pt-card" data-testid="additional-planning-card">
        <div class="pt-card__header">
            <h3 class="pt-card__title">Additional Planning</h3>
        </div>

        <!-- Home Exercise Program -->
        <div class="pt-card__field">
            <label class="pt-card__field-label" for="hep-notes">Home Exercise Program (HEP)</label>
            <textarea id="hep-notes" class="pt-card__textarea" rows="3"
                      placeholder="Describe home exercises, frequency, precautions, and patient education..."
                      disabled="@IsReadOnly"
                      value="@Vm.HomeExerciseProgramNotes"
                      @onchange="e => SetAndNotify(vm => vm.HomeExerciseProgramNotes = e.Value?.ToString())"></textarea>
        </div>

        <!-- Discharge Planning -->
        <div class="pt-card__field">
            <div class="pt-card__field-header">
                <p class="pt-card__field-label">Discharge Planning</p>
                @if (!IsReadOnly)
                {
                    <AiGenerateButton ButtonLabel="AI Suggest"
                                      IsGenerating="@_isGeneratingDischarge"
                                      OnGenerate="HandleAiSuggestDischargeAsync"
                                      TestId="ai-suggest-discharge-btn" />
                }
            </div>
            <EditableNarrativeBox @ref="_dischargePlanningBox"
                                  Label=""
                                  Placeholder="Long-term maintenance plan, self-management strategies, return-to-care criteria..."
                                  Value="@(Vm.DischargePlanningNotes ?? string.Empty)"
                                  ValueChanged="@(v => SetAndNotify(vm => vm.DischargePlanningNotes = v))"
                                  OnAccepted="HandleDischargeAcceptedAsync"
                                  OnDiscarded="() => SetAndNotify(vm => vm.DischargePlanningNotes = string.Empty)"
                                  IsReadOnly="@IsReadOnly"
                                  Rows="3"
                                  TestId="discharge-planning-box" />
        </div>

        <!-- Follow-up Instructions -->
        <div class="pt-card__field">
            <div class="pt-card__field-header">
                <p class="pt-card__field-label">Follow-up Instructions</p>
                @if (!IsReadOnly)
                {
                    <AiGenerateButton ButtonLabel="AI Suggest"
                                      IsGenerating="@_isGeneratingFollowUp"
                                      OnGenerate="HandleAiSuggestFollowUpAsync"
                                      TestId="ai-suggest-followup-btn" />
                }
            </div>
            <EditableNarrativeBox @ref="_followUpBox"
                                  Label=""
                                  Placeholder="Next appointment recommendations, referrals, precautions after discharge..."
                                  Value="@(Vm.FollowUpInstructions ?? string.Empty)"
                                  ValueChanged="@(v => SetAndNotify(vm => vm.FollowUpInstructions = v))"
                                  OnAccepted="HandleFollowUpAcceptedAsync"
                                  OnDiscarded="() => SetAndNotify(vm => vm.FollowUpInstructions = string.Empty)"
                                  IsReadOnly="@IsReadOnly"
                                  Rows="3"
                                  TestId="followup-instructions-box" />
        </div>
    </div>

    <!-- 4. Clinical Summary (SOAP) -->
    <div class="pt-card" data-testid="clinical-summary-card">
        <div class="pt-card__header">
            <div>
                <h3 class="pt-card__title">Clinical Summary (SOAP)</h3>
                <p class="pt-card__subtitle">AI-generated comprehensive summary of all SOAP sections</p>
            </div>
            @if (!IsReadOnly)
            {
                <AiGenerateButton ButtonLabel="Generate Summary"
                                  IsGenerating="@_isGeneratingSummary"
                                  OnGenerate="HandleGenerateSummaryAsync"
                                  TestId="generate-summary-btn" />
            }
        </div>

        <EditableNarrativeBox @ref="_clinicalSummaryBox"
                              Label=""
                              Placeholder="Click 'Generate Summary' to create a comprehensive SOAP note summary, or type manually..."
                              Value="@(Vm.ClinicalSummary ?? string.Empty)"
                              ValueChanged="@(v => SetAndNotify(vm => vm.ClinicalSummary = v))"
                              OnAccepted="HandleClinicalSummaryAcceptedAsync"
                              OnDiscarded="() => SetAndNotify(vm => vm.ClinicalSummary = string.Empty)"
                              IsReadOnly="@IsReadOnly"
                              Rows="6"
                              TestId="clinical-summary-box" />
    </div>

</div>

@code {
    [Parameter, EditorRequired] public PlanVm Vm { get; set; } = new();
    [Parameter, EditorRequired] public EventCallback<PlanVm> VmChanged { get; set; }
    [Parameter] public bool IsReadOnly { get; set; }
    [Parameter] public Guid NoteId { get; set; }
    [Parameter] public string? DiagnosisSummary { get; set; }
    [Parameter] public string? AssessmentSummary { get; set; }
    [Parameter] public string? GoalsSummary { get; set; }
    [Parameter] public string? PrecautionsSummary { get; set; }

    private bool _isGeneratingDischarge;
    private bool _isGeneratingFollowUp;
    private bool _isGeneratingSummary;
    private bool _isSearchingCpt;
    private string? _errorMessage;
    private string? _cptLookupError;
    private string _cptSearchQuery = string.Empty;
    private List<CodeLookupEntry> _cptResults = [];
    private CancellationTokenSource? _cptSearchCts;
    private EditableNarrativeBox? _dischargePlanningBox;
    private EditableNarrativeBox? _followUpBox;
    private EditableNarrativeBox? _clinicalSummaryBox;

    // ── Static: Favorite CPT codes ─────────────────────────────────

    private record FavoriteCptCode(string Code, string ShortName, int DefaultUnits);

    private static readonly FavoriteCptCode[] _favoriteCptCodes =
    [
        new("97140", "Manual Therapy",           2),
        new("97110", "Therapeutic Exercise",      2),
        new("97112", "Neuromuscular Re-ed",       2),
        new("97530", "Therapeutic Activities",    2),
        new("97116", "Gait Training",             2),
        new("97535", "Self-care/ADL Training",    2),
    ];

    private static readonly string[] _frequencyOptions =
    [
        "1x/week",  "2x/week",   "3x/week",   "4x/week",   "5x/week",
        "1x/month", "2x/month",  "PRN",        "Daily (home HEP only)"
    ];

    private static readonly string[] _durationOptions =
    [
        "2 weeks",  "4 weeks",  "6 weeks",  "8 weeks", "10 weeks",
        "12 weeks", "16 weeks", "20 weeks", "24 weeks", "Ongoing"
    ];

    // ── Helpers ────────────────────────────────────────────────────

    private Task SetAndNotify(Action<PlanVm> update)
    {
        update(Vm);
        return VmChanged.InvokeAsync(Vm);
    }

    private async Task ToggleCptFavoriteAsync(FavoriteCptCode fav)
    {
        var existing = Vm.SelectedCptCodes.FirstOrDefault(c => c.Code == fav.Code);
        if (existing is not null)
        {
            Vm.SelectedCptCodes.Remove(existing);
            await VmChanged.InvokeAsync(Vm);
            return;
        }

        Vm.SelectedCptCodes.Add(await BuildCptEntryAsync(
            fav.Code,
            fav.ShortName,
            fav.DefaultUnits));
        await VmChanged.InvokeAsync(Vm);
    }

    private async Task AddCptCodeAsync(CodeLookupEntry result)
    {
        var existing = Vm.SelectedCptCodes.FirstOrDefault(code =>
            string.Equals(code.Code, result.Code, StringComparison.OrdinalIgnoreCase));

        if (existing is not null)
        {
            existing.Description = result.Description;
            existing.ModifierOptions = [.. result.ModifierOptions];
            existing.SuggestedModifiers = [.. result.SuggestedModifiers];
            existing.ModifierSource = result.ModifierSource;
            if (existing.Modifiers.Count == 0 && result.SuggestedModifiers.Count > 0)
            {
                existing.Modifiers = [.. result.SuggestedModifiers];
            }
            await VmChanged.InvokeAsync(Vm);
            return;
        }

        Vm.SelectedCptCodes.Add(new UiCptCodeEntry
        {
            Code = result.Code,
            Description = result.Description,
            Units = ResolveDefaultUnits(result.Code),
            Modifiers = [.. result.SuggestedModifiers],
            ModifierOptions = [.. result.ModifierOptions],
            SuggestedModifiers = [.. result.SuggestedModifiers],
            ModifierSource = result.ModifierSource
        });
        await VmChanged.InvokeAsync(Vm);
    }

    private async Task<UiCptCodeEntry> BuildCptEntryAsync(string code, string description, int defaultUnits)
    {
        try
        {
            var matches = await NoteWorkspaceService.SearchCptAsync(code, take: 5);
            var exactMatch = matches.FirstOrDefault(match =>
                string.Equals(match.Code, code, StringComparison.OrdinalIgnoreCase));

            if (exactMatch is not null)
            {
                return new UiCptCodeEntry
                {
                    Code = exactMatch.Code,
                    Description = exactMatch.Description,
                    Units = defaultUnits,
                    Modifiers = [.. exactMatch.SuggestedModifiers],
                    ModifierOptions = [.. exactMatch.ModifierOptions],
                    SuggestedModifiers = [.. exactMatch.SuggestedModifiers],
                    ModifierSource = exactMatch.ModifierSource
                };
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Unable to enrich CPT code {Code} with modifier metadata for note {NoteId}", code, NoteId);
        }

        return new UiCptCodeEntry
        {
            Code = code,
            Description = description,
            Units = defaultUnits
        };
    }

    private void ChangeUnits(UiCptCodeEntry entry, int delta)
    {
        entry.Units = Math.Max(1, entry.Units + delta);
        VmChanged.InvokeAsync(Vm);
    }

    private void RemoveCptCode(UiCptCodeEntry entry)
    {
        Vm.SelectedCptCodes.Remove(entry);
        VmChanged.InvokeAsync(Vm);
    }

    private void ToggleModifier(UiCptCodeEntry entry, string modifier)
    {
        if (entry.Modifiers.Contains(modifier, StringComparer.OrdinalIgnoreCase))
        {
            entry.Modifiers.RemoveAll(value => string.Equals(value, modifier, StringComparison.OrdinalIgnoreCase));
        }
        else
        {
            entry.Modifiers.Add(modifier);
        }

        VmChanged.InvokeAsync(Vm);
    }

    private void UpdateMinutes(UiCptCodeEntry entry, object? value)
    {
        if (int.TryParse(value?.ToString(), out var minutes))
        {
            entry.Minutes = Math.Max(0, minutes);
        }
        else
        {
            entry.Minutes = null;
        }

        VmChanged.InvokeAsync(Vm);
    }

    private async Task HandleCptSearchChangedAsync(ChangeEventArgs args)
    {
        _cptSearchQuery = args.Value?.ToString() ?? string.Empty;
        _cptSearchCts?.Cancel();
        _cptSearchCts?.Dispose();
        _cptSearchCts = new CancellationTokenSource();
        var cancellationToken = _cptSearchCts.Token;

        if (string.IsNullOrWhiteSpace(_cptSearchQuery))
        {
            _cptResults = [];
            _cptLookupError = null;
            _isSearchingCpt = false;
            StateHasChanged();
            return;
        }

        _isSearchingCpt = true;
        _cptLookupError = null;
        StateHasChanged();

        try
        {
            await Task.Delay(250, cancellationToken);
            var results = await NoteWorkspaceService.SearchCptAsync(_cptSearchQuery, take: 8, cancellationToken);
            if (cancellationToken.IsCancellationRequested)
            {
                return;
            }

            _cptResults = [.. results];
        }
        catch (OperationCanceledException)
        {
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "CPT lookup failed for note {NoteId} and query {Query}", NoteId, _cptSearchQuery);
            _cptLookupError = "Unable to search CPT codes.";
            _cptResults = [];
        }
        finally
        {
            if (!cancellationToken.IsCancellationRequested)
            {
                _isSearchingCpt = false;
                StateHasChanged();
            }
        }
    }

    private List<string> GetBillingAdvisories()
    {
        var advisories = new List<string>();

        var timedCodesMissingMinutes = Vm.SelectedCptCodes
            .Where(entry => KnownTimedCptCodes.Codes.Contains(entry.Code) && entry.Units > 0 && entry.Minutes is null or <= 0)
            .Select(entry => entry.Code)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        if (timedCodesMissingMinutes.Count > 0)
        {
            advisories.Add($"Timed CPT minutes are still needed for: {string.Join(", ", timedCodesMissingMinutes)}.");
        }

        var missingSuggestedModifiers = Vm.SelectedCptCodes
            .Where(entry => entry.SuggestedModifiers.Any(suggested => !entry.Modifiers.Contains(suggested, StringComparer.OrdinalIgnoreCase)))
            .Select(entry => entry.Code)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        if (missingSuggestedModifiers.Count > 0)
        {
            advisories.Add($"Review suggested modifiers before billing: {string.Join(", ", missingSuggestedModifiers)}.");
        }

        return advisories;
    }

    private static int ResolveDefaultUnits(string code) =>
        KnownTimedCptCodes.Codes.Contains(code) ? 2 : 1;

    private Task HandleCustomizeCptAsync()
    {
        // Reserved for a future CPT customization dialog.
        return Task.CompletedTask;
    }

    private async Task HandleAiSuggestDischargeAsync()
    {
        if (IsReadOnly) return;
        _isGeneratingDischarge = true;
        _errorMessage = null;
        StateHasChanged();
        try
        {
            var result = await AiService.GeneratePlanOfCareAsync(BuildPlanRequest());
            if (!result.Success)
            {
                _errorMessage = result.ErrorMessage ?? "Unable to generate discharge planning guidance.";
                return;
            }

            var suggestion = result.GeneratedText;
            if (_dischargePlanningBox is not null)
            {
                await _dischargePlanningBox.LoadAiSuggestionAsync(suggestion);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Discharge plan generation failed for note {NoteId}", NoteId);
            _errorMessage = "Unable to generate discharge planning guidance.";
        }
        finally { _isGeneratingDischarge = false; }
    }

    private async Task HandleAiSuggestFollowUpAsync()
    {
        if (IsReadOnly) return;
        _isGeneratingFollowUp = true;
        _errorMessage = null;
        StateHasChanged();
        try
        {
            var result = await AiService.GeneratePlanOfCareAsync(BuildPlanRequest());
            if (!result.Success)
            {
                _errorMessage = result.ErrorMessage ?? "Unable to generate follow-up instructions.";
                return;
            }

            var suggestion = result.GeneratedText;
            if (_followUpBox is not null)
            {
                await _followUpBox.LoadAiSuggestionAsync(suggestion);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Follow-up generation failed for note {NoteId}", NoteId);
            _errorMessage = "Unable to generate follow-up instructions.";
        }
        finally { _isGeneratingFollowUp = false; }
    }

    private async Task HandleGenerateSummaryAsync()
    {
        if (IsReadOnly) return;
        _isGeneratingSummary = true;
        _errorMessage = null;
        StateHasChanged();
        try
        {
            var result = await AiService.GeneratePlanOfCareAsync(BuildPlanRequest());
            if (!result.Success)
            {
                _errorMessage = result.ErrorMessage ?? "Unable to generate a clinical summary.";
                return;
            }

            var suggestion = result.GeneratedText;
            if (_clinicalSummaryBox is not null)
            {
                await _clinicalSummaryBox.LoadAiSuggestionAsync(suggestion);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Clinical summary generation failed for note {NoteId}", NoteId);
            _errorMessage = "Unable to generate a clinical summary.";
        }
        finally { _isGeneratingSummary = false; }
    }

    private Task HandleDischargeAcceptedAsync(string acceptedText) =>
        SetAndNotify(vm => vm.DischargePlanningNotes = acceptedText);

    private Task HandleFollowUpAcceptedAsync(string acceptedText) =>
        SetAndNotify(vm => vm.FollowUpInstructions = acceptedText);

    private async Task HandleClinicalSummaryAcceptedAsync(string acceptedText)
    {
        if (NoteId != Guid.Empty)
        {
            var acceptance = await NoteWorkspaceService.AcceptAiSuggestionAsync(
                NoteId,
                section: "plan",
                generatedText: acceptedText,
                generationType: "ClinicalSummary");

            if (!acceptance.Success)
            {
                _errorMessage = acceptance.ErrorMessage ?? "Unable to accept AI-generated summary content.";
                return;
            }
        }

        await SetAndNotify(vm => vm.ClinicalSummary = acceptedText);
        _errorMessage = null;
    }

    private PlanOfCareGenerationRequest BuildPlanRequest()
    {
        return new PlanOfCareGenerationRequest
        {
            NoteId = NoteId,
            Diagnosis = string.IsNullOrWhiteSpace(DiagnosisSummary)
                ? "Physical therapy plan of care"
                : DiagnosisSummary!,
            AssessmentSummary = AssessmentSummary,
            Goals = GoalsSummary,
            Precautions = PrecautionsSummary,
            IsNoteSigned = IsReadOnly
        };
    }

    public void Dispose()
    {
        _cptSearchCts?.Cancel();
        _cptSearchCts?.Dispose();
    }
}
