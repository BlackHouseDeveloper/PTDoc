@using System.ComponentModel.DataAnnotations
@using System.Globalization
@using System.Text.Json
@inject IJSRuntime JS
@implements IAsyncDisposable

@if (IsOpen)
{
    <div class="modal-overlay" @onclick="HandleOverlayClick" @onclick:stopPropagation="false">
        <div id="@modalId" class="modal-container" @ref="modalContainerRef" @onclick:stopPropagation="true" role="dialog"
             aria-labelledby="modal-title" aria-describedby="modal-description" aria-modal="true">
            
            <!-- Modal Header -->
            <div class="modal-header">
                <div class="modal-title-container">
                    <svg class="modal-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M10 5V15M5 10H15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        <circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="2"/>
                    </svg>
                    <h2 id="modal-title">Add New Patient</h2>
                </div>
                <p id="modal-description" class="modal-description">Create a new patient profile to begin treatment</p>
            </div>

            <!-- Modal Body -->
            <form class="modal-body" novalidate @onsubmit="() => HandleSubmit(PatientSubmitIntent.AddPatient)" @onsubmit:preventDefault="true">
                @if (ValidationErrors.Count > 0)
                {
                    <div id="@ValidationSummaryId" class="form-error form-validation-summary" role="alert" aria-live="assertive">
                        <strong>Review required patient details.</strong>
                        <ul>
                            @foreach (var error in ValidationErrors.Values)
                            {
                                <li>@error</li>
                            }
                        </ul>
                    </div>
                }

                <!-- First Name & Last Name Row -->
                <div class="form-row">
                    <div class="form-field">
                        <label for="firstName" class="form-label">First Name <span class="required">*</span></label>
                        <input 
                            id="firstName" 
                            type="text" 
                            class="form-input" 
                            placeholder="John"
                            @bind="FirstName"
                            @ref="firstInputRef"
                            required 
                            aria-required="true"
                            aria-invalid="@AriaInvalid(nameof(FirstName))"
                            aria-describedby="@GetFieldDescribedBy(nameof(FirstName))" />
                        @if (TryGetFieldError(nameof(FirstName), out var firstNameError))
                        {
                            <p id="@GetFieldErrorId(nameof(FirstName))" class="field-error" role="alert">@firstNameError</p>
                        }
                    </div>
                    <div class="form-field">
                        <label for="lastName" class="form-label">Last Name <span class="required">*</span></label>
                        <input 
                            id="lastName" 
                            type="text" 
                            class="form-input" 
                            placeholder="Doe"
                            @bind="LastName"
                            required 
                            aria-required="true"
                            aria-invalid="@AriaInvalid(nameof(LastName))"
                            aria-describedby="@GetFieldDescribedBy(nameof(LastName))" />
                        @if (TryGetFieldError(nameof(LastName), out var lastNameError))
                        {
                            <p id="@GetFieldErrorId(nameof(LastName))" class="field-error" role="alert">@lastNameError</p>
                        }
                    </div>
                </div>

                <!-- Email Address -->
                <div class="form-field">
                    <label for="email" class="form-label">Email Address <span class="required">*</span></label>
                    <input 
                        id="email" 
                        type="email" 
                        class="form-input" 
                        placeholder="john.doe@example.com"
                        @bind="Email"
                        required 
                        aria-required="true"
                        aria-invalid="@AriaInvalid(nameof(Email))"
                        aria-describedby="@GetFieldDescribedBy(nameof(Email))" />
                    @if (TryGetFieldError(nameof(Email), out var emailError))
                    {
                        <p id="@GetFieldErrorId(nameof(Email))" class="field-error" role="alert">@emailError</p>
                    }
                </div>

                <!-- Phone Number -->
                <div class="form-field">
                    <label for="phone" class="form-label">Phone Number</label>
                    <input 
                        id="phone" 
                        type="tel" 
                        class="form-input" 
                        placeholder="(555) 123-4567"
                        @bind="PhoneNumber" />
                </div>

                <!-- Date of Birth -->
                <div class="form-field">
                    <label for="dob" class="form-label">Date of Birth <span class="required">*</span></label>
                    <input 
                        id="dob" 
                        type="date" 
                        class="form-input" 
                        value="@DateOfBirthInput"
                        autocomplete="bday"
                        @oninput="OnDateOfBirthChanged"
                        @onchange="OnDateOfBirthChanged"
                        required
                        aria-required="true"
                        aria-invalid="@AriaInvalid(nameof(DateOfBirth))"
                        aria-describedby="@GetFieldDescribedBy(nameof(DateOfBirth))" />
                    @if (TryGetFieldError(nameof(DateOfBirth), out var dateOfBirthError))
                    {
                        <p id="@GetFieldErrorId(nameof(DateOfBirth))" class="field-error" role="alert">@dateOfBirthError</p>
                    }
                </div>

                <section class="form-section" aria-labelledby="patient-payer-section-title">
                    <div class="form-section-header">
                        <h3 id="patient-payer-section-title">Insurance</h3>
                        <p>Optional payer details can be completed now or updated later in Patient &amp; Payer Information.</p>
                    </div>

                    <div class="form-row">
                        <div class="form-field">
                            <label for="primaryInsuranceCompany" class="form-label">Primary Insurance</label>
                            <input id="primaryInsuranceCompany"
                                   type="text"
                                   class="form-input"
                                   placeholder="Insurance company"
                                   @bind="PrimaryInsuranceCompany" />
                        </div>
                        <div class="form-field">
                            <label for="primaryMemberId" class="form-label">Primary Member ID / Policy #</label>
                            <input id="primaryMemberId"
                                   type="text"
                                   class="form-input"
                                   placeholder="Member or policy number"
                                   @bind="PrimaryMemberId" />
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-field">
                            <label for="secondaryInsuranceCompany" class="form-label">Secondary Insurance</label>
                            <input id="secondaryInsuranceCompany"
                                   type="text"
                                   class="form-input"
                                   placeholder="Insurance company"
                                   @bind="SecondaryInsuranceCompany" />
                        </div>
                        <div class="form-field">
                            <label for="secondaryMemberId" class="form-label">Secondary Member ID / Policy #</label>
                            <input id="secondaryMemberId"
                                   type="text"
                                   class="form-input"
                                   placeholder="Member or policy number"
                                   @bind="SecondaryMemberId" />
                        </div>
                    </div>
                </section>

                <section class="form-section" aria-labelledby="patient-referral-section-title">
                    <div class="form-section-header">
                        <h3 id="patient-referral-section-title">Referral &amp; Authorization</h3>
                        <p>Optional PCP, referring physician, and authorization details for the chart.</p>
                    </div>

                    <div class="form-row">
                        <div class="form-field">
                            <label for="primaryCareProvider" class="form-label">Primary Care Provider</label>
                            <input id="primaryCareProvider"
                                   type="text"
                                   class="form-input"
                                   placeholder="PCP name"
                                   @bind="PrimaryCareProvider" />
                        </div>
                        <div class="form-field">
                            <label for="referringPhysician" class="form-label">Referring Physician</label>
                            <input id="referringPhysician"
                                   type="text"
                                   class="form-input"
                                   placeholder="Referring physician name"
                                   @bind="ReferringPhysician" />
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-field">
                            <label for="physicianNpi" class="form-label">Physician NPI</label>
                            <input id="physicianNpi"
                                   type="text"
                                   inputmode="numeric"
                                   maxlength="10"
                                   class="form-input"
                                   placeholder="10-digit NPI"
                                   @bind="PhysicianNpi"
                                   aria-invalid="@AriaInvalid(nameof(PhysicianNpi))"
                                   aria-describedby="@GetFieldDescribedBy(nameof(PhysicianNpi))" />
                            @if (TryGetFieldError(nameof(PhysicianNpi), out var physicianNpiError))
                            {
                                <p id="@GetFieldErrorId(nameof(PhysicianNpi))" class="field-error" role="alert">@physicianNpiError</p>
                            }
                        </div>
                        <div class="form-field">
                            <label for="authorizationRequired" class="form-label">Authorization Required?</label>
                            <select id="authorizationRequired"
                                    class="form-input"
                                    @bind="AuthorizationRequired">
                                <option value="">Unknown</option>
                                <option value="Yes">Yes</option>
                                <option value="No">No</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-field">
                        <label for="authorizationNumber" class="form-label">Authorization Number</label>
                        <input id="authorizationNumber"
                               type="text"
                               class="form-input"
                               placeholder="Authorization number"
                               @bind="AuthorizationNumber" />
                    </div>
                </section>

                @if (!string.IsNullOrWhiteSpace(SubmitError))
                {
                    <div class="form-error" role="alert">@SubmitError</div>
                }

                <!-- Info Box -->
                <div class="info-box" role="note">
                    <p><strong>Note:</strong> Use Add Patient + Send Intake to open the intake invite workflow after creating the patient.</p>
                </div>

                <!-- Modal Footer (Buttons) -->
                <div class="modal-footer">
                    <button type="button" class="btn-cancel" @onclick="Close" disabled="@IsSubmitting">
                        Cancel
                    </button>
                    <button type="submit" class="btn-secondary" disabled="@IsSubmitting" aria-busy="@IsSubmitting">
                        @(IsSubmitting && ActiveSubmitIntent == PatientSubmitIntent.AddPatient ? "Adding..." : "Add Patient")
                    </button>
                    <button type="button"
                            class="btn-primary"
                            disabled="@IsSubmitting"
                            aria-busy="@IsSubmitting"
                            @onclick="() => HandleSubmit(PatientSubmitIntent.AddPatientAndSendIntake)">
                        <svg class="btn-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                            <path d="M8 3V13M3 8H13" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            <circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1"/>
                        </svg>
                        @(IsSubmitting && ActiveSubmitIntent == PatientSubmitIntent.AddPatientAndSendIntake ? "Adding..." : "Add Patient + Send Intake")
                    </button>
                </div>
            </form>

            <!-- Close Button -->
            <button type="button" class="modal-close" @onclick="Close" aria-label="Close modal" disabled="@IsSubmitting">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M12 4L4 12M4 4L12 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </button>
        </div>
    </div>
}

@code {
    [Parameter]
    public bool IsOpen { get; set; }

    [Parameter]
    public EventCallback<bool> IsOpenChanged { get; set; }

    [Parameter]
    public Func<PatientFormData, Task<bool>>? OnSubmit { get; set; }

    private ElementReference firstInputRef;
    private ElementReference modalContainerRef;
    private IJSObjectReference? modalModule;
    private DotNetObjectReference<AddPatientModal>? dotNetRef;
    private string modalId = $"modal-{Guid.NewGuid():N}";
    private string ValidationSummaryId => $"{modalId}-validation-summary";
    private bool _isModalActive;

    private string FirstName { get; set; } = string.Empty;
    private string LastName { get; set; } = string.Empty;
    private string Email { get; set; } = string.Empty;
    private string PhoneNumber { get; set; } = string.Empty;
    private string DateOfBirthInput { get; set; } = string.Empty;
    private DateTime? DateOfBirth { get; set; }
    private string PrimaryInsuranceCompany { get; set; } = string.Empty;
    private string PrimaryMemberId { get; set; } = string.Empty;
    private string SecondaryInsuranceCompany { get; set; } = string.Empty;
    private string SecondaryMemberId { get; set; } = string.Empty;
    private string PrimaryCareProvider { get; set; } = string.Empty;
    private string ReferringPhysician { get; set; } = string.Empty;
    private string PhysicianNpi { get; set; } = string.Empty;
    private string AuthorizationRequired { get; set; } = string.Empty;
    private string AuthorizationNumber { get; set; } = string.Empty;
    private string? SubmitError { get; set; }
    private bool IsSubmitting { get; set; }
    private PatientSubmitIntent? ActiveSubmitIntent { get; set; }
    private Dictionary<string, string> ValidationErrors { get; } = new(StringComparer.Ordinal);
    private static readonly EmailAddressAttribute EmailValidator = new();
    private static readonly JsonSerializerOptions PayerJsonOptions = new()
    {
        PropertyNamingPolicy = JsonNamingPolicy.CamelCase
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (modalModule is null || dotNetRef is null)
        {
            try
            {
                modalModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "./_content/PTDoc.UI/js/modal.js");
                dotNetRef ??= DotNetObjectReference.Create(this);
            }
            catch (Exception ex) when (IsExpectedJsCancellation(ex))
            {
            }
            catch (Exception ex)
            {
                LogSafeException("LoadModalModule", ex);
            }
        }

        if (IsOpen && !_isModalActive && modalModule != null && dotNetRef != null)
        {
            var shouldCleanupPartialActivation = false;
            try
            {
                // Lock body scroll
                await modalModule.InvokeVoidAsync("lockBodyScroll");
                shouldCleanupPartialActivation = true;
                
                // Register ESC key handler
                await modalModule.InvokeVoidAsync("registerEscapeHandler", modalId, dotNetRef);
                
                // Focus first input
                await firstInputRef.FocusAsync();

                _isModalActive = true;
            }
            catch (Exception ex) when (IsExpectedJsCancellation(ex))
            {
                _isModalActive = false;
                if (shouldCleanupPartialActivation)
                {
                    await CleanupModalInteropAsync(logErrors: false);
                }
            }
            catch (Exception ex)
            {
                _isModalActive = false;
                if (shouldCleanupPartialActivation)
                {
                    await CleanupModalInteropAsync(logErrors: false);
                }

                LogSafeException("ModalInterop", ex);
            }
        }
        else if (!IsOpen && _isModalActive && modalModule != null)
        {
            _isModalActive = false;
            await CleanupModalInteropAsync(logErrors: true);
        }
        else if (!IsOpen)
        {
            _isModalActive = false;
        }
    }

    [JSInvokable]
    public async Task CloseFromJs()
    {
        await Close();
    }

    private async Task Close()
    {
        if (IsSubmitting)
        {
            return;
        }

        IsOpen = false;
        await IsOpenChanged.InvokeAsync(false);
        
        // Clear form
        FirstName = string.Empty;
        LastName = string.Empty;
        Email = string.Empty;
        PhoneNumber = string.Empty;
        DateOfBirthInput = string.Empty;
        DateOfBirth = null;
        PrimaryInsuranceCompany = string.Empty;
        PrimaryMemberId = string.Empty;
        SecondaryInsuranceCompany = string.Empty;
        SecondaryMemberId = string.Empty;
        PrimaryCareProvider = string.Empty;
        ReferringPhysician = string.Empty;
        PhysicianNpi = string.Empty;
        AuthorizationRequired = string.Empty;
        AuthorizationNumber = string.Empty;
        SubmitError = null;
        ValidationErrors.Clear();
    }

    private void HandleOverlayClick()
    {
        // Close modal when clicking overlay
        _ = Close();
    }

    private async Task HandleSubmit(PatientSubmitIntent submitIntent)
    {
        SubmitError = null;
        ValidationErrors.Clear();
        DateOfBirth = ParseDateOfBirthInput(DateOfBirthInput);

        ValidateRequiredFields();
        if (ValidationErrors.Count > 0)
        {
            return;
        }

        if (OnSubmit is null)
        {
            SubmitError = "Patient creation is not available right now.";
            return;
        }

        var formData = new PatientFormData
        {
            FirstName = FirstName.Trim(),
            LastName = LastName.Trim(),
            Email = Email.Trim(),
            PhoneNumber = PhoneNumber.Trim(),
            DateOfBirth = DateOfBirth,
            PrimaryInsuranceCompany = PrimaryInsuranceCompany.Trim(),
            PrimaryMemberId = PrimaryMemberId.Trim(),
            SecondaryInsuranceCompany = SecondaryInsuranceCompany.Trim(),
            SecondaryMemberId = SecondaryMemberId.Trim(),
            PrimaryCareProvider = PrimaryCareProvider.Trim(),
            ReferringPhysician = ReferringPhysician.Trim(),
            PhysicianNpi = PhysicianNpi.Trim(),
            AuthorizationRequired = AuthorizationRequired.Trim(),
            AuthorizationNumber = AuthorizationNumber.Trim(),
            PayerInfoJson = BuildPayerInfoJson(),
            SubmitIntent = submitIntent
        };

        IsSubmitting = true;
        ActiveSubmitIntent = submitIntent;
        try
        {
            var succeeded = await OnSubmit.Invoke(formData);
            if (succeeded)
            {
                IsSubmitting = false;
                await Close();
                return;
            }

            SubmitError = "The patient was not created. Review the details and try again.";
        }
        catch (Exception ex)
        {
            SubmitError = "The patient was not created. Review the details and try again.";
            LogSafeException("Submit", ex);
        }
        finally
        {
            IsSubmitting = false;
            ActiveSubmitIntent = null;
        }
    }

    private void OnDateOfBirthChanged(ChangeEventArgs args)
    {
        DateOfBirthInput = args.Value?.ToString() ?? string.Empty;
        DateOfBirth = ParseDateOfBirthInput(DateOfBirthInput);

        if (DateOfBirth.HasValue)
        {
            ValidationErrors.Remove(nameof(DateOfBirth));
        }
    }

    private void ValidateRequiredFields()
    {
        if (string.IsNullOrWhiteSpace(FirstName))
        {
            ValidationErrors[nameof(FirstName)] = "First name is required.";
        }

        if (string.IsNullOrWhiteSpace(LastName))
        {
            ValidationErrors[nameof(LastName)] = "Last name is required.";
        }

        if (string.IsNullOrWhiteSpace(Email))
        {
            ValidationErrors[nameof(Email)] = "Email address is required.";
        }
        else if (!EmailValidator.IsValid(Email.Trim()))
        {
            ValidationErrors[nameof(Email)] = "Enter a valid email address.";
        }

        if (string.IsNullOrWhiteSpace(DateOfBirthInput))
        {
            ValidationErrors[nameof(DateOfBirth)] = "Date of birth is required.";
        }
        else if (!DateOfBirth.HasValue)
        {
            ValidationErrors[nameof(DateOfBirth)] = "Enter a valid date of birth.";
        }

        var trimmedNpi = PhysicianNpi.Trim();
        if (!string.IsNullOrWhiteSpace(trimmedNpi) && (trimmedNpi.Length != 10 || !trimmedNpi.All(char.IsDigit)))
        {
            ValidationErrors[nameof(PhysicianNpi)] = "Physician NPI must be exactly 10 digits.";
        }
    }

    private string BuildPayerInfoJson()
    {
        var hasPayerInfo =
            HasValue(PrimaryInsuranceCompany) ||
            HasValue(PrimaryMemberId) ||
            HasValue(SecondaryInsuranceCompany) ||
            HasValue(SecondaryMemberId) ||
            HasValue(PrimaryCareProvider) ||
            HasValue(ReferringPhysician) ||
            HasValue(PhysicianNpi) ||
            HasValue(AuthorizationRequired) ||
            HasValue(AuthorizationNumber);

        if (!hasPayerInfo)
        {
            return "{}";
        }

        var normalizedAuthorizationRequired = TrimOrNull(AuthorizationRequired);
        var payload = new
        {
            InsuranceCompanyName = TrimOrNull(PrimaryInsuranceCompany),
            MemberOrPolicyNumber = TrimOrNull(PrimaryMemberId),
            MemberIdPolicyNumber = TrimOrNull(PrimaryMemberId),
            InsurancePriority = HasValue(PrimaryInsuranceCompany) || HasValue(PrimaryMemberId) ? "primary" : null,
            SecondaryInsuranceCompanyName = TrimOrNull(SecondaryInsuranceCompany),
            SecondaryMemberIdPolicyNumber = TrimOrNull(SecondaryMemberId),
            PrimaryCareProviderName = TrimOrNull(PrimaryCareProvider),
            ReferringPhysicianName = TrimOrNull(ReferringPhysician),
            PhysicianNpiNumber = TrimOrNull(PhysicianNpi),
            AuthorizationRequired = normalizedAuthorizationRequired,
            AuthorizationStatus = normalizedAuthorizationRequired == "Yes" ? "pending" : null,
            AuthorizationNumber = TrimOrNull(AuthorizationNumber)
        };

        return JsonSerializer.Serialize(payload, PayerJsonOptions);
    }

    private static bool HasValue(string? value) => !string.IsNullOrWhiteSpace(value);

    private static string? TrimOrNull(string? value)
        => string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    private static DateTime? ParseDateOfBirthInput(string? rawValue)
    {
        if (string.IsNullOrWhiteSpace(rawValue))
        {
            return null;
        }

        if (DateTime.TryParseExact(rawValue, "yyyy-MM-dd", CultureInfo.InvariantCulture, DateTimeStyles.None, out var exactDate))
        {
            return exactDate.Date;
        }

        return null;
    }

    private bool TryGetFieldError(string fieldName, out string error)
        => ValidationErrors.TryGetValue(fieldName, out error!);

    private string AriaInvalid(string fieldName)
        => ValidationErrors.ContainsKey(fieldName) ? "true" : "false";

    private string GetFieldErrorId(string fieldName)
        => $"{modalId}-{fieldName.ToLowerInvariant()}-error";

    private string? GetFieldDescribedBy(string fieldName)
    {
        if (!ValidationErrors.ContainsKey(fieldName))
        {
            return null;
        }

        return $"{ValidationSummaryId} {GetFieldErrorId(fieldName)}";
    }

    private static bool IsExpectedJsCancellation(Exception exception)
        => exception is OperationCanceledException or Microsoft.JSInterop.JSDisconnectedException;

    private async Task CleanupModalInteropAsync(bool logErrors)
    {
        if (modalModule is null)
        {
            return;
        }

        try
        {
            // Unlock body scroll
            await modalModule.InvokeVoidAsync("unlockBodyScroll");

            // Unregister ESC handler
            await modalModule.InvokeVoidAsync("unregisterEscapeHandler", modalId);
        }
        catch (Exception ex) when (IsExpectedJsCancellation(ex))
        {
        }
        catch (Exception ex)
        {
            if (logErrors)
            {
                LogSafeException("ModalCleanup", ex);
            }
        }
    }

    private static void LogSafeException(string operation, Exception exception)
        => Console.WriteLine($"[AddPatientModal] {operation} error type: {exception.GetType().Name}");

    public async ValueTask DisposeAsync()
    {
        // Clean up JS interop
        if (modalModule != null)
        {
            try
            {
                await modalModule.InvokeVoidAsync("unlockBodyScroll");
                await modalModule.InvokeVoidAsync("unregisterEscapeHandler", modalId);
                await modalModule.DisposeAsync();
            }
            catch { /* Ignore disposal errors */ }
        }

        dotNetRef?.Dispose();
    }

    public enum PatientSubmitIntent
    {
        AddPatient,
        AddPatientAndSendIntake
    }

    public class PatientFormData
    {
        public string FirstName { get; set; } = string.Empty;
        public string LastName { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string PhoneNumber { get; set; } = string.Empty;
        public DateTime? DateOfBirth { get; set; }
        public string PrimaryInsuranceCompany { get; set; } = string.Empty;
        public string PrimaryMemberId { get; set; } = string.Empty;
        public string SecondaryInsuranceCompany { get; set; } = string.Empty;
        public string SecondaryMemberId { get; set; } = string.Empty;
        public string PrimaryCareProvider { get; set; } = string.Empty;
        public string ReferringPhysician { get; set; } = string.Empty;
        public string PhysicianNpi { get; set; } = string.Empty;
        public string AuthorizationRequired { get; set; } = string.Empty;
        public string AuthorizationNumber { get; set; } = string.Empty;
        public string PayerInfoJson { get; set; } = "{}";
        public PatientSubmitIntent SubmitIntent { get; set; } = PatientSubmitIntent.AddPatient;
    }
}
