@namespace PTDoc.UI.Components
@using System.Reflection
@using PTDoc.UI.Components.Intake
@using PTDoc.UI.Components.Layout
@using PTDoc.UI.Pages
@using PTDoc.UI.Pages.Intake
@implements IDisposable
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ILogger<Routes> Logger

<Router AppAssembly="@typeof(Routes).Assembly" AdditionalAssemblies="@resolvedAdditionalAssemblies">
    <Found Context="routeData">
        @if (ShouldUseStandaloneIntakeLayout(routeData))
        {
            <StandaloneIntakeAccessGate>
                <RouteView RouteData="@routeData" DefaultLayout="@typeof(StandaloneIntakeLayout)" />
            </StandaloneIntakeAccessGate>
        }
        else
        {
            <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)">
                <Authorizing>
                    <p>Loading...</p>
                </Authorizing>
                <NotAuthorized>
                    @if (isAuthenticated)
                    {
                        <RedirectToAccessDenied />
                    }
                    else
                    {
                        <RedirectToLogin />
                    }
                </NotAuthorized>
            </AuthorizeRouteView>
        }
    </Found>

    <NotFound>
        <LayoutView Layout="@typeof(MainLayout)">
            <section class="not-found-page" aria-labelledby="router-not-found-title">
                <div class="not-found-page__panel">
                    <p class="not-found-page__eyebrow">404</p>
                    <h1 id="router-not-found-title">Page not found</h1>
                    <p>The page you requested is not available in PTDoc.</p>
                </div>
            </section>
        </LayoutView>
    </NotFound>
</Router>

@code {
    private bool isAuthenticated;
    private IReadOnlyList<Assembly>? resolvedAdditionalAssemblies;

    protected override async Task OnInitializedAsync()
    {
        resolvedAdditionalAssemblies = ResolveAdditionalAssemblies();
        AuthenticationStateProvider.AuthenticationStateChanged += OnAuthenticationStateChanged;

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        isAuthenticated = authState.User.Identity?.IsAuthenticated == true;
    }

    private void OnAuthenticationStateChanged(Task<AuthenticationState> authStateTask)
    {
        _ = HandleAuthenticationStateChangedAsync(authStateTask);
    }

    private async Task HandleAuthenticationStateChangedAsync(Task<AuthenticationState> authStateTask)
    {
        try
        {
            var authState = await authStateTask;
            isAuthenticated = authState.User.Identity?.IsAuthenticated == true;
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Authentication state change handler failed.");
        }
    }

    private bool ShouldUseStandaloneIntakeLayout(RouteData routeData)
    {
        if (routeData.PageType != typeof(IntakeWizardPage))
        {
            return false;
        }

        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        var query = uri.Query;
        var isPatientQueryMode = query.Contains("mode=patient", StringComparison.OrdinalIgnoreCase);

        return isPatientQueryMode || !isAuthenticated;
    }

    public void Dispose()
    {
        AuthenticationStateProvider.AuthenticationStateChanged -= OnAuthenticationStateChanged;
    }

    private static IReadOnlyList<Assembly>? ResolveAdditionalAssemblies()
    {
        var appAssembly = Assembly.GetEntryAssembly();
        if (appAssembly is null || appAssembly == typeof(Routes).Assembly)
        {
            return null;
        }

        return [appAssembly];
    }
}
