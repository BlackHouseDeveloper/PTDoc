@* Export Options Panel
    Purpose: Hosts export options that depend on Format selection
    Subcomponents:
    - PasswordProtectToggleRow: Label + toggle switch (disabled when Format != PDF)
    - PasswordInput: Conditional (appears only when Format == PDF AND toggle is ON)
    
    States & conditional logic:
    - If Format != PDF:
      - Toggle is disabled
      - Password input is hidden
    - Toggle ON:
      - Reveal password input immediately
    - Toggle OFF:
      - Clear stored password value
      - Hide password input
    
    Data behavior: Store password in memory only; do not persist across sessions
    Password is currently an in-memory UI option used for PDF export flow scaffolding.
*@

<div class="export-options-panel">
    <h3 class="export-options-panel__title">Export Options</h3>
    
    <div class="export-options-panel__content">
        <!-- Password Protect Toggle -->
        <div class="export-options-panel__section">
            <div class="password-protect-row">
                <span class="password-protect-row__icon" aria-hidden="true">
                    <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <rect x="4" y="8" width="10" height="7" rx="1.5" stroke="currentColor" stroke-width="1.5"/>
                        <path d="M6.5 8V6.5a2.5 2.5 0 1 1 5 0V8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                    </svg>
                </span>
                
                <label class="password-protect-row__label">
                    <span class="password-protect-row__text">Password-protect PDF</span>
                    
                    <input
                        type="checkbox"
                        class="password-protect-row__toggle"
                        checked="@State.IsPasswordProtected"
                        @onchange="@((ChangeEventArgs e) => TogglePasswordProtect((bool)e!.Value!))"
                        disabled="@(SelectedFormat != ExportFormat.PDF)"
                        aria-label="Password-protect PDF" />
                    
                    <span class="toggle-switch" aria-hidden="true"></span>
                </label>
            </div>
        </div>
        
        <!-- Conditional Password Input -->
        @if (SelectedFormat == ExportFormat.PDF && State.IsPasswordProtected)
        {
            <div class="export-options-panel__section">
                <label for="@PasswordInputId" class="export-options-panel__password-label">Password</label>
                
                <input
                    id="@PasswordInputId"
                    type="password"
                    class="export-options-panel__password-input"
                    placeholder="Enter a password"
                    @bind="State.PasswordValue"
                    @bind:event="oninput"
                    minlength="6"
                    aria-label="Password" />
                
                @if (!IsPasswordValid())
                {
                    <div class="export-options-panel__password-hint" role="alert">
                        Password must be at least 6 characters
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    [Parameter]
    [EditorRequired]
    public ExportFormat SelectedFormat { get; set; } = ExportFormat.PDF;

    [Parameter]
    [EditorRequired]
    public ExportDraftState State { get; set; } = new();

    [Parameter]
    public EventCallback StateChanged { get; set; }

    private string PasswordInputId { get; } = $"password-input-{Guid.NewGuid()}";

    private void TogglePasswordProtect(bool isProtected)
    {
        State.IsPasswordProtected = isProtected;
        
        // Clear password if toggle is off
        if (!isProtected)
        {
            State.PasswordValue = string.Empty;
        }

        StateChanged.InvokeAsync();
    }

    private bool IsPasswordValid()
    {
        // If not attempting to protect, consider valid
        if (!State.IsPasswordProtected)
            return true;

        // If protecting, password must be at least 6 chars
        return State.PasswordValue.Length >= 6;
    }
}
