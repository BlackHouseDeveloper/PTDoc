<div class="providers-dropdown">
    <label for="@DropdownId" class="providers-dropdown__label">Providers</label>

    <button
        id="@DropdownId"
        class="providers-dropdown__trigger"
        @onclick="ToggleOpen"
        type="button"
        aria-expanded="@IsOpen"
        aria-haspopup="listbox">
        <span class="providers-dropdown__display">
            @if (SelectedProviderIds.Count == 0)
            {
                <span>All providers</span>
            }
            else if (SelectedProviderIds.Count == 1)
            {
                <span>@GetSelectedLabel(SelectedProviderIds[0])</span>
            }
            else
            {
                <span>@SelectedProviderIds.Count selected</span>
            }
        </span>

        <span class="providers-dropdown__icon" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M3.5 5.5L7 9L10.5 5.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        </span>
    </button>

    @if (IsOpen)
    {
        <div class="providers-dropdown__menu" role="listbox">
            <div class="providers-dropdown__search">
                <input
                    type="text"
                    class="providers-dropdown__search-input"
                    placeholder="Search providers..."
                    @bind="SearchQuery"
                    @bind:event="oninput"
                    aria-label="Search providers" />
            </div>

            <div class="providers-dropdown__list">
                @if (GetFilteredProviders().Count == 0)
                {
                    <div class="providers-dropdown__empty">No providers match the current search.</div>
                }
                else
                {
                    @foreach (var provider in GetFilteredProviders())
                    {
                        var isSelected = SelectedProviderIds.Contains(provider.Id);
                        <label class="providers-dropdown__option">
                            <input
                                type="checkbox"
                                class="providers-dropdown__checkbox"
                                checked="@isSelected"
                                @onchange="@((ChangeEventArgs e) => ToggleProvider(provider.Id, (bool)e!.Value!))"
                                aria-label="@provider.Label" />
                            <span class="providers-dropdown__option-label">@provider.Label</span>
                        </label>
                    }
                }
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public List<string> SelectedProviderIds { get; set; } = new();

    [Parameter]
    public EventCallback<List<string>> SelectedProviderIdsChanged { get; set; }

    [Parameter]
    public IReadOnlyList<ExportCenterSelectableItem> Providers { get; set; } = Array.Empty<ExportCenterSelectableItem>();

    private string DropdownId { get; } = $"providers-dropdown-{Guid.NewGuid()}";
    private bool IsOpen { get; set; }
    private string SearchQuery { get; set; } = string.Empty;

    private void ToggleOpen()
    {
        IsOpen = !IsOpen;
    }

    private Task ToggleProvider(string providerId, bool isSelected)
    {
        var next = SelectedProviderIds.ToList();

        if (isSelected && !next.Contains(providerId))
        {
            next.Add(providerId);
        }
        else if (!isSelected && next.Contains(providerId))
        {
            next.Remove(providerId);
        }

        return SelectedProviderIdsChanged.InvokeAsync(next);
    }

    private IReadOnlyList<ExportCenterSelectableItem> GetFilteredProviders()
    {
        if (string.IsNullOrWhiteSpace(SearchQuery))
        {
            return Providers;
        }

        var query = SearchQuery.Trim();
        return Providers
            .Where(provider => provider.Label.Contains(query, StringComparison.OrdinalIgnoreCase))
            .ToList();
    }

    private string GetSelectedLabel(string providerId)
    {
        return Providers.FirstOrDefault(provider => string.Equals(provider.Id, providerId, StringComparison.OrdinalIgnoreCase))?.Label
            ?? "Unknown provider";
    }
}
