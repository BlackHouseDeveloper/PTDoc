@* Providers Dropdown (Multi-select)
    Label "Providers"
    Multi-select dropdown
    Same display rules as Patients dropdown
    TODO: Populate options from service
*@

<div class="providers-dropdown">
    <label for="@DropdownId" class="providers-dropdown__label">Providers</label>
    
    <button
        id="@DropdownId"
        class="providers-dropdown__trigger"
        @onclick="ToggleOpen"
        type="button"
        aria-expanded="@IsOpen"
        aria-haspopup="listbox">
        
        <span class="providers-dropdown__display">
            @if (SelectedProviderIds.Count == 0)
            {
                <span>All providers</span>
            }
            else if (SelectedProviderIds.Count == 1)
            {
                <span>@GetProviderLabel(SelectedProviderIds[0])</span>
            }
            else
            {
                <span>@SelectedProviderIds.Count selected</span>
            }
        </span>
        
        <span class="providers-dropdown__icon" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M3.5 5.5L7 9L10.5 5.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        </span>
    </button>
    
    @if (IsOpen)
    {
        <div class="providers-dropdown__menu" role="listbox">
            <div class="providers-dropdown__search">
                <input
                    type="text"
                    class="providers-dropdown__search-input"
                    placeholder="Search providers..."
                    @bind="SearchQuery"
                    @bind:event="oninput"
                    aria-label="Search providers" />
            </div>
            
            <div class="providers-dropdown__list">
                @foreach (var (id, name) in GetFilteredProviders())
                {
                    var isSelected = SelectedProviderIds.Contains(id);
                    <label class="providers-dropdown__option">
                        <input
                            type="checkbox"
                            class="providers-dropdown__checkbox"
                            checked="@isSelected"
                            @onchange="@((ChangeEventArgs e) => ToggleProvider(id, (bool)e!.Value!))"
                            aria-label="@name" />
                        <span class="providers-dropdown__option-label">@name</span>
                    </label>
                }
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public List<int> SelectedProviderIds { get; set; } = new();

    [Parameter]
    public EventCallback<List<int>> SelectedProviderIdsChanged { get; set; }

    private string DropdownId { get; } = $"providers-dropdown-{Guid.NewGuid()}";
    private bool IsOpen { get; set; } = false;
    private string SearchQuery { get; set; } = string.Empty;

    private void ToggleOpen()
    {
        IsOpen = !IsOpen;
    }

    private void ToggleProvider(int providerId, bool isSelected)
    {
        if (isSelected && !SelectedProviderIds.Contains(providerId))
        {
            SelectedProviderIds.Add(providerId);
        }
        else if (!isSelected && SelectedProviderIds.Contains(providerId))
        {
            SelectedProviderIds.Remove(providerId);
        }

        SelectedProviderIdsChanged.InvokeAsync(SelectedProviderIds);
    }

    private IEnumerable<(int, string)> GetFilteredProviders()
    {
        // TODO: Fetch from service (mock data for now)
        var allProviders = new List<(int, string)>
        {
            (1, "Dr. Sarah Anderson"),
            (2, "Dr. James Mitchell"),
            (3, "Dr. Emily Rodriguez"),
            (4, "Dr. Michael Clarke"),
        };

        if (string.IsNullOrWhiteSpace(SearchQuery))
            return allProviders;

        var query = SearchQuery.ToLower();
        return allProviders.Where(p => p.Item2.ToLower().Contains(query));
    }

    private string GetProviderLabel(int providerId)
    {
        // TODO: Fetch from service
        return providerId switch
        {
            1 => "Dr. Sarah Anderson",
            2 => "Dr. James Mitchell",
            3 => "Dr. Emily Rodriguez",
            4 => "Dr. Michael Clarke",
            _ => "Unknown Provider"
        };
    }
}
