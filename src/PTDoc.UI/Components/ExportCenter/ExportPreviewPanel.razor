@implements IAsyncDisposable
@using System.IO
@using System.Text.Json
@using Microsoft.JSInterop
@using PTDoc.Application.DTOs
@using PTDoc.Application.Pdf
@using PTDoc.UI.Services
@inject INoteService NoteService
@inject INoteWorkspaceService NoteWorkspaceService
@inject IJSRuntime JS

<div class="export-preview-panel">
    <div class="export-preview-panel__header">
        <span class="export-preview-panel__icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M2 9s2.5-4 7-4 7 4 7 4-2.5 4-7 4-7-4-7-4Z" stroke="currentColor" stroke-width="1.5" />
                <circle cx="9" cy="9" r="2" stroke="currentColor" stroke-width="1.5" />
            </svg>
        </span>
        <h3 class="export-preview-panel__title">Export Preview</h3>
    </div>

    <div class="export-preview-panel__metadata">
        <div class="metadata-row">
            <span class="metadata-label">Category</span>
            <span class="metadata-value">@TabLabel(SelectedTab)</span>
        </div>
        <div class="metadata-row">
            <span class="metadata-label">Format</span>
            <span class="metadata-value">@FormatLabel(SelectedFormat)</span>
        </div>
        <div class="metadata-row">
            <span class="metadata-label">Date Range</span>
            <span class="metadata-value">@DateRangeLabel(State)</span>
        </div>
        <div class="metadata-row">
            <span class="metadata-label">Preview Target</span>
            <span class="metadata-value">@PreviewTargetLabel()</span>
        </div>
    </div>

    <div class="record-count-section">
        @if (!SupportsPreview)
        {
            <div class="record-count-disabled">
                <p class="record-count-disabled__title">Preview unavailable</p>
                <p class="record-count-disabled__text">@UnsupportedReason</p>
            </div>
        }
        else if (_isResolvingTarget)
        {
            <div class="record-count-loading" role="status" aria-live="polite">
                <span class="spinner" aria-hidden="true"></span>
                <span>Resolving preview target…</span>
            </div>
        }
        else if (!_previewTarget.CanPreview)
        {
            <div class="record-count-disabled">
                <p class="record-count-disabled__title">No preview target</p>
                <p class="record-count-disabled__text">@_previewTarget.UnavailableReason</p>
            </div>
        }
        else if (_isPreviewLoading)
        {
            <div class="record-count-loading" role="status" aria-live="polite">
                <span class="spinner" aria-hidden="true"></span>
                <span>Loading document hierarchy…</span>
            </div>
        }
        else if (_hierarchy is not null)
        {
            <div class="record-count-display">
                <span class="record-count-number">@_hierarchy.Root.Children.Count</span>
                <span class="record-count-label">top-level sections loaded</span>
            </div>
        }
        else
        {
            <div class="record-count-disabled">
                <p class="record-count-disabled__title">Preview ready</p>
                <p class="record-count-disabled__text">
                    Generate a hierarchy preview for @_previewTarget.Title.
                </p>
            </div>
        }
    </div>

    @if (!string.IsNullOrWhiteSpace(_previewTarget.SelectionNotice))
    {
        <div class="phi-warning-card phi-warning-card--info" role="status">
            <span class="phi-warning-icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="9" cy="9" r="6.25" stroke="currentColor" stroke-width="1.5" />
                    <path d="M9 8V12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                    <circle cx="9" cy="5.5" r="0.75" fill="currentColor" />
                </svg>
            </span>
            <div class="phi-warning-content">
                <div class="phi-warning-title">Preview selection</div>
                <div class="phi-warning-text">@_previewTarget.SelectionNotice</div>
            </div>
        </div>
    }

    @if (_previewTarget.CanPreview && !_previewTarget.CanDownloadPdf)
    {
        <div class="phi-warning-card" role="status">
            <span class="phi-warning-icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M9 2.5 16 14.5H2L9 2.5Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" />
                    <path d="M9 7V10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                    <circle cx="9" cy="12.5" r="0.8" fill="currentColor" />
                </svg>
            </span>
            <div class="phi-warning-content">
                <div class="phi-warning-title">Finalization required</div>
                <div class="phi-warning-text">Hierarchy preview is available for this note, but PDF download stays disabled until the note is signed.</div>
            </div>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(_previewErrorMessage))
    {
        <div class="phi-warning-card phi-warning-card--error" role="alert">
            <span class="phi-warning-icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M9 2.5 16 14.5H2L9 2.5Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" />
                    <path d="M9 7V10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                    <circle cx="9" cy="12.5" r="0.8" fill="currentColor" />
                </svg>
            </span>
            <div class="phi-warning-content">
                <div class="phi-warning-title">Preview failed</div>
                <div class="phi-warning-text">@_previewErrorMessage</div>
            </div>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(_statusMessage))
    {
        <div class="phi-warning-card phi-warning-card--success" role="status">
            <span class="phi-warning-icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="9" cy="9" r="6.25" stroke="currentColor" stroke-width="1.5" />
                    <path d="m6.5 9 1.75 1.75L11.75 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
            </span>
            <div class="phi-warning-content">
                <div class="phi-warning-title">Export ready</div>
                <div class="phi-warning-text">@_statusMessage</div>
            </div>
        </div>
    }

    @if (_hierarchy is not null)
    {
        <div class="export-preview-panel__document" role="region" aria-label="Document hierarchy preview">
            @foreach (var node in _hierarchy.Root.Children)
            {
                <ExportDocumentHierarchyNode Node="node" />
            }
        </div>
    }

    <div class="export-preview-panel__actions">
        <button class="btn btn-secondary" type="button" @onclick="HandleGeneratePreviewAsync" disabled="@(!_previewTarget.CanPreview || _isPreviewLoading || _isResolvingTarget)">
            @if (_isPreviewLoading)
            {
                <span class="spinner" aria-hidden="true"></span>
                <span>Loading Preview…</span>
            }
            else
            {
                <span>@(_hierarchy is null ? "Generate Preview" : "Refresh Preview")</span>
            }
        </button>

        <button class="btn btn-primary" type="button" @onclick="HandleDownloadPdfAsync" disabled="@(!_previewTarget.CanDownloadPdf || _isDownloading || _isResolvingTarget)">
            @if (_isDownloading)
            {
                <span class="spinner" aria-hidden="true"></span>
                <span>Downloading…</span>
            }
            else
            {
                <span>Download PDF</span>
            }
        </button>
    </div>

    <div class="export-preview-panel__footer">
        <span class="footer-icon" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="4" y="8" width="10" height="7" rx="1.5" stroke="currentColor" stroke-width="1.5" />
                <path d="M6.5 8V6.5a2.5 2.5 0 1 1 5 0V8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
            </svg>
        </span>
        <span class="footer-text">PDF exports remain backend-audited and finalized-note rules still apply.</span>
    </div>
</div>

@code {
    private ClinicalDocumentHierarchy? _hierarchy;
    private string? _lastPreviewKey;
    private string? _previewErrorMessage;
    private string? _statusMessage;
    private bool _isResolvingTarget;
    private bool _isPreviewLoading;
    private bool _isDownloading;
    private ExportPreviewTarget _previewTarget = new();
    private IJSObjectReference? _downloadModule;
    private CancellationTokenSource? _previewTargetCts;

    [Parameter]
    [EditorRequired]
    public ExportTab SelectedTab { get; set; } = ExportTab.SoapNotes;

    [Parameter]
    [EditorRequired]
    public ExportFormat SelectedFormat { get; set; } = ExportFormat.PDF;

    [Parameter]
    [EditorRequired]
    public ExportDraftState State { get; set; } = new();

    private bool SupportsPreview => SelectedTab == ExportTab.SoapNotes && SelectedFormat == ExportFormat.PDF;

    private string UnsupportedReason => SelectedTab != ExportTab.SoapNotes
        ? "Preview is currently available only for SOAP note exports."
        : "Preview is currently available only for PDF note exports.";

    protected override async Task OnParametersSetAsync()
    {
        var nextKey = BuildPreviewKey();
        if (string.Equals(_lastPreviewKey, nextKey, StringComparison.Ordinal))
        {
            return;
        }

        _lastPreviewKey = nextKey;
        _hierarchy = null;
        _previewErrorMessage = null;
        _statusMessage = null;
        State.HasGeneratedPreview = false;
        State.RecordCount = null;
        State.IsLoadingPreview = false;
        State.IsDownloading = false;

        await ResolvePreviewTargetAsync();
    }

    public async ValueTask DisposeAsync()
    {
        _previewTargetCts?.Cancel();
        _previewTargetCts?.Dispose();

        if (_downloadModule is not null)
        {
            await _downloadModule.DisposeAsync();
        }
    }

    private async Task ResolvePreviewTargetAsync()
    {
        _previewTargetCts?.Cancel();
        _previewTargetCts?.Dispose();
        _previewTargetCts = new CancellationTokenSource();
        var cancellationToken = _previewTargetCts.Token;

        if (!SupportsPreview)
        {
            _previewTarget = new ExportPreviewTarget
            {
                UnavailableReason = UnsupportedReason
            };
            return;
        }

        if (State.SelectedProviderIds.Count > 0)
        {
            _previewTarget = new ExportPreviewTarget
            {
                UnavailableReason = "Preview cannot apply provider filters yet because the current note list projection does not expose clinician identity."
            };
            return;
        }

        _isResolvingTarget = true;

        try
        {
            var response = await NoteService.ResolveExportPreviewTargetAsync(
                new ExportPreviewTargetRequest
                {
                    PatientIds = ParseGuids(State.SelectedPatientIds),
                    DateRangeStart = State.DateRangeStart,
                    DateRangeEnd = State.DateRangeEnd,
                    NoteTypeFilters = State.SelectedNoteTypes.ToArray()
                },
                cancellationToken);

            if (cancellationToken.IsCancellationRequested)
            {
                return;
            }

            _previewTarget = new ExportPreviewTarget
            {
                NoteId = response.NoteId,
                Title = response.Title,
                Subtitle = response.Subtitle,
                NoteStatus = response.NoteStatus,
                SelectionNotice = response.SelectionNotice,
                UnavailableReason = response.UnavailableReason,
                CanDownloadPdf = response.CanDownloadPdf
            };
        }
        catch (OperationCanceledException)
        {
            return;
        }
        catch (HttpRequestException ex)
        {
            _previewTarget = new ExportPreviewTarget
            {
                UnavailableReason = string.IsNullOrWhiteSpace(ex.Message)
                    ? "Unable to resolve the export preview target."
                    : ex.Message
            };
        }
        catch (JsonException)
        {
            _previewTarget = new ExportPreviewTarget
            {
                UnavailableReason = "Preview target payload could not be read."
            };
        }
        catch (Exception)
        {
            _previewTarget = new ExportPreviewTarget
            {
                UnavailableReason = "Unable to resolve the export preview target."
            };
        }
        finally
        {
            _isResolvingTarget = false;
        }
    }

    private async Task HandleGeneratePreviewAsync()
    {
        if (!_previewTarget.CanPreview || !_previewTarget.NoteId.HasValue)
        {
            _previewErrorMessage = _previewTarget.UnavailableReason;
            _statusMessage = null;
            return;
        }

        _isPreviewLoading = true;
        State.IsLoadingPreview = true;
        _previewErrorMessage = null;
        _statusMessage = null;

        try
        {
            var result = await NoteWorkspaceService.GetDocumentHierarchyAsync(_previewTarget.NoteId.Value);
            if (!result.Success || result.Hierarchy is null)
            {
                _hierarchy = null;
                _previewErrorMessage = result.ErrorMessage ?? "Unable to generate the export preview.";
                return;
            }

            _hierarchy = result.Hierarchy;
            State.HasGeneratedPreview = true;
            State.RecordCount = result.Hierarchy.Root.Children.Count;
        }
        catch (HttpRequestException ex)
        {
            _hierarchy = null;
            _previewErrorMessage = string.IsNullOrWhiteSpace(ex.Message)
                ? "Unable to generate the export preview."
                : ex.Message;
        }
        catch (JsonException)
        {
            _hierarchy = null;
            _previewErrorMessage = "Preview hierarchy payload could not be read.";
        }
        catch (JSException)
        {
            _hierarchy = null;
            _previewErrorMessage = "The browser could not display the preview.";
        }
        catch (Exception)
        {
            _hierarchy = null;
            _previewErrorMessage = "Unable to generate the export preview.";
        }
        finally
        {
            _isPreviewLoading = false;
            State.IsLoadingPreview = false;
        }
    }

    private async Task HandleDownloadPdfAsync()
    {
        if (!_previewTarget.CanDownloadPdf || !_previewTarget.NoteId.HasValue)
        {
            _previewErrorMessage = _previewTarget.IsSigned
                ? _previewTarget.UnavailableReason
                : "Only signed notes can be downloaded as PDF.";
            _statusMessage = null;
            return;
        }

        _isDownloading = true;
        State.IsDownloading = true;
        _previewErrorMessage = null;
        _statusMessage = null;

        try
        {
            var result = await NoteWorkspaceService.ExportPdfAsync(_previewTarget.NoteId.Value);
            if (!result.Success)
            {
                _previewErrorMessage = result.ErrorMessage ?? "Unable to download the PDF.";
                return;
            }

            _downloadModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "./_content/PTDoc.UI/js/export-preview.js");
            using var streamReference = new DotNetStreamReference(new MemoryStream(result.Content));
            await _downloadModule.InvokeVoidAsync(
                "downloadStreamFile",
                result.FileName,
                result.ContentType,
                streamReference);

            _statusMessage = "PDF download started.";
        }
        catch (HttpRequestException ex)
        {
            _previewErrorMessage = string.IsNullOrWhiteSpace(ex.Message)
                ? "Unable to download the PDF."
                : ex.Message;
        }
        catch (JsonException)
        {
            _previewErrorMessage = "Download response payload could not be read.";
        }
        catch (JSException)
        {
            _previewErrorMessage = "The browser could not start the PDF download.";
        }
        catch (Exception)
        {
            _previewErrorMessage = "Unable to download the PDF.";
        }
        finally
        {
            _isDownloading = false;
            State.IsDownloading = false;
        }
    }

    private string PreviewTargetLabel()
    {
        if (!SupportsPreview)
        {
            return "Not supported";
        }

        if (_isResolvingTarget)
        {
            return "Resolving…";
        }

        if (!_previewTarget.CanPreview)
        {
            return "No matching note";
        }

        return _previewTarget.Title;
    }

    private string BuildPreviewKey()
    {
        return string.Join(
            "|",
            SelectedTab,
            SelectedFormat,
            State.DateRangeStart?.ToString("O") ?? string.Empty,
            State.DateRangeEnd?.ToString("O") ?? string.Empty,
            string.Join(",", State.SelectedPatientIds.OrderBy(id => id, StringComparer.Ordinal)),
            string.Join(",", State.SelectedProviderIds.OrderBy(id => id, StringComparer.Ordinal)),
            string.Join(",", State.SelectedNoteTypes.OrderBy(value => value, StringComparer.Ordinal)));
    }

    private static IReadOnlyList<Guid> ParseGuids(IEnumerable<string> values)
    {
        return values
            .Select(value => Guid.TryParse(value, out var parsed) ? parsed : Guid.Empty)
            .Where(id => id != Guid.Empty)
            .Distinct()
            .ToList();
    }

    private static string TabLabel(ExportTab tab) => tab switch
    {
        ExportTab.SoapNotes => "SOAP Notes",
        ExportTab.PatientData => "Patient Data",
        ExportTab.Appointments => "Appointments",
        ExportTab.Reports => "Reports",
        _ => "Unknown"
    };

    private static string FormatLabel(ExportFormat format) => format switch
    {
        ExportFormat.PDF => "PDF",
        ExportFormat.CSV => "CSV",
        ExportFormat.Excel => "Excel",
        ExportFormat.JSON => "JSON",
        _ => "Unknown"
    };

    private static string DateRangeLabel(ExportDraftState state)
    {
        if (!state.DateRangeStart.HasValue && !state.DateRangeEnd.HasValue)
        {
            return "All time";
        }

        if (state.DateRangeStart.HasValue && state.DateRangeEnd.HasValue)
        {
            return $"{state.DateRangeStart:MMM dd, yyyy} - {state.DateRangeEnd:MMM dd, yyyy}";
        }

        if (state.DateRangeStart.HasValue)
        {
            return $"{state.DateRangeStart:MMM dd, yyyy} onwards";
        }

        return $"Until {state.DateRangeEnd:MMM dd, yyyy}";
    }
}
