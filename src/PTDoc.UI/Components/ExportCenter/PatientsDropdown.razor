<div class="patients-dropdown">
    <label for="@DropdownId" class="patients-dropdown__label">Patients</label>

    <button
        id="@DropdownId"
        class="patients-dropdown__trigger"
        @onclick="ToggleOpen"
        type="button"
        aria-expanded="@IsOpen"
        aria-haspopup="listbox">
        <span class="patients-dropdown__display">
            @if (SelectedPatientIds.Count == 0)
            {
                <span>All patients</span>
            }
            else if (SelectedPatientIds.Count == 1)
            {
                <span>@GetSelectedLabel(SelectedPatientIds[0])</span>
            }
            else
            {
                <span>@SelectedPatientIds.Count selected</span>
            }
        </span>

        <span class="patients-dropdown__icon" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M3.5 5.5L7 9L10.5 5.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        </span>
    </button>

    @if (IsOpen)
    {
        <div class="patients-dropdown__menu" role="listbox">
            <div class="patients-dropdown__search">
                <input
                    type="text"
                    class="patients-dropdown__search-input"
                    placeholder="Search patients..."
                    @bind="SearchQuery"
                    @bind:event="oninput"
                    aria-label="Search patients" />
            </div>

            <div class="patients-dropdown__list">
                @if (GetFilteredPatients().Count == 0)
                {
                    <div class="patients-dropdown__empty">No patients match the current search.</div>
                }
                else
                {
                    @foreach (var patient in GetFilteredPatients())
                    {
                        var isSelected = SelectedPatientIds.Contains(patient.Id);
                        <label class="patients-dropdown__option">
                            <input
                                type="checkbox"
                                class="patients-dropdown__checkbox"
                                checked="@isSelected"
                                @onchange="@((ChangeEventArgs e) => TogglePatient(patient.Id, (bool)e!.Value!))"
                                aria-label="@patient.Label" />
                            <span class="patients-dropdown__option-label">@patient.Label</span>
                        </label>
                    }
                }
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public List<string> SelectedPatientIds { get; set; } = new();

    [Parameter]
    public EventCallback<List<string>> SelectedPatientIdsChanged { get; set; }

    [Parameter]
    public IReadOnlyList<ExportCenterSelectableItem> Patients { get; set; } = Array.Empty<ExportCenterSelectableItem>();

    private string DropdownId { get; } = $"patients-dropdown-{Guid.NewGuid()}";
    private bool IsOpen { get; set; }
    private string SearchQuery { get; set; } = string.Empty;

    private void ToggleOpen()
    {
        IsOpen = !IsOpen;
    }

    private Task TogglePatient(string patientId, bool isSelected)
    {
        var next = SelectedPatientIds.ToList();

        if (isSelected && !next.Contains(patientId))
        {
            next.Add(patientId);
        }
        else if (!isSelected && next.Contains(patientId))
        {
            next.Remove(patientId);
        }

        return SelectedPatientIdsChanged.InvokeAsync(next);
    }

    private IReadOnlyList<ExportCenterSelectableItem> GetFilteredPatients()
    {
        if (string.IsNullOrWhiteSpace(SearchQuery))
        {
            return Patients;
        }

        var query = SearchQuery.Trim();
        return Patients
            .Where(patient => patient.Label.Contains(query, StringComparison.OrdinalIgnoreCase))
            .ToList();
    }

    private string GetSelectedLabel(string patientId)
    {
        return Patients.FirstOrDefault(patient => string.Equals(patient.Id, patientId, StringComparison.OrdinalIgnoreCase))?.Label
            ?? "Unknown patient";
    }
}
