@* Context Info Banner
    Displays info icon + helper text describing current tab's export scope.
    Updates immediately on tab switch.
    States: Default only (no complex interaction).
    TODO: Finalize banner copy strings per tab as product-approved.
*@

<div class="context-info-banner">
    <span class="context-info-banner__icon" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="9" cy="9" r="7" stroke="currentColor" stroke-width="1.5" />
            <path d="M9 8v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
            <circle cx="9" cy="5.5" r="0.8" fill="currentColor" />
        </svg>
    </span>
    <span class="context-info-banner__text">
        @GetContextText(SelectedTab)
    </span>
</div>

@code {
    [Parameter]
    [EditorRequired]
    public ExportTab SelectedTab { get; set; } = ExportTab.SoapNotes;

    private static string GetContextText(ExportTab tab) => tab switch
    {
        ExportTab.SoapNotes => "Clinical documentation by patient, provider, and date. Includes SOAP notes and clinical assessments.",
        ExportTab.PatientData => "Patient demographics, visit history, and clinical documentation. Includes all patient-related records and attachments.",
        ExportTab.Appointments => "Appointment records filtered by date range, provider, and status. Includes scheduling and visit data.",
        ExportTab.Reports => "Analytics and reporting exports including visit metrics, outcomes, and billing summaries.",
        _ => "Export contextual information"
    };
}
