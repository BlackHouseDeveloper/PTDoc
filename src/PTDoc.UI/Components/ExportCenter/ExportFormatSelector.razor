@* Export Format Selector Panel
    Purpose: Single-select format cards (PDF, CSV, Excel, JSON)
    Placement: Left column, below FiltersPanel
    Visual: Horizontal group of 4 cards, each includes icon + label + description
    States: Selected (emerald border + light fill), Unselected, Hover
    Interaction: Clicking a format selects immediately (single-select)
    On tab switch reset to PDF
    Descriptions currently use concise, generic format guidance.
*@

<div class="export-format-selector">
    <h3 class="export-format-selector__title">Export Format</h3>
    
    <div class="export-format-selector__grid" role="radiogroup" aria-label="Export Format">
        @foreach (var format in Enum.GetValues<ExportFormat>())
        {
            var isSelected = SelectedFormat == format;
            <label class="export-format-selector__card @(isSelected ? "export-format-selector__card--selected" : "")">
                <input
                    type="radio"
                    name="export-format"
                    class="export-format-selector__radio"
                    checked="@isSelected"
                    @onchange="@((ChangeEventArgs e) => OnFormatSelected(format))"
                    aria-label="@GetFormatLabel(format)" />
                
                <span class="export-format-selector__icon" aria-hidden="true">
                    @GetFormatIcon(format)
                </span>
                
                <span class="export-format-selector__label">
                    @GetFormatLabel(format)
                </span>
                
                <span class="export-format-selector__description">
                    @GetFormatDescription(format)
                </span>
            </label>
        }
    </div>
</div>

@code {
    [Parameter]
    [EditorRequired]
    public ExportFormat SelectedFormat { get; set; } = ExportFormat.PDF;

    [Parameter]
    public EventCallback<ExportFormat> SelectedFormatChanged { get; set; }

    private async Task OnFormatSelected(ExportFormat format)
    {
        if (SelectedFormat != format)
        {
            SelectedFormat = format;
            await SelectedFormatChanged.InvokeAsync(format);
        }
    }

    private static string GetFormatLabel(ExportFormat format) => format switch
    {
        ExportFormat.PDF => "PDF",
        ExportFormat.CSV => "CSV",
        ExportFormat.Excel => "Excel",
        ExportFormat.JSON => "JSON",
        _ => "Unknown"
    };

    private static string GetFormatDescription(ExportFormat format) => format switch
    {
        ExportFormat.PDF => "Formatted, print-ready",
        ExportFormat.CSV => "Structured raw data",
        ExportFormat.Excel => "Formatted spreadsheet",
