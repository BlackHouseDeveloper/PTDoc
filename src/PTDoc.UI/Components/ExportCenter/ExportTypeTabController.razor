@* Export Type Tab Controller
    Provides segmented tabs for export type selection (SOAP Notes, Patient Data, Appointments, Reports).
    On tab switch, resets all lower state (filters, format, options, preview).
    Single-select control with icon + label per tab.
    States: Active (emerald bg + black text), Inactive (neutral), Hover.
    Interaction: Clicking tab sets SelectedTab and triggers ResetOnSwitch callback.
*@

<div class="export-type-tab-controller" role="tablist">
    @foreach (var tab in Enum.GetValues<ExportTab>())
    {
        var isSelected = SelectedTab == tab;
        <button
            class="export-type-tab @(isSelected ? "export-type-tab--active" : "export-type-tab--inactive")"
            role="tab"
            aria-selected="@isSelected"
            @onclick="() => HandleTabClick(tab)"
            type="button">
            
            <span class="export-type-tab__icon" aria-hidden="true">
                @GetTabIcon(tab)
            </span>
            
            <span class="export-type-tab__label">
                @GetTabLabel(tab)
            </span>
        </button>
    }
</div>

@code {
    [Parameter]
    [EditorRequired]
    public ExportTab SelectedTab { get; set; } = ExportTab.SoapNotes;

    [Parameter]
    public EventCallback<ExportTab> SelectedTabChanged { get; set; }

    [Parameter]
    public EventCallback OnTabSwitched { get; set; }

    private async Task HandleTabClick(ExportTab selectedTab)
    {
        if (selectedTab == SelectedTab)
            return;

        // Update selected tab
        SelectedTab = selectedTab;
        await SelectedTabChanged.InvokeAsync(SelectedTab);

        // Notify parent to reset lower state
        await OnTabSwitched.InvokeAsync();
    }

    private static string GetTabLabel(ExportTab tab) => tab switch
    {
        ExportTab.SoapNotes => "SOAP Notes",
        ExportTab.PatientData => "Patient Data",
        ExportTab.Appointments => "Appointments",
