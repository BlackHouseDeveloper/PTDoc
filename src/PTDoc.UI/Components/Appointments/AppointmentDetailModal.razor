@inject IJSRuntime JS
@implements IAsyncDisposable

@if (IsOpen && Appointment is not null)
{
    <div class="appointment-detail-modal__overlay"
         @onclick="HandleOverlayClick"
         @onclick:stopPropagation="false">
        <div class="appointment-detail-modal__container"
             @onclick:stopPropagation="true"
             role="dialog"
             aria-labelledby="appointment-detail-title"
             aria-describedby="appointment-detail-description"
             aria-modal="true">
            <div class="appointment-detail-modal__header">
                <div class="appointment-detail-modal__header-content">
                    <div class="appointment-detail-modal__title-row">
                        <svg class="appointment-detail-modal__title-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                            <path d="M10 10C12.2091 10 14 8.20914 14 6C14 3.79086 12.2091 2 10 2C7.79086 2 6 3.79086 6 6C6 8.20914 7.79086 10 10 10Z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                            <path d="M3.5 17C4.65685 14.3431 7.09594 12.5 10 12.5C12.9041 12.5 15.3431 14.3431 16.5 17" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                        <div class="appointment-detail-modal__title-stack">
                            <h2 id="appointment-detail-title" class="appointment-detail-modal__title">Appointment Details</h2>
                            <p id="appointment-detail-description" class="appointment-detail-modal__subtitle">
                                Complete information for @Appointment.PatientName
                            </p>
                        </div>
                    </div>
                </div>

                <button type="button"
                        class="appointment-detail-modal__close"
                        @onclick="Close"
                        @ref="closeButtonRef"
                        aria-label="Close appointment details">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M12 4L4 12M4 4L12 12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </button>
            </div>

            <div class="appointment-detail-modal__content">
                <section class="appointment-detail-modal__info-card" aria-label="Patient appointment summary">
                    <div class="appointment-detail-modal__info-grid">
                        <div class="appointment-detail-modal__info-item">
                            <p class="appointment-detail-modal__field-label">Patient Name</p>
                            <p class="appointment-detail-modal__field-value appointment-detail-modal__field-value--strong">@Appointment.PatientName</p>
                        </div>
                        <div class="appointment-detail-modal__info-item">
                            <p class="appointment-detail-modal__field-label">Patient ID</p>
                            <p class="appointment-detail-modal__field-value appointment-detail-modal__field-value--strong">@Appointment.PatientId</p>
                        </div>
                        <div class="appointment-detail-modal__info-item">
                            <p class="appointment-detail-modal__field-label">Date</p>
                            <p class="appointment-detail-modal__field-value">@Appointment.AppointmentDate.ToString("ddd, MMM d, yyyy")</p>
                        </div>
                        <div class="appointment-detail-modal__info-item">
                            <p class="appointment-detail-modal__field-label">Time</p>
                            <p class="appointment-detail-modal__field-value appointment-detail-modal__field-value--strong">@Appointment.StartTime.ToString("h:mm tt")</p>
                        </div>
                        <div class="appointment-detail-modal__info-item">
                            <p class="appointment-detail-modal__field-label">Duration</p>
                            <p class="appointment-detail-modal__field-value">@($"{Appointment.DurationMinutes} minutes")</p>
                        </div>
                        <div class="appointment-detail-modal__info-item">
                            <p class="appointment-detail-modal__field-label">End Time</p>
                            <p class="appointment-detail-modal__field-value">@Appointment.EndTime.ToString("h:mm tt")</p>
                        </div>
                    </div>
                </section>

                <section class="appointment-detail-modal__section" aria-label="Appointment details">
                    <div class="appointment-detail-modal__info-item">
                        <p class="appointment-detail-modal__field-label">Appointment Type</p>
                        <p class="appointment-detail-modal__field-value appointment-detail-modal__field-value--strong">@Appointment.AppointmentType</p>
                    </div>

                    <div class="appointment-detail-modal__status-grid">
                        <div class="appointment-detail-modal__info-item">
                            <p class="appointment-detail-modal__field-label">Appointment Status</p>
                            <span class="@GetStatusBadgeClass(EffectiveAppointmentStatus)">
                                @EffectiveAppointmentStatus
                            </span>
                        </div>
                        <div class="appointment-detail-modal__info-item">
                            <p class="appointment-detail-modal__field-label">Intake Status</p>
                            <span class="@GetStatusBadgeClass(Appointment.IntakeStatus)">
                                @GetIntakeStatusLabel()
                            </span>
                        </div>
                    </div>
                </section>

                <section class="appointment-detail-modal__section" aria-label="Appointment notes">
                    <p class="appointment-detail-modal__field-label">Appointment Notes</p>
                    <div class="appointment-detail-modal__notes">
                        <p class="appointment-detail-modal__notes-text">@GetNotesText()</p>
                    </div>
                </section>

                <section class="appointment-detail-modal__section" aria-label="Billing and document readiness">
                    <div class="appointment-detail-modal__section-heading">
                        <p class="appointment-detail-modal__field-label">Billing & Documents</p>
                        <span class="@GetCopayBadgeClass()">@GetCopayStatusLabel()</span>
                    </div>

                    <div class="appointment-detail-modal__readiness-grid">
                        <div class="appointment-detail-modal__readiness-item">
                            <span class="@GetDocumentBadgeClass(Appointment.IntakeStatus)">
                                @GetDocumentBadgeLabel("Intake", Appointment.IntakeStatus)
                            </span>
                            <p>Intake form</p>
                        </div>
                        <div class="appointment-detail-modal__readiness-item">
                            <span class="@GetDocumentBadgeClass(VisitNoteReadinessStatus)">
                                @GetDocumentBadgeLabel("Visit note", VisitNoteReadinessStatus)
                            </span>
                            <p>Clinical document</p>
                        </div>
                    </div>

                    <button type="button"
                            class="appointment-detail-modal__quick-action appointment-detail-modal__quick-action--secondary appointment-detail-modal__quick-action--full"
                            disabled="@(!CanRecordCopay)"
                            @onclick="HandleRecordCopayRequested"
                            aria-describedby="@GetCopayActionDescriptionId()">
                        <svg class="appointment-detail-modal__button-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                            <path d="M3 5.25H13M4.5 3.25H11.5C12.3284 3.25 13 3.92157 13 4.75V11.25C13 12.0784 12.3284 12.75 11.5 12.75H4.5C3.67157 12.75 3 12.0784 3 11.25V4.75C3 3.92157 3.67157 3.25 4.5 3.25Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                            <path d="M5.5 9.75H7.25" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                        </svg>
                        <span>Record Copay</span>
                    </button>
                    @if (!CanRecordCopay)
                    {
                        <p id="@CopayActionReasonId" class="appointment-detail-modal__quick-action-reason">
                            @GetCopayActionUnavailableReason()
                        </p>
                    }
                </section>

                <section class="appointment-detail-modal__section" aria-label="Quick actions">
                    <p class="appointment-detail-modal__field-label">Quick Actions</p>
                    <div class="appointment-detail-modal__quick-actions-grid">
                        <button type="button"
                                class="@GetContextualQuickActionClass()"
                                @onclick="HandlePrimaryActionRequested"
                                disabled="@(!CanUsePrimaryAction)"
                                aria-describedby="@GetPrimaryActionDescriptionId()">
                            @RenderPrimaryActionIcon()
                            <span>@GetPrimaryActionLabel()</span>
                        </button>

                        @if (!CanUsePrimaryAction)
                        {
                            <p id="@PrimaryActionDisabledReasonId" class="appointment-detail-modal__quick-action-reason">
                                @GetPrimaryActionDisabledReason()
                            </p>
                        }

                        <button type="button"
                                class="appointment-detail-modal__quick-action appointment-detail-modal__quick-action--secondary"
                                @onclick="HandleEditAppointmentRequested"
                                disabled="@IsTerminalStatus"
                                aria-describedby="@GetTerminalActionDescriptionId()">
                            <svg class="appointment-detail-modal__button-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                <path d="M4 2.75V4.25M12 2.75V4.25M3.25 6H12.75" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                                <rect x="3.25" y="3.5" width="9.5" height="9.25" rx="1.5" stroke="currentColor" stroke-width="1.5" />
                            </svg>
                            <span>Edit Appointment</span>
                        </button>
                    </div>
                </section>
            </div>

            <div class="appointment-detail-modal__footer">
                <button type="button"
                        class="appointment-detail-modal__footer-button appointment-detail-modal__footer-button--secondary"
                        @onclick="Close">
                    Close
                </button>

                <button type="button"
                        class="appointment-detail-modal__footer-button appointment-detail-modal__footer-button--primary"
                        @onclick="HandlePrimaryActionRequested"
                        disabled="@(!CanUsePrimaryAction)"
                        aria-describedby="@GetPrimaryActionDescriptionId()">
                    @RenderPrimaryActionIcon()
                    <span>@GetPrimaryActionLabel()</span>
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public bool IsOpen { get; set; }

    [Parameter]
    public EventCallback<bool> IsOpenChanged { get; set; }

    [Parameter]
    public AppointmentDetailViewModel? Appointment { get; set; }

    [Parameter]
    public EventCallback<string> OnActionRequested { get; set; }

    private ElementReference closeButtonRef;
    private IJSObjectReference? modalModule;
    private DotNetObjectReference<AppointmentDetailModal>? dotNetRef;
    private readonly string modalId = $"appointment-detail-modal-{Guid.NewGuid():N}";
    private bool modalAccessibilityActive;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                modalModule = await JS.InvokeAsync<IJSObjectReference>("import", "./_content/PTDoc.UI/js/modal.js");
                dotNetRef = DotNetObjectReference.Create(this);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Failed to load modal.js: {ex.Message}");
            }
        }

        if (IsOpen && !modalAccessibilityActive && modalModule is not null && dotNetRef is not null)
        {
            try
            {
                await modalModule.InvokeVoidAsync("lockBodyScroll");
                await modalModule.InvokeVoidAsync("registerEscapeHandler", modalId, dotNetRef);
                await closeButtonRef.FocusAsync();
                modalAccessibilityActive = true;
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Modal JS interop error: {ex.Message}");
            }
        }
        else if (!IsOpen && modalAccessibilityActive && modalModule is not null)
        {
            try
            {
                await modalModule.InvokeVoidAsync("unlockBodyScroll");
                await modalModule.InvokeVoidAsync("unregisterEscapeHandler", modalId);
                modalAccessibilityActive = false;
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Modal cleanup error: {ex.Message}");
            }
        }
    }

    [JSInvokable]
    public Task CloseFromJs() => Close();

    private Task Close() => IsOpenChanged.InvokeAsync(false);

    private void HandleOverlayClick()
    {
        _ = Close();
    }

    private Task HandleActionRequested(string actionName) =>
        OnActionRequested.HasDelegate
            ? OnActionRequested.InvokeAsync(actionName)
            : Task.CompletedTask;

    private string EffectiveAppointmentStatus =>
        string.IsNullOrWhiteSpace(Appointment?.VisitWorkflowStatus)
            ? Appointment?.AppointmentStatus ?? string.Empty
            : Appointment.VisitWorkflowStatus;

    private bool CanCheckIn =>
        string.Equals(EffectiveAppointmentStatus, "Scheduled", StringComparison.OrdinalIgnoreCase);

    private bool CanStartVisit =>
        string.Equals(EffectiveAppointmentStatus, "Checked In", StringComparison.OrdinalIgnoreCase)
        || string.Equals(EffectiveAppointmentStatus, "In Progress", StringComparison.OrdinalIgnoreCase)
        || string.Equals(EffectiveAppointmentStatus, "Note Started", StringComparison.OrdinalIgnoreCase);

    private bool IsTerminalStatus =>
        string.Equals(EffectiveAppointmentStatus, "Cancelled", StringComparison.OrdinalIgnoreCase)
        || string.Equals(EffectiveAppointmentStatus, "No Show", StringComparison.OrdinalIgnoreCase)
        || string.Equals(EffectiveAppointmentStatus, "Completed", StringComparison.OrdinalIgnoreCase);

    private bool CanUsePrimaryAction => CanCheckIn || CanStartVisit;

    private string PrimaryActionDisabledReasonId => $"{modalId}-primary-action-reason";

    private string CopayActionReasonId => $"{modalId}-copay-action-reason";

    private string? GetPrimaryActionDescriptionId() => CanUsePrimaryAction ? null : PrimaryActionDisabledReasonId;

    private string? GetTerminalActionDescriptionId() => IsTerminalStatus ? PrimaryActionDisabledReasonId : null;

    private bool CanRecordCopay => Appointment?.CanRecordCopay == true;

    private string? GetCopayActionDescriptionId() => CanRecordCopay ? null : CopayActionReasonId;

    private Task HandleStartVisitRequested() => HandleActionRequested("start-visit");

    private Task HandleCheckInRequested() => HandleActionRequested("check-in");

    private Task HandleRecordCopayRequested() =>
        CanRecordCopay ? HandleActionRequested("record-copay") : Task.CompletedTask;

    private Task HandlePrimaryActionRequested()
    {
        if (CanCheckIn)
        {
            return HandleCheckInRequested();
        }

        if (CanStartVisit)
        {
            return HandleStartVisitRequested();
        }

        return Task.CompletedTask;
    }

    private Task HandleEditAppointmentRequested() => HandleActionRequested("edit-appointment");

    private string GetContextualQuickActionClass()
    {
        return "appointment-detail-modal__quick-action appointment-detail-modal__quick-action--outlined";
    }

    private string GetPrimaryActionLabel()
    {
        if (CanCheckIn)
        {
            return "Check In";
        }

        if (string.Equals(EffectiveAppointmentStatus, "Note Started", StringComparison.OrdinalIgnoreCase)
            || string.Equals(EffectiveAppointmentStatus, "In Progress", StringComparison.OrdinalIgnoreCase))
        {
            return "Enter Visit";
        }

        return "Start Visit";
    }

    private string GetPrimaryActionDisabledReason()
    {
        if (IsTerminalStatus)
        {
            return "This appointment is closed and cannot be started.";
        }

        return "Check in the patient before starting the visit.";
    }

    private RenderFragment RenderPrimaryActionIcon() => builder =>
    {
        builder.OpenElement(0, "svg");
        builder.AddAttribute(1, "class", "appointment-detail-modal__button-icon");
        builder.AddAttribute(2, "width", "16");
        builder.AddAttribute(3, "height", "16");
        builder.AddAttribute(4, "viewBox", "0 0 16 16");
        builder.AddAttribute(5, "fill", "none");
        builder.AddAttribute(6, "xmlns", "http://www.w3.org/2000/svg");
        builder.AddAttribute(7, "aria-hidden", "true");
        builder.OpenElement(8, "circle");
        builder.AddAttribute(9, "cx", "8");
        builder.AddAttribute(10, "cy", "8");
        builder.AddAttribute(11, "r", "6.25");
        builder.AddAttribute(12, "stroke", "currentColor");
        builder.AddAttribute(13, "stroke-width", "1.5");
        builder.CloseElement();
        builder.OpenElement(14, "path");
        builder.AddAttribute(15, "d", "M6.5 5.5L10.5 8L6.5 10.5V5.5Z");
        builder.AddAttribute(16, "stroke", "currentColor");
        builder.AddAttribute(17, "stroke-width", "1.5");
        builder.AddAttribute(18, "stroke-linejoin", "round");
        builder.CloseElement();
        builder.CloseElement();
    };

    private string GetNotesText() =>
        string.IsNullOrWhiteSpace(Appointment?.Notes)
            ? "Appointment notes are not available yet."
            : Appointment.Notes;

    private string VisitNoteReadinessStatus
    {
        get
        {
            if (Appointment?.VisitNoteId is null)
            {
                return string.Equals(EffectiveAppointmentStatus, "Completed", StringComparison.OrdinalIgnoreCase)
                    || string.Equals(EffectiveAppointmentStatus, "Signed", StringComparison.OrdinalIgnoreCase)
                        ? "Missing"
                        : "Pending";
            }

            return string.Equals(EffectiveAppointmentStatus, "Completed", StringComparison.OrdinalIgnoreCase)
                || string.Equals(EffectiveAppointmentStatus, "Signed", StringComparison.OrdinalIgnoreCase)
                    ? "Completed"
                    : "Note Started";
        }
    }

    private string GetCopayStatusLabel() =>
        string.IsNullOrWhiteSpace(Appointment?.CopayStatusLabel)
            ? "Copay not configured"
            : Appointment.CopayStatusLabel;

    private string GetCopayActionUnavailableReason() =>
        string.IsNullOrWhiteSpace(Appointment?.CopayActionUnavailableReason)
            ? "Copay collection is not configured for this appointment."
            : Appointment.CopayActionUnavailableReason;

    private string GetIntakeStatusLabel() =>
        string.IsNullOrWhiteSpace(Appointment?.IntakeStatus)
            ? "Pending"
            : Appointment.IntakeStatus;

    private string GetCopayBadgeClass() =>
        "appointment-detail-modal__status-badge appointment-detail-modal__status-badge--neutral";

    private static string GetDocumentBadgeLabel(string label, string? status)
    {
        if (string.Equals(status, "Completed", StringComparison.OrdinalIgnoreCase)
            || string.Equals(status, "Signed", StringComparison.OrdinalIgnoreCase))
        {
            return $"{label} complete";
        }

        if (string.Equals(status, "Missing", StringComparison.OrdinalIgnoreCase))
        {
            return $"{label} missing";
        }

        if (string.Equals(status, "Note Started", StringComparison.OrdinalIgnoreCase)
            || string.Equals(status, "In Progress", StringComparison.OrdinalIgnoreCase)
            || string.Equals(status, "Checked In", StringComparison.OrdinalIgnoreCase))
        {
            return $"{label} in progress";
        }

        return $"{label} pending";
    }

    private static string GetDocumentBadgeClass(string? status)
    {
        var variant = NormalizeBadgeStatus(status) switch
        {
            "completed" or "signed" => "appointment-detail-modal__status-badge--completed",
            "missing" => "appointment-detail-modal__status-badge--missing",
            "checked in" or "in progress" or "note started" => "appointment-detail-modal__status-badge--note-started",
            _ => "appointment-detail-modal__status-badge--neutral"
        };

        return $"appointment-detail-modal__status-badge {variant}";
    }

    private string GetStatusBadgeClass(string? status)
    {
        var variant = NormalizeBadgeStatus(status) switch
        {
            "scheduled" => "appointment-detail-modal__status-badge--scheduled",
            "checked in" => "appointment-detail-modal__status-badge--checked-in",
            "in progress" => "appointment-detail-modal__status-badge--note-started",
            "note started" => "appointment-detail-modal__status-badge--note-started",
            "completed" => "appointment-detail-modal__status-badge--completed",
            _ => "appointment-detail-modal__status-badge--neutral"
        };

        return $"appointment-detail-modal__status-badge {variant}";
    }

    private static string NormalizeBadgeStatus(string? status) =>
        string.IsNullOrWhiteSpace(status)
            ? string.Empty
            : status.Trim().ToLowerInvariant();

    public async ValueTask DisposeAsync()
    {
        if (modalModule is not null)
        {
            try
            {
                await modalModule.InvokeVoidAsync("unlockBodyScroll");
                await modalModule.InvokeVoidAsync("unregisterEscapeHandler", modalId);
                await modalModule.DisposeAsync();
                modalAccessibilityActive = false;
            }
            catch
            {
                // Ignore disposal errors.
            }
        }

        dotNetRef?.Dispose();
    }
}
