@* Appointments Left Column - Composition Component *@

<div class="appointments-left-column">
    <AppointmentsViewTabs SelectedView="@SelectedView"
                          OnViewChanged="@OnViewChanged" />

    @if (SelectedView == AppointmentsView.Week)
    {
        @if (ShowClinicianSelector)
        {
            <div class="week-clinician-selector" data-testid="appointments-week-clinician-selector">
                <label for="appointments-week-clinician-search" class="week-clinician-selector__label">Clinician</label>
                <input id="appointments-week-clinician-search"
                       type="search"
                       class="week-clinician-selector__search"
                       placeholder="Search PT or PTA"
                       disabled="@(ClinicianOptions.Count == 0)"
                       aria-disabled="@(ClinicianOptions.Count == 0 ? "true" : "false")"
                       value="@clinicianSearchText"
                       @oninput="HandleClinicianSearchChanged" />
                <select id="appointments-week-clinician-select"
                        class="week-clinician-selector__select"
                        aria-label="Select week clinician"
                        disabled="@(FilteredClinicianOptions.Count == 0)"
                        value="@SelectedClinicianId"
                        @onchange="HandleClinicianSelectionChangedAsync">
                    @if (FilteredClinicianOptions.Count == 0)
                    {
                        <option value="">No clinicians available</option>
                    }
                    else
                    {
                        @foreach (var clinician in FilteredClinicianOptions)
                        {
                            <option value="@clinician.Id">@clinician.Name</option>
                        }
                    }
                </select>
            </div>
        }

        <div class="week-grouping-control" role="group" aria-label="Week grouping">
            <button type="button"
                    class="week-grouping-control__button @(WeekGrouping == AppointmentsWeekGrouping.Clinician ? "selected" : "")"
                    aria-pressed="@GetPressedState(AppointmentsWeekGrouping.Clinician)"
                    @onclick="() => SelectWeekGrouping(AppointmentsWeekGrouping.Clinician)">
                Clinician
            </button>
            <button type="button"
                    class="week-grouping-control__button @(WeekGrouping == AppointmentsWeekGrouping.Day ? "selected" : "")"
                    aria-pressed="@GetPressedState(AppointmentsWeekGrouping.Day)"
                    @onclick="() => SelectWeekGrouping(AppointmentsWeekGrouping.Day)">
                Day
            </button>
        </div>
    }
    
    <button type="button" 
            class="filters-button @(IsFiltersOpen ? "active" : "")" 
            @onclick="ToggleFilters">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M2 4H14M4 8H12M6 12H10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span>Filters</span>
        <svg class="chevron @(IsFiltersOpen ? "open" : "")" width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M4 6L8 10L12 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
    </button>
    
    @if (IsFiltersOpen)
    {
        <AppointmentFiltersPanel Filter="@CurrentFilter" 
                                OnFilterChanged="OnFilterChanged" />
    }
    
    <AppointmentsDaySwitcher SelectedDate="SelectedDate"
                             SelectedView="SelectedView"
                             OnPrevDay="OnPrevDay"
                             OnNextDay="OnNextDay"
                             OnToday="OnToday" />
    
    <PatientStatusOverview TotalCount="TotalCount"
                          InProgressCount="InProgressCount"
                          CheckedInCount="CheckedInCount"
                          MissingIntakeCount="MissingIntakeCount" />
</div>

@code {
    [Parameter]
    public AppointmentsView SelectedView { get; set; } = AppointmentsView.Today;

    [Parameter]
    public AppointmentsWeekGrouping WeekGrouping { get; set; } = AppointmentsWeekGrouping.Clinician;

    [Parameter]
    public EventCallback<AppointmentsWeekGrouping> OnWeekGroupingChanged { get; set; }

    [Parameter]
    public bool ShowClinicianSelector { get; set; }

    [Parameter]
    public IReadOnlyList<WeekClinicianFilterOption> ClinicianOptions { get; set; } = Array.Empty<WeekClinicianFilterOption>();

    [Parameter]
    public string SelectedClinicianId { get; set; } = string.Empty;

    [Parameter]
    public EventCallback<string> OnSelectedClinicianIdChanged { get; set; }

    [Parameter]
    public EventCallback<AppointmentsView> OnViewChanged { get; set; }

    [Parameter]
    public DateTime SelectedDate { get; set; } = DateTime.Today;

    [Parameter]
    public EventCallback OnPrevDay { get; set; }

    [Parameter]
    public EventCallback OnNextDay { get; set; }

    [Parameter]
    public EventCallback OnToday { get; set; }

    [Parameter]
    public int TotalCount { get; set; } = 12;

    [Parameter]
    public int InProgressCount { get; set; } = 1;

    [Parameter]
    public int CheckedInCount { get; set; } = 1;

    [Parameter]
    public int MissingIntakeCount { get; set; } = 2;

    [Parameter]
    public bool IsFiltersOpen { get; set; } = false;

    [Parameter]
    public EventCallback<bool> IsFiltersOpenChanged { get; set; }

    [Parameter]
    public AppointmentsFilter CurrentFilter { get; set; } = new();

    [Parameter]
    public EventCallback<AppointmentsFilter> OnFilterChanged { get; set; }

    private string clinicianSearchText = string.Empty;

    private IReadOnlyList<WeekClinicianFilterOption> FilteredClinicianOptions =>
        string.IsNullOrWhiteSpace(clinicianSearchText)
            ? ClinicianOptions
            : ClinicianOptions
                .Where(option => option.Name.Contains(clinicianSearchText, StringComparison.OrdinalIgnoreCase))
                .ToList();

    protected override async Task OnParametersSetAsync()
    {
        if (ShowClinicianSelector
            && ClinicianOptions.Count > 0
            && !ClinicianOptions.Any(option => string.Equals(option.Id, SelectedClinicianId, StringComparison.OrdinalIgnoreCase)))
        {
            clinicianSearchText = string.Empty;
            await OnSelectedClinicianIdChanged.InvokeAsync(ClinicianOptions[0].Id);
        }
    }

    private async Task ToggleFilters()
    {
        await IsFiltersOpenChanged.InvokeAsync(!IsFiltersOpen);
    }

    private void HandleClinicianSearchChanged(ChangeEventArgs args)
    {
        clinicianSearchText = args.Value?.ToString() ?? string.Empty;
    }

    private async Task HandleClinicianSelectionChangedAsync(ChangeEventArgs args)
    {
        await OnSelectedClinicianIdChanged.InvokeAsync(args.Value?.ToString() ?? string.Empty);
    }

    private async Task SelectWeekGrouping(AppointmentsWeekGrouping grouping)
    {
        if (WeekGrouping != grouping)
        {
            await OnWeekGroupingChanged.InvokeAsync(grouping);
        }
    }

    private string GetPressedState(AppointmentsWeekGrouping grouping) =>
        WeekGrouping == grouping ? "true" : "false";
}
