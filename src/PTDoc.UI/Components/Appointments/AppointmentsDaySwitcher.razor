@* Day Switcher Component *@

<div class="day-switcher">
    <div class="switcher-content">
        <button type="button" class="nav-button" @onclick="OnPrevDay" aria-label="@PreviousLabel">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M10 12L6 8L10 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        </button>
        
        <div class="date-content">
            <h2>@FormattedDate</h2>
            <p>@Label</p>
        </div>
        
        <button type="button" class="nav-button" @onclick="OnNextDay" aria-label="@NextLabel">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M6 4L10 8L6 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        </button>
    </div>
</div>

@code {
    [Parameter]
    public DateTime SelectedDate { get; set; } = DateTime.Today;

    [Parameter]
    public AppointmentsView SelectedView { get; set; } = AppointmentsView.Today;

    [Parameter]
    public EventCallback OnPrevDay { get; set; }

    [Parameter]
    public EventCallback OnNextDay { get; set; }

    [Parameter]
    public EventCallback OnToday { get; set; }

    private string FormattedDate => SelectedView == AppointmentsView.Week
        ? AppointmentsDateFormatter.FormatWeekRange(SelectedDate)
        : SelectedDate.ToString("dddd, MMMM d, yyyy");

    private string Label => SelectedView == AppointmentsView.Week
        ? "Week Schedule"
        : SelectedDate.Date == DateTime.Today.Date ? "Today's Schedule" : "Schedule";

    private string PreviousLabel => SelectedView == AppointmentsView.Week ? "Previous week" : "Previous day";

    private string NextLabel => SelectedView == AppointmentsView.Week ? "Next week" : "Next day";
}
