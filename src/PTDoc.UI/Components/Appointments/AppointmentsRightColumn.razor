@using PTDoc.Application.DTOs
@using PTDoc.Core.Models

@* Appointments Right Column - Composition Component *@

<div class="appointments-right-column">
    <AppointmentsRightHeader ViewLabel="@ViewLabel" />
    
    <ClinicianScheduler SelectedDate="@SelectedDate" 
                       Clinicians="@Clinicians"
                       Appointments="@Appointments"
                       View="@View"
                       Filter="@Filter"
                       OnAppointmentSelected="@OnAppointmentSelected"
                       AppointmentStatusOverrides="@AppointmentStatusOverrides" />
</div>

@code {
    [Parameter]
    public string ViewLabel { get; set; } = "Today's Appointments";

    [Parameter]
    public DateTime SelectedDate { get; set; } = DateTime.Today;

    [Parameter]
    public List<ClinicianSchedule>? Clinicians { get; set; }

    [Parameter]
    public IReadOnlyList<AppointmentListItemResponse>? Appointments { get; set; }

    [Parameter]
    public AppointmentsView View { get; set; } = AppointmentsView.Today;

    [Parameter]
    public AppointmentsFilter? Filter { get; set; }

    [Parameter]
    public EventCallback<AppointmentDetailViewModel> OnAppointmentSelected { get; set; }

    [Parameter]
    public IReadOnlyDictionary<string, string>? AppointmentStatusOverrides { get; set; }
}
