@using PTDoc.Application.DTOs
@using PTDoc.Core.Models

@* Clinician Scheduler Component *@

<div class="clinician-scheduler">
    <div class="scheduler-viewport">
        <div class="scheduler-grid @(View == AppointmentsView.Week ? "week-view" : "")">
            @* Time Column *@
            <div class="time-column">
                <div class="time-header">
                    @if (View == AppointmentsView.Week)
                    {
                        <span class="week-time-label">Time</span>
                    }
                </div>
                <div class="time-slots-grid" style="@GetSlotGridStyle()">
                    @foreach (var time in TimeSlots)
                    {
                        <div class="time-slot">@time</div>
                    }
                </div>
            </div>
            
            @if (View == AppointmentsView.Today)
            {
                @* Clinician Columns (Today View) *@
                @if (Clinicians != null)
                {
                    @foreach (var clinician in Clinicians)
                    {
                        <div class="clinician-column">
                            <div class="clinician-header">
                                <div class="clinician-info">
                                    <h3>@clinician.Name</h3>
                                    <p>@clinician.AppointmentCount appts</p>
                                </div>
                            </div>
                            
                            <div class="appointments-container">
                                <div class="appointment-slots-grid" style="@GetSlotGridStyle()" aria-hidden="true">
                                    @for (int i = 0; i < SlotCount; i++)
                                    {
                                        <div class="appointment-slot"></div>
                                    }
                                </div>
                                
                                @* Render appointments for this clinician *@
                                @foreach (var appt in GetAppointmentsForClinician(clinician.Name))
                                {
                                    var effectiveBlockStatus = GetEffectiveBlockStatus(appt, SelectedDate);
                                    <button type="button"
                                            class="appointment-block @GetAppointmentClass(effectiveBlockStatus) @GetAppointmentDensityClass(appt)"
                                            title="@($"{appt.Time} - {appt.PatientName}")"
                                            aria-label="@($"Open appointment details for {appt.PatientName} at {appt.Time}")"
                                            style="@GetAppointmentStyle(appt)"
                                            @onclick="@(() => OpenAppointmentDetailsAsync(appt, SelectedDate))">
                                        <div class="appointment-content">
                                            <div class="appointment-time">
                                                <svg width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                                                    <circle cx="6" cy="6" r="5" stroke="currentColor" stroke-width="1.5"/>
                                                    <path d="M6 3V6L8 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                                                </svg>
                                                <span>@appt.Time</span>
                                            </div>
                                            <div class="appointment-patient">@appt.PatientName</div>
                                            @if (string.Equals(GetEffectiveAppointmentStatusLabel(appt, SelectedDate), "Completed", StringComparison.OrdinalIgnoreCase))
                                            {
                                                <div class="appointment-status">
                                                    <span class="checkmark">✓</span>
                                                </div>
                                            }
                                        </div>
                                    </button>
                                }
                            </div>
                        </div>
                    }
                }
            }
            else
            {
                @* Week View - Day Columns *@
                @foreach (var day in GetWeekDays())
                {
                    <div class="clinician-column week-day-column">
                        <div class="clinician-header">
                            <div class="clinician-info">
                                <h3>@day.DayName</h3>
                                <p>@day.Date.ToString("MMM d")</p>
                            </div>
                        </div>
                        
                        <div class="appointments-container">
                            <div class="appointment-slots-grid" style="@GetSlotGridStyle()" aria-hidden="true">
                                @for (int i = 0; i < SlotCount; i++)
                                {
                                    <div class="appointment-slot"></div>
                                }
                            </div>
                            
                            @* Render appointments for this day *@
                            @foreach (var appt in GetAppointmentsForDay(day.Date))
                            {
                                var effectiveBlockStatus = GetEffectiveBlockStatus(appt, day.Date);
                                <button type="button"
                                        class="appointment-block @GetAppointmentClass(effectiveBlockStatus) @GetAppointmentDensityClass(appt)"
                                        title="@($"{appt.Time} - {appt.PatientName}")"
                                        aria-label="@($"Open appointment details for {appt.PatientName} at {appt.Time}")"
                                        style="@GetAppointmentStyle(appt)"
                                        @onclick="@(() => OpenAppointmentDetailsAsync(appt, day.Date))">
                                    <div class="appointment-content">
                                        <div class="appointment-time">
                                            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                                                <circle cx="6" cy="6" r="5" stroke="currentColor" stroke-width="1.5"/>
                                                <path d="M6 3V6L8 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                                            </svg>
                                            <span>@appt.Time</span>
                                        </div>
                                        <div class="appointment-patient">@appt.PatientName</div>
                                        @if (string.Equals(GetEffectiveAppointmentStatusLabel(appt, day.Date), "Completed", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <div class="appointment-status">
                                                <span class="checkmark">✓</span>
                                            </div>
                                        }
                                    </div>
                                </button>
                            }
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

@code {
    [Parameter]
    public DateTime SelectedDate { get; set; } = DateTime.Today;

    [Parameter]
    public List<ClinicianSchedule>? Clinicians { get; set; }

    [Parameter]
    public IReadOnlyList<AppointmentListItemResponse>? Appointments { get; set; }

    [Parameter]
    public AppointmentsView View { get; set; } = AppointmentsView.Today;

    [Parameter]
    public AppointmentsFilter? Filter { get; set; }

    [Parameter]
    public EventCallback<AppointmentDetailViewModel> OnAppointmentSelected { get; set; }

    [Parameter]
    public IReadOnlyDictionary<string, string>? AppointmentStatusOverrides { get; set; }

    // Scheduler configuration. These parameters allow the calendar range to adapt
    // automatically if scheduling settings change.
    [Parameter] public int StartHour { get; set; } = 7;
    [Parameter] public int EndHour { get; set; } = 19;
    [Parameter] public int SlotMinutes { get; set; } = 60;
    
    // Week start configuration (Sunday is standard for US healthcare scheduling)
    // Change to DayOfWeek.Monday for international users where weeks start on Monday
    private const DayOfWeek WeekStartDay = DayOfWeek.Sunday;

    private int EffectiveStartHour { get; set; }
    private int EffectiveEndHour { get; set; }
    private int EffectiveSlotMinutes { get; set; }

    private TimeOnly CalendarStart => new(EffectiveStartHour, 0);
    private TimeOnly CalendarEnd => new(EffectiveEndHour, 0);

    private int SlotCount { get; set; }
    private int TotalCalendarMinutes { get; set; }
    private IReadOnlyList<string> TimeSlots { get; set; } = Array.Empty<string>();

    protected override void OnParametersSet()
    {
        // Reinitialize scheduler geometry whenever date/view/settings change so time slots
        // remain visible and consistent across navigation.
        EffectiveStartHour = Math.Clamp(StartHour, 0, 23);
        EffectiveEndHour = Math.Clamp(EndHour, EffectiveStartHour + 1, 23);
        EffectiveSlotMinutes = Math.Max(15, SlotMinutes);

        var rangeMinutes = (CalendarEnd.ToTimeSpan() - CalendarStart.ToTimeSpan()).TotalMinutes;

        // SlotCount is the number of intervals in the visible range, not the number of labels.
        // Example: 7:00 AM -> 7:00 PM is 12 one-hour intervals.
        SlotCount = Math.Max(1, (int)Math.Ceiling(rangeMinutes / EffectiveSlotMinutes));
        TotalCalendarMinutes = SlotCount * EffectiveSlotMinutes;
        TimeSlots = Enumerable
            .Range(0, SlotCount)
            .Select(index => CalendarStart.AddMinutes(index * EffectiveSlotMinutes).ToString("h:mm tt"))
            .ToList();
    }

    private string GetSlotGridStyle() => $"grid-template-rows: repeat({SlotCount}, minmax(0, 1fr));";

    private List<WeekDay> GetWeekDays()
    {
        // Calculate start of week based on configured WeekStartDay
        // Formula: ((currentDay - weekStartDay + 7) % 7) gives days from week start
        // Example: If today is Wednesday (3) and week starts Sunday (0): ((3 - 0 + 7) % 7) = 3 days
        // Example: If today is Sunday (0) and week starts Sunday (0): ((0 - 0 + 7) % 7) = 0 days
        var daysFromWeekStart = ((int)SelectedDate.DayOfWeek - (int)WeekStartDay + 7) % 7;
        var startOfWeek = SelectedDate.AddDays(-daysFromWeekStart);
        
        var weekDays = new List<WeekDay>();

        for (int i = 0; i < 7; i++)
        {
            var date = startOfWeek.AddDays(i);
            weekDays.Add(new WeekDay
            {
                Date = date,
                DayName = date.ToString("ddd")
            });
        }

        return weekDays;
    }

    private List<SchedulerAppointmentItem> GetAppointmentsForClinician(string clinicianName)
    {
        if (Appointments is null)
        {
            return new List<SchedulerAppointmentItem>();
        }

        return Appointments
            .Where(appointment =>
                string.Equals(GetEffectiveClinicianName(appointment), clinicianName, StringComparison.OrdinalIgnoreCase)
                && ToLocalTime(appointment.StartTimeUtc).Date == SelectedDate.Date)
            .OrderBy(appointment => ToLocalTime(appointment.StartTimeUtc))
            .Select(BuildSchedulerAppointment)
            .ToList();
    }

    private List<SchedulerAppointmentItem> GetAppointmentsForDay(DateTime date)
    {
        if (Appointments is null)
        {
            return new List<SchedulerAppointmentItem>();
        }

        return Appointments
            .Where(appointment => ToLocalTime(appointment.StartTimeUtc).Date == date.Date)
            .OrderBy(appointment => ToLocalTime(appointment.StartTimeUtc))
            .Select(BuildSchedulerAppointment)
            .ToList();
    }

    private string GetAppointmentClass(string status)
    {
        return status switch
        {
            "in-progress" => "in-progress",
            "checked-in" => "checked-in",
            "missing-intake" => "missing-intake",
            "completed" => "completed",
            _ => ""
        };
    }

    private string GetAppointmentDensityClass(SchedulerAppointmentItem appt)
    {
        if (appt.DurationMinutes <= 30)
        {
            return "appointment-block--compact";
        }

        if (appt.DurationMinutes <= 45)
        {
            return "appointment-block--regular";
        }

        return "appointment-block--comfortable";
    }

    private string GetAppointmentStyle(SchedulerAppointmentItem appt)
    {
        var startMinutes = Math.Clamp(GetAppointmentStartOffsetMinutes(appt), 0, TotalCalendarMinutes);
        var visibleDurationMinutes = Math.Clamp(appt.DurationMinutes, 0, TotalCalendarMinutes - startMinutes);

        // Use percentages instead of pixels so the calendar scales with the container height.
        var topPercent = TotalCalendarMinutes == 0 ? 0 : (startMinutes / (double)TotalCalendarMinutes) * 100;
        var heightPercent = TotalCalendarMinutes == 0 ? 0 : (visibleDurationMinutes / (double)TotalCalendarMinutes) * 100;

        return FormattableString.Invariant($"top: {topPercent:F4}%; height: {heightPercent:F4}%;");
    }

    private int GetAppointmentStartOffsetMinutes(SchedulerAppointmentItem appt)
    {
        return (int)(appt.StartTime.ToTimeSpan() - CalendarStart.ToTimeSpan()).TotalMinutes;
    }

    private Task OpenAppointmentDetailsAsync(SchedulerAppointmentItem appointment, DateTime appointmentDate)
    {
        if (!OnAppointmentSelected.HasDelegate)
        {
            return Task.CompletedTask;
        }

        return OnAppointmentSelected.InvokeAsync(BuildAppointmentDetail(appointment, appointmentDate));
    }

    private AppointmentDetailViewModel BuildAppointmentDetail(SchedulerAppointmentItem appointment, DateTime appointmentDate)
    {
        return new AppointmentDetailViewModel
        {
            AppointmentId = appointment.AppointmentId,
            PatientRecordId = appointment.PatientRecordId,
            PatientName = appointment.PatientName,
            PatientId = GetDisplayPatientIdentifier(appointment),
            ClinicianId = appointment.ClinicianId,
            ClinicianName = appointment.ClinicianName,
            AppointmentDate = appointmentDate,
            StartTime = appointment.StartTime,
            DurationMinutes = appointment.DurationMinutes,
            AppointmentType = appointment.AppointmentType,
            AppointmentStatus = GetEffectiveAppointmentStatusLabel(appointment, appointmentDate),
            IntakeStatus = appointment.IntakeStatus,
            Notes = appointment.Notes
        };
    }

    private string GetEffectiveBlockStatus(SchedulerAppointmentItem appointment, DateTime appointmentDate)
    {
        var appointmentStatus = GetEffectiveAppointmentStatusLabel(appointment, appointmentDate);

        return appointmentStatus.ToLowerInvariant() switch
        {
            "checked in" => "checked-in",
            "in progress" => "in-progress",
            "completed" => "completed",
            _ when string.Equals(appointment.IntakeStatus, "Missing", StringComparison.OrdinalIgnoreCase) => "missing-intake",
            _ => "scheduled"
        };
    }

    private string GetEffectiveAppointmentStatusLabel(SchedulerAppointmentItem appointment, DateTime appointmentDate)
    {
        var key = BuildAppointmentKey(appointment);

        if (AppointmentStatusOverrides is not null
            && AppointmentStatusOverrides.TryGetValue(key, out var overriddenStatus))
        {
            return overriddenStatus;
        }

        return appointment.AppointmentStatus;
    }

    private static string BuildAppointmentKey(SchedulerAppointmentItem appointment) =>
        appointment.AppointmentId.ToString("D");

    private static string GetDisplayPatientIdentifier(SchedulerAppointmentItem appointment)
    {
        if (!string.IsNullOrWhiteSpace(appointment.MedicalRecordNumber))
        {
            return appointment.MedicalRecordNumber;
        }

        var compactId = appointment.PatientRecordId.ToString("N");
        return $"PT-{compactId[..6].ToUpperInvariant()}";
    }

    private static DateTime ToLocalTime(DateTime utcTime)
    {
        var normalizedUtc = utcTime.Kind == DateTimeKind.Utc
            ? utcTime
            : DateTime.SpecifyKind(utcTime, DateTimeKind.Utc);

        return normalizedUtc.ToLocalTime();
    }

    private static string GetEffectiveClinicianName(AppointmentListItemResponse appointment)
    {
        if (string.IsNullOrWhiteSpace(appointment.ClinicianName))
        {
            return "Assigned Clinician";
        }

        return appointment.ClinicianName.StartsWith("Dr. ", StringComparison.OrdinalIgnoreCase)
            ? appointment.ClinicianName
            : $"Dr. {appointment.ClinicianName}";
    }

    private static SchedulerAppointmentItem BuildSchedulerAppointment(AppointmentListItemResponse appointment)
    {
        var localStartTime = ToLocalTime(appointment.StartTimeUtc);
        var localEndTime = ToLocalTime(appointment.EndTimeUtc);
        var durationMinutes = (int)Math.Round((localEndTime - localStartTime).TotalMinutes);

        if (durationMinutes <= 0)
        {
            durationMinutes = 45;
        }

        return new SchedulerAppointmentItem
        {
            AppointmentId = appointment.Id,
            PatientRecordId = appointment.PatientRecordId,
            PatientName = appointment.PatientName,
            MedicalRecordNumber = appointment.MedicalRecordNumber,
            ClinicianId = appointment.ClinicianId?.ToString() ?? string.Empty,
            ClinicianName = GetEffectiveClinicianName(appointment),
            Time = localStartTime.ToString("h:mm tt"),
            StartTime = TimeOnly.FromDateTime(localStartTime),
            Status = appointment.AppointmentStatus,
            AppointmentType = appointment.AppointmentType,
            AppointmentStatus = appointment.AppointmentStatus,
            IntakeStatus = appointment.IntakeStatus,
            StartMinute = (int)(localStartTime.TimeOfDay - new TimeSpan(localStartTime.Hour, localStartTime.Minute, 0)).TotalMinutes,
            DurationMinutes = durationMinutes,
            Notes = appointment.Notes
        };
    }

    private sealed class SchedulerAppointmentItem
    {
        public Guid AppointmentId { get; init; }
        public Guid PatientRecordId { get; init; }
        public string PatientName { get; init; } = string.Empty;
        public string? MedicalRecordNumber { get; init; }
        public string ClinicianId { get; init; } = string.Empty;
        public string ClinicianName { get; init; } = string.Empty;
        public string Time { get; init; } = string.Empty;
        public TimeOnly StartTime { get; init; }
        public string Status { get; init; } = string.Empty;
        public string AppointmentType { get; init; } = string.Empty;
        public string AppointmentStatus { get; init; } = string.Empty;
        public string IntakeStatus { get; init; } = string.Empty;
        public int StartMinute { get; init; }
        public int DurationMinutes { get; init; }
        public string Notes { get; init; } = string.Empty;
    }
}
