@inject IJSRuntime JS
@implements IAsyncDisposable

@if (IsOpen)
{
    <div class="modal-overlay" @onclick="HandleOverlayClick" @onclick:stopPropagation="false">
        <div class="modal-container" @ref="modalContainerRef" @onclick:stopPropagation="true" role="dialog" 
             aria-labelledby="new-appointment-title" aria-describedby="new-appointment-description" aria-modal="true">
            
            <!-- Modal Header -->
            <div class="modal-header">
                <div class="modal-title-container">
                    <svg class="modal-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M10 5V15M5 10H15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        <circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="2"/>
                    </svg>
                    <h2 id="new-appointment-title">@Title</h2>
                </div>
                <p id="new-appointment-description" class="modal-description">@Description</p>
            </div>

            <!-- Modal Body -->
            <form class="modal-body" novalidate @onsubmit="HandleSubmit" @onsubmit:preventDefault="true">
                @if (validationErrors.Count > 0)
                {
                    <div class="validation-summary" role="alert" aria-live="assertive">
                        <p>Review required appointment details.</p>
                        <ul>
                            @foreach (var error in validationErrors.Values)
                            {
                                <li>@error</li>
                            }
                        </ul>
                    </div>
                }

                <!-- Patient Selection -->
                <div class="form-field">
                    <label for="patient" class="form-label">Patient <span class="required">*</span></label>
                    <select 
                        id="patient" 
                        class="@GetInputClass(nameof(PatientId))"
                        @bind="PatientId"
                        @ref="firstInputRef"
                        aria-required="true"
                        aria-invalid="@AriaInvalid(nameof(PatientId))"
                        aria-describedby="@GetFieldDescriptionId(nameof(PatientId))">
                        @if (GetPatientOptions().Count == 0)
                        {
                            <option value="">No patients available</option>
                        }
                        else
                        {
                            <option value="">Select a patient...</option>
                            @foreach (var patient in GetPatientOptions())
                            {
                                <option value="@patient.Id">@patient.Name</option>
                            }
                        }
                    </select>
                    @RenderFieldError(nameof(PatientId))
                </div>

                <!-- Appointment Type -->
                <div class="form-field">
                    <label for="appointmentType" class="form-label">Appointment Type <span class="required">*</span></label>
                    <select 
                        id="appointmentType" 
                        class="@GetInputClass(nameof(AppointmentType))"
                        @bind="AppointmentType"
                        @ref="appointmentTypeInputRef"
                        aria-required="true"
                        aria-invalid="@AriaInvalid(nameof(AppointmentType))"
                        aria-describedby="@GetFieldDescriptionId(nameof(AppointmentType))">
                        <option value="">Select type...</option>
                        <option value="Initial Evaluation">Initial Evaluation</option>
                        <option value="Follow Up">Follow Up</option>
                        <option value="Re-Evaluation">Re-Evaluation</option>
                        <option value="Discharge">Discharge</option>
                    </select>
                    @RenderFieldError(nameof(AppointmentType))
                </div>

                <!-- Date & Time Row -->
                <div class="form-row">
                    <div class="form-field">
                        <label for="appointmentDate" class="form-label">Date <span class="required">*</span></label>
                        <input 
                        id="appointmentDate"
                        type="date"
                        class="@GetInputClass(nameof(AppointmentDate))"
                        @bind="AppointmentDate"
                        @ref="appointmentDateInputRef"
                        aria-required="true"
                        aria-invalid="@AriaInvalid(nameof(AppointmentDate))"
                        aria-describedby="@GetFieldDescriptionId(nameof(AppointmentDate))" />
                        @RenderFieldError(nameof(AppointmentDate))
                    </div>
                    <div class="form-field">
                        <label for="appointmentTime" class="form-label">Time <span class="required">*</span></label>
                        <input 
                            id="appointmentTime" 
                            type="time" 
                            class="@GetInputClass(nameof(AppointmentTimeInput))"
                            @bind="AppointmentTimeInput"
                            @ref="appointmentTimeInputRef"
                            aria-required="true"
                            aria-invalid="@AriaInvalid(nameof(AppointmentTimeInput))"
                            aria-describedby="@GetFieldDescriptionId(nameof(AppointmentTimeInput))" />
                        @RenderFieldError(nameof(AppointmentTimeInput))
                    </div>
                </div>

                <!-- Duration -->
                <div class="form-field">
                    <label for="duration" class="form-label">Duration (minutes) <span class="required">*</span></label>
                    <select 
                        id="duration" 
                        class="@GetInputClass(nameof(DurationMinutes))"
                        @bind="DurationMinutes"
                        @ref="durationInputRef"
                        aria-required="true"
                        aria-invalid="@AriaInvalid(nameof(DurationMinutes))"
                        aria-describedby="@GetFieldDescriptionId(nameof(DurationMinutes))">
                        <option value="30">30 minutes</option>
                        <option value="45">45 minutes</option>
                        <option value="60">60 minutes</option>
                        <option value="90">90 minutes</option>
                    </select>
                    @RenderFieldError(nameof(DurationMinutes))
                </div>

                <!-- Clinician Selection -->
                <div class="form-field">
                    <label for="clinician" class="form-label">Clinician <span class="required">*</span></label>
                    <select 
                        id="clinician" 
                        class="@GetInputClass(nameof(ClinicianId))"
                        @bind="ClinicianId"
                        @ref="clinicianInputRef"
                        aria-required="true"
                        aria-invalid="@AriaInvalid(nameof(ClinicianId))"
                        aria-describedby="@GetFieldDescriptionId(nameof(ClinicianId))">
                        @if (GetClinicianOptions().Count == 0)
                        {
                            <option value="">No clinicians available</option>
                        }
                        else
                        {
                            <option value="">Select clinician...</option>
                            @foreach (var clinician in GetClinicianOptions())
                            {
                                <option value="@clinician.Id">@clinician.Name</option>
                            }
                        }
                    </select>
                    @RenderFieldError(nameof(ClinicianId))
                </div>

                @if (!string.IsNullOrWhiteSpace(submitFeedbackMessage))
                {
                    <div class="submit-feedback submit-feedback--error" role="alert" aria-live="assertive">
                        @submitFeedbackMessage
                    </div>
                }

                <!-- Notes (Optional) -->
                <div class="form-field">
                    <label for="notes" class="form-label">Notes</label>
                    <textarea 
                        id="notes" 
                        class="form-input form-textarea" 
                        rows="3"
                        placeholder="Add any additional notes..."
                        @bind="Notes"></textarea>
                </div>

                <!-- Modal Footer (Buttons) -->
                <div class="modal-footer">
                    <button type="button" class="btn-cancel" @onclick="Close">
                        Cancel
                    </button>
                    <button type="submit" class="btn-primary" disabled="@isSubmitting" aria-busy="@isSubmitting">
                        <svg class="btn-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                            <path d="M8 3V13M3 8H13" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            <circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1"/>
                        </svg>
                        @(isSubmitting ? "Saving..." : SubmitButtonText)
                    </button>
                </div>
            </form>

            <!-- Close Button -->
            <button type="button" class="modal-close" @onclick="Close" aria-label="Close modal">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M12 4L4 12M4 4L12 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </button>
        </div>
    </div>
}

@code {
    [Parameter]
    public bool IsOpen { get; set; }

    [Parameter]
    public EventCallback<bool> IsOpenChanged { get; set; }

    [Parameter]
    public Func<AppointmentFormData, Task<bool>>? OnSubmit { get; set; }

    [Parameter]
    public string Title { get; set; } = "New Appointment";

    [Parameter]
    public string Description { get; set; } = "Schedule a new appointment for a patient";

    [Parameter]
    public string SubmitButtonText { get; set; } = "Schedule Appointment";

    [Parameter]
    public AppointmentFormData? InitialValues { get; set; }

    [Parameter]
    public List<PatientOption> AvailablePatients { get; set; } = new();

    [Parameter]
    public List<ClinicianOption> AvailableClinicians { get; set; } = new();

    private ElementReference firstInputRef;
    private ElementReference appointmentTypeInputRef;
    private ElementReference appointmentDateInputRef;
    private ElementReference appointmentTimeInputRef;
    private ElementReference durationInputRef;
    private ElementReference clinicianInputRef;
    private ElementReference modalContainerRef;
    private IJSObjectReference? modalModule;
    private DotNetObjectReference<NewAppointmentModal>? dotNetRef;
    private string modalId = $"new-appointment-modal-{Guid.NewGuid():N}";
    private bool wasOpen;
    private bool modalAccessibilityActive;

    private string PatientId { get; set; } = string.Empty;
    private string AppointmentType { get; set; } = string.Empty;
    private DateTime? AppointmentDate { get; set; } = DateTime.Today;
    private TimeOnly? AppointmentTimeInput { get; set; } = new TimeOnly(9, 0);
    private int DurationMinutes { get; set; } = 45;
    private string ClinicianId { get; set; } = string.Empty;
    private string Notes { get; set; } = string.Empty;
    private string? submitFeedbackMessage;
    private bool isSubmitting;
    private readonly Dictionary<string, string> validationErrors = new(StringComparer.Ordinal);

    protected override void OnParametersSet()
    {
        if (IsOpen && !wasOpen)
        {
            ApplyFormState(InitialValues);
        }

        wasOpen = IsOpen;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                modalModule = await JS.InvokeAsync<IJSObjectReference>("import", "./_content/PTDoc.UI/js/modal.js");
                dotNetRef = DotNetObjectReference.Create(this);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Failed to load modal.js: {ex.Message}");
            }
        }

        if (IsOpen && !modalAccessibilityActive && modalModule != null && dotNetRef != null)
        {
            try
            {
                await modalModule.InvokeVoidAsync("lockBodyScroll");
                await modalModule.InvokeVoidAsync("registerEscapeHandler", modalId, dotNetRef);
                await firstInputRef.FocusAsync();
                modalAccessibilityActive = true;
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Modal JS interop error: {ex.Message}");
            }
        }
        else if (!IsOpen && modalAccessibilityActive && modalModule != null)
        {
            try
            {
                await modalModule.InvokeVoidAsync("unlockBodyScroll");
                await modalModule.InvokeVoidAsync("unregisterEscapeHandler", modalId);
                modalAccessibilityActive = false;
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Modal cleanup error: {ex.Message}");
            }
        }
    }

    [JSInvokable]
    public async Task CloseFromJs()
    {
        await Close();
    }

    private async Task Close()
    {
        if (isSubmitting)
        {
            return;
        }

        await IsOpenChanged.InvokeAsync(false);

        ApplyFormState(null);
        submitFeedbackMessage = null;
        wasOpen = false;
    }

    private void HandleOverlayClick()
    {
        _ = Close();
    }

    private async Task HandleSubmit()
    {
        if (isSubmitting)
        {
            return;
        }

        submitFeedbackMessage = null;
        validationErrors.Clear();

        if (!ValidateForm())
        {
            await FocusFirstInvalidFieldAsync();
            return;
        }

        // Convert TimeOnly to TimeSpan
        var timeOnly = AppointmentTimeInput ?? new TimeOnly(9, 0);
        TimeSpan parsedTime = new TimeSpan(timeOnly.Hour, timeOnly.Minute, 0);
        
        var formData = new AppointmentFormData
        {
            PatientId = PatientId,
            AppointmentType = AppointmentType,
            AppointmentDate = AppointmentDate ?? DateTime.Today,
            AppointmentTime = parsedTime,
            DurationMinutes = DurationMinutes,
            ClinicianId = ClinicianId,
            Notes = Notes
        };

        isSubmitting = true;

        bool wasSuccessful;
        try
        {
            wasSuccessful = OnSubmit is null || await OnSubmit(formData);
        }
        catch
        {
            submitFeedbackMessage = "Unable to save the appointment right now. Please try again.";
            return;
        }
        finally
        {
            isSubmitting = false;
        }

        if (wasSuccessful)
        {
            await Close();
            return;
        }

        submitFeedbackMessage ??= "Unable to save the appointment. Review the details and try again.";
    }

    private bool ValidateForm()
    {
        validationErrors.Clear();

        if (string.IsNullOrWhiteSpace(PatientId))
        {
            validationErrors[nameof(PatientId)] = "Select a patient.";
        }

        if (string.IsNullOrWhiteSpace(AppointmentType))
        {
            validationErrors[nameof(AppointmentType)] = "Select an appointment type.";
        }

        if (!AppointmentDate.HasValue)
        {
            validationErrors[nameof(AppointmentDate)] = "Select an appointment date.";
        }

        if (!AppointmentTimeInput.HasValue)
        {
            validationErrors[nameof(AppointmentTimeInput)] = "Select an appointment time.";
        }

        if (DurationMinutes <= 0)
        {
            validationErrors[nameof(DurationMinutes)] = "Select a valid duration.";
        }

        if (string.IsNullOrWhiteSpace(ClinicianId))
        {
            validationErrors[nameof(ClinicianId)] = "Select a clinician.";
        }

        return validationErrors.Count == 0;
    }

    private async Task FocusFirstInvalidFieldAsync()
    {
        if (validationErrors.Count == 0)
        {
            return;
        }

        var firstInvalidField = validationErrors.Keys.First();

        try
        {
            switch (firstInvalidField)
            {
                case nameof(PatientId):
                    await firstInputRef.FocusAsync();
                    break;
                case nameof(AppointmentType):
                    await appointmentTypeInputRef.FocusAsync();
                    break;
                case nameof(AppointmentDate):
                    await appointmentDateInputRef.FocusAsync();
                    break;
                case nameof(AppointmentTimeInput):
                    await appointmentTimeInputRef.FocusAsync();
                    break;
                case nameof(DurationMinutes):
                    await durationInputRef.FocusAsync();
                    break;
                case nameof(ClinicianId):
                    await clinicianInputRef.FocusAsync();
                    break;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Appointment validation focus failed: {ex.Message}");
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (modalModule != null)
        {
            try
            {
                await modalModule.InvokeVoidAsync("unlockBodyScroll");
                await modalModule.InvokeVoidAsync("unregisterEscapeHandler", modalId);
                await modalModule.DisposeAsync();
                modalAccessibilityActive = false;
            }
            catch { /* Ignore disposal errors */ }
        }

        dotNetRef?.Dispose();
    }

    public class AppointmentFormData
    {
        public string PatientId { get; set; } = string.Empty;
        public string AppointmentType { get; set; } = string.Empty;
        public DateTime AppointmentDate { get; set; }
        public TimeSpan AppointmentTime { get; set; }
        public int DurationMinutes { get; set; }
        public string ClinicianId { get; set; } = string.Empty;
        public string Notes { get; set; } = string.Empty;
    }

    public class PatientOption
    {
        public string Id { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
    }

    public class ClinicianOption
    {
        public string Id { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
    }

    private IReadOnlyList<PatientOption> GetPatientOptions()
    {
        return AvailablePatients;
    }

    private IReadOnlyList<ClinicianOption> GetClinicianOptions()
    {
        return AvailableClinicians;
    }

    private void ApplyFormState(AppointmentFormData? initialValues)
    {
        if (initialValues is null)
        {
            PatientId = string.Empty;
            AppointmentType = string.Empty;
            AppointmentDate = DateTime.Today;
            AppointmentTimeInput = new TimeOnly(9, 0);
            DurationMinutes = 45;
            ClinicianId = string.Empty;
            Notes = string.Empty;
            validationErrors.Clear();
            return;
        }

        PatientId = initialValues.PatientId;
        AppointmentType = initialValues.AppointmentType;
        AppointmentDate = initialValues.AppointmentDate;
        AppointmentTimeInput = TimeOnly.FromTimeSpan(initialValues.AppointmentTime);
        DurationMinutes = initialValues.DurationMinutes;
        ClinicianId = initialValues.ClinicianId;
        Notes = initialValues.Notes;
        validationErrors.Clear();
    }

    private bool HasValidationError(string fieldName) => validationErrors.ContainsKey(fieldName);

    private string AriaInvalid(string fieldName) => HasValidationError(fieldName) ? "true" : "false";

    private string GetInputClass(string fieldName) =>
        HasValidationError(fieldName) ? "form-input form-input--invalid" : "form-input";

    private string? GetFieldDescriptionId(string fieldName) =>
        HasValidationError(fieldName) ? GetFieldErrorId(fieldName) : null;

    private string GetFieldErrorId(string fieldName) => $"new-appointment-{fieldName}-error";

    private RenderFragment RenderFieldError(string fieldName) => builder =>
    {
        if (!validationErrors.TryGetValue(fieldName, out var message))
        {
            return;
        }

        builder.OpenElement(0, "p");
        builder.AddAttribute(1, "id", GetFieldErrorId(fieldName));
        builder.AddAttribute(2, "class", "field-validation-error");
        builder.AddAttribute(3, "role", "alert");
        builder.AddContent(4, message);
        builder.CloseElement();
    };
}
