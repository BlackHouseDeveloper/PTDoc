@using PTDoc.UI.Components.Intake.Cards
@using PTDoc.UI.Components.Intake.Models
@using PTDoc.Application.Intake

<section class="demographics-step" data-testid="demographics-step">
    <BasicInfoCard
        FullName="@State.FullName"
        DateOfBirth="@State.DateOfBirth"
        SexAtBirth="@State.SexAtBirth"
        EmailAddress="@State.EmailAddress"
        PhoneNumber="@State.PhoneNumber"
        ValidationErrors="@ValidationErrors"
        AddressLine1="@State.AddressLine1"
        AddressLine2="@State.AddressLine2"
        City="@State.City"
        StateOrProvince="@State.StateOrProvince"
        PostalCode="@State.PostalCode"
        EmergencyContactName="@State.EmergencyContactName"
        EmergencyContactPhone="@State.EmergencyContactPhone"
        FullNameChanged="OnFullNameChanged"
        DateOfBirthChanged="OnDateOfBirthChanged"
        SexAtBirthChanged="OnSexAtBirthChanged"
        EmailAddressChanged="OnEmailAddressChanged"
        PhoneNumberChanged="OnPhoneNumberChanged"
        AddressLine1Changed="OnAddressLine1Changed"
        AddressLine2Changed="OnAddressLine2Changed"
        CityChanged="OnCityChanged"
        StateOrProvinceChanged="OnStateOrProvinceChanged"
        PostalCodeChanged="OnPostalCodeChanged"
        EmergencyContactNameChanged="OnEmergencyContactNameChanged"
        EmergencyContactPhoneChanged="OnEmergencyContactPhoneChanged" />

    <CareTeamCard
        PrimaryDoctorName="@State.PrimaryDoctorName"
        PrimaryDoctorPhone="@State.PrimaryDoctorPhone"
        ReferringDoctorName="@State.ReferringDoctorName"
        ReferringDoctorNpi="@State.ReferringDoctorNpi"
        ReferringDoctorPhone="@State.ReferringDoctorPhone"
        PrimaryDoctorNameChanged="OnPrimaryDoctorNameChanged"
        PrimaryDoctorPhoneChanged="OnPrimaryDoctorPhoneChanged"
        ReferringDoctorNameChanged="OnReferringDoctorNameChanged"
        ReferringDoctorNpiChanged="OnReferringDoctorNpiChanged"
        ReferringDoctorPhoneChanged="OnReferringDoctorPhoneChanged" />

    <InsurancePayerCard
        InsuranceCompanyName="@State.InsuranceCompanyName"
        MemberOrPolicyNumber="@State.MemberOrPolicyNumber"
        GroupNumber="@State.GroupNumber"
        PayerType="@State.PayerType"
        InsuranceCoverageType="@State.InsuranceCoverageType"
        SecondaryInsuranceCompanyName="@State.SecondaryInsuranceCompanyName"
        SecondaryMemberOrPolicyNumber="@State.SecondaryMemberOrPolicyNumber"
        SecondaryGroupNumber="@State.SecondaryGroupNumber"
        AdjusterName="@State.AdjusterName"
        AdjusterPhone="@State.AdjusterPhone"
        AdjusterEmail="@State.AdjusterEmail"
        AdjusterFax="@State.AdjusterFax"
        InsuranceCompanyNameChanged="OnInsuranceCompanyNameChanged"
        MemberOrPolicyNumberChanged="OnMemberOrPolicyNumberChanged"
        GroupNumberChanged="OnGroupNumberChanged"
        PayerTypeChanged="OnPayerTypeChanged"
        InsuranceCoverageTypeChanged="OnInsuranceCoverageTypeChanged"
        SecondaryInsuranceCompanyNameChanged="OnSecondaryInsuranceCompanyNameChanged"
        SecondaryMemberOrPolicyNumberChanged="OnSecondaryMemberOrPolicyNumberChanged"
        SecondaryGroupNumberChanged="OnSecondaryGroupNumberChanged"
        AdjusterNameChanged="OnAdjusterNameChanged"
        AdjusterPhoneChanged="OnAdjusterPhoneChanged"
        AdjusterEmailChanged="OnAdjusterEmailChanged"
        AdjusterFaxChanged="OnAdjusterFaxChanged" />

    <HipaaPrivacyNoticeCard
        HipaaAcknowledged="@HipaaAcknowledged"
        HipaaAcknowledgedChanged="OnHipaaAcknowledgedChanged"
        ConsentToTreatAcknowledged="@TreatmentConsentAccepted"
        ConsentToTreatAcknowledgedChanged="OnConsentToTreatChanged" />

    @if (!string.IsNullOrWhiteSpace(ValidationMessage))
    {
        <div class="demographics-step__warning" role="alert" aria-live="assertive">@ValidationMessage</div>
    }

    <div class="demographics-step__actions">
        <button type="button" class="btn btn-primary" @onclick="OnContinueClicked" data-testid="continue-button">Continue to Medical History / Pain Assessment</button>
    </div>

    <p class="demographics-step__footer">Step 1 of 5 • 20% Complete</p>
</section>

@code {
    [Parameter, EditorRequired] public IntakeWizardState State { get; set; } = new();
    [Parameter] public string? ValidationMessage { get; set; }
    [Parameter] public IReadOnlyDictionary<string, string>? ValidationErrors { get; set; }
    [Parameter] public EventCallback OnContinue { get; set; }
    [Parameter] public EventCallback OnStateChanged { get; set; }

    private IntakeConsentPacket ConsentPacket => State.EnsureConsentPacket();
    private bool HipaaAcknowledged => ConsentPacket.HipaaAcknowledged == true;
    private bool TreatmentConsentAccepted => ConsentPacket.TreatmentConsentAccepted == true;

    private async Task UpdateStateAsync(Action update)
    {
        update();
        State.IsDirty = true;

        if (OnStateChanged.HasDelegate)
        {
            await OnStateChanged.InvokeAsync();
        }
    }

    private Task OnFullNameChanged(string? value)
    {
        return UpdateStateAsync(() => State.FullName = value);
    }

    private Task OnDateOfBirthChanged(DateTime? value)
    {
        return UpdateStateAsync(() => State.DateOfBirth = value);
    }

    private Task OnSexAtBirthChanged(string? value)
    {
        return UpdateStateAsync(() => State.SexAtBirth = value);
    }

    private Task OnEmailAddressChanged(string? value)
    {
        return UpdateStateAsync(() => State.EmailAddress = value);
    }

    private Task OnPhoneNumberChanged(string? value)
    {
        return UpdateStateAsync(() => State.PhoneNumber = value);
    }

    private Task OnAddressLine1Changed(string? value)
    {
        return UpdateStateAsync(() => State.AddressLine1 = value);
    }

    private Task OnAddressLine2Changed(string? value)
    {
        return UpdateStateAsync(() => State.AddressLine2 = value);
    }

    private Task OnCityChanged(string? value)
    {
        return UpdateStateAsync(() => State.City = value);
    }

    private Task OnStateOrProvinceChanged(string? value)
    {
        return UpdateStateAsync(() => State.StateOrProvince = value);
    }

    private Task OnPostalCodeChanged(string? value)
    {
        return UpdateStateAsync(() => State.PostalCode = value);
    }

    private Task OnEmergencyContactNameChanged(string? value)
    {
        return UpdateStateAsync(() => State.EmergencyContactName = value);
    }

    private Task OnEmergencyContactPhoneChanged(string? value)
    {
        return UpdateStateAsync(() => State.EmergencyContactPhone = value);
    }

    private Task OnPrimaryDoctorNameChanged(string? value) => UpdateStateAsync(() => State.PrimaryDoctorName = value);
    private Task OnPrimaryDoctorPhoneChanged(string? value) => UpdateStateAsync(() => State.PrimaryDoctorPhone = value);
    private Task OnReferringDoctorNameChanged(string? value) => UpdateStateAsync(() => State.ReferringDoctorName = value);
    private Task OnReferringDoctorNpiChanged(string? value) => UpdateStateAsync(() => State.ReferringDoctorNpi = value);
    private Task OnReferringDoctorPhoneChanged(string? value) => UpdateStateAsync(() => State.ReferringDoctorPhone = value);

    private Task OnInsuranceCompanyNameChanged(string? value) => UpdateStateAsync(() => State.InsuranceCompanyName = value);
    private Task OnMemberOrPolicyNumberChanged(string? value) => UpdateStateAsync(() => State.MemberOrPolicyNumber = value);
    private Task OnGroupNumberChanged(string? value) => UpdateStateAsync(() => State.GroupNumber = value);
    private Task OnPayerTypeChanged(string? value) => UpdateStateAsync(() => State.PayerType = value);
    private Task OnInsuranceCoverageTypeChanged(string? value) => UpdateStateAsync(() => State.InsuranceCoverageType = value);
    private Task OnSecondaryInsuranceCompanyNameChanged(string? value) => UpdateStateAsync(() => State.SecondaryInsuranceCompanyName = value);
    private Task OnSecondaryMemberOrPolicyNumberChanged(string? value) => UpdateStateAsync(() => State.SecondaryMemberOrPolicyNumber = value);
    private Task OnSecondaryGroupNumberChanged(string? value) => UpdateStateAsync(() => State.SecondaryGroupNumber = value);
    private Task OnAdjusterNameChanged(string? value) => UpdateStateAsync(() => State.AdjusterName = value);
    private Task OnAdjusterPhoneChanged(string? value) => UpdateStateAsync(() => State.AdjusterPhone = value);
    private Task OnAdjusterEmailChanged(string? value) => UpdateStateAsync(() => State.AdjusterEmail = value);
    private Task OnAdjusterFaxChanged(string? value) => UpdateStateAsync(() => State.AdjusterFax = value);

    private Task OnHipaaAcknowledgedChanged(bool value) => UpdateStateAsync(() =>
    {
        ConsentPacket.HipaaAcknowledged = value;
        State.HipaaAcknowledged = value;
    });

    private Task OnConsentToTreatChanged(bool value) => UpdateStateAsync(() =>
    {
        ConsentPacket.TreatmentConsentAccepted = value;
        State.ConsentToTreatAcknowledged = value;
    });
    private Task OnContinueClicked() => OnContinue.HasDelegate ? OnContinue.InvokeAsync() : Task.CompletedTask;
}
