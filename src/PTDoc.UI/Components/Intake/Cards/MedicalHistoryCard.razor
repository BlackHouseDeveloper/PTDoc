@using PTDoc.Application.Intake
@using PTDoc.Application.ReferenceData
@using PTDoc.UI.Components.Intake.Models
@inject IIntakeReferenceDataCatalogService IntakeReferenceData

<section class="intake-card">
    <div class="intake-card__header">
        <div>
            <h2>Medical History</h2>
            <p class="intake-card__subtext">Use the validated intake lists instead of typing where structured options are available.</p>
        </div>
        <div class="intake-card__status-group">
            <span class="intake-card__status @(State.HasCurrentMedications ? "intake-card__status--active" : "")">Medications</span>
            <span class="intake-card__status @(State.HasOtherMedicalConditions ? "intake-card__status--active" : "")">Comorbidities</span>
            <span class="intake-card__status @(State.UsesAssistiveDevices ? "intake-card__status--active" : "")">Assistive Devices</span>
        </div>
    </div>

    <section class="intake-card__section">
        <label class="intake-card__field-label" for="medication-search">Medication Search</label>
        <input id="medication-search"
               class="form-control intake-card__search"
               type="search"
               placeholder="Search brand or generic medication"
               @bind="_medicationSearch"
               @bind:event="oninput" />

        @if (SelectedMedicationItems.Count > 0)
        {
            <div class="intake-card__chip-list">
                @foreach (var medication in SelectedMedicationItems)
                {
                    <button type="button" class="intake-card__chip intake-card__chip--selected" @onclick="() => ToggleMedicationAsync(medication.Id)">
                        @medication.DisplayLabel
                    </button>
                }
            </div>
        }

        <div class="intake-card__option-grid">
            @foreach (var medication in FilteredMedications)
            {
                var isSelected = SelectedMedicationIds.Contains(medication.Id, StringComparer.OrdinalIgnoreCase);
                <button type="button"
                        class="intake-card__chip @(isSelected ? "intake-card__chip--selected" : "")"
                        @onclick="() => ToggleMedicationAsync(medication.Id)">
                    @medication.DisplayLabel
                </button>
            }
        </div>
    </section>

    <section class="intake-card__section">
        <span class="intake-card__field-label">Comorbidities</span>
        <div class="intake-card__option-grid">
            @foreach (var option in ComorbidityCatalog)
            {
                var isSelected = SelectedComorbidityIds.Contains(option.Id, StringComparer.OrdinalIgnoreCase);
                <button type="button"
                        class="intake-card__chip @(isSelected ? "intake-card__chip--selected" : "")"
                        @onclick="() => ToggleCatalogSelectionAsync(option.Id, SelectionKind.Comorbidity)">
                    @option.Label
                </button>
            }
        </div>
    </section>

    <section class="intake-card__section">
        <span class="intake-card__field-label">Living Situation</span>
        <div class="intake-card__option-grid">
            @foreach (var option in LivingSituationCatalog)
            {
                var isSelected = SelectedLivingSituationIds.Contains(option.Id, StringComparer.OrdinalIgnoreCase);
                <button type="button"
                        class="intake-card__chip @(isSelected ? "intake-card__chip--selected" : "")"
                        @onclick="() => ToggleCatalogSelectionAsync(option.Id, SelectionKind.LivingSituation)">
                    @option.Label
                </button>
            }
        </div>
    </section>

    <section class="intake-card__section">
        <label class="intake-card__field-label" for="assistive-search">Assistive Devices</label>
        <input id="assistive-search"
               class="form-control intake-card__search"
               type="search"
               placeholder="Search assistive devices"
               @bind="_assistiveSearch"
               @bind:event="oninput" />

        <div class="intake-card__option-grid">
            @foreach (var option in FilteredAssistiveDevices)
            {
                var isSelected = SelectedAssistiveDeviceIds.Contains(option.Id, StringComparer.OrdinalIgnoreCase);
                <button type="button"
                        class="intake-card__chip @(isSelected ? "intake-card__chip--selected" : "")"
                        @onclick="() => ToggleCatalogSelectionAsync(option.Id, SelectionKind.AssistiveDevice)">
                    @option.Label
                </button>
            }
        </div>
    </section>

    <section class="intake-card__section">
        <span class="intake-card__field-label">Home Layout</span>
        <div class="intake-card__option-grid">
            @foreach (var option in HouseLayoutCatalog)
            {
                var isSelected = SelectedHouseLayoutOptionIds.Contains(option.Id, StringComparer.OrdinalIgnoreCase);
                <button type="button"
                        class="intake-card__chip @(isSelected ? "intake-card__chip--selected" : "")"
                        @onclick="() => SelectHouseLayoutAsync(option.Id)">
                    @option.Label
                </button>
            }
        </div>
    </section>

    <section class="intake-card__section intake-card__section--stacked">
        <label class="intake-card__toggle">
            <input type="checkbox"
                   class="form-check-input"
                   checked="@State.HasPreviousSurgeriesOrInjuries"
                   @onchange="OnPreviousSurgeriesChangedAsync" />
            <span>Previous Surgeries or Injuries</span>
        </label>

        <label class="intake-card__notes">Notes (optional)
            <textarea class="form-control"
                      value="@State.MedicalHistoryNotes"
                      @oninput="OnMedicalHistoryNotesChangedAsync"></textarea>
        </label>
    </section>
</section>

@code {
    [Parameter, EditorRequired] public IntakeWizardState State { get; set; } = new();
    [Parameter] public EventCallback StateChanged { get; set; }

    private string _medicationSearch = string.Empty;
    private string _assistiveSearch = string.Empty;

    private IReadOnlyList<IntakeMedicationItemDto> MedicationCatalog => IntakeReferenceData.GetMedications();
    private IReadOnlyList<IntakeCatalogOptionDto> ComorbidityCatalog => IntakeReferenceData.GetComorbidities();
    private IReadOnlyList<IntakeCatalogOptionDto> LivingSituationCatalog => IntakeReferenceData.GetLivingSituations();
    private IReadOnlyList<IntakeCatalogOptionDto> AssistiveDeviceCatalog => IntakeReferenceData.GetAssistiveDevices();
    private IReadOnlyList<IntakeCatalogOptionDto> HouseLayoutCatalog => IntakeReferenceData.GetHouseLayoutOptions();

    private IntakeStructuredDataDto StructuredData => State.EnsureStructuredData(IntakeReferenceData.GetCatalog().Version);

    private IReadOnlyList<string> SelectedMedicationIds => StructuredData.MedicationIds;
    private IReadOnlyList<string> SelectedComorbidityIds => StructuredData.ComorbidityIds;
    private IReadOnlyList<string> SelectedLivingSituationIds => StructuredData.LivingSituationIds;
    private IReadOnlyList<string> SelectedAssistiveDeviceIds => StructuredData.AssistiveDeviceIds;
    private IReadOnlyList<string> SelectedHouseLayoutOptionIds => StructuredData.HouseLayoutOptionIds;

    private IReadOnlyList<IntakeMedicationItemDto> SelectedMedicationItems => MedicationCatalog
        .Where(item => SelectedMedicationIds.Contains(item.Id, StringComparer.OrdinalIgnoreCase))
        .OrderBy(item => item.DisplayOrder)
        .ToList();

    private IReadOnlyList<IntakeMedicationItemDto> FilteredMedications => MedicationCatalog
        .Where(item => string.IsNullOrWhiteSpace(_medicationSearch)
            || item.DisplayLabel.Contains(_medicationSearch, StringComparison.OrdinalIgnoreCase)
            || item.BrandName.Contains(_medicationSearch, StringComparison.OrdinalIgnoreCase)
            || item.GenericName.Contains(_medicationSearch, StringComparison.OrdinalIgnoreCase))
        .Take(string.IsNullOrWhiteSpace(_medicationSearch) ? 8 : 12)
        .ToList();

    private IReadOnlyList<IntakeCatalogOptionDto> FilteredAssistiveDevices => AssistiveDeviceCatalog
        .Where(option => string.IsNullOrWhiteSpace(_assistiveSearch)
            || option.Label.Contains(_assistiveSearch, StringComparison.OrdinalIgnoreCase))
        .Take(string.IsNullOrWhiteSpace(_assistiveSearch) ? 12 : 20)
        .ToList();

    private async Task ToggleMedicationAsync(string medicationId)
    {
        if (StructuredData.MedicationIds.Contains(medicationId, StringComparer.OrdinalIgnoreCase))
        {
            StructuredData.MedicationIds.RemoveAll(id => string.Equals(id, medicationId, StringComparison.OrdinalIgnoreCase));
        }
        else
        {
            StructuredData.MedicationIds.Add(medicationId);
        }

        State.HasCurrentMedications = StructuredData.MedicationIds.Count > 0;
        await NotifyStateChangedAsync();
    }

    private async Task ToggleCatalogSelectionAsync(string optionId, SelectionKind selectionKind)
    {
        var target = selectionKind switch
        {
            SelectionKind.Comorbidity => StructuredData.ComorbidityIds,
            SelectionKind.AssistiveDevice => StructuredData.AssistiveDeviceIds,
            SelectionKind.LivingSituation => StructuredData.LivingSituationIds,
            _ => throw new ArgumentOutOfRangeException(nameof(selectionKind), selectionKind, null)
        };

        if (target.Contains(optionId, StringComparer.OrdinalIgnoreCase))
        {
            target.RemoveAll(id => string.Equals(id, optionId, StringComparison.OrdinalIgnoreCase));
        }
        else
        {
            target.Add(optionId);
        }

        SyncLegacySupplementalSelections();

        await NotifyStateChangedAsync();
    }

    private async Task SelectHouseLayoutAsync(string optionId)
    {
        if (StructuredData.HouseLayoutOptionIds.Contains(optionId, StringComparer.OrdinalIgnoreCase))
        {
            StructuredData.HouseLayoutOptionIds.Clear();
        }
        else
        {
            StructuredData.HouseLayoutOptionIds.Clear();
            StructuredData.HouseLayoutOptionIds.Add(optionId);
        }

        SyncLegacySupplementalSelections();
        await NotifyStateChangedAsync();
    }

    private async Task OnPreviousSurgeriesChangedAsync(ChangeEventArgs args)
    {
        State.HasPreviousSurgeriesOrInjuries = (bool)(args.Value ?? false);
        await NotifyStateChangedAsync();
    }

    private async Task OnMedicalHistoryNotesChangedAsync(ChangeEventArgs args)
    {
        State.MedicalHistoryNotes = args.Value?.ToString();
        await NotifyStateChangedAsync();
    }

    private async Task NotifyStateChangedAsync()
    {
        State.IsDirty = true;

        if (StateChanged.HasDelegate)
        {
            await StateChanged.InvokeAsync();
        }
    }

    protected override void OnParametersSet()
    {
        _ = StructuredData;
        SyncLegacySupplementalSelections();
        State.HasCurrentMedications = StructuredData.MedicationIds.Count > 0;
    }

    private void SyncLegacySupplementalSelections()
    {
        State.SelectedComorbidities = StructuredData.ComorbidityIds
            .Select(id => IntakeReferenceData.GetComorbidity(id)?.Label ?? id)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);
        State.SelectedAssistiveDevices = StructuredData.AssistiveDeviceIds
            .Select(id => IntakeReferenceData.GetAssistiveDevice(id)?.Label ?? id)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);
        State.SelectedLivingSituations = StructuredData.LivingSituationIds
            .Select(id => IntakeReferenceData.GetLivingSituation(id)?.Label ?? id)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);
        State.SelectedHouseLayoutOptions = StructuredData.HouseLayoutOptionIds
            .Select(id => IntakeReferenceData.GetHouseLayoutOption(id)?.Label ?? id)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);
        State.HasOtherMedicalConditions = StructuredData.ComorbidityIds.Count > 0;
        State.UsesAssistiveDevices = StructuredData.AssistiveDeviceIds.Count > 0;
    }

    private enum SelectionKind
    {
        Comorbidity,
        AssistiveDevice,
        LivingSituation
    }
}
