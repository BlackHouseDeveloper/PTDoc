@using PTDoc.UI.Components.Intake.Models

<header class="intake-header" data-testid="intake-header">
    <div class="intake-header__inner">
        <button type="button" class="intake-header__back" @onclick="OnBackClicked" data-testid="back-button" aria-label="Go back">
            ←
        </button>

        <div class="intake-header__brand">PTDoc</div>

        <div class="intake-header__text">
            <h1>Patient Intake</h1>
            <p>Step @GetStepNumber(CurrentStep) of 5</p>
        </div>
    </div>
</header>

@code {
    [Parameter, EditorRequired] public IntakeStep CurrentStep { get; set; }
    [Parameter] public EventCallback OnBack { get; set; }

    private Task OnBackClicked()
    {
        return OnBack.HasDelegate ? OnBack.InvokeAsync() : Task.CompletedTask;
    }

    private static int GetStepNumber(IntakeStep step)
    {
        return step switch
        {
            IntakeStep.Demographics => 1,
            IntakeStep.PainAssessment => 2,
            IntakeStep.PainDetails => 3,
            IntakeStep.OutcomeMeasures => 4,
            IntakeStep.Review => 5,
            _ => 1
        };
    }
}
