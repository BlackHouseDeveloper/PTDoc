@using System.Net.Http.Json
@using System.Timers

@inject HttpClient HttpClient
@implements IDisposable

<div class="intake-patient-selector" data-testid="clinician-patient-selector">
    <label for="intake-patient-search" class="intake-patient-selector__label">Patient</label>

    <input
        id="intake-patient-search"
        type="search"
        class="intake-patient-selector__search"
        placeholder="Search by name or MRN"
        value="@_searchText"
        @oninput="HandleSearchInputAsync"
        disabled="@Disabled" />

    @if (_isLoading)
    {
        <p class="intake-patient-selector__status">Loading patients...</p>
    }
    else if (!string.IsNullOrWhiteSpace(_loadError))
    {
        <p class="intake-patient-selector__error" role="alert">@_loadError</p>
    }
    else
    {
        <select
            id="intake-patient-select"
            aria-label="Select patient"
            class="intake-patient-selector__select"
            value="@SelectedPatientIdString"
            @onchange="HandleSelectionChangedAsync"
            disabled="@Disabled">
            <option value="">Select a patient</option>
            @foreach (var patient in _patients)
            {
                <option value="@patient.Id">@FormatPatientOption(patient)</option>
            }
        </select>
    }
</div>

@code {
    [Parameter] public Guid? SelectedPatientId { get; set; }
    [Parameter] public EventCallback<Guid?> SelectedPatientIdChanged { get; set; }
    [Parameter] public bool Disabled { get; set; }

    private readonly List<PatientListItem> _patients = new();
    private string _searchText = string.Empty;
    private bool _isLoading = false;
    private string? _loadError;
    private Timer? _debounceTimer;
    private const int DebounceMs = 300;

    private string SelectedPatientIdString => SelectedPatientId?.ToString() ?? string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadPatientsAsync(string.Empty);
    }

    private void HandleSearchInputAsync(ChangeEventArgs args)
    {
        _searchText = args.Value?.ToString() ?? string.Empty;

        _debounceTimer?.Stop();
        if (_debounceTimer is null)
        {
            _debounceTimer = new Timer(DebounceMs);
            _debounceTimer.AutoReset = false;
            _debounceTimer.Elapsed += OnDebounceElapsed;
        }
        else
        {
            _debounceTimer.Interval = DebounceMs;
        }
        _debounceTimer.Start();
    }

    private void OnDebounceElapsed(object? sender, System.Timers.ElapsedEventArgs e)
    {
        _ = InvokeAsync(async () =>
        {
            try
            {
                await LoadPatientsAsync(_searchText);
            }
            catch
            {
                _loadError = "Unable to load patient list.";
                _isLoading = false;
            }
            StateHasChanged();
        });
    }

    private async Task LoadPatientsAsync(string query)
    {
        _isLoading = true;
        _loadError = null;

        try
        {
            var url = string.IsNullOrWhiteSpace(query)
                ? "/api/v1/patients?take=100"
                : $"/api/v1/patients?query={Uri.EscapeDataString(query.Trim())}&take=50";

            var result = await HttpClient.GetFromJsonAsync<List<PatientListItem>>(url);
            if (result is not null)
            {
                _patients.Clear();
                _patients.AddRange(result);
            }
        }
        catch
        {
            _loadError = "Unable to load patient list.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task HandleSelectionChangedAsync(ChangeEventArgs args)
    {
        var raw = args.Value?.ToString();
        if (string.IsNullOrWhiteSpace(raw))
        {
            await SelectedPatientIdChanged.InvokeAsync(null);
            return;
        }

        if (Guid.TryParse(raw, out var patientId))
        {
            await SelectedPatientIdChanged.InvokeAsync(patientId);
        }
    }

    private static string FormatPatientOption(PatientListItem patient)
    {
        if (string.IsNullOrWhiteSpace(patient.MedicalRecordNumber))
        {
            return patient.DisplayName;
        }

        return $"{patient.DisplayName} ({patient.MedicalRecordNumber})";
    }

    public void Dispose()
    {
        _debounceTimer?.Dispose();
    }

    private sealed class PatientListItem
    {
        public Guid Id { get; set; }
        public string DisplayName { get; set; } = string.Empty;
        public string? MedicalRecordNumber { get; set; }
    }
}
