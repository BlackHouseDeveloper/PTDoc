@* AuthorizationDetailsPanel — authorization metadata and visit/unit limits *@
@using System.Globalization
@using PTDoc.UI.Components.PatientInfo.Models

<PatientInfoSectionPanel Title="Authorization / PCP Referral Details">
    @if (!ShouldShowDetails)
    {
        <div class="pi-auth-details-empty" role="status">
            <p>@DetailsPrompt</p>
        </div>
    }
    else
    {
        <PatientInfoFormGrid>

        <PatientInfoField Label="Authorization / Referral Number" ForId="pi-auth-number" Error="@GetError("authNumber")">
            <PatientInfoTextInput Id="pi-auth-number"
                                  Value="@Model.AuthorizationNumber"
                                  ValueChanged="@(v => SetField(v, f => f.AuthorizationNumber = v))"
                                  HasError="@HasError("authNumber")" />
        </PatientInfoField>

        <PatientInfoField Label="Date Authorization / Referral Received" ForId="pi-auth-received" Error="@GetError("authReceived")">
            <PatientInfoTextInput Id="pi-auth-received"
                                  Value="@Model.DateAuthorizationReceived"
                                  ValueChanged="@(v => SetField(v, f => f.DateAuthorizationReceived = v))"
                                  HasError="@HasError("authReceived")" />
            @* Text date input retained for consistency with existing JSON-backed model fields. *@
        </PatientInfoField>

        <PatientInfoField Label="Authorization / Referral Start Date" ForId="pi-auth-start" Error="@GetError("authStart")">
            <PatientInfoTextInput Id="pi-auth-start"
                                  Value="@Model.AuthorizationStartDate"
                                  ValueChanged="@(v => SetField(v, f => f.AuthorizationStartDate = v))"
                                  HasError="@HasError("authStart")" />
            @* Text date input retained for consistency with existing JSON-backed model fields. *@
        </PatientInfoField>

        <PatientInfoField Label="Authorization / Referral End Date" ForId="pi-auth-end" Error="@GetError("authEnd")">
            <PatientInfoTextInput Id="pi-auth-end"
                                  Value="@Model.AuthorizationEndDate"
                                  ValueChanged="@(v => SetField(v, f => f.AuthorizationEndDate = v))"
                                  HasError="@HasError("authEnd")" />
        </PatientInfoField>

        @* Left-only row: "Number of Visits or Units Authorized" in left col + spacer in right col *@
        <PatientInfoField Label="Number of Visits or Units Authorized"
                          ForId="pi-auth-units"
                          Error="@GetError("authUnits")">
            <PatientInfoTextInput Id="pi-auth-units"
                                  Value="@Model.NumberOfVisitsOrUnitsAuthorized"
                                  ValueChanged="@(v => SetField(v, f => f.NumberOfVisitsOrUnitsAuthorized = v))"
                                  HasError="@HasError("authUnits")" />
            @* Label supports both unit- and visit-based payer authorization workflows. *@
        </PatientInfoField>
        @* Explicit right-column spacer so "units" field stays left-only on desktop *@
        <div class="pi-form-grid-spacer" aria-hidden="true"></div>

        </PatientInfoFormGrid>

        @* UI-only validation: start date must be <= end date *@
        @if (!string.IsNullOrEmpty(DateRangeError))
        {
            <p class="pi-auth-date-range-error" role="alert">@DateRangeError</p>
        }
    }
</PatientInfoSectionPanel>

@code {
    [Parameter, EditorRequired] public AuthorizationDetailsVm Model { get; set; } = null!;
    [Parameter] public EventCallback<AuthorizationDetailsVm> ModelChanged { get; set; }
    [Parameter] public string AuthorizationRequired { get; set; } = string.Empty;
    [Parameter] public bool IsReadOnly { get; set; }
    [Parameter] public Dictionary<string, string> FieldErrors { get; set; } = new();
    [Parameter] public EventCallback OnAnyFieldChanged { get; set; }

    private string DateRangeError => ValidateDateRange();
    private bool IsRequiredYes => string.Equals(AuthorizationRequired, "Yes", StringComparison.OrdinalIgnoreCase);
    private bool IsRequiredNo => string.Equals(AuthorizationRequired, "No", StringComparison.OrdinalIgnoreCase);
    private bool IsRequiredUnknown => string.Equals(AuthorizationRequired, "Unknown", StringComparison.OrdinalIgnoreCase);
    private bool HasAnyDetails =>
        !string.IsNullOrWhiteSpace(Model.AuthorizationNumber) ||
        !string.IsNullOrWhiteSpace(Model.DateAuthorizationReceived) ||
        !string.IsNullOrWhiteSpace(Model.AuthorizationStartDate) ||
        !string.IsNullOrWhiteSpace(Model.AuthorizationEndDate) ||
        !string.IsNullOrWhiteSpace(Model.NumberOfVisitsOrUnitsAuthorized);
    private bool ShouldShowDetails => IsRequiredYes || HasAnyDetails;
    private string DetailsPrompt =>
        IsRequiredNo
            ? "Authorization or PCP referral is marked not required for this patient."
            : IsRequiredUnknown
                ? "Authorization / PCP referral requirement is marked unknown for this patient. Select Yes to enter details if available."
                : "Select Yes for Authorization / PCP Referral Required to enter authorization, referral, or prescription details.";

    private string GetError(string key) =>
        FieldErrors.TryGetValue(key, out var msg) ? msg : string.Empty;

    private bool HasError(string key) => FieldErrors.ContainsKey(key);

    private async Task SetField(string value, Action<AuthorizationDetailsVm> setter)
    {
        setter(Model);
        await ModelChanged.InvokeAsync(Model);
        await OnAnyFieldChanged.InvokeAsync();
    }

    // UI-side guard complements server validation to catch invalid date ordering before save.
    private string ValidateDateRange()
    {
        if (string.IsNullOrWhiteSpace(Model.AuthorizationStartDate) ||
            string.IsNullOrWhiteSpace(Model.AuthorizationEndDate))
        {
            return string.Empty;
        }

        if (DateTime.TryParse(Model.AuthorizationStartDate, CultureInfo.InvariantCulture, DateTimeStyles.None, out var start) &&
            DateTime.TryParse(Model.AuthorizationEndDate, CultureInfo.InvariantCulture, DateTimeStyles.None, out var end) &&
            start > end)
        {
            return "Authorization / Referral Start Date must be on or before Authorization / Referral End Date.";
        }

        return string.Empty;
    }
}
