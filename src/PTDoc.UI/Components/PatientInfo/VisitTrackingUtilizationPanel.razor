@* VisitTrackingUtilizationPanel — visit counters, first-visit date, and notes *@
@using PTDoc.UI.Components.PatientInfo.Models

<PatientInfoSectionPanel Title="Visit Tracking &amp; Utilization">
    <PatientInfoFormGrid>

        <PatientInfoField Label="Visits Used" ForId="pi-visits-used" Error="@GetError("visitsUsed")">
            <PatientInfoTextInput Id="pi-visits-used"
                                  Value="@Model.VisitsUsed"
                                  ValueChanged="@(v => SetField(v, f => f.VisitsUsed = v))"
                                  HasError="@HasError("visitsUsed")" />
            @* Visits used and remaining are editable because payer rules vary by clinic workflow. *@
        </PatientInfoField>

        <PatientInfoField Label="Visits Remaining" ForId="pi-visits-remaining" Error="@GetError("visitsRemaining")">
            <PatientInfoTextInput Id="pi-visits-remaining"
                                  Value="@Model.VisitsRemaining"
                                  ValueChanged="@(v => SetField(v, f => f.VisitsRemaining = v))"
                                  HasError="@HasError("visitsRemaining")" />
        </PatientInfoField>

        <PatientInfoField Label="Visit Limit Type" ForId="pi-visit-limit-type" Error="@GetError("visitLimitType")">
            <PatientInfoSelect Id="pi-visit-limit-type"
                               Value="@Model.VisitLimitType"
                               ValueChanged="@(v => SetField(v, f => f.VisitLimitType = v))"
                               Placeholder="Select limit type"
                               Options="@VisitLimitTypeOptions"
                               HasError="@HasError("visitLimitType")" />
        </PatientInfoField>

        <PatientInfoField Label="Visit Limit Period" ForId="pi-visit-limit-period" Error="@GetError("visitLimitPeriod")">
            <PatientInfoSelect Id="pi-visit-limit-period"
                               Value="@Model.VisitLimitPeriod"
                               ValueChanged="@(v => SetField(v, f => f.VisitLimitPeriod = v))"
                               Placeholder="Select limit period"
                               Options="@VisitLimitPeriodOptions"
                               HasError="@HasError("visitLimitPeriod")" />
        </PatientInfoField>

        <PatientInfoField Label="Total Visit Limit" ForId="pi-total-visit-limit" Error="@GetError("totalVisitLimit")">
            <PatientInfoTextInput Id="pi-total-visit-limit"
                                  Value="@Model.TotalVisitLimit"
                                  ValueChanged="@(v => SetField(v, f => f.TotalVisitLimit = v))"
                                  Placeholder="e.g., 20"
                                  HasError="@HasError("totalVisitLimit")" />
        </PatientInfoField>

        <div class="pi-form-grid-spacer" aria-hidden="true"></div>

        @* Full-width row: spans both grid columns *@
        <PatientInfoField Label="Date of First Visit Under Authorization"
                          ForId="pi-first-visit-date"
                          Error="@GetError("firstVisitDate")"
                          SpanFull="true">
            <PatientInfoTextInput Id="pi-first-visit-date"
                                  Value="@Model.DateOfFirstVisitUnderAuthorization"
                                  ValueChanged="@(v => SetField(v, f => f.DateOfFirstVisitUnderAuthorization = v))"
                                  HasError="@HasError("firstVisitDate")" />
            @* Text date input retained for consistency with existing JSON-backed model fields. *@
        </PatientInfoField>

        @* Full-width row: notes textarea *@
        <PatientInfoField Label="Notes / Comments"
                          ForId="pi-notes"
                          Error="@GetError("notes")"
                          SpanFull="true">
            <PatientInfoTextArea Id="pi-notes"
                                 Value="@Model.NotesComments"
                                 ValueChanged="@(v => SetField(v, f => f.NotesComments = v))"
                                 Placeholder="Add any relevant notes about authorization, coverage limitations, or special instructions..."
                                 Rows="5"
                                 HasError="@HasError("notes")" />
            @* Notes remain unconstrained here; backend limits apply during save validation. *@
        </PatientInfoField>

    </PatientInfoFormGrid>
</PatientInfoSectionPanel>

@code {
    [Parameter, EditorRequired] public UtilizationVm Model { get; set; } = null!;
    [Parameter] public EventCallback<UtilizationVm> ModelChanged { get; set; }
    [Parameter] public bool IsReadOnly { get; set; }
    [Parameter] public Dictionary<string, string> FieldErrors { get; set; } = new();
    [Parameter] public EventCallback OnAnyFieldChanged { get; set; }
    private static readonly IReadOnlyList<PatientInfoSelectOptionVm> VisitLimitTypeOptions = new[]
    {
        new PatientInfoSelectOptionVm("visits", "Visits"),
        new PatientInfoSelectOptionVm("units", "Units"),
        new PatientInfoSelectOptionVm("combined", "Combined visits / units"),
        new PatientInfoSelectOptionVm("none", "No limit"),
        new PatientInfoSelectOptionVm("unknown", "Unknown / Verify"),
    };

    private static readonly IReadOnlyList<PatientInfoSelectOptionVm> VisitLimitPeriodOptions = new[]
    {
        new PatientInfoSelectOptionVm("authorization_period", "Authorization period"),
        new PatientInfoSelectOptionVm("calendar_year", "Calendar year"),
        new PatientInfoSelectOptionVm("plan_year", "Plan year"),
        new PatientInfoSelectOptionVm("episode", "Episode of care"),
        new PatientInfoSelectOptionVm("lifetime", "Lifetime"),
    };

    private string GetError(string key) =>
        FieldErrors.TryGetValue(key, out var msg) ? msg : string.Empty;

    private bool HasError(string key) => FieldErrors.ContainsKey(key);

    private async Task SetField(string value, Action<UtilizationVm> setter)
    {
        setter(Model);
        await ModelChanged.InvokeAsync(Model);
        await OnAnyFieldChanged.InvokeAsync();
    }
}
