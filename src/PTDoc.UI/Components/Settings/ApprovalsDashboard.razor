@using PTDoc.UI.Services
@using PTDoc.Application.Identity
@inject IAdminApprovalService AdminApprovalService
@inject NavigationManager Navigation
@implements IDisposable

<section class="approvals-dashboard" aria-label="Admin Approval Dashboard">
    <header class="approvals-header">
        <div>
            <h1>Admin Approval Dashboard</h1>
            <p>Review onboarding and access requests prior to account activation.</p>
        </div>

        <div class="approvals-header-actions">
            <div class="pending-summary" aria-label="Pending request count">
                <span class="pending-summary-label">@SummaryLabel</span>
                <strong class="pending-summary-value">@PendingCount</strong>
            </div>

            <button type="button" class="btn btn-outline" @onclick="RefreshPlaceholders">Refresh</button>
        </div>
    </header>

    <div class="refresh-meta">
        Last refreshed: @lastRefreshed
    </div>

    <div class="status-tabs" role="tablist" aria-label="Request status filters">
        @foreach (var tab in statusTabs)
        {
            <button
                type="button"
                role="tab"
                class="status-tab @(selectedStatusTab == tab ? "is-active" : string.Empty)"
                aria-selected="@(selectedStatusTab == tab)"
                @onclick="() => SetStatusTab(tab)">
                @tab
            </button>
        }
    </div>

    @if (isLoading)
    {
        <div class="data-state" role="status">Loading approval requests...</div>
    }
    else if (!string.IsNullOrWhiteSpace(loadError))
    {
        <div class="data-state error" role="alert">@loadError</div>
    }

    <section class="approvals-filters" aria-label="Search and filter controls">
        <div class="filter-row">
            <label class="filter-field">
                <span>Search</span>
                <input type="text" placeholder="Name, email, or request ID" value="@searchQuery" @oninput="OnSearchInput" />
            </label>

            <label class="filter-field">
                <span>Status</span>
                <select value="@statusFilter" @onchange="OnStatusFilterChanged">
                    <option>All</option>
                    <option>Pending</option>
                    <option>Approved</option>
                    <option>Rejected</option>
                    <option>On Hold</option>
                    <option>Cancelled</option>
                </select>
            </label>

            <label class="filter-field">
                <span>Role</span>
                <select value="@roleFilter" @onchange="OnRoleFilterChanged">
                    <option>All Roles</option>
                    @foreach (var roleOption in AvailableRoleFilters)
                    {
                        <option value="@roleOption">@roleOption</option>
                    }
                </select>
            </label>

            <label class="filter-field">
                <span>Clinic</span>
                <select value="@clinicFilter" @onchange="OnClinicFilterChanged">
                    <option>All Clinics</option>
                    @foreach (var clinicOption in AvailableClinicFilters)
                    {
                        <option value="@clinicOption">@clinicOption</option>
                    }
                </select>
            </label>
        </div>

        <div class="filter-row">
            <label class="filter-field">
                <span>Date From</span>
                <input type="date" value="@FormatDateForInput(dateFrom)" @onchange="OnDateFromChanged" />
            </label>

            <label class="filter-field">
                <span>Date To</span>
                <input type="date" value="@FormatDateForInput(dateTo)" @onchange="OnDateToChanged" />
            </label>

            <label class="filter-field">
                <span>Sort By</span>
                <select value="@sortBy" @onchange="OnSortByChanged">
                    <option>Date submitted</option>
                    <option>Name</option>
                    <option>Status</option>
                </select>
            </label>
        </div>
    </section>

    <div class="approvals-table-card">
        <div class="approvals-table-meta" aria-live="polite">
            <span class="approvals-table-summary">@ResultsSummary</span>
            @if (HasActiveFilters)
            {
                <button type="button" class="btn btn-outline btn-sm" @onclick="ClearFilters">Clear filters</button>
            }
        </div>

        @if (!isLoading && string.IsNullOrWhiteSpace(loadError) && !FilteredRequests.Any())
        {
            <div class="data-state approvals-empty-state" role="status" data-testid="approvals-empty-state">
                <strong>No results found</strong>
                <p>@NoResultsMessage</p>
                @if (HasActiveFilters)
                {
                    <button type="button" class="btn btn-outline" @onclick="ClearFilters">Reset filters</button>
                }
            </div>
        }
        else
        {
            <div class="approvals-table-wrapper" role="region" aria-label="Approval requests table">
                <table class="approvals-table">
                    <thead>
                        <tr>
                            <th scope="col">Request ID</th>
                            <th scope="col">Applicant Name</th>
                            <th scope="col">Email</th>
                            <th scope="col">Requested Role</th>
                            <th scope="col">Clinic / Organization</th>
                            <th scope="col">Submitted Timestamp</th>
                            <th scope="col">Credential Check</th>
                            <th scope="col">Status</th>
                            <th scope="col">Reviewed By</th>
                            <th scope="col">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var request in FilteredRequests)
                        {
                            <tr>
                                <td>@request.RequestId</td>
                                <td>@request.ApplicantName</td>
                                <td>@request.Email</td>
                                <td>@request.RequestedRole</td>
                                <td>@request.Clinic</td>
                                <td>@request.SubmittedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                                <td>
                                    <span class="credential-indicator @(request.CredentialsComplete ? "is-complete" : "is-warning")"
                                          aria-label="@(request.CredentialsComplete ? "Credential fields complete" : "Credential fields missing")">
                                        @if (request.CredentialsComplete)
                                        {
                                            <span aria-hidden="true">&#10003;</span>
                                            <span>Complete</span>
                                        }
                                        else
                                        {
                                            <span aria-hidden="true">&#9888;</span>
                                            <span>Missing data</span>
                                        }
                                    </span>
                                </td>
                                <td>
                                    <ApprovalStatusBadge Status="@request.Status" />
                                </td>
                                <td>@(string.IsNullOrWhiteSpace(request.ReviewedBy) ? "-" : request.ReviewedBy)</td>
                                <td>
                                    <button type="button" class="btn btn-primary btn-sm" @onclick="() => OpenReview(request)">
                                        Review
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <footer class="pagination-row" aria-label="Pagination controls">
                <div class="pagination-meta">
                    <label class="filter-field inline-field">
                        <span>Page Size</span>
                        <select value="@pageSize" @onchange="OnPageSizeChanged">
                            <option value="10">10</option>
                            <option value="25">25</option>
                            <option value="50">50</option>
                        </select>
                    </label>

                    <span>Page @currentPage of @TotalPages</span>
                    <span>@FilteredCount total results</span>
                </div>

                <div class="pagination-actions">
                    <button type="button" class="btn btn-outline" @onclick="PreviousPage" disabled="@(currentPage <= 1)">Previous</button>
                    <button type="button" class="btn btn-outline" @onclick="NextPage" disabled="@(currentPage >= TotalPages)">Next</button>
                </div>
            </footer>
        }
    </div>
</section>

@if (selectedRequest is not null)
{
    <div class="detail-backdrop" @onclick="CloseReviewPanel">
        <aside class="detail-panel" @onclick:stopPropagation="true" role="dialog" aria-modal="true" aria-labelledby="review-title">
            <header class="detail-panel-header">
                <div>
                    <h2 id="review-title">Request Detail</h2>
                    <p>Review request metadata, credentials, and action readiness.</p>
                </div>

                <button type="button" class="icon-close" @onclick="CloseReviewPanel" aria-label="Close review panel">
                    &#10005;
                </button>
            </header>

            <section class="detail-group" aria-label="Request metadata">
                <h3>Request Metadata</h3>
                <dl>
                    <div><dt>ID</dt><dd>@selectedRequest.RequestId</dd></div>
                    <div><dt>Submitted</dt><dd>@selectedRequest.SubmittedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</dd></div>
                    <div><dt>Source</dt><dd>Self-service registration</dd></div>
                    <div><dt>Status</dt><dd><ApprovalStatusBadge Status="@(selectedRequestDetail?.Status ?? selectedRequest.Status)" /></dd></div>
                </dl>
            </section>

            @if (isLoadingDetail)
            {
                <div class="data-state" role="status">Loading request detail...</div>
            }
            else if (!string.IsNullOrWhiteSpace(detailLoadError))
            {
                <div class="data-state error" role="alert">@detailLoadError</div>
            }
            else if (selectedRequestDetail is not null)
            {
                <section class="detail-group" aria-label="Applicant information">
                    <div class="detail-section-header">
                        <h3>Applicant Information</h3>
                        @if (!isEditingDetail)
                        {
                            <button type="button" class="btn btn-outline" @onclick="BeginEditDetail" disabled="@isSubmittingAction">Edit Request</button>
                        }
                    </div>

                    @if (isEditingDetail)
                    {
                        <div class="detail-edit-grid">
                            <label class="filter-field">
                                <span>Username</span>
                                <input type="text" value="@selectedRequestDetail.Username" readonly />
                            </label>

                            <label class="filter-field">
                                <span>Full Legal Name</span>
                                <input type="text" value="@editModel.FullName" @oninput="OnFullNameChanged" />
                                @RenderValidationMessage("FullName")
                            </label>

                            <label class="filter-field">
                                <span>Email</span>
                                <input type="email" value="@editModel.Email" @oninput="OnEmailChanged" />
                                @RenderValidationMessage("Email")
                            </label>

                            <label class="filter-field">
                                <span>Date of Birth</span>
                                <input type="date" value="@editModel.DateOfBirth" @oninput="OnDateOfBirthChanged" />
                                @RenderValidationMessage("DateOfBirth")
                            </label>

                            <label class="filter-field">
                                <span>Role Requested</span>
                                <select value="@editModel.RoleKey" @onchange="OnEditRoleChanged">
                                    @foreach (var roleOption in editableRoles)
                                    {
                                        <option value="@roleOption.Key">@roleOption.DisplayName</option>
                                    }
                                </select>
                                @RenderValidationMessage("RoleKey")
                            </label>

                            <label class="filter-field">
                                <span>Clinic</span>
                                <input type="text" value="@selectedRequestDetail.ClinicName" readonly />
                            </label>
                        </div>
                    }
                    else
                    {
                        <dl>
                            <div><dt>Username</dt><dd>@selectedRequestDetail.Username</dd></div>
                            <div><dt>Name</dt><dd>@selectedRequestDetail.FullName</dd></div>
                            <div><dt>Email</dt><dd>@selectedRequestDetail.Email</dd></div>
                            <div><dt>Date of Birth</dt><dd>@FormatDetailDate(selectedRequestDetail.DateOfBirth)</dd></div>
                            <div><dt>Role Requested</dt><dd>@selectedRequestDetail.RoleKey</dd></div>
                            <div><dt>Clinic</dt><dd>@selectedRequestDetail.ClinicName</dd></div>
                        </dl>
                    }
                </section>

                <section class="detail-group" aria-label="Credential information">
                    <h3>Credential / License Data</h3>

                    @if (RequiresLicenseRole(isEditingDetail ? editModel.RoleKey : selectedRequestDetail.RoleKey))
                    {
                        @if (isEditingDetail)
                        {
                            <div class="detail-edit-grid">
                                <label class="filter-field">
                                    <span>License Number</span>
                                    <input type="text" value="@editModel.LicenseNumber" @oninput="OnLicenseNumberChanged" />
                                    @RenderValidationMessage("LicenseNumber")
                                </label>

                                <label class="filter-field">
                                    <span>License State</span>
                                    <select value="@editModel.LicenseState" @onchange="OnLicenseStateChanged">
                                        <option value="">Select state</option>
                                        @foreach (var state in licenseStates)
                                        {
                                            <option value="@state.Code">@state.Code - @state.Name</option>
                                        }
                                    </select>
                                    @RenderValidationMessage("LicenseState")
                                </label>
                            </div>
                        }
                        else
                        {
                            <dl>
                                <div><dt>License Requirement</dt><dd>Required for @selectedRequestDetail.RoleKey</dd></div>
                                <div><dt>License Number</dt><dd>@(selectedRequestDetail.LicenseNumber ?? "Not provided")</dd></div>
                                <div><dt>License State</dt><dd>@(selectedRequestDetail.LicenseState ?? "Not provided")</dd></div>
                            </dl>
                        }
                    }
                    else
                    {
                        <p>No license data is required for the selected role.</p>
                    }

                    @if (selectedRequestDetail.MissingFields.Count > 0)
                    {
                        <p class="detail-warning" role="note">Approval disabled until the required fields below are completed.</p>
                        <ul class="detail-missing-list">
                            @foreach (var missingField in selectedRequestDetail.MissingFields)
                            {
                                <li>@missingField</li>
                            }
                        </ul>
                    }
                </section>
            }

            <section class="detail-group" aria-label="Audit timeline placeholder">
                <h3>Audit / History Timeline</h3>
                <div class="placeholder-box">Timeline events will appear here once backend audit APIs are connected.</div>
            </section>

            <section class="detail-group" aria-label="Admin notes placeholder">
                <h3>Admin Notes</h3>
                <textarea rows="3" placeholder="Add reviewer notes (placeholder only)"></textarea>
            </section>

            <footer class="detail-actions">
                @if (isEditingDetail)
                {
                    <button type="button" class="btn btn-primary" disabled="@isSavingDetail" @onclick="SaveDetailAsync">Save Changes</button>
                    <button type="button" class="btn btn-outline" disabled="@isSavingDetail" @onclick="CancelDetailEdit">Cancel Edit</button>
                }
                <button type="button" class="btn btn-primary" disabled="@(!CanApproveSelectedRequest)" @onclick="OpenApproveConfirmation">Approve</button>
                <button type="button" class="btn btn-outline-danger" disabled="@(!CanManageSelectedRequest)" @onclick="OpenRejectConfirmation">Reject</button>
                <button type="button" class="btn btn-outline" disabled="@(!CanManageSelectedRequest)" @onclick="OpenOnHoldConfirmation">On Hold</button>
                <button type="button" class="btn btn-outline" disabled="@(!CanManageSelectedRequest)" @onclick="OpenCancelConfirmation">Cancel Request</button>
                <button type="button" class="btn btn-outline" disabled>Revoke Invite</button>
            </footer>

            @if (!string.IsNullOrWhiteSpace(actionFeedback))
            {
                <p class="action-feedback" role="status">@actionFeedback</p>
            }
        </aside>
    </div>
}

@if (showConfirmationModal)
{
    <div class="detail-backdrop" @onclick="CloseConfirmation">
        <div class="confirmation-modal" @onclick:stopPropagation="true" role="dialog" aria-modal="true" aria-labelledby="confirmation-title">
            <h3 id="confirmation-title">@confirmationTitle</h3>
            <p>@confirmationBody</p>
            <div class="confirmation-actions">
                <button type="button" class="btn btn-outline" @onclick="CloseConfirmation">Cancel</button>
                <button type="button" class="btn btn-primary" @onclick="ConfirmActionAsync" disabled="@isSubmittingAction">Confirm</button>
            </div>
        </div>
    </div>
}

@code {
    private const string DefaultStatusTab = "Pending";
    private const string DefaultStatusFilter = "All";
    private const string DefaultRoleFilter = "All Roles";
    private const string DefaultClinicFilter = "All Clinics";
    private const string DefaultSortBy = "Date submitted";
    private const int DefaultPageSize = 25;

    private string lastRefreshed = "Not refreshed yet";

    private string selectedStatusTab = DefaultStatusTab;
    private string searchQuery = string.Empty;
    private string statusFilter = DefaultStatusFilter;
    private string roleFilter = DefaultRoleFilter;
    private string clinicFilter = DefaultClinicFilter;
    private DateTime? dateFrom;
    private DateTime? dateTo;
    private string sortBy = DefaultSortBy;

    private int pageSize = DefaultPageSize;
    private int currentPage = 1;
    private int totalServerCount;

    private ApprovalRequestRow? selectedRequest;
    private PendingUserDetail? selectedRequestDetail;
    private ApprovalEditModel editModel = new();

    private bool showConfirmationModal;
    private string confirmationTitle = "Confirm action";
    private string confirmationBody = "This is a UI placeholder confirmation modal.";
    private ApprovalAction? pendingAction;

    private bool isLoading;
    private string? loadError;
    private bool isSubmittingAction;
    private bool isLoadingDetail;
    private bool isEditingDetail;
    private bool isSavingDetail;
    private string? actionFeedback;
    private string? detailLoadError;
    private bool suppressQuerySync;
    private string? lastLoadedQuery;
    private Dictionary<string, string> detailValidationErrors = new(StringComparer.Ordinal);

    private static readonly IReadOnlyList<string> statusTabs =
    [
        "Pending",
        "Approved",
        "Rejected",
        "On Hold",
        "Cancelled"
    ];

    private static readonly IReadOnlyList<RoleSummary> editableRoles =
    [
        new("PT", "Physical Therapist"),
        new("PTA", "Physical Therapist Assistant"),
        new("FrontDesk", "Front Desk"),
        new("Owner", "Owner"),
        new("Billing", "Billing"),
        new("Patient", "Patient")
    ];

    private static readonly IReadOnlyList<(string Code, string Name)> licenseStates =
    [
        ("AL", "Alabama"), ("AK", "Alaska"), ("AZ", "Arizona"), ("AR", "Arkansas"),
        ("CA", "California"), ("CO", "Colorado"), ("CT", "Connecticut"), ("DE", "Delaware"),
        ("FL", "Florida"), ("GA", "Georgia"), ("HI", "Hawaii"), ("ID", "Idaho"),
        ("IL", "Illinois"), ("IN", "Indiana"), ("IA", "Iowa"), ("KS", "Kansas"),
        ("KY", "Kentucky"), ("LA", "Louisiana"), ("ME", "Maine"), ("MD", "Maryland"),
        ("MA", "Massachusetts"), ("MI", "Michigan"), ("MN", "Minnesota"), ("MS", "Mississippi"),
        ("MO", "Missouri"), ("MT", "Montana"), ("NE", "Nebraska"), ("NV", "Nevada"),
        ("NH", "New Hampshire"), ("NJ", "New Jersey"), ("NM", "New Mexico"), ("NY", "New York"),
        ("NC", "North Carolina"), ("ND", "North Dakota"), ("OH", "Ohio"), ("OK", "Oklahoma"),
        ("OR", "Oregon"), ("PA", "Pennsylvania"), ("RI", "Rhode Island"), ("SC", "South Carolina"),
        ("SD", "South Dakota"), ("TN", "Tennessee"), ("TX", "Texas"), ("UT", "Utah"),
        ("VT", "Vermont"), ("VA", "Virginia"), ("WA", "Washington"), ("WV", "West Virginia"),
        ("WI", "Wisconsin"), ("WY", "Wyoming")
    ];

    private List<ApprovalRequestRow> requests = [];

    private int PendingCount => totalServerCount;

    private string SummaryLabel => selectedStatusTab == DefaultStatusTab
        ? "Pending Requests"
        : $"{selectedStatusTab} Requests";

    private int FilteredCount => totalServerCount;

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(totalServerCount / (double)Math.Max(1, pageSize)));

    private IEnumerable<ApprovalRequestRow> FilteredRequests => requests;

    private bool HasActiveFilters =>
        !string.IsNullOrWhiteSpace(searchQuery)
        || !string.Equals(selectedStatusTab, DefaultStatusTab, StringComparison.Ordinal)
        || !string.Equals(statusFilter, DefaultStatusFilter, StringComparison.Ordinal)
        || !string.Equals(roleFilter, DefaultRoleFilter, StringComparison.Ordinal)
        || !string.Equals(clinicFilter, DefaultClinicFilter, StringComparison.Ordinal)
        || dateFrom.HasValue
        || dateTo.HasValue
        || !string.Equals(sortBy, DefaultSortBy, StringComparison.Ordinal);

    private string ResultsSummary => FilteredCount == 1
        ? BuildResultsSummary("1 request")
        : BuildResultsSummary($"{FilteredCount} requests");

    private string NoResultsMessage
    {
        get
        {
            if (!HasActiveFilters)
            {
                return "There are no requests to review right now.";
            }

            if (string.IsNullOrWhiteSpace(searchQuery))
            {
                return "No requests matched the current filters.";
            }

            return $"No requests matched the current filters for \"{searchQuery.Trim()}\".";
        }
    }

    private IEnumerable<string> AvailableRoleFilters =>
        requests
            .Select(request => request.RequestedRole)
            .Where(role => !string.IsNullOrWhiteSpace(role))
            .Distinct(StringComparer.Ordinal)
            .OrderBy(role => role, StringComparer.Ordinal);

    private IEnumerable<string> AvailableClinicFilters =>
        requests
            .Select(request => request.Clinic)
            .Where(clinic => !string.IsNullOrWhiteSpace(clinic) && !string.Equals(clinic, "Unassigned", StringComparison.OrdinalIgnoreCase))
            .Distinct(StringComparer.Ordinal)
            .OrderBy(clinic => clinic, StringComparer.Ordinal);

    private bool CanManageSelectedRequest =>
        selectedRequest is not null
        && selectedRequestDetail is not null
        && !isSubmittingAction
        && !isEditingDetail
        && !isSavingDetail;

    private bool CanApproveSelectedRequest =>
        CanManageSelectedRequest
        && selectedRequestDetail!.CredentialsComplete;

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += HandleLocationChanged;
        ApplyStateFromQuery(Navigation.Uri);
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadPendingRequestsAsync();
    }

    private async Task RefreshPlaceholders()
    {
        await LoadPendingRequestsAsync();
    }

    private async Task OpenReview(ApprovalRequestRow request)
    {
        selectedRequest = request;
        selectedRequestDetail = null;
        detailLoadError = null;
        actionFeedback = null;
        isEditingDetail = false;
        detailValidationErrors = new Dictionary<string, string>(StringComparer.Ordinal);
        isLoadingDetail = true;

        try
        {
            selectedRequestDetail = await AdminApprovalService.GetPendingDetailAsync(request.UserId);
            if (selectedRequestDetail is null)
            {
                detailLoadError = "The selected registration could not be found.";
            }
            else
            {
                editModel = ApprovalEditModel.FromDetail(selectedRequestDetail);
            }
        }
        catch (Exception ex)
        {
            detailLoadError = ex.Message;
        }
        finally
        {
            isLoadingDetail = false;
        }
    }

    private void CloseReviewPanel()
    {
        selectedRequest = null;
        selectedRequestDetail = null;
        isEditingDetail = false;
        detailLoadError = null;
        detailValidationErrors = new Dictionary<string, string>(StringComparer.Ordinal);
    }

    private void OpenApproveConfirmation()
    {
        pendingAction = ApprovalAction.Approve;
        confirmationTitle = "Approve request";
        confirmationBody = "You are confirming approval for this request.";
        showConfirmationModal = true;
    }

    private void OpenRejectConfirmation()
    {
        pendingAction = ApprovalAction.Reject;
        confirmationTitle = "Reject request";
        confirmationBody = "You are confirming rejection for this request.";
        showConfirmationModal = true;
    }

    private void OpenOnHoldConfirmation()
    {
        pendingAction = ApprovalAction.OnHold;
        confirmationTitle = "Place request on hold";
        confirmationBody = "You are placing this request on hold.";
        showConfirmationModal = true;
    }

    private void OpenCancelConfirmation()
    {
        pendingAction = ApprovalAction.Cancel;
        confirmationTitle = "Cancel request";
        confirmationBody = "You are cancelling this registration request.";
        showConfirmationModal = true;
    }

    private void CloseConfirmation()
    {
        showConfirmationModal = false;
        pendingAction = null;
    }

    private async Task ConfirmActionAsync()
    {
        if (selectedRequest is null || pendingAction is null)
        {
            CloseConfirmation();
            return;
        }

        isSubmittingAction = true;
        actionFeedback = null;

        AdminApprovalActionResult result = pendingAction.Value switch
        {
            ApprovalAction.Approve => await AdminApprovalService.ApproveAsync(selectedRequest.UserId),
            ApprovalAction.Reject => await AdminApprovalService.RejectAsync(selectedRequest.UserId),
            ApprovalAction.OnHold => await AdminApprovalService.HoldAsync(selectedRequest.UserId),
            ApprovalAction.Cancel => await AdminApprovalService.CancelAsync(selectedRequest.UserId),
            _ => new AdminApprovalActionResult(false, null, "Unsupported action")
        };

        if (result.Succeeded)
        {
            actionFeedback = pendingAction switch
            {
                ApprovalAction.Approve => "Request approved successfully.",
                ApprovalAction.Reject => "Request rejected successfully.",
                ApprovalAction.OnHold => "Request placed on hold successfully.",
                ApprovalAction.Cancel => "Request cancelled successfully.",
                _ => "Request updated successfully."
            };

            CloseConfirmation();
            await LoadPendingRequestsAsync();
            selectedRequest = null;
            selectedRequestDetail = null;
        }
        else
        {
            actionFeedback = result.Error ?? "Unable to process action.";
            detailValidationErrors = FlattenValidationErrors(result.ValidationErrors);
        }

        isSubmittingAction = false;
    }

    private async Task LoadPendingRequestsAsync()
    {
        isLoading = true;
        loadError = null;

        try
        {
            var effectiveStatus = selectedStatusTab == DefaultStatusTab
                ? statusFilter
                : selectedStatusTab;

            var response = await AdminApprovalService.GetPendingAsync(new AdminApprovalQuery(
                Search: searchQuery,
                Status: effectiveStatus,
                Role: roleFilter,
                Clinic: clinicFilter,
                FromDate: dateFrom,
                ToDate: dateTo,
                SortBy: sortBy,
                Page: currentPage,
                PageSize: pageSize));

            requests = response.Items
                .Select(item => new ApprovalRequestRow(
                    item.Id,
                    item.Id.ToString("N")[..8].ToUpperInvariant(),
                    item.FullName,
                    item.Email,
                    item.RoleKey,
                    item.ClinicName ?? "Unassigned",
                    item.RequestedAtUtc,
                    item.CredentialsComplete,
                    item.Status,
                    item.ReviewedBy,
                    item.MissingFields))
                .ToList();

            // Re-validate dynamic filters against loaded data to prevent querystring
            // values that are not present in the dropdown from desynchronizing state.
            var availableRoles = AvailableRoleFilters.ToHashSet(StringComparer.Ordinal);
            if (!string.Equals(roleFilter, DefaultRoleFilter, StringComparison.Ordinal)
                && !availableRoles.Contains(roleFilter))
            {
                roleFilter = DefaultRoleFilter;
            }

            var availableClinics = AvailableClinicFilters.ToHashSet(StringComparer.Ordinal);
            if (!string.Equals(clinicFilter, DefaultClinicFilter, StringComparison.Ordinal)
                && !availableClinics.Contains(clinicFilter))
            {
                clinicFilter = DefaultClinicFilter;
            }

            totalServerCount = response.TotalCount;
            currentPage = Math.Clamp(response.Page, 1, TotalPages);
            pageSize = response.PageSize;
            lastLoadedQuery = GetQueryPart(Navigation.Uri);
            lastRefreshed = DateTime.Now.ToString("yyyy-MM-dd hh:mm tt");
        }
        catch (Exception ex)
        {
            loadError = ex.Message;
            requests = [];
            totalServerCount = 0;
            currentPage = 1;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void PreviousPage()
    {
        if (currentPage > 1)
        {
            currentPage--;
            SyncQueryFromState();
        }
    }

    private void NextPage()
    {
        if (currentPage < TotalPages)
        {
            currentPage++;
            SyncQueryFromState();
        }
    }

