    {
        currentPage = 1;
        SyncQueryFromState();
    }

    private void ClearFilters()
    {
        selectedStatusTab = DefaultStatusTab;
        searchQuery = string.Empty;
        statusFilter = DefaultStatusFilter;
        roleFilter = DefaultRoleFilter;
        clinicFilter = DefaultClinicFilter;
        dateFrom = null;
        dateTo = null;
        sortBy = DefaultSortBy;
        currentPage = 1;
        SyncQueryFromState();
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        var nextQuery = GetQueryPart(e.Location);
        if (string.Equals(nextQuery, lastLoadedQuery, StringComparison.Ordinal))
        {
            return;
        }

        ApplyStateFromQuery(e.Location);
        currentPage = Math.Clamp(currentPage, 1, TotalPages);
        _ = InvokeAsync(async () =>
        {
            await LoadPendingRequestsAsync();
            StateHasChanged();
        });
    }

    private void ApplyStateFromQuery(string location)
    {
        var uri = Navigation.ToAbsoluteUri(location);
        var query = ParseQueryString(uri.Query);

        suppressQuerySync = true;

        selectedStatusTab = ReadString(query, "tab", DefaultStatusTab, statusTabs.Contains);
        searchQuery = ReadString(query, "q", string.Empty, _ => true);
        statusFilter = ReadString(query, "status", DefaultStatusFilter, IsAllowedStatusFilter);
        roleFilter = ReadString(query, "role", DefaultRoleFilter, IsAllowedRoleFilter);
        clinicFilter = ReadString(query, "clinic", DefaultClinicFilter, IsAllowedClinicFilter);
        sortBy = ReadString(query, "sort", DefaultSortBy, IsAllowedSortBy);
        dateFrom = ParseDate(ReadString(query, "from", string.Empty, _ => true));
        dateTo = ParseDate(ReadString(query, "to", string.Empty, _ => true));
        pageSize = ReadInt(query, "pageSize", DefaultPageSize, value => value is 10 or 25 or 50);
        currentPage = ReadInt(query, "page", 1, value => value >= 1);

        suppressQuerySync = false;
    }

    private void SyncQueryFromState()
    {
        if (suppressQuerySync)
        {
            return;
        }

        currentPage = Math.Clamp(currentPage, 1, TotalPages);

        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var basePath = uri.GetLeftPart(UriPartial.Path);
        var query = new Dictionary<string, string?>();

        if (!string.IsNullOrWhiteSpace(searchQuery))
        {
            query["q"] = searchQuery.Trim();
        }

        if (!string.Equals(selectedStatusTab, DefaultStatusTab, StringComparison.Ordinal))
        {
            query["tab"] = selectedStatusTab;
        }

        if (!string.Equals(statusFilter, DefaultStatusFilter, StringComparison.Ordinal))
        {
            query["status"] = statusFilter;
        }

        if (!string.Equals(roleFilter, DefaultRoleFilter, StringComparison.Ordinal))
        {
            query["role"] = roleFilter;
        }

        if (!string.Equals(clinicFilter, DefaultClinicFilter, StringComparison.Ordinal))
        {
            query["clinic"] = clinicFilter;
        }

        if (dateFrom.HasValue)
        {
            query["from"] = dateFrom.Value.ToString("yyyy-MM-dd");
        }

        if (dateTo.HasValue)
        {
            query["to"] = dateTo.Value.ToString("yyyy-MM-dd");
        }

        if (!string.Equals(sortBy, DefaultSortBy, StringComparison.Ordinal))
        {
            query["sort"] = sortBy;
        }

        if (pageSize != DefaultPageSize)
        {
            query["pageSize"] = pageSize.ToString();
        }

        if (currentPage > 1)
        {
            query["page"] = currentPage.ToString();
        }

        var nextUri = query.Count == 0
            ? basePath
            : $"{basePath}?{BuildQueryString(query)}";

        if (!string.Equals(uri.ToString(), nextUri, StringComparison.Ordinal))
        {
            Navigation.NavigateTo(nextUri, replace: true);
        }
    }

    private static DateTime? ParseDate(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return null;
        }

        return DateTime.TryParse(value, out var parsedDate)
            ? parsedDate.Date
            : null;
    }

    private static string FormatDateForInput(DateTime? date) =>
        date?.ToString("yyyy-MM-dd") ?? string.Empty;

    private static string ReadString(
        IDictionary<string, string> query,
        string key,
        string defaultValue,
        Func<string, bool> isAllowed)
    {
        if (!query.TryGetValue(key, out var value))
        {
            return defaultValue;
        }

        var parsed = value.ToString();
        return string.IsNullOrWhiteSpace(parsed) || !isAllowed(parsed)
            ? defaultValue
            : parsed;
    }

    private static int ReadInt(
        IDictionary<string, string> query,
        string key,
        int defaultValue,
        Func<int, bool> isAllowed)
    {
        if (!query.TryGetValue(key, out var value))
        {
            return defaultValue;
        }

        return int.TryParse(value.ToString(), out var parsed) && isAllowed(parsed)
            ? parsed
            : defaultValue;
    }

    private static bool IsAllowedStatusFilter(string value) => value is "All" or "Pending" or "Approved" or "Rejected" or "On Hold" or "Cancelled";

    private static bool IsAllowedRoleFilter(string value) => !string.IsNullOrWhiteSpace(value);

    private static bool IsAllowedClinicFilter(string value) => !string.IsNullOrWhiteSpace(value);

    private static bool IsAllowedSortBy(string value) => value is "Date submitted" or "Name" or "Status";

    private static Dictionary<string, string> ParseQueryString(string queryString)
    {
        var results = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
        if (string.IsNullOrWhiteSpace(queryString))
        {
            return results;
        }

        var trimmed = queryString.StartsWith('?') ? queryString[1..] : queryString;
        foreach (var pair in trimmed.Split('&', StringSplitOptions.RemoveEmptyEntries))
        {
            var separatorIndex = pair.IndexOf('=');
            if (separatorIndex < 0)
            {
                continue;
            }

            var key = Uri.UnescapeDataString(pair[..separatorIndex]);
            var value = Uri.UnescapeDataString(pair[(separatorIndex + 1)..]);
            results[key] = value;
        }

        return results;
    }

    private static string BuildQueryString(IReadOnlyDictionary<string, string?> query)
    {
        return string.Join(
            "&",
            query
                .Where(entry => !string.IsNullOrWhiteSpace(entry.Value))
                .Select(entry => $"{Uri.EscapeDataString(entry.Key)}={Uri.EscapeDataString(entry.Value!)}"));
    }

    private static string GetQueryPart(string location)
    {
        var uri = new Uri(location, UriKind.Absolute);
        return uri.Query;
    }

    private string BuildResultsSummary(string countLabel)
    {
        if (!string.IsNullOrWhiteSpace(searchQuery))
        {
            return string.Concat(countLabel, " matching \"", searchQuery.Trim(), "\"");
        }

        return HasActiveFilters ? $"{countLabel} matching the current filters" : countLabel;
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= HandleLocationChanged;
    }

    private void BeginEditDetail()
    {
        if (selectedRequestDetail is null)
        {
            return;
        }

        isEditingDetail = true;
        editModel = ApprovalEditModel.FromDetail(selectedRequestDetail);
        detailValidationErrors = new Dictionary<string, string>(StringComparer.Ordinal);
        actionFeedback = null;
    }

    private void CancelDetailEdit()
    {
        if (selectedRequestDetail is null)
        {
            return;
        }

        isEditingDetail = false;
        editModel = ApprovalEditModel.FromDetail(selectedRequestDetail);
        detailValidationErrors = new Dictionary<string, string>(StringComparer.Ordinal);
    }

    private async Task SaveDetailAsync()
    {
        if (selectedRequest is null || selectedRequestDetail is null)
        {
            return;
        }

        isSavingDetail = true;
        actionFeedback = null;
        detailValidationErrors = new Dictionary<string, string>(StringComparer.Ordinal);

        try
        {
            var updateResult = await AdminApprovalService.UpdateAsync(selectedRequest.UserId, editModel.ToRequest());
            if (!updateResult.Succeeded || updateResult.Detail is null)
            {
                actionFeedback = updateResult.Error ?? "Unable to save registration changes.";
                detailValidationErrors = FlattenValidationErrors(updateResult.ValidationErrors);
                return;
            }

            selectedRequestDetail = updateResult.Detail;
            var updatedRequest = selectedRequest with
            {
                ApplicantName = updateResult.Detail.FullName,
                Email = updateResult.Detail.Email,
                RequestedRole = updateResult.Detail.RoleKey,
                Clinic = updateResult.Detail.ClinicName ?? selectedRequest.Clinic,
                CredentialsComplete = updateResult.Detail.CredentialsComplete,
                Status = updateResult.Detail.Status,
                ReviewedBy = updateResult.Detail.ReviewedBy,
                MissingFields = updateResult.Detail.MissingFields
            };
            selectedRequest = updatedRequest;
            requests = requests
                .Select(item => item.UserId == updatedRequest.UserId ? updatedRequest : item)
                .ToList();
            editModel = ApprovalEditModel.FromDetail(updateResult.Detail);
            isEditingDetail = false;
            actionFeedback = "Registration changes saved.";
        }
        finally
        {
            isSavingDetail = false;
        }
    }

    private void OnFullNameChanged(ChangeEventArgs args) => editModel.FullName = args.Value?.ToString() ?? string.Empty;

    private void OnEmailChanged(ChangeEventArgs args) => editModel.Email = args.Value?.ToString() ?? string.Empty;

    private void OnDateOfBirthChanged(ChangeEventArgs args) => editModel.DateOfBirth = args.Value?.ToString() ?? string.Empty;

    private void OnLicenseNumberChanged(ChangeEventArgs args) => editModel.LicenseNumber = args.Value?.ToString() ?? string.Empty;

    private void OnLicenseStateChanged(ChangeEventArgs args) => editModel.LicenseState = args.Value?.ToString() ?? string.Empty;

    private void OnEditRoleChanged(ChangeEventArgs args)
    {
        editModel.RoleKey = args.Value?.ToString() ?? string.Empty;
        if (!RequiresLicenseRole(editModel.RoleKey))
        {
            editModel.LicenseNumber = string.Empty;
            editModel.LicenseState = string.Empty;
        }
    }

    private static Dictionary<string, string> FlattenValidationErrors(IReadOnlyDictionary<string, string[]>? errors)
    {
        if (errors is null || errors.Count == 0)
        {
            return new Dictionary<string, string>(StringComparer.Ordinal);
        }

        return errors.ToDictionary(
            entry => entry.Key,
            entry => string.Join(" ", entry.Value),
            StringComparer.Ordinal);
    }

    private static bool RequiresLicenseRole(string? roleKey) =>
        string.Equals(roleKey, "PT", StringComparison.OrdinalIgnoreCase)
        || string.Equals(roleKey, "PTA", StringComparison.OrdinalIgnoreCase);

    private string FormatDetailDate(DateTime? value) =>
        value?.ToString("yyyy-MM-dd") ?? "Not provided";

    private RenderFragment RenderValidationMessage(string fieldName) => builder =>
    {
        if (!detailValidationErrors.TryGetValue(fieldName, out var message) || string.IsNullOrWhiteSpace(message))
        {
            return;
        }

        builder.OpenElement(0, "p");
        builder.AddAttribute(1, "class", "auth-validation");
        builder.AddContent(2, message);
        builder.CloseElement();
    };

    private sealed record ApprovalRequestRow(
        Guid UserId,
        string RequestId,
        string ApplicantName,
        string Email,
        string RequestedRole,
        string Clinic,
        DateTime SubmittedAtUtc,
        bool CredentialsComplete,
        string Status,
        string? ReviewedBy,
        IReadOnlyList<string> MissingFields);

    private sealed class ApprovalEditModel
    {
        public string FullName { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string DateOfBirth { get; set; } = string.Empty;
        public string RoleKey { get; set; } = string.Empty;
        public string LicenseNumber { get; set; } = string.Empty;
        public string LicenseState { get; set; } = string.Empty;

        public AdminRegistrationUpdateRequest ToRequest()
        {
            DateTime? parsedDate = null;
            if (DateTime.TryParse(DateOfBirth, out var dateOfBirth))
            {
                parsedDate = dateOfBirth.Date;
            }

            return new AdminRegistrationUpdateRequest(
                FullName.Trim(),
                Email.Trim(),
                parsedDate,
                RoleKey.Trim(),
                RequiresLicenseRoleLocal(RoleKey) ? NormalizeOptionalValue(LicenseNumber) : null,
                RequiresLicenseRoleLocal(RoleKey) ? NormalizeOptionalValue(LicenseState)?.ToUpperInvariant() : null);
        }

        public static ApprovalEditModel FromDetail(PendingUserDetail detail) =>
            new()
            {
                FullName = detail.FullName,
                Email = detail.Email,
                DateOfBirth = detail.DateOfBirth?.ToString("yyyy-MM-dd") ?? string.Empty,
                RoleKey = detail.RoleKey,
                LicenseNumber = detail.LicenseNumber ?? string.Empty,
                LicenseState = detail.LicenseState ?? string.Empty
            };

        private static string? NormalizeOptionalValue(string? value) =>
            string.IsNullOrWhiteSpace(value) ? null : value.Trim();

        private static bool RequiresLicenseRoleLocal(string? roleKey) =>
            string.Equals(roleKey, "PT", StringComparison.OrdinalIgnoreCase)
            || string.Equals(roleKey, "PTA", StringComparison.OrdinalIgnoreCase);
    }

    private enum ApprovalAction
    {
        Approve,
        Reject,
        OnHold,
        Cancel
    }
