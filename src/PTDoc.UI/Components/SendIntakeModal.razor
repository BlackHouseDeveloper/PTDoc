@using PTDoc.Application.Intake
@using PTDoc.Application.Services
@inject IJSRuntime JS
@inject IIntakeService IntakeService
@inject IIntakeDeliveryService IntakeDeliveryService
@inject IToastService ToastService
@implements IAsyncDisposable

@if (IsOpen)
{
    <div class="modal-overlay" @onclick="HandleOverlayClick" @onclick:stopPropagation="false">
        <div class="modal-container" @ref="modalContainerRef" @onclick:stopPropagation="true" role="dialog"
             aria-labelledby="send-intake-title" aria-describedby="send-intake-description" aria-modal="true">

            <div class="modal-header">
                <div class="modal-title-container">
                    <svg class="modal-icon modal-icon-info" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M17.5 7.5L9.16667 15M17.5 7.5L12.5 18.3333L9.16667 15M17.5 7.5L2.5 2.5L9.16667 15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <h2 id="send-intake-title">Send Intake Form</h2>
                </div>
                <p id="send-intake-description" class="modal-description">Generate a secure invite link, QR code, and optional email or SMS delivery.</p>
            </div>

            <form class="modal-body" @onsubmit="HandleSubmit" @onsubmit:preventDefault="true">
                @if (!string.IsNullOrWhiteSpace(_errorMessage))
                {
                    <div class="success-box" role="alert">
                        <strong>Unable to continue.</strong>
                        <p>@_errorMessage</p>
                    </div>
                }

                <div class="form-field">
                    <label for="patient-select" class="form-label">Select Patient <span class="required">*</span></label>
                    <div class="select-wrapper">
                        <select
                            id="patient-select"
                            class="form-select"
                            value="@SelectedPatientId"
                            @onchange="HandlePatientChanged"
                            @ref="firstInputRef"
                            required
                            aria-required="true"
                            disabled="@_isBusy">
                            <option value="">Select a patient</option>
                            @foreach (var patient in AvailablePatients)
                            {
                                <option value="@patient.Id">@patient.Name</option>
                            }
                        </select>
                        <svg class="select-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                            <path d="M4 6L8 10L12 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </div>
                </div>

                <div class="form-field">
                    <label for="email" class="form-label">Email Address</label>
                    <input
                        id="email"
                        type="email"
                        class="form-input"
                        placeholder="patient@example.com"
                        @bind="Email"
                        disabled="@_isBusy" />
                </div>

                <div class="form-field">
                    <label for="phone" class="form-label">Phone Number</label>
                    <input
                        id="phone"
                        type="tel"
                        class="form-input"
                        placeholder="(555) 123-4567"
                        @bind="PhoneNumber"
                        disabled="@_isBusy" />
                    <p class="input-helper-text">Provide one or both destinations. Copy link and QR remain available even without outbound delivery.</p>
                </div>

                <div class="success-box" role="note">
                    <div class="success-box-header">
                        <svg class="success-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                            <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="2"/>
                            <path d="M5 8L7 10L11 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                        <strong>Invite Options</strong>
                    </div>
                    <ul class="success-box-list">
                        <li>Generate a secure web link</li>
                        <li>Render a QR code from the same invite</li>
                        <li>Send email and optional SMS from the backend</li>
                    </ul>
                </div>

                <div class="form-field">
                    <div class="modal-footer" style="padding: 0; justify-content: flex-start;">
                        <button type="button" class="btn-cancel" @onclick="GenerateLinkAsync" disabled="@(_isBusy || string.IsNullOrWhiteSpace(SelectedPatientId))">
                            Generate Link &amp; QR
                        </button>
                        <button type="button" class="btn-info" @onclick="CopyLinkAsync" disabled="@(_isBusy || _bundle is null)">
                            Copy Link
                        </button>
                    </div>
                </div>

                @if (_bundle is not null)
                {
                    <div class="form-field">
                        <label class="form-label" for="generated-link">Invite Link</label>
                        <input id="generated-link" class="form-input" value="@_bundle.InviteUrl" readonly />
                        <p class="input-helper-text">Expires @(_bundle.ExpiresAt.ToLocalTime().ToString("f")).</p>
                    </div>

                    <div class="success-box" role="note">
                        <div class="success-box-header">
                            <strong>QR Code</strong>
                        </div>
                        <div>@((MarkupString)_bundle.QrSvg)</div>
                    </div>
                }

                @if (_status is not null)
                {
                    <div class="success-box" role="note">
                        <div class="success-box-header">
                            <strong>Delivery Status</strong>
                        </div>
                        <ul class="success-box-list">
                            <li>Invite active: @(_status.InviteActive ? "Yes" : "No")</li>
                            <li>Last link generated: @(FormatDateTime(_status.LastLinkGeneratedAt))</li>
                            <li>Last email sent: @(FormatDateTime(_status.LastEmailSentAt)) @(string.IsNullOrWhiteSpace(_status.LastEmailDestinationMasked) ? string.Empty : $"({_status.LastEmailDestinationMasked})")</li>
                            <li>Last SMS sent: @(FormatDateTime(_status.LastSmsSentAt)) @(string.IsNullOrWhiteSpace(_status.LastSmsDestinationMasked) ? string.Empty : $"({_status.LastSmsDestinationMasked})")</li>
                        </ul>
                    </div>
                }

                <div class="modal-footer">
                    <button type="button" class="btn-cancel" @onclick="Close" disabled="@_isBusy">
                        Cancel
                    </button>
                    <button type="submit" class="btn-info" disabled="@(_isBusy || string.IsNullOrWhiteSpace(SelectedPatientId))">
                        <svg class="btn-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                            <path d="M14 2L7 9M14 2L9.33333 14.6667L7 9M14 2L2 6.66667L7 9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                        @if (_isBusy)
                        {
                            <span>Sending...</span>
                        }
                        else
                        {
                            <span>Send Invite</span>
                        }
                    </button>
                </div>
            </form>

            <button type="button" class="modal-close" @onclick="Close" aria-label="Close modal" disabled="@_isBusy">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M12 4L4 12M4 4L12 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </button>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback<bool> IsOpenChanged { get; set; }
    [Parameter] public EventCallback<IntakeFormData> OnSubmit { get; set; }
    [Parameter] public List<PatientOption> AvailablePatients { get; set; } = new();

    private ElementReference firstInputRef;
    private ElementReference modalContainerRef;
    private IJSObjectReference? modalModule;
    private DotNetObjectReference<SendIntakeModal>? dotNetRef;
    private readonly string modalId = $"modal-{Guid.NewGuid():N}";

    private string SelectedPatientId { get; set; } = string.Empty;
    private string Email { get; set; } = string.Empty;
    private string PhoneNumber { get; set; } = string.Empty;
    private bool _isBusy;
    private string? _errorMessage;
    private Guid? _intakeId;
    private IntakeDeliveryBundleResponse? _bundle;
    private IntakeDeliveryStatusResponse? _status;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                modalModule = await JS.InvokeAsync<IJSObjectReference>("import", "./_content/PTDoc.UI/js/modal.js");
                dotNetRef = DotNetObjectReference.Create(this);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Failed to load modal.js: {ex.Message}");
            }
        }

        if (IsOpen && modalModule != null && dotNetRef != null)
        {
            try
            {
                await modalModule.InvokeVoidAsync("lockBodyScroll");
                await modalModule.InvokeVoidAsync("registerEscapeHandler", modalId, dotNetRef);
                await firstInputRef.FocusAsync();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Modal JS interop error: {ex.Message}");
            }
        }
        else if (!IsOpen && modalModule != null)
        {
            try
            {
                await modalModule.InvokeVoidAsync("unlockBodyScroll");
                await modalModule.InvokeVoidAsync("unregisterEscapeHandler", modalId);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Modal cleanup error: {ex.Message}");
            }
        }
    }

    [JSInvokable]
    public async Task CloseFromJs()
    {
        await Close();
    }

    private async Task HandlePatientChanged(ChangeEventArgs args)
    {
        SelectedPatientId = args.Value?.ToString() ?? string.Empty;
        _errorMessage = null;
        _bundle = null;
        _status = null;
        _intakeId = null;

        var selectedPatient = AvailablePatients.FirstOrDefault(patient => patient.Id == SelectedPatientId);
        Email = selectedPatient?.Email ?? string.Empty;
        PhoneNumber = selectedPatient?.PhoneNumber ?? string.Empty;

        if (Guid.TryParse(SelectedPatientId, out var patientId))
        {
            try
            {
                _isBusy = true;
                var ensureResult = await IntakeService.EnsureDraftAsync(patientId, new IntakeResponseDraft
                {
                    PatientId = patientId,
                    EmailAddress = string.IsNullOrWhiteSpace(Email) ? null : Email,
                    PhoneNumber = string.IsNullOrWhiteSpace(PhoneNumber) ? null : PhoneNumber,
                    AllowEmailMessages = !string.IsNullOrWhiteSpace(Email),
                    AllowTextMessages = !string.IsNullOrWhiteSpace(PhoneNumber),
                    AllowPhoneCalls = !string.IsNullOrWhiteSpace(PhoneNumber)
                });

                if (ensureResult.Status == IntakeEnsureDraftStatus.Locked)
                {
                    _errorMessage = ensureResult.ErrorMessage ?? "This patient already has a locked intake and cannot receive a new invite.";
                    return;
                }

                if (ensureResult.Status == IntakeEnsureDraftStatus.PatientNotFound)
                {
                    _errorMessage = ensureResult.ErrorMessage ?? "The selected patient could not be found.";
                    return;
                }

                _intakeId = ensureResult.Draft?.IntakeId;
                if (_intakeId.HasValue)
                {
                    await LoadStatusAsync(_intakeId.Value);
                }
            }
            catch (Exception ex)
            {
                _errorMessage = ex.Message;
            }
            finally
            {
                _isBusy = false;
            }
        }
    }

    private async Task GenerateLinkAsync()
    {
        _errorMessage = null;

        try
        {
            _isBusy = true;
            var intakeId = await EnsureIntakeIdAsync();
            _bundle = await IntakeDeliveryService.GetDeliveryBundleAsync(intakeId);
            await LoadStatusAsync(intakeId);
            ToastService.ShowSuccess("Secure intake link generated.");
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task CopyLinkAsync()
    {
        _errorMessage = null;

        try
        {
            _isBusy = true;
            if (_bundle is null)
            {
                var intakeId = await EnsureIntakeIdAsync();
                _bundle = await IntakeDeliveryService.GetDeliveryBundleAsync(intakeId);
                await LoadStatusAsync(intakeId);
            }

            if (modalModule is null || _bundle is null)
            {
                return;
            }

            await modalModule.InvokeVoidAsync("copyToClipboard", _bundle.InviteUrl);
            ToastService.ShowSuccess("Secure intake link copied.");
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task HandleSubmit()
    {
        _errorMessage = null;

        if (string.IsNullOrWhiteSpace(Email) && string.IsNullOrWhiteSpace(PhoneNumber))
        {
            _errorMessage = "Provide an email address, a phone number, or generate a shareable link.";
            return;
        }

        try
        {
            _isBusy = true;
            var intakeId = await EnsureIntakeIdAsync();
            var sentChannels = new List<string>();

            if (!string.IsNullOrWhiteSpace(Email))
            {
                var emailResult = await IntakeDeliveryService.SendInviteAsync(new IntakeSendInviteRequest
                {
                    IntakeId = intakeId,
                    Channel = IntakeDeliveryChannel.Email,
                    Destination = Email
                });

                if (!emailResult.Success)
                {
                    throw new InvalidOperationException(emailResult.ErrorMessage ?? "Unable to send the intake email.");
                }

                sentChannels.Add("email");
            }

            if (!string.IsNullOrWhiteSpace(PhoneNumber))
            {
                var smsResult = await IntakeDeliveryService.SendInviteAsync(new IntakeSendInviteRequest
                {
                    IntakeId = intakeId,
                    Channel = IntakeDeliveryChannel.Sms,
                    Destination = PhoneNumber
                });

                if (!smsResult.Success)
                {
                    throw new InvalidOperationException(smsResult.ErrorMessage ?? "Unable to send the intake text message.");
                }

                sentChannels.Add("SMS");
            }

            _bundle = await IntakeDeliveryService.GetDeliveryBundleAsync(intakeId);
            await LoadStatusAsync(intakeId);

            ToastService.ShowSuccess($"Intake invite sent via {string.Join(" and ", sentChannels)}.");
            await OnSubmit.InvokeAsync(new IntakeFormData
            {
                PatientId = SelectedPatientId,
                Email = Email,
                PhoneNumber = PhoneNumber
            });
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task<Guid> EnsureIntakeIdAsync()
    {
        if (!Guid.TryParse(SelectedPatientId, out var patientId))
        {
            throw new InvalidOperationException("Select a patient before generating or sending an intake invite.");
        }

        if (_intakeId.HasValue)
        {
            return _intakeId.Value;
        }

        var ensuredDraft = await IntakeService.EnsureDraftAsync(patientId, new IntakeResponseDraft
        {
            PatientId = patientId,
            EmailAddress = string.IsNullOrWhiteSpace(Email) ? null : Email,
            PhoneNumber = string.IsNullOrWhiteSpace(PhoneNumber) ? null : PhoneNumber,
            AllowEmailMessages = !string.IsNullOrWhiteSpace(Email),
            AllowTextMessages = !string.IsNullOrWhiteSpace(PhoneNumber),
            AllowPhoneCalls = !string.IsNullOrWhiteSpace(PhoneNumber)
        });

        if (ensuredDraft.Status == IntakeEnsureDraftStatus.Locked)
        {
            throw new InvalidOperationException(ensuredDraft.ErrorMessage ?? "This patient already has a locked intake and cannot receive a new invite.");
        }

        if (ensuredDraft.Status == IntakeEnsureDraftStatus.PatientNotFound)
        {
            throw new InvalidOperationException(ensuredDraft.ErrorMessage ?? "The selected patient could not be found.");
        }

        if (ensuredDraft.Draft?.IntakeId is not Guid createdIntakeId)
        {
            throw new InvalidOperationException("Intake draft creation succeeded but no intake record was returned.");
        }

        _intakeId = createdIntakeId;
        return createdIntakeId;
    }

    private async Task LoadStatusAsync(Guid intakeId)
    {
        try
        {
            _status = await IntakeDeliveryService.GetDeliveryStatusAsync(intakeId);
        }
        catch
        {
            _status = null;
        }
    }

    private async Task Close()
    {
        IsOpen = false;
        await IsOpenChanged.InvokeAsync(false);

        SelectedPatientId = string.Empty;
        Email = string.Empty;
        PhoneNumber = string.Empty;
        _errorMessage = null;
        _intakeId = null;
        _bundle = null;
        _status = null;
    }

    private void HandleOverlayClick()
    {
        if (_isBusy)
        {
            return;
        }

        _ = Close();
    }

    private static string FormatDateTime(DateTimeOffset? value)
        => value.HasValue ? value.Value.ToLocalTime().ToString("g") : "Not sent";

    public async ValueTask DisposeAsync()
    {
        if (modalModule != null)
        {
            try
            {
                await modalModule.InvokeVoidAsync("unlockBodyScroll");
                await modalModule.InvokeVoidAsync("unregisterEscapeHandler", modalId);
                await modalModule.DisposeAsync();
            }
            catch
            {
            }
        }

        dotNetRef?.Dispose();
    }

    public class IntakeFormData
    {
        public string PatientId { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string PhoneNumber { get; set; } = string.Empty;
    }

    public class PatientOption
    {
        public string Id { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string? Email { get; set; }
        public string? PhoneNumber { get; set; }
    }
}
