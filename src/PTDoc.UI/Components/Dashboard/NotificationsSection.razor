@using PTDoc.UI.Services
@inject Microsoft.AspNetCore.Components.NavigationManager Navigation

@* Notifications & Alerts Section *@

<div class="notifications-section">
    <div class="notifications-card">
        <div class="notifications-header">
            <div class="notifications-header-left">
                <svg class="section-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M15 6.66667C15 5.34058 14.4732 4.06881 13.5355 3.13113C12.5979 2.19345 11.3261 1.66667 10 1.66667C8.67392 1.66667 7.40215 2.19345 6.46447 3.13113C5.52678 4.06881 5 5.34058 5 6.66667C5 12.5 2.5 14.1667 2.5 14.1667H17.5C17.5 14.1667 15 12.5 15 6.66667Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M11.4417 17.5C11.2952 17.7526 11.0849 17.9622 10.8319 18.108C10.5788 18.2537 10.2918 18.3304 10 18.3304C9.70819 18.3304 9.42116 18.2537 9.16808 18.108C8.91501 17.9622 8.70475 17.7526 8.55833 17.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <h2 class="notifications-title">Notifications & Alerts</h2>
                <span class="urgent-badge">@UrgentCount Urgent</span>
            </div>
        </div>
        <div class="notifications-content">
            @if (Notifications.Count == 0)
            {
                <div class="empty-state">
                    <p class="empty-state-text">No new notifications</p>
                </div>
            }
            else
            {
                <div class="activity-list">
                    @foreach (var notification in Notifications)
                    {
                        <div class="activity-item">
                            <div class="activity-indicator" style="background: @(notification.IsUrgent ? "var(--destructive)" : "var(--info)")"></div>
                            <div class="activity-content">
                                <p class="activity-text">
                                    <strong>@notification.Title</strong>
                                    @if (!string.IsNullOrWhiteSpace(notification.Message))
                                    {
                                        <text> @notification.Message</text>
                                    }
                                </p>
                                <span class="activity-time">@FormatTimestamp(notification.Timestamp)</span>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(ResolveNavigationTarget(notification)))
                            {
                                <button type="button"
                                        class="view-all-link"
                                        aria-label="@($"Open {notification.Title}")"
                                        @onclick="() => HandleNotificationClick(notification)">
                                    Open
                                </button>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public int UrgentCount { get; set; }
    [Parameter] public IReadOnlyList<NotificationCenterItem> Notifications { get; set; } = Array.Empty<NotificationCenterItem>();

    private void HandleNotificationClick(NotificationCenterItem notification)
    {
        var target = ResolveNavigationTarget(notification);
        if (!string.IsNullOrWhiteSpace(target))
        {
            Navigation.NavigateTo(target);
        }
    }

    private static string? ResolveNavigationTarget(NotificationCenterItem notification)
    {
        if (!string.IsNullOrWhiteSpace(notification.TargetUrl))
        {
            return notification.TargetUrl;
        }

        return notification.Type.ToLowerInvariant() switch
        {
            "note" => "/notes",
            "appointment" => "/appointments",
            _ => null
        };
    }

    private static string FormatTimestamp(DateTimeOffset timestamp)
    {
        var elapsed = DateTimeOffset.UtcNow - timestamp;
        if (elapsed.TotalMinutes < 1)
        {
            return "Just now";
        }

        if (elapsed.TotalHours < 1)
        {
            return $"{Math.Max(1, (int)elapsed.TotalMinutes)}m ago";
        }

        if (elapsed.TotalDays < 1)
        {
            return $"{Math.Max(1, (int)elapsed.TotalHours)}h ago";
        }

        return $"{Math.Max(1, (int)elapsed.TotalDays)}d ago";
    }
}
