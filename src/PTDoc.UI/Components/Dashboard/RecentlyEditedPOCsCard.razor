@using PTDoc.Application.DTOs
@inject Microsoft.AspNetCore.Components.NavigationManager Navigation

@* Recently Edited POCs Card - Shows plan-of-care summaries derived from clinical notes. *@

<div class="card recently-edited-pocs-card">
    <div class="card-header poc-card-header">
        <div class="card-header-left">
            <svg class="section-icon poc-section-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M5.33333 1.33337V4.00004" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M10.6667 1.33337V4.00004" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M2.33333 6.33337H13.6667" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M12 2.66663H4C3.26362 2.66663 2.66667 3.26358 2.66667 3.99996V12C2.66667 12.7363 3.26362 13.3333 4 13.3333H12C12.7364 13.3333 13.3333 12.7363 13.3333 12V3.99996C13.3333 3.26358 12.7364 2.66663 12 2.66663Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <h3 class="card-title poc-card-title">Recently Edited Plan of Care</h3>
        </div>
        <button type="button" class="view-all-link poc-view-all" aria-label="View all notes" @onclick="HandleViewAll">
            View All
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M3.33333 8H12.6667" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M8.66667 4L12.6667 8L8.66667 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        </button>
    </div>

    <div class="card-content poc-card-content">
        @if (Items.Count == 0)
        {
            <div class="empty-state">
                <p class="empty-state-text">No recently edited plans of care</p>
            </div>
        }
        else
        {
            <div class="pocs-list">
                @foreach (var poc in Items)
                {
                    <article class="poc-item">
                        <div class="poc-header">
                            <div class="poc-patient-info">
                                <div class="poc-patient-line">
                                    <span class="poc-patient-name">@poc.PatientName</span>
                                    <span class="poc-status-badge @GetStatusCssClass(poc.Status)">@FormatStatus(poc.Status)</span>
                                </div>
                                <div class="poc-id">@BuildMetaText(poc)</div>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(poc.TargetUrl))
                            {
                                <button type="button"
                                        class="poc-view-button"
                                        aria-label="View plan of care for @poc.PatientName"
                                        @onclick="() => HandleOpen(poc)">
                                    View
                                </button>
                            }
                        </div>

                        @if (HasMetrics(poc))
                        {
                            <div class="poc-metrics" aria-label="Plan of care metrics">
                                @if (poc.WeekCurrent.HasValue && poc.WeekTotal.HasValue)
                                {
                                    <div class="poc-metric">
                                        <svg viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                            <path d="M6 11C8.76142 11 11 8.76142 11 6C11 3.23858 8.76142 1 6 1C3.23858 1 1 3.23858 1 6C1 8.76142 3.23858 11 6 11Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                            <path d="M6 3V6L8 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                        </svg>
                                        <span>Wk <strong>@poc.WeekCurrent/@poc.WeekTotal</strong></span>
                                    </div>
                                }

                                @if (poc.VisitsCurrent.HasValue && poc.VisitsTotal.HasValue)
                                {
                                    <div class="poc-metric poc-metric-progress">
                                        <svg viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                            <path d="M1 7H3.2L4.4 3L6.6 9L8 5H11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                        </svg>
                                        <span><strong>@poc.VisitsCurrent/@poc.VisitsTotal</strong></span>
                                    </div>
                                }

                                @if (poc.Sessions.HasValue && poc.SessionsTotal.HasValue)
                                {
                                    <div class="poc-metric poc-metric-info">
                                        <svg viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                            <circle cx="6" cy="6" r="4.5" stroke="currentColor" stroke-width="1.5"/>
                                            <circle cx="6" cy="6" r="1.5" stroke="currentColor" stroke-width="1.5"/>
                                        </svg>
                                        <span><strong>@poc.Sessions/@poc.SessionsTotal</strong></span>
                                    </div>
                                }
                                else if (poc.Sessions.HasValue)
                                {
                                    <div class="poc-metric poc-metric-info">
                                        <svg viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                            <circle cx="6" cy="6" r="4.5" stroke="currentColor" stroke-width="1.5"/>
                                            <circle cx="6" cy="6" r="1.5" stroke="currentColor" stroke-width="1.5"/>
                                        </svg>
                                        <span><strong>@poc.Sessions</strong> CPT units</span>
                                    </div>
                                }

                                @if (poc.IcdCount.HasValue)
                                {
                                    <div class="poc-metric @(poc.IcdCount.Value == 0 ? "poc-metric-error" : "poc-metric-complete")">
                                        <svg viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                            @if (poc.IcdCount.Value == 0)
                                            {
                                                <path d="M6 11C8.76142 11 11 8.76142 11 6C11 3.23858 8.76142 1 6 1C3.23858 1 1 3.23858 1 6C1 8.76142 3.23858 11 6 11Z" stroke="currentColor" stroke-width="1.5"/>
                                                <path d="M6 3.5V6.25" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                                                <path d="M6 8.5H6.005" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                                            }
                                            else
                                            {
                                                <path d="M10 3L4.5 8.5L2 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                            }
                                        </svg>
                                        <span>ICD <strong>@poc.IcdCount</strong></span>
                                    </div>
                                }
                            </div>
                        }

                        @if (poc.UtilizationPercentage.HasValue)
                        {
                            <div class="poc-utilization">
                                <span class="utilization-label">Utilization</span>
                                <span class="utilization-value">@ClampPercent(poc.UtilizationPercentage.Value)%</span>
                            </div>
                            <div class="progress-bar poc-progress-bar" aria-hidden="true">
                                <div class="progress-fill" style="width: @ClampPercent(poc.UtilizationPercentage.Value)%"></div>
                            </div>
                        }

                        @if (!string.IsNullOrWhiteSpace(poc.Alert))
                        {
                            <div class="poc-alert @GetAlertCssClass(poc.AlertType)">
                                <svg viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                    <path d="M6 11C8.76142 11 11 8.76142 11 6C11 3.23858 8.76142 1 6 1C3.23858 1 1 3.23858 1 6C1 8.76142 3.23858 11 6 11Z" stroke="currentColor" stroke-width="1.5"/>
                                    <path d="M6 3.5V6.25" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                                    <path d="M6 8.5H6.005" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                                </svg>
                                @poc.Alert
                            </div>
                        }
                    </article>
                }
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public IReadOnlyList<DashboardPlanOfCareSummaryResponse> Items { get; set; } = Array.Empty<DashboardPlanOfCareSummaryResponse>();

    private void HandleViewAll() => Navigation.NavigateTo("/notes");

    private void HandleOpen(DashboardPlanOfCareSummaryResponse poc)
    {
        if (!string.IsNullOrWhiteSpace(poc.TargetUrl))
        {
            Navigation.NavigateTo(poc.TargetUrl);
        }
    }

    private static bool HasMetrics(DashboardPlanOfCareSummaryResponse poc) =>
        (poc.WeekCurrent.HasValue && poc.WeekTotal.HasValue) ||
        (poc.VisitsCurrent.HasValue && poc.VisitsTotal.HasValue) ||
        poc.Sessions.HasValue ||
        poc.IcdCount.HasValue;

    private static string BuildMetaText(DashboardPlanOfCareSummaryResponse poc)
    {
        var pieces = new List<string>
        {
            string.IsNullOrWhiteSpace(poc.Title) ? "Plan of Care" : poc.Title,
            FormatRelativeTime(poc.LastEditedAt)
        };

        if (!string.IsNullOrWhiteSpace(poc.LastEditedBy))
        {
            pieces.Add($"edited by {poc.LastEditedBy}");
        }

        return string.Join(" • ", pieces);
    }

    private static string FormatStatus(string status) =>
        string.IsNullOrWhiteSpace(status) ? "active" : status;

    private static string GetStatusCssClass(string status)
    {
        if (string.IsNullOrWhiteSpace(status))
        {
            return "poc-status-active";
        }

        var normalized = status.Trim().ToLowerInvariant();
        return normalized switch
        {
            "signed" or "active" => "poc-status-active",
            "pending review" or "pending co-sign" or "pending" => "poc-status-pending",
            "draft" => "poc-status-draft",
            _ => "poc-status-active"
        };
    }

    private static string GetAlertCssClass(string? alertType) =>
        string.Equals(alertType, "error", StringComparison.OrdinalIgnoreCase)
            ? "poc-alert-error"
            : "poc-alert-warning";

    private static int ClampPercent(int value) => Math.Clamp(value, 0, 100);

    private static string FormatRelativeTime(DateTime timestamp)
    {
        var utc = timestamp.Kind switch
        {
            DateTimeKind.Utc => timestamp,
            DateTimeKind.Local => timestamp.ToUniversalTime(),
            _ => DateTime.SpecifyKind(timestamp, DateTimeKind.Utc)
        };

        var elapsed = DateTime.UtcNow - utc;
        if (elapsed.TotalMinutes < 1)
        {
            return "just now";
        }

        if (elapsed.TotalHours < 1)
        {
            var minutes = Math.Max(1, (int)Math.Floor(elapsed.TotalMinutes));
            return minutes == 1 ? "1 min ago" : $"{minutes} mins ago";
        }

        if (elapsed.TotalDays < 1)
        {
            var hours = Math.Max(1, (int)Math.Floor(elapsed.TotalHours));
            return hours == 1 ? "1 hr ago" : $"{hours} hrs ago";
        }

        if (elapsed.TotalDays < 30)
        {
            var days = Math.Max(1, (int)Math.Floor(elapsed.TotalDays));
            return days == 1 ? "1 day ago" : $"{days} days ago";
        }

        return utc.ToString("MMM d, yyyy");
    }
}
