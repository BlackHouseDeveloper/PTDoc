      "AllowedLaunchHosts": [ "wibbi.com", "physiotec.ca" ],
      "DefaultLocale": "en-US",
      "TokenRefreshSkew": "00:05:00"
    },
    "DocumentStore": {
      "ContainerName": "integration-documents",
      "DevelopmentPath": "",
      "MaxFileBytes": 52428800
    },
    "DocumentScanner": {
      "Enabled": true,
      "Host": "",
      "Port": 3310,
      "MaxFileBytes": 52428800,
      "Timeout": "00:01:30"
    },
    "Worker": {
      "Enabled": true,
      "BatchSize": 10,
      "PollInterval": "00:00:10"
    }
  },
  "AllowedHosts": "*"
