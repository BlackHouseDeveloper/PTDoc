{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "",
    "PTDocsServer": "",
    "Redis": ""
  },
  "AzureStorageConnectionString": "",
  "AzureOpenAIEndpoint": "",
  "AzureOpenAIKey": "",
  "AzureOpenAIDeployment": "",
  "AzureOpenAIApiVersion": "",
  "Ai": {
    "MaxOutputTokens": 400
  },
  "Jwt": {
    "Issuer": "PTDoc.Api",
    "Audience": "PTDoc",
    "SigningKey": "REPLACE_WITH_A_MIN_32_CHAR_SECRET",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 30
  },
  "IntakeInvite": {
    "SigningKey": "REPLACE_WITH_A_SECURE_32_CHAR_KEY_FOR_INTAKE_INVITE_TOKENS",
    "OtpExpiryMinutes": 10,
    "AccessTokenExpiryMinutes": 120,
    "InviteExpiryMinutes": 1440,
    "PublicWebBaseUrl": ""
  },
  "Communication": {
    "PublicBaseUrl": "https://app.ptdoc.com",
    "RecipientHashSalt": "",
    "TokenExpiryMinutes": {
      "PasswordReset": 30,
      "Intake": 10080
    },
    "Retention": {
      "ResetTokensDays": 30,
      "DeliveryLogsDays": 2190
    },
    "RateLimits": {
      "PasswordResetMaxPerWindow": 3,
      "PasswordResetWindowMinutes": 15,
      "IntakeMaxPerDay": 5
    },
    "Azure": {
      "ConnectionString": "",
      "EmailFromAddress": "no-reply@ptdoc.com",
      "SmsFromPhoneNumber": ""
    }
  },
  "EntraExternalId": {
    "Enabled": false,
    "DisplayName": "Microsoft",
    "Domain": "",
    "TenantId": "",
    "Audience": "",
    "ClientId": "",
    "ClientSecret": "",
    "UserFlow": "",
    "Scope": "openid profile email",
    "CallbackPath": "/signin-microsoft",
    "SignedOutCallbackPath": "/signout-callback-microsoft",
    "MetadataAddressOverride": "",
    "Claims": {
      "SubjectClaimType": "oid",
      "NameClaimType": "name",
      "UsernameClaimType": "preferred_username",
      "EmailClaimType": "email",
      "RoleClaimType": "roles",
      "ClinicIdClaimType": "clinic_id",
      "PatientIdClaimType": "patient_id",
      "StandardRoleClaimType": "http://schemas.microsoft.com/ws/2008/06/identity/claims/role"
    }
  },
  "Integrations": {
    "Features": {
      "EnableHumbleFax": false,
      "EnableHumbleInboundFax": false,
      "EnableWibbiProvisioning": false,
      "EnableWibbiProgramPublishing": false,
      "EnableWibbiTrackingSync": false
    },
    "Fax": {
      "Enabled": false,
      "BaseUrl": "https://api.humblefax.com",
      "MaxFileBytes": 52428800,
      "RateLimitInstanceBudget": 4
    },
    "Hep": {
      "Enabled": false,
      "PatientLaunchEnabled": false,
      "ClinicianAssignmentEnabled": false,
      "BaseUrl": "https://v4.api.wibbi.com",
