{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AllowedHosts": "*",

  "EntraExternalId": {
    "Enabled": false,
    "DisplayName": "Microsoft",
    "Domain": "",
    "TenantId": "",
    "Audience": "",
    "ClientId": "",
    "ClientSecret": "",
    "UserFlow": "",
    "Scope": "openid profile email",
    "CallbackPath": "/signin-microsoft",
    "SignedOutCallbackPath": "/signout-callback-microsoft",
    "MetadataAddressOverride": "",
    "Claims": {
      "SubjectClaimType": "oid",
      "NameClaimType": "name",
      "UsernameClaimType": "preferred_username",
      "EmailClaimType": "email",
      "RoleClaimType": "roles",
      "ClinicIdClaimType": "clinic_id",
      "PatientIdClaimType": "patient_id",
      "StandardRoleClaimType": "http://schemas.microsoft.com/ws/2008/06/identity/claims/role"
    }
  },

  "IntakeInvite": {
    "SigningKey": "REPLACE_WITH_A_SECURE_32_CHAR_KEY_FOR_INTAKE_INVITE_TOKENS",
    "OtpExpiryMinutes": 10,
    "AccessTokenExpiryMinutes": 120
  },

  "ReverseProxy": {
    "Routes": {
      "authRoute": {
        "ClusterId": "apiCluster",
        "Match": {
          "Path": "/auth/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "apiCluster": {
        "Destinations": {
          "api": {
            "Address": "http://localhost:5170/"
          }
        }
      }
    }
  }
}
